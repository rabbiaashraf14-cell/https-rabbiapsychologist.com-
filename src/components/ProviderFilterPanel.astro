---
---

<div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 sticky top-24">
  <h3 class="text-lg font-bold text-brand-navy mb-4 border-b pb-2">Filter Providers</h3>

  <form class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Region</label>
      <select class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust sm:text-sm p-2 border">
        <option value="all">All Regions</option>
        <option value="usa">USA</option>
        <option value="australia">Australia</option>
        <option value="uk-europe">UK & Europe</option>
        <option value="mena-gulf">MENA & Gulf</option>
        <option value="pakistan">Pakistan</option>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Service Type</label>
      <div class="space-y-2">
        {['Parent Consultation', 'School Consultation', 'Educational Guidance', 'Local Assessment Only'].map((service) => (
          <div class="flex items-center">
            <input id={`service-${service}`} type="checkbox" class="h-4 w-4 text-brand-trust focus:ring-brand-trust border-gray-300 rounded" />
            <label for={`service-${service}`} class="ml-2 block text-sm text-gray-600">{service}</label>
          </div>
        ))}
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Area of Support</label>
      <div class="space-y-2">
        {['ASD Support', 'ADHD Support', 'Behavior Support'].map((area) => (
          <div class="flex items-center">
            <input id={`area-${area}`} type="checkbox" class="h-4 w-4 text-brand-trust focus:ring-brand-trust border-gray-300 rounded" />
            <label for={`area-${area}`} class="ml-2 block text-sm text-gray-600">{area}</label>
          </div>
        ))}
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Language</label>
      <select class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust sm:text-sm p-2 border">
        <option value="all">All Languages</option>
        <option value="english">English</option>
        <option value="urdu">Urdu</option>
        <option value="arabic">Arabic</option>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Verification Status</label>
      <div class="flex items-center">
        <input id="verified-only" type="checkbox" checked class="h-4 w-4 text-brand-trust focus:ring-brand-trust border-gray-300 rounded" />
        <label for="verified-only" class="ml-2 block text-sm text-gray-600">Verified Profile</label>
      </div>
    </div>

    <button type="button" class="w-full bg-brand-navy text-white py-2 px-4 rounded-md hover:bg-blue-900 transition-colors font-medium">
      Apply Filters
    </button>
  </form>
</div>
