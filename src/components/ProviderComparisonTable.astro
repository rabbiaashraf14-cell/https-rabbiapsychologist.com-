---
export interface Props {
  providers: {
    id: string;
    name: string;
    region: string;
    language: string;
    serviceType: string;
    price: string;
    scope: string;
    regulatedTherapy: boolean;
    educationalOnly: boolean;
    credentials: string;
    bookingLink: string;
  }[];
}

const { providers } = Astro.props;
---

<div class="overflow-x-auto bg-white rounded-lg shadow-sm border border-gray-200 my-8">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Provider</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Region & Language</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Service Type</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Scope & Credentials</th>
        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
        <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      {providers.map(provider => (
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm font-bold text-brand-navy">{provider.name}</div>
          </td>
          <td class="px-6 py-4">
            <div class="text-sm text-gray-900">{provider.region}</div>
            <div class="text-xs text-gray-500">{provider.language}</div>
          </td>
          <td class="px-6 py-4">
            <div class="text-sm text-gray-900">{provider.serviceType}</div>
            <div class="mt-1 flex flex-col gap-1">
              {provider.regulatedTherapy && (
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                  Regulated Services Available*
                </span>
              )}
              {provider.educationalOnly && (
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                  Educational Guidance Only
                </span>
              )}
            </div>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500">
            <div class="truncate max-w-xs" title={provider.scope}>{provider.scope}</div>
            <div class="text-xs mt-1 text-gray-400">{provider.credentials}</div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
            {provider.price}
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
            <a href={provider.bookingLink} class="text-brand-trust hover:text-brand-navy bg-brand-sky hover:bg-blue-100 px-3 py-1.5 rounded-full transition-colors">Book</a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
  <div class="px-6 py-3 bg-gray-50 text-xs text-gray-500 border-t border-gray-200">
    *Regulated therapy, diagnosis, assessment, or treatment is only available when the provider is legally allowed to provide it in the client's location.
  </div>
</div>
