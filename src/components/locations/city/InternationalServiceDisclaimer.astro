---
import type { CityLocation } from '../../../data/locations/locationTypes';

interface Props {
  city: CityLocation;
}

const { city } = Astro.props;
---

<section class="py-8 px-6 lg:px-8 max-w-4xl mx-auto">
  <div class="bg-gray-50 rounded-[24px] p-6 text-sm text-gray-600 border border-gray-200">
    <h3 class="font-bold text-gray-800 mb-2">Important Information About International Services</h3>
    <ul class="space-y-2 list-disc pl-5">
      {city.crossBorderDisclaimer && <li>{city.crossBorderDisclaimer}</li>}
      {city.formalDiagnosisDisclaimer && <li>{city.formalDiagnosisDisclaimer}</li>}
      {city.emergencyServiceDisclaimer && <li>{city.emergencyServiceDisclaimer}</li>}
    </ul>
  </div>
</section>
