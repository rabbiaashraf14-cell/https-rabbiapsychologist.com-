---
import type { CityLocation } from '../../../data/locations/locationTypes';

interface Props {
  city: CityLocation;
}

const { city } = Astro.props;

if (!city.assessmentWaitingSupport) {
    return;
}
---

<section class="py-12 bg-white">
  <div class="max-w-4xl mx-auto px-6 lg:px-8">
    <div class="border-l-4 border-indigo-500 pl-6 py-2">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Waiting for Local Assessment in {city.cityName}?</h2>
      <div class="prose max-w-none text-gray-700">
        <p>{city.assessmentWaitingSupport}</p>

        {city.practicalParentGuidance && city.practicalParentGuidance.length > 0 && (
          <div class="mt-6">
            <h3 class="text-lg font-semibold text-gray-900">What You Can Do Now</h3>
            <ul class="list-disc pl-5 mt-3 space-y-2">
              {city.practicalParentGuidance.map(step => (
                <li>{step}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
