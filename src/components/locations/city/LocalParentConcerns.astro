---
import type { CityLocation } from '../../../data/locations/locationTypes';

interface Props {
  city: CityLocation;
}

const { city } = Astro.props;

if (!city.localParentChallenges || city.localParentChallenges.length === 0) {
    return;
}
---

<section class="py-12 bg-gray-50">
  <div class="max-w-4xl mx-auto px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Common Concerns for Families in {city.cityName}</h2>

    <div class="grid md:grid-cols-2 gap-6">
      {city.localParentChallenges.map(challenge => (
        <div class="bg-white p-6 rounded-[24px] shadow-sm hover-lift border border-gray-100">
           <div class="flex items-start">
             <div class="text-blue-500 mr-4 mt-1">
               <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
             </div>
             <p class="text-gray-700">{challenge}</p>
           </div>
        </div>
      ))}
    </div>

    {city.culturalContext && (
       <div class="mt-8 bg-white p-6 rounded-[24px] shadow-sm border border-blue-100 prose max-w-none text-gray-700">
         <h3 class="text-xl font-semibold mb-3 text-gray-900">Cultural & Family Context</h3>
         <p>{city.culturalContext}</p>
       </div>
    )}

    {city.multilingualFamilyContext && (
       <div class="mt-6 bg-white p-6 rounded-[24px] shadow-sm border border-blue-100 prose max-w-none text-gray-700">
         <h3 class="text-xl font-semibold mb-3 text-gray-900">Supporting Multilingual Families</h3>
         <p>{city.multilingualFamilyContext}</p>
       </div>
    )}
  </div>
</section>
