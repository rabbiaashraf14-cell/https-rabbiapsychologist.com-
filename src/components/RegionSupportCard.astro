---
interface Props {
  title: string;
  description: string;
  href: string;
  features?: string[];
  disclaimer?: string;
}

const { title, description, href, features = [], disclaimer } = Astro.props;
---
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 sm:p-8 flex flex-col h-full hover:shadow-md transition-shadow">
  <h3 class="text-xl font-bold text-brand-navy mb-3">{title}</h3>
  <p class="text-gray-600 mb-6 flex-grow">{description}</p>

  {features.length > 0 && (
    <ul class="mb-6 space-y-2">
      {features.map((feature) => (
        <li class="flex items-start text-sm text-gray-700">
          <svg class="h-5 w-5 text-brand-growth mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>{feature}</span>
        </li>
      ))}
    </ul>
  )}

  {disclaimer && (
    <p class="text-xs text-gray-500 bg-gray-50 p-3 rounded mb-6 border border-gray-100 italic">
      {disclaimer}
    </p>
  )}

  <div class="mt-auto">
    <a href={href} class="inline-flex items-center text-brand-trust hover:text-brand-navy font-medium transition-colors">
      View region support
      <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </a>
  </div>
</div>
