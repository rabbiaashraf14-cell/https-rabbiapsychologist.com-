---
---

<div class="bg-white rounded-lg shadow-sm border border-gray-100 p-8 max-w-3xl mx-auto my-8">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-brand-navy mb-2">Provider Matching Request</h2>
    <p class="text-gray-600">
      Fill out this form to receive informational suggestions on providers who may fit your family's needs.
    </p>
    <div class="bg-yellow-50 border border-yellow-200 p-4 rounded-md mt-4 text-sm text-yellow-800">
      <strong>Note:</strong> Provider suggestions are informational and do not guarantee clinical suitability, diagnosis, treatment outcome, or provider availability.
    </div>
  </div>

  <form class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="parentName" class="block text-sm font-medium text-gray-700 mb-1">Parent/Guardian Name</label>
        <input type="text" id="parentName" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border" required />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
        <input type="email" id="email" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border" required />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div>
        <label for="country" class="block text-sm font-medium text-gray-700 mb-1">Country</label>
        <input type="text" id="country" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border" required />
      </div>
      <div>
        <label for="timezone" class="block text-sm font-medium text-gray-700 mb-1">Time Zone</label>
        <input type="text" id="timezone" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border" required />
      </div>
      <div>
        <label for="childAge" class="block text-sm font-medium text-gray-700 mb-1">Child's Age</label>
        <input type="text" id="childAge" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border" required />
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">Main Concerns (Select all that apply)</label>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <label class="flex items-center"><input type="checkbox" class="mr-2 border-gray-300 text-brand-trust focus:ring-brand-trust" /> ASD concern</label>
        <label class="flex items-center"><input type="checkbox" class="mr-2 border-gray-300 text-brand-trust focus:ring-brand-trust" /> ADHD concern</label>
        <label class="flex items-center"><input type="checkbox" class="mr-2 border-gray-300 text-brand-trust focus:ring-brand-trust" /> Behavior concern</label>
        <label class="flex items-center"><input type="checkbox" class="mr-2 border-gray-300 text-brand-trust focus:ring-brand-trust" /> School concern</label>
      </div>
    </div>

    <div>
      <label for="mainConcern" class="block text-sm font-medium text-gray-700 mb-1">Please briefly describe your main concern</label>
      <textarea id="mainConcern" rows="3" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border" required></textarea>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="language" class="block text-sm font-medium text-gray-700 mb-1">Preferred Language</label>
        <select id="language" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border">
          <option>English</option>
          <option>Urdu</option>
          <option>Arabic</option>
          <option>Other</option>
        </select>
      </div>
      <div>
        <label for="budget" class="block text-sm font-medium text-gray-700 mb-1">Budget Range (Per Session)</label>
        <select id="budget" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border">
          <option>Under $50 USD</option>
          <option>$50 - $100 USD</option>
          <option>$100 - $150 USD</option>
          <option>Over $150 USD</option>
        </select>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-2">What kind of support are you looking for?</label>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
        <label class="flex items-center"><input type="checkbox" class="mr-2 border-gray-300 text-brand-trust focus:ring-brand-trust" /> Parent Consultation</label>
        <label class="flex items-center"><input type="checkbox" class="mr-2 border-gray-300 text-brand-trust focus:ring-brand-trust" /> School Guidance</label>
        <label class="flex items-center"><input type="checkbox" class="mr-2 border-gray-300 text-brand-trust focus:ring-brand-trust" /> Therapy (if available in my region)</label>
        <label class="flex items-center"><input type="checkbox" class="mr-2 border-gray-300 text-brand-trust focus:ring-brand-trust" /> Assessment (if available in my region)</label>
        <label class="flex items-center"><input type="checkbox" class="mr-2 border-gray-300 text-brand-trust focus:ring-brand-trust" /> Educational Resources</label>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div>
        <label for="prevDiagnosis" class="block text-sm font-medium text-gray-700 mb-1">Previous Diagnosis?</label>
        <select id="prevDiagnosis" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border">
          <option>No</option>
          <option>Yes</option>
          <option>In progress</option>
        </select>
      </div>
      <div>
        <label for="prevAssessment" class="block text-sm font-medium text-gray-700 mb-1">Previous Assessment?</label>
        <select id="prevAssessment" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border">
          <option>No</option>
          <option>Yes</option>
          <option>Scheduled</option>
        </select>
      </div>
      <div>
        <label for="urgency" class="block text-sm font-medium text-gray-700 mb-1">Urgency Level</label>
        <select id="urgency" class="w-full border-gray-300 rounded-md shadow-sm focus:border-brand-trust focus:ring-brand-trust p-2 border">
          <option>Standard (Within 2 weeks)</option>
          <option>Soon (Within 1 week)</option>
          <option>Just browsing options</option>
        </select>
      </div>
    </div>

    <div class="space-y-4 border-t border-gray-200 pt-6">
      <h3 class="text-lg font-medium text-brand-navy">Consent & Privacy</h3>

      <div class="flex items-start">
        <div class="flex items-center h-5">
          <input id="consent" type="checkbox" class="focus:ring-brand-trust h-4 w-4 text-brand-trust border-gray-300 rounded" required />
        </div>
        <div class="ml-3 text-sm">
          <label for="consent" class="font-medium text-gray-700">Parent/Guardian Consent</label>
          <p class="text-gray-500">I confirm I am the legal parent or guardian of the child referenced in this form.</p>
        </div>
      </div>

      <div class="flex items-start">
        <div class="flex items-center h-5">
          <input id="dataPrivacy" type="checkbox" class="focus:ring-brand-trust h-4 w-4 text-brand-trust border-gray-300 rounded" required />
        </div>
        <div class="ml-3 text-sm">
          <label for="dataPrivacy" class="font-medium text-gray-700">Child Data Privacy & Use</label>
          <p class="text-gray-500">I understand that the information provided is used solely to suggest suitable educational or consultative providers. I have the right to request deletion of this data at any time. Region-specific privacy rights (e.g., EU GDPR, UK GDPR) apply where relevant.</p>
        </div>
      </div>

      <div class="flex items-start">
        <div class="flex items-center h-5">
          <input id="providerSharing" type="checkbox" class="focus:ring-brand-trust h-4 w-4 text-brand-trust border-gray-300 rounded" required />
        </div>
        <div class="ml-3 text-sm">
          <label for="providerSharing" class="font-medium text-gray-700">Provider Sharing Consent</label>
          <p class="text-gray-500">I consent to this non-clinical information being shared with potential providers on the platform to check their availability and suitability.</p>
        </div>
      </div>

      <div class="flex items-start">
        <div class="flex items-center h-5">
          <input id="emergency" type="checkbox" class="focus:ring-brand-trust h-4 w-4 text-brand-trust border-gray-300 rounded" required />
        </div>
        <div class="ml-3 text-sm">
          <label for="emergency" class="font-medium text-gray-700">Emergency Disclaimer Acknowledgment</label>
          <p class="text-gray-500">I acknowledge this platform is not suitable for emergencies, self-harm risk, abuse crisis, medical emergencies, or immediate safety concerns. This form is not monitored for emergencies.</p>
        </div>
      </div>
    </div>

    <div class="pt-4">
      <button type="button" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-brand-navy hover:bg-blue-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-navy">
        Submit Request
      </button>
      <p class="text-center text-xs text-gray-500 mt-3">Form backend integration pending.</p>
    </div>
  </form>
</div>
