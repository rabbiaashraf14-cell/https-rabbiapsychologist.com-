---
const currentYear = new Date().getFullYear();
---
<footer class="bg-brand-navy text-white pt-12 pb-8 mt-20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div class="col-span-1 md:col-span-1">
        <h3 class="text-xl font-bold mb-4">Rabbia Ashraf</h3>
        <p class="text-gray-300 text-sm mb-4">Clinical Child Psychologist, Researcher, Behavior Therapist. Global child psychology consultation and parent education platform.</p>
        <a href="https://www.linkedin.com/in/rabbiapsychologist" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-white transition-colors">
          <span class="sr-only">LinkedIn</span>
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-4 text-brand-sky">Services</h4>
        <ul class="space-y-2 text-sm text-gray-300">
          <li><a href="/global-consultation" class="hover:text-white">Global Consultation</a></li>
          <li><a href="/autism-support" class="hover:text-white">Autism Support</a></li>
          <li><a href="/adhd-support" class="hover:text-white">ADHD Support</a></li>
          <li><a href="/parent-training" class="hover:text-white">Parent Training</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-4 text-brand-sky">Resources</h4>
        <ul class="space-y-2 text-sm text-gray-300">
          <li><a href="/resource-vault" class="hover:text-white">Resource Vault</a></li>
          <li><a href="/free-downloads" class="hover:text-white">Free Downloads</a></li>
          <li><a href="/blog" class="hover:text-white">Blog</a></li>
          <li><a href="/faqs" class="hover:text-white">FAQs</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-lg font-semibold mb-4 text-brand-sky">Important Info</h4>
        <ul class="space-y-2 text-sm text-gray-300">
          <li><a href="/pricing" class="hover:text-white">Pricing</a></li>
          <li><a href="/contact" class="hover:text-white">Contact</a></li>
          <li><a href="/privacy-policy" class="hover:text-white">Privacy Policy</a></li>
          <li><a href="/terms-and-disclaimer" class="hover:text-white">Terms & Disclaimer</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-700 pt-8">
      <div class="bg-gray-800 p-4 rounded-lg mb-6">
        <p class="text-xs text-gray-400 leading-relaxed">
          <strong class="text-gray-300">Important Disclaimer:</strong> Clinical therapy, diagnosis, and regulated psychological services are provided only where legally and ethically permitted. International consultations are educational, parent-guidance, and support-planning services unless otherwise allowed by local regulations.
        </p>
      </div>
      <p class="text-sm text-gray-400 text-center">&copy; {currentYear} Rabbia Ashraf. All rights reserved.</p>
    </div>
  </div>
</footer>
