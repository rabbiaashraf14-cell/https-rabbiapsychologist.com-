---
export interface Props {
  activeRegion?: 'all' | 'usa' | 'australia' | 'uk-europe' | 'mena-gulf' | 'pakistan';
}

const { activeRegion = 'all' } = Astro.props;

const regions = [
  { id: 'all', name: 'All Regions', href: '/providers' },
  { id: 'usa', name: 'USA', href: '/providers/usa' },
  { id: 'australia', name: 'Australia', href: '/providers/australia' },
  { id: 'uk-europe', name: 'UK & Europe', href: '/providers/uk-europe' },
  { id: 'mena-gulf', name: 'MENA & Gulf', href: '/providers/mena-gulf' },
  { id: 'pakistan', name: 'Pakistan', href: '/providers/pakistan' }
];
---

<div class="mb-8 overflow-x-auto pb-2">
  <nav class="flex space-x-2 min-w-max" aria-label="Region Filters">
    {regions.map(region => (
      <a
        href={region.href}
        class={`px-4 py-2 text-sm font-medium rounded-full transition-colors ${
          activeRegion === region.id
            ? 'bg-brand-navy text-white'
            : 'bg-white text-gray-700 hover:bg-gray-100 border border-gray-200'
        }`}
      >
        {region.name}
      </a>
    ))}
  </nav>
</div>
