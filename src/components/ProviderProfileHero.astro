---
export interface Props {
  provider: {
    name: string;
    photoUrl?: string;
    title: string;
    country: string;
    timezone: string;
    languages: string[];
    education: string;
    verifiedCredentials: string[];
    bookingLink: string;
  };
}

const { provider } = Astro.props;
---

<div class="bg-brand-navy rounded-2xl overflow-hidden shadow-xl mb-12">
  <div class="md:flex">
    <div class="md:w-1/3 bg-brand-sky flex items-center justify-center p-8 md:p-0">
      {provider.photoUrl ? (
        <img src={provider.photoUrl} alt={provider.name} class="w-48 h-48 md:w-full md:h-full object-cover" />
      ) : (
        <div class="w-48 h-48 md:w-full md:h-full flex items-center justify-center bg-gray-200 text-gray-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
      )}
    </div>

    <div class="md:w-2/3 p-8 md:p-12 text-white">
      <h1 class="text-3xl md:text-4xl font-bold mb-2">{provider.name}</h1>
      <p class="text-brand-sky text-xl mb-6">{provider.title}</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div>
          <h3 class="text-gray-400 text-xs uppercase tracking-wider mb-1">Location & Time</h3>
          <p>{provider.country} • {provider.timezone}</p>
        </div>
        <div>
          <h3 class="text-gray-400 text-xs uppercase tracking-wider mb-1">Languages</h3>
          <p>{provider.languages.join(', ')}</p>
        </div>
        <div class="md:col-span-2">
          <h3 class="text-gray-400 text-xs uppercase tracking-wider mb-1">Education</h3>
          <p>{provider.education}</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-4 items-center">
        <a href={provider.bookingLink} target="_blank" rel="noopener noreferrer" class="bg-white text-brand-navy font-bold py-3 px-8 rounded-full hover:bg-gray-100 transition-colors">
          Book Consultation
        </a>
        <a href="#services" class="text-white border border-white/30 py-3 px-8 rounded-full hover:bg-white/10 transition-colors">
          View Services
        </a>
      </div>
    </div>
  </div>
</div>
