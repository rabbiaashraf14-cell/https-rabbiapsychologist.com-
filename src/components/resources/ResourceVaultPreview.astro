---
import { resources } from '../../data/resources';
---
<section class="py-16 bg-white">
  <div class="container mx-auto px-4 max-w-4xl text-center">
    <h2 class="text-3xl font-bold text-brand-navy mb-6">Resource Vault</h2>
    <p class="text-gray-600 mb-8">Access our free downloadable resources for parents.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      {resources.map(resource => (
        <a href={resource.url} class="bg-brand-cream border border-gray-200 rounded-lg p-6 hover:shadow-md transition text-left">
          <span class="text-xs font-bold text-brand-trust uppercase tracking-wider mb-2 block">{resource.type}</span>
          <h3 class="text-xl font-bold text-brand-navy">{resource.title}</h3>
        </a>
      ))}
    </div>
    <a href="/resources" class="text-brand-trust font-bold hover:underline">Explore all resources &rarr;</a>
  </div>
</section>
