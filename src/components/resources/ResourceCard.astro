---
export interface Props {
  resource: {
    title: string;
    description: string;
    type: string;
    href: string;
    price?: string;
  };
}

const { resource } = Astro.props;
---

<a href={resource.href} class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col h-full hover-lift group block">
  <div class="flex items-start justify-between mb-4">
    <h3 class="text-xl font-bold text-brand-navy leading-tight group-hover:text-brand-trust transition-colors">{resource.title}</h3>
    <span class="text-xs font-bold uppercase tracking-wider bg-brand-cream text-brand-trust px-2 py-1 rounded ml-2 whitespace-nowrap">{resource.type}</span>
  </div>
  <p class="text-gray-600 mb-6 flex-grow">{resource.description}</p>
  <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-100">
    <span class="text-sm font-bold text-gray-500">{resource.price || "Free"}</span>
    <span class="text-sm font-bold text-brand-gold group-hover:translate-x-1 transition-transform">Access &rarr;</span>
  </div>
</a>
