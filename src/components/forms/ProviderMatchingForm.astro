---
<div class="bg-brand-cream rounded-xl p-8 border border-gray-200 max-w-2xl mx-auto">
  <h2 class="text-2xl font-bold text-brand-navy mb-4 text-center">Not sure where to start?</h2>
  <p class="text-gray-600 mb-6 text-center">Answer a few questions and we'll help guide you to the right provider or resource.</p>
  <form class="space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Your Location (Country)</label>
      <input type="text" class="w-full border border-gray-300 rounded p-2 focus:ring-brand-trust focus:border-brand-trust" placeholder="e.g. USA, Australia" />
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Primary Concern</label>
      <select class="w-full border border-gray-300 rounded p-2 focus:ring-brand-trust focus:border-brand-trust">
        <option>Behavior challenges</option>
        <option>Developmental delay</option>
        <option>ASD/ADHD support</option>
        <option>School/IEP help</option>
        <option>Other</option>
      </select>
    </div>
    <button type="button" class="w-full bg-brand-trust text-white font-bold py-3 rounded hover:bg-blue-700 transition">Show Recommendations</button>
    <p class="text-xs text-gray-500 text-center mt-4">This is a frontend placeholder form. No data is stored.</p>
  </form>
</div>
