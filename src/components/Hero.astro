---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
}

const {
  title,
  subtitle,
  ctaText = "Book Consultation",
  ctaLink = "https://calendar.app.google/zMKejpnpCjh91WRG7",
  secondaryCtaText = "Learn More",
  secondaryCtaLink = "/about"
} = Astro.props;
---

<div class="bg-brand-sky py-20 lg:py-32 overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-navy mb-6 leading-tight">
        {title}
      </h1>
      <p class="text-xl md:text-2xl text-gray-700 mb-10 max-w-2xl mx-auto">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href={ctaLink} target={ctaLink.startsWith('http') ? "_blank" : "_self"} rel={ctaLink.startsWith('http') ? "noopener noreferrer" : ""} class="bg-brand-navy text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-blue-900 transition-colors shadow-lg hover:shadow-xl">
          {ctaText}
        </a>
        <a href={secondaryCtaLink} class="bg-white text-brand-navy px-8 py-4 rounded-full font-bold text-lg border-2 border-brand-navy hover:bg-gray-50 transition-colors">
          {secondaryCtaText}
        </a>
      </div>
    </div>
  </div>
</div>
