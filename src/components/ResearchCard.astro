---
interface Props {
  title: string;
  journal: string;
  year: string;
  href?: string;
}

const { title, journal, year, href } = Astro.props;
---

<div class="bg-white p-6 rounded-lg border border-gray-200 shadow-sm">
  <div class="flex items-start justify-between">
    <div>
      <h3 class="text-lg font-bold text-brand-navy mb-2">{title}</h3>
      <div class="flex flex-wrap items-center text-sm text-gray-600 gap-2 mb-3">
        <span class="font-medium bg-gray-100 px-2 py-1 rounded">{journal}</span>
        <span>•</span>
        <span>{year}</span>
      </div>
    </div>
  </div>
  {href && (
    <a href={href} target="_blank" rel="noopener noreferrer" class="text-sm text-brand-navy hover:text-blue-700 font-medium inline-flex items-center">
      View Publication
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  )}
</div>
