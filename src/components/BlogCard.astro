---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  href: string;
}

const { title, excerpt, date, href } = Astro.props;
---

<article class="bg-white rounded-xl overflow-hidden shadow-sm border border-brand-border flex flex-col h-full hover:shadow-md transition-shadow">
  <div class="h-48 bg-gray-200 flex items-center justify-center">
    <!-- Placeholder for image -->
    <svg class="h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
  </div>
  <div class="p-6 flex-grow flex flex-col">
    <time class="text-sm text-gray-500 mb-2">{date}</time>
    <h3 class="text-xl font-bold text-brand-navy mb-3 line-clamp-2"><a href={href} class="hover:text-blue-700">{title}</a></h3>
    <p class="text-gray-600 mb-4 flex-grow line-clamp-3">{excerpt}</p>
    <a href={href} class="text-brand-navy font-medium hover:text-blue-700">Read Article &rarr;</a>
  </div>
</article>
