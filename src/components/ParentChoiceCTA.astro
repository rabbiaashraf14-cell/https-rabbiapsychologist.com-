---
export interface Props {
  heading?: string;
  copy?: string;
  primaryButtonText?: string;
  primaryButtonLink?: string;
  secondaryButtonText?: string;
  secondaryButtonLink?: string;
}

const {
  heading = "Ready to choose your provider?",
  copy = "The platform gives provider information, education, and booking pathways. Parents are responsible for choosing the provider they wish to book. The platform does not assign or force a provider.",
  primaryButtonText = "Browse Provider Directory",
  primaryButtonLink = "/providers",
  secondaryButtonText = "Not sure who to choose?",
  secondaryButtonLink = "/not-sure-where-to-start"
} = Astro.props;
---

<div class="bg-brand-sky rounded-xl p-8 md:p-12 text-center max-w-4xl mx-auto my-12 border border-blue-100">
  <h2 class="text-2xl md:text-3xl font-bold text-brand-navy mb-4">{heading}</h2>
  <p class="text-gray-700 mb-8 max-w-2xl mx-auto">{copy}</p>

  <div class="flex flex-col sm:flex-row justify-center gap-4">
    <a href={primaryButtonLink} class="bg-brand-navy text-white font-bold py-3 px-8 rounded-full hover:bg-blue-900 transition-colors">
      {primaryButtonText}
    </a>
    <a href={secondaryButtonLink} class="bg-white text-brand-navy border border-brand-navy font-bold py-3 px-8 rounded-full hover:bg-gray-50 transition-colors">
      {secondaryButtonText}
    </a>
  </div>

  <p class="text-xs text-gray-500 mt-6">
    This platform does not guarantee diagnosis, treatment outcome, school placement, insurance coverage, or emergency support.
  </p>
</div>
