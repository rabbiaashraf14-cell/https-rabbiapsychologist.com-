---
import { pricing } from '../../data/pricing';
const displayPricing = pricing.slice(0, 4);
---
<section class="py-16 bg-gray-50">
  <div class="container mx-auto px-4 max-w-4xl">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">Transparent Pricing</h2>
      <p class="text-gray-600">Clear pricing structure for all services.</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <ul class="divide-y divide-gray-100">
        {displayPricing.map(item => (
          <li class="flex justify-between items-center p-4 hover:bg-gray-50">
            <span class="font-medium text-brand-navy">{item.name}</span>
            <span class="text-gray-600">{item.price}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="text-center mt-8">
      <a href="/pricing" class="text-brand-trust font-bold hover:underline">View full pricing details &rarr;</a>
    </div>
  </div>
</section>
