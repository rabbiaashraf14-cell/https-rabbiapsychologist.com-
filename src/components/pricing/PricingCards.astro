---
export interface Props {
  title: string;
  price: string;
  description: string;
  features: string[];
  isPopular?: boolean;
}
const { title, price, description, features, isPopular = false } = Astro.props;
---
<div class={`bg-white rounded-xl p-8 flex flex-col transition-all duration-300 hover:-translate-y-2 relative
    ${isPopular ? 'border-2 border-brand-trust shadow-md scale-105 z-10' : 'border border-gray-200 shadow-sm'}
`}>
  {isPopular && (
    <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-brand-trust text-white px-4 py-1 rounded-full text-xs font-bold uppercase tracking-wide">
      Most Recommended
    </div>
  )}
  <h3 class="text-xl font-bold text-brand-navy mb-2">{title}</h3>
  <div class="text-3xl font-bold text-gray-900 mb-4">{price}</div>
  <p class="text-gray-600 text-sm mb-6 flex-grow">{description}</p>
  <ul class="space-y-3 mb-8">
    {features.map(f => (
      <li class="flex items-start">
        <svg class="w-5 h-5 text-brand-trust mr-3 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span class="text-gray-700 text-sm">{f}</span>
      </li>
    ))}
  </ul>
  <a href="/choose-a-provider" class={`w-full text-center py-3 rounded-lg font-bold transition-colors ${
    isPopular ? 'bg-brand-navy text-white hover:bg-blue-900' : 'bg-brand-trust text-white hover:bg-blue-700'
  }`}>
    View Options
  </a>
</div>
