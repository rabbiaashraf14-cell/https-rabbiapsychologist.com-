---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;
---
<div class="space-y-4 my-8 max-w-3xl mx-auto">
  {faqs.map((faq, index) => (
    <div class="border border-gray-200 rounded-lg overflow-hidden bg-white">
      <button
        class="w-full px-6 py-4 text-left font-semibold text-brand-navy bg-gray-50 hover:bg-gray-100 focus:outline-none flex justify-between items-center region-faq-btn"
        aria-expanded="false"
        data-target={`faq-content-${index}`}
      >
        <span>{faq.question}</span>
        <svg class="h-5 w-5 text-gray-500 transform transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div id={`faq-content-${index}`} class="hidden px-6 py-4 text-gray-700">
        <p set:html={faq.answer}></p>
      </div>
    </div>
  ))}
</div>

<script>
  const faqBtns = document.querySelectorAll('.region-faq-btn');
  faqBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      if (targetId) {
        const content = document.getElementById(targetId);
        const icon = btn.querySelector('svg');
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';

        // Close all others
        faqBtns.forEach(otherBtn => {
            if (otherBtn !== btn) {
                otherBtn.setAttribute('aria-expanded', 'false');
                const otherTargetId = otherBtn.getAttribute('data-target');
                if (otherTargetId) {
                  document.getElementById(otherTargetId)?.classList.add('hidden');
                }
                otherBtn.querySelector('svg')?.classList.remove('rotate-180');
            }
        });

        if (content && icon) {
          if (isExpanded) {
            content.classList.add('hidden');
            btn.setAttribute('aria-expanded', 'false');
            icon.classList.remove('rotate-180');
          } else {
            content.classList.remove('hidden');
            btn.setAttribute('aria-expanded', 'true');
            icon.classList.add('rotate-180');
          }
        }
      }
    });
  });
</script>
