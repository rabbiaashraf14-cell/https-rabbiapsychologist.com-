---
interface Props {
  time: string;
  age: string;
  evidenceBased?: boolean;
  reviewed?: boolean;
  parentFriendly?: boolean;
}

const { time, age, evidenceBased = true, reviewed = true, parentFriendly = true } = Astro.props;
---
<div class="bg-brand-cream rounded-xl p-6 my-8 border border-brand-border">
  <h3 class="text-brand-navy font-bold text-lg mb-4 flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    Quick Facts
  </h3>

  <div class="grid grid-cols-2 md:grid-cols-3 gap-y-4 gap-x-6 text-sm">
    <div class="flex items-start gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <span class="block text-gray-500 text-xs font-semibold uppercase tracking-wider">Reading Time</span>
        <span class="font-medium text-brand-navy">{time}</span>
      </div>
    </div>

    <div class="flex items-start gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
      <div>
        <span class="block text-gray-500 text-xs font-semibold uppercase tracking-wider">Age Group</span>
        <span class="font-medium text-brand-navy">{age}</span>
      </div>
    </div>

    {evidenceBased && (
      <div class="flex items-start gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-trust flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
        </svg>
        <div>
          <span class="block text-gray-500 text-xs font-semibold uppercase tracking-wider">Methodology</span>
          <span class="font-medium text-brand-navy">Evidence Based</span>
        </div>
      </div>
    )}

    {reviewed && (
      <div class="flex items-start gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-trust flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
          <span class="block text-gray-500 text-xs font-semibold uppercase tracking-wider">Reviewed By</span>
          <span class="font-medium text-brand-navy">Clinical Psychologist</span>
        </div>
      </div>
    )}

    {parentFriendly && (
      <div class="flex items-start gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-brand-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
        </svg>
        <div>
          <span class="block text-gray-500 text-xs font-semibold uppercase tracking-wider">Tone</span>
          <span class="font-medium text-brand-navy">Parent Friendly</span>
        </div>
      </div>
    )}
  </div>
</div>
