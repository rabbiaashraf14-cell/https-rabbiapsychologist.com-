---
import { Image } from 'astro:assets';
import { articles } from '../../data/blogArticles';
import { getArticleImage, getCategoryFallbackSvg } from '../../utils/imageMatching';
import BlogImageSlideshow from './BlogImageSlideshow.astro';

interface Props {
  currentUrl: string;
}

const { currentUrl } = Astro.props;

// Dynamically import all blog images
const localImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/blog/*.{jpeg,jpg,png,webp,gif}', { eager: true });

// Find the current article to get its categories
const currentArticle = articles.find(a => a.href === currentUrl);
const currentCategories = currentArticle ? currentArticle.categories : [];

// Filter out the current article
let relatedArticles = articles.filter(a => a.href !== currentUrl);

// Sort logic: first by number of matching categories, then by date descending
relatedArticles.sort((a, b) => {
  const aMatchCount = a.categories.filter(c => currentCategories.includes(c)).length;
  const bMatchCount = b.categories.filter(c => currentCategories.includes(c)).length;

  if (aMatchCount !== bMatchCount) {
    return bMatchCount - aMatchCount;
  }
  return new Date(b.date).getTime() - new Date(a.date).getTime();
});

// Take top 4
const displayArticles = relatedArticles.slice(0, 4);

// Function to find the image for an article based on requested logic: sanityImage -> localImage -> imageUrl -> fallback

---

<div class="mt-8 border-t border-brand-border pt-8 lg:border-t-0 lg:pt-0 lg:mt-8">
  <h3 class="text-xl font-bold text-brand-navy mb-6">Related Articles</h3>

  <div class="flex flex-col gap-6">
    {displayArticles.map(article => {
      const imageData = getArticleImage(article, localImages);
      return (
        <a href={article.href} class="group block bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover-lift transition-all">

          {imageData.type === 'local' || imageData.type === 'remote' ? (
            <div class="aspect-w-16 aspect-h-9 w-full overflow-hidden bg-gray-100 border-b border-gray-100">
              {imageData.type === 'local' ? (
                <Image
                  src={imageData.src as ImageMetadata}
                  alt={article.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  width={400}
                  height={225}
                />
              ) : (
                <img
                  src={imageData.src as string}
                  alt={article.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  onerror={`this.onerror=null; this.src='${getCategoryFallbackSvg(article.categories)}';`}
                />
              )}
            </div>
          ) : (
            <div class="aspect-w-16 aspect-h-9 w-full overflow-hidden bg-gray-100 border-b border-gray-100">
              <BlogImageSlideshow articleTitle={article.title} fallbackSvg={imageData.src as string} />
            </div>
          )}
          <div class="p-4">
            <div class="flex flex-wrap gap-2 mb-2">
              {article.categories.slice(0, 2).map((cat: string) => (
                <span class="text-[10px] font-bold uppercase tracking-wider text-brand-trust bg-brand-cream px-2 py-1 rounded">{cat}</span>
              ))}
            </div>
            <h4 class="font-bold text-brand-navy group-hover:text-brand-gold transition-colors text-sm leading-tight mb-2 line-clamp-2">
              {article.title}
            </h4>
            <p class="text-xs text-gray-500 line-clamp-2 mb-3">
              {article.excerpt}
            </p>
            <div class="text-xs font-bold text-brand-gold flex items-center gap-1 group-hover:translate-x-1 transition-transform w-fit">
              Read article <span aria-hidden="true">&rarr;</span>
            </div>
          </div>
        </a>
      );
    })}
  </div>
</div>
