---
// src/components/blog/FAQAccordion.astro
interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;
---
<div class="my-10">
  <h3 class="text-2xl font-bold text-brand-navy mb-6">Frequently Asked Questions</h3>
  <div class="space-y-4">
    {faqs.map((faq, index) => (
      <details class="group bg-white border border-brand-border rounded-lg overflow-hidden [&_summary::-webkit-details-marker]:hidden">
        <summary class="flex items-center justify-between cursor-pointer p-5 font-bold text-brand-navy hover:text-brand-gold transition-colors">
          <span>{faq.question}</span>
          <span class="transition duration-300 group-open:-rotate-180">
            <svg class="w-5 h-5 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </span>
        </summary>
        <div class="p-5 pt-0 text-gray-700 bg-white border-t border-gray-100">
          {faq.answer}
        </div>
      </details>
    ))}
  </div>
</div>
