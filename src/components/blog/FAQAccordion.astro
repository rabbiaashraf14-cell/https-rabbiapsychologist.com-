---
interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;

// Schema generation is usually handled in the page head,
// but we ensure the component structure matches a beautiful accordion
---
<div class="my-12">
  <h2 class="text-2xl font-bold text-brand-navy mb-6">Frequently Asked Questions</h2>

  <div class="space-y-4">
    {faqs.map((faq, index) => (
      <details class="group bg-white rounded-xl border border-brand-border shadow-sm overflow-hidden" name="faq-accordion">
        <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-brand-navy hover:bg-gray-50 transition-colors">
          <span class="text-lg pr-6">{faq.question}</span>
          <span class="transition group-open:rotate-180 flex-shrink-0 text-brand-gold">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <div class="p-6 pt-0 text-gray-700 leading-relaxed border-t border-gray-100 mt-2">
          <p class="m-0 text-base">{faq.answer}</p>
        </div>
      </details>
    ))}
  </div>
</div>
