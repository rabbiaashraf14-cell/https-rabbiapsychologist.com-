---
interface Props {
  datePublished?: string;
  dateModified?: string;
  readTime?: string;
}

const { datePublished, dateModified, readTime } = Astro.props;
---
<div class="bg-white rounded-xl shadow-sm border border-brand-border overflow-hidden my-12">
  <div class="p-6 md:p-8 flex flex-col md:flex-row items-center md:items-start gap-6">
    <div class="w-32 h-32 rounded-full overflow-hidden bg-brand-cream flex-shrink-0 border-4 border-white shadow-md">
      <img src="/images/rabbia-ashraf-psychologist.jpg" alt="Rabbia Ashraf, Clinical Psychologist" class="w-full h-full object-cover" onerror="this.src='/favicon.png'" />
    </div>

    <div class="flex-grow text-center md:text-left">
      <h3 class="font-bold text-brand-navy m-0 text-2xl mb-1">Rabbia Ashraf</h3>
      <p class="text-brand-gold font-medium mb-3">Clinical Psychologist | Child & Adolescent Development</p>

      <p class="text-sm text-gray-700 mb-4 leading-relaxed max-w-2xl mx-auto md:mx-0">
        Rabbia Ashraf is a dedicated Clinical Psychologist specializing in child and adolescent development. She provides parent coaching, developmental guidance, and psychoeducation.
      </p>

      <div class="flex flex-wrap items-center justify-center md:justify-start gap-3 mb-6">
        <span class="inline-flex items-center px-3 py-1 rounded-full bg-brand-cream text-brand-navy text-xs font-medium border border-brand-border">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 mr-1.5 text-brand-gold" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          Clinical Psychologist
        </span>
        <span class="inline-flex items-center px-3 py-1 rounded-full bg-brand-cream text-brand-navy text-xs font-medium border border-brand-border">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 mr-1.5 text-brand-gold" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z" />
          </svg>
          M.Phil, MS Clinical Psychology
        </span>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start">
        <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-5 py-2.5 bg-brand-navy hover:bg-brand-gold text-white font-medium rounded-lg transition-colors duration-200">
          Book Consultation
        </a>
        <a href="/about" class="inline-flex items-center justify-center px-5 py-2.5 bg-white border-2 border-brand-navy text-brand-navy hover:bg-brand-cream font-medium rounded-lg transition-colors duration-200">
          View Profile
        </a>
      </div>
    </div>
  </div>

  {(datePublished || dateModified || readTime) && (
    <div class="bg-gray-50 border-t border-brand-border px-6 py-3 flex flex-wrap gap-4 text-xs text-gray-500 items-center justify-center md:justify-start">
      {datePublished && <span>Published: {datePublished}</span>}
      {dateModified && <span>Updated: {dateModified}</span>}
      {readTime && <span>{readTime} read</span>}
    </div>
  )}
</div>
