---
// src/components/blog/PrevNextNav.astro
interface ArticlePreview {
  title: string;
  href: string;
}

interface Props {
  prev?: ArticlePreview;
  next?: ArticlePreview;
}

const { prev, next } = Astro.props;
---
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-12 py-8 border-y border-gray-200">
  <div class="flex flex-col">
    {prev && (
      <a href={prev.href} class="group p-4 rounded-lg hover:bg-brand-cream transition-colors border border-transparent hover:border-brand-border">
        <span class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 block">&larr; Previous Article</span>
        <h4 class="font-bold text-brand-navy group-hover:text-brand-gold transition-colors">{prev.title}</h4>
      </a>
    )}
  </div>
  <div class="flex flex-col text-right">
    {next && (
      <a href={next.href} class="group p-4 rounded-lg hover:bg-brand-cream transition-colors border border-transparent hover:border-brand-border">
        <span class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2 block">Next Article &rarr;</span>
        <h4 class="font-bold text-brand-navy group-hover:text-brand-gold transition-colors">{next.title}</h4>
      </a>
    )}
  </div>
</div>
