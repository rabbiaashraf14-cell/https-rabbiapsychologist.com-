---
interface Props {
  items: string[];
}

const { items } = Astro.props;
const displayItems = items.slice(0, 5); // Ensure maximum 5 items as per spec
---
<div class="my-12 bg-gradient-to-br from-brand-navy to-[#1a3a5f] rounded-2xl p-1 shadow-xl">
  <div class="bg-white rounded-xl p-8 md:p-10 h-full w-full">
    <div class="flex items-center justify-center gap-3 mb-8 pb-6 border-b border-gray-100">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
      </svg>
      <h2 class="text-2xl font-bold text-brand-navy m-0">Key Takeaways</h2>
    </div>

    <ul class="space-y-5 ml-0 pl-0 list-none m-0">
      {displayItems.map(item => (
        <li class="flex items-start gap-4 m-0 p-0 text-gray-800 text-lg">
          <div class="mt-1 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" />
            </svg>
          </div>
          <span class="font-medium leading-relaxed">{item}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
