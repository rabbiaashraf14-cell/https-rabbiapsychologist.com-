---
interface Props {
  title?: string;
  items: string[];
}

const { title = "What Parents Can Do Today", items } = Astro.props;
---
<div class="my-10 bg-brand-navy rounded-xl p-8 text-white shadow-lg">
  <div class="flex items-center gap-3 mb-6 border-b border-white/20 pb-4">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-brand-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
    </svg>
    <h3 class="font-bold text-2xl text-white m-0">{title}</h3>
  </div>

  <ul class="space-y-4 ml-0 pl-0 list-none m-0">
    {items.map(item => (
      <li class="flex items-start gap-4 m-0 p-0">
        <div class="w-6 h-6 rounded-full bg-brand-gold/20 flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-brand-gold" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        </div>
        <span class="text-white text-lg font-medium">{item}</span>
      </li>
    ))}
  </ul>
</div>
