---
// src/components/blog/ProgressBar.astro
---
<div id="reading-progress-container" class="fixed top-0 left-0 w-full h-1 bg-brand-cream z-50">
  <div id="reading-progress-bar" class="h-full bg-brand-gold w-0 transition-all duration-150 ease-out"></div>
</div>

<script>
  document.addEventListener('scroll', () => {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    const bar = document.getElementById("reading-progress-bar");
    if (bar) {
      bar.style.width = scrolled + "%";
    }
  });
</script>
