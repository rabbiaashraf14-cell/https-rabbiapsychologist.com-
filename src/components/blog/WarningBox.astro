---
interface Props {
  title?: string;
  items: string[];
}

const { title = "Seek professional advice if your child", items } = Astro.props;
---
<div class="my-10 bg-[#FFF5F5] border-l-4 border-red-500 rounded-r-lg p-6 md:p-8 shadow-sm">
  <div class="flex items-center gap-3 mb-4">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
    </svg>
    <h3 class="font-bold text-red-800 m-0 text-lg">{title}</h3>
  </div>

  <ul class="space-y-2 mt-4 ml-0 pl-0 list-none m-0">
    {items.map(item => (
      <li class="flex items-start gap-3 text-red-900 m-0 p-0">
        <span class="text-red-500 font-bold flex-shrink-0 mt-0.5">&bull;</span>
        <span class="font-medium">{item}</span>
      </li>
    ))}
  </ul>
</div>
