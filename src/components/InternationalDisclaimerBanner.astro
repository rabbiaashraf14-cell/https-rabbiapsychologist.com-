---
interface Props {
  text?: string;
}

const { text = "International support may include parent education, developmental guidance, ASD/ADHD support planning, behavior strategy discussion, executive-function routines, school communication preparation, resource guidance, and referral direction. Clinical therapy, diagnosis, assessment, and regulated psychological services are provided only where legally and ethically permitted by the professional's credentials and the client's location." } = Astro.props;
---
<div class="bg-gray-800 text-white p-4 sm:p-6 rounded-lg text-sm md:text-base leading-relaxed border-l-4 border-brand-sky my-8">
  <div class="flex items-start">
    <svg class="h-6 w-6 text-brand-sky mr-3 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <p>
      <strong>Important Notice:</strong> {text}
    </p>
  </div>
</div>
