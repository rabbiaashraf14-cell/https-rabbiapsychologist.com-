---
interface Props {
  title: string;
  description: string;
  duration: string;
  format: string;
  href: string;
}

const { title, description, duration, format, href } = Astro.props;
---

<div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm flex flex-col h-full">
  <div class="flex gap-2 mb-4">
    <span class="bg-brand-sky text-brand-navy text-xs font-bold px-2 py-1 rounded">{format}</span>
    <span class="bg-gray-100 text-gray-700 text-xs font-bold px-2 py-1 rounded">{duration}</span>
  </div>
  <h3 class="text-xl font-bold text-brand-navy mb-3">{title}</h3>
  <p class="text-gray-600 mb-6 flex-grow">{description}</p>
  <a href={href} class="block w-full text-center bg-brand-navy text-white py-2 rounded-lg font-medium hover:bg-blue-900 transition-colors">
    Program Details
  </a>
</div>
