---
import { mainNav } from '../../data/navigation';

const servicesNav = [
  { label: 'ADHD Support', href: '/services/adhd-support' },
  { label: 'ASD Support', href: '/services/asd-support' },
  { label: 'Behaviour Planning', href: '/services/behaviour-planning' },
  { label: 'School Consultation', href: '/services/school-consultation' },
  { label: 'Local Assessment', href: '/services/local-assessment' },
  { label: 'Report Review', href: '/report-review' },
  { label: 'Parent Support', href: '/parent-support' }
];

const resourcesNav = [
  { label: 'Blog', href: '/blog' },
  { label: 'Resource Vault', href: '/resource-vault' },
  { label: 'Free Downloads', href: '/free-downloads' },
  { label: 'FAQs', href: '/faqs' }
];

---
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="container mx-auto px-4 h-[80px] flex items-center justify-between">
    <a href="/" class="z-50 shrink-0">
      <img src="/logo.png" alt="Rabbia Psychologist Child Development Services logo" class="h-[48px] md:h-[64px] w-auto object-contain" />
    </a>

    <nav class="hidden lg:flex space-x-6 items-center">
      {mainNav.filter(item => item.label !== 'Book Consultation').map(item => {
        if (item.label === 'Services') {
          return (
            <div class="relative group">
              <a href={item.href} class="text-gray-600 hover:text-brand-navy font-medium transition-colors flex items-center gap-1">
                {item.label}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
              </a>
              <div class="absolute left-0 mt-2 w-56 bg-white border border-gray-100 shadow-lg rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <ul class="py-2">
                  {servicesNav.map(subItem => (
                    <li><a href={subItem.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand-navy">{subItem.label}</a></li>
                  ))}
                </ul>
              </div>
            </div>
          );
        }
        if (item.label === 'Resources') {
          return (
            <div class="relative group">
              <a href={item.href} class="text-gray-600 hover:text-brand-navy font-medium transition-colors flex items-center gap-1">
                {item.label}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
              </a>
              <div class="absolute left-0 mt-2 w-56 bg-white border border-gray-100 shadow-lg rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <ul class="py-2">
                  {resourcesNav.map(subItem => (
                    <li><a href={subItem.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand-navy">{subItem.label}</a></li>
                  ))}
                </ul>
              </div>
            </div>
          );
        }
        if (item.label === 'Blog') {
          return (
            <div class="relative group">
              <a href={item.href} class="text-gray-600 hover:text-brand-navy font-medium transition-colors flex items-center gap-1">
                {item.label}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
              </a>
              <div class="absolute left-0 mt-2 w-56 bg-white border border-gray-100 shadow-lg rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <ul class="py-2">
                  <li><a href="/blog" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand-navy">All Articles</a></li>
                  <li><a href="/blog#start-here" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand-navy">Start Here</a></li>
                  <li><a href="/blog#latest" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand-navy">Latest Articles</a></li>
                </ul>
              </div>
            </div>
          );
        }
        return <a href={item.href} class="text-gray-600 hover:text-brand-navy font-medium transition-colors">{item.label}</a>;
      })}
      <a href="/book" class="bg-brand-navy text-white px-6 py-2.5 rounded-lg font-bold hover:bg-blue-900 transition-colors shadow-sm inline-block">Book Consultation</a>
    </nav>

    <div class="flex items-center gap-3 lg:hidden z-50">
      <a href="/book" class="bg-brand-navy text-white px-4 py-2 text-sm rounded-lg font-bold hover:bg-blue-900 transition-colors shadow-sm whitespace-nowrap">
        Book Now
      </a>
      <button id="mobile-menu-btn" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Toggle mobile menu" class="text-brand-navy p-1 focus:outline-none focus:ring-2 focus:ring-brand-navy rounded">
        <svg id="icon-menu" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        <svg id="icon-close" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
  </div>

  <!-- Overlay -->
  <div id="mobile-menu-overlay" class="hidden fixed inset-0 bg-brand-navy/50 z-40 lg:hidden" aria-hidden="true"></div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden absolute top-[80px] left-0 w-full bg-white shadow-xl z-50 border-t border-gray-100 max-h-[calc(100vh-80px)] overflow-y-auto lg:hidden" role="dialog" aria-modal="true" aria-label="Mobile navigation">
    <nav class="px-4 py-6 flex flex-col">
      <ul class="space-y-1">
        <li><a href="/" class="block text-brand-navy hover:text-blue-700 font-bold py-3 border-b border-gray-50 text-lg">Home</a></li>
        <li><a href="/start-here" class="block text-brand-navy hover:text-blue-700 font-bold py-3 border-b border-gray-50 text-lg">Start Here</a></li>

        <li class="py-3 border-b border-gray-50">
          <a href="/services" class="block text-brand-navy hover:text-blue-700 font-bold text-lg mb-2">Services</a>
          <ul class="pl-4 space-y-3 border-l-2 border-brand-gold/30 ml-2 mt-3">
            {servicesNav.map(item => (
              <li><a href={item.href} class="block text-gray-700 hover:text-brand-navy py-1.5 text-base">{item.label}</a></li>
            ))}
          </ul>
        </li>

        <li class="py-3 border-b border-gray-50">
          <a href="/resources" class="block text-brand-navy hover:text-blue-700 font-bold text-lg mb-2">Resources</a>
          <ul class="pl-4 space-y-3 border-l-2 border-brand-gold/30 ml-2 mt-3">
            {resourcesNav.map(item => (
              <li><a href={item.href} class="block text-gray-700 hover:text-brand-navy py-1.5 text-base">{item.label}</a></li>
            ))}
          </ul>
        </li>

        <li><a href="/pricing" class="block text-brand-navy hover:text-blue-700 font-bold py-3 border-b border-gray-50 text-lg">Pricing</a></li>
        <li><a href="/about" class="block text-brand-navy hover:text-blue-700 font-bold py-3 border-b border-gray-50 text-lg">About Rabbia</a></li>
      </ul>

      <div class="mt-8 pt-4 pb-12">
        <a href="/book" class="bg-brand-navy text-white px-4 py-4 text-center rounded-lg font-bold hover:bg-blue-900 block w-full text-lg shadow-md">Book Consultation</a>
      </div>
    </nav>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-menu-overlay');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');
    const links = menu?.querySelectorAll('a');

    if (btn && menu && overlay && iconMenu && iconClose) {
      const toggleMenu = () => {
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', (!isExpanded).toString());
        menu.classList.toggle('hidden');
        overlay.classList.toggle('hidden');
        iconMenu.classList.toggle('hidden');
        iconClose.classList.toggle('hidden');

        if (!isExpanded) {
          document.body.style.overflow = 'hidden';
        } else {
          document.body.style.overflow = '';
        }
      };

      const closeMenu = () => {
        menu.classList.add('hidden');
        overlay.classList.add('hidden');
        iconMenu.classList.remove('hidden');
        iconClose.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      };

      btn.addEventListener('click', toggleMenu);
      overlay.addEventListener('click', closeMenu);

      links?.forEach(link => {
        link.addEventListener('click', closeMenu);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
          closeMenu();
          btn.focus();
        }
      });
    }
  });
</script>
