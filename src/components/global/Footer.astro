---
import { siteConfig } from '../../data/site';
---
<footer class="bg-brand-navy text-white py-12 mt-16">
  <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-8">
    <div class="col-span-1 md:col-span-2">
      <h3 class="font-bold text-xl mb-4">{siteConfig.siteName}</h3>
      <p class="text-gray-300 mb-4">{siteConfig.tagline}</p>
      <p class="text-xs text-gray-400 mb-2"><strong>Emergency Disclaimer:</strong> {siteConfig.disclaimers.emergency}</p>
      <p class="text-xs text-gray-400"><strong>International Services:</strong> {siteConfig.disclaimers.international}</p>
    </div>
    <div>
      <h4 class="font-bold mb-4">Links</h4>
      <ul class="space-y-2">
        <li><a href="/about" class="text-gray-300 hover:text-white">About</a></li>
        <li><a href="/services" class="text-gray-300 hover:text-white">Services</a></li>
        <li><a href="/providers" class="text-gray-300 hover:text-white">Providers</a></li>
        <li><a href="/pricing" class="text-gray-300 hover:text-white">Pricing</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-bold mb-4">Legal</h4>
      <ul class="space-y-2">
        <li><a href="/privacy-policy" class="text-gray-300 hover:text-white">Privacy Policy</a></li>
        <li><a href="/terms-and-disclaimer" class="text-gray-300 hover:text-white">Terms & Disclaimer</a></li>
      </ul>
    </div>
  </div>
  <div class="container mx-auto px-4 mt-8 pt-8 border-t border-gray-700 text-center text-sm text-gray-400">
    &copy; {new Date().getFullYear()} {siteConfig.siteName}. All rights reserved.
  </div>
</footer>
