---
import { regions } from '../../data/regions';
---
<section class="py-16 bg-brand-navy text-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold mb-4">Support by Region</h2>
      <p class="text-gray-300">Understanding service boundaries based on your location.</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      {regions.map(region => (
        <a href={`/regions/${region.slug}`} class="bg-gray-800 rounded-lg p-4 text-center hover:bg-gray-700 transition">
          <span class="block font-medium">{region.title}</span>
        </a>
      ))}
    </div>
  </div>
</section>
