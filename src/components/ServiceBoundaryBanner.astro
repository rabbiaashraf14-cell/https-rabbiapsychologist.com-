---
export interface Props {
  region: string;
  isInternational?: boolean;
}

const { region, isInternational = false } = Astro.props;
---

<div class="bg-blue-50 border-l-4 border-brand-trust p-4 mb-8 rounded-r-lg">
  <div class="flex">
    <div class="flex-shrink-0">
      <svg class="h-5 w-5 text-brand-trust" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
      </svg>
    </div>
    <div class="ml-3">
      <h3 class="text-sm font-medium text-brand-navy">Service Boundaries for {region}</h3>
      <div class="mt-2 text-sm text-gray-700">
        <p class="mb-2">
          This platform helps parents access education, parent guidance, consultation options, and provider information. Parents are responsible for choosing the provider they wish to book.
        </p>
        {isInternational ? (
          <p class="mb-2">
            <strong>International consultations</strong> may include parent education, developmental guidance, ASD/ADHD support planning, behavior strategy discussion, executive-function routines, school communication preparation, and referral guidance. Clinical therapy, diagnosis, assessment, and regulated psychological services are provided only where legally and ethically permitted.
          </p>
        ) : (
          <p class="mb-2">
            Each provider is responsible for working within their own professional scope, qualifications, license, registration, and regional legal requirements.
          </p>
        )}
      </div>
    </div>
  </div>
</div>
