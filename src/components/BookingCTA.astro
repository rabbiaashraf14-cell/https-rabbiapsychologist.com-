---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Start with an initial parent consultation.",
  description = "Book an initial consultation to discuss your concerns and learn how we can support your family's unique needs."
} = Astro.props;
---

<div class="bg-brand-navy rounded-3xl p-8 md:p-12 text-center text-white my-16 shadow-xl flex flex-col items-center">
  <img src="/brand/logo-icon.svg" alt="" class="h-12 w-12 mb-6 opacity-80" aria-hidden="true" />
  <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
  <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-2xl mx-auto">{description}</p>
  <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" target="_blank" rel="noopener noreferrer" class="inline-block bg-white text-brand-navy px-8 py-4 rounded-full font-bold text-lg hover:bg-gray-100 transition-colors shadow-lg">
    Book Your Consultation Now
  </a>
</div>
