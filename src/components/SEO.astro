---
interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  type?: string;
  image?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title,
  description,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  type = "website",
  image = "/og-brand-card.png",
  ogTitle,
  ogDescription
} = Astro.props;

const siteName = "Rabbia Psychologist Child Development Services";
---

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title} | {siteName}</title>
<meta name="title" content={`${title} | ${siteName}`} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={ogTitle || title} />
<meta property="og:description" content={ogDescription || description} />
<meta property="og:image" content={new URL(image, Astro.site).href} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={ogTitle || title} />
<meta property="twitter:description" content={ogDescription || description} />
<meta property="twitter:image" content={new URL(image, Astro.site).href} />
