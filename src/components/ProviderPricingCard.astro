---
export interface Props {
  pricing: {
    serviceName: string;
    price: string;
    description?: string;
  }[];
  disclaimer?: string;
}

const { pricing, disclaimer } = Astro.props;
---

<div class="bg-brand-cream rounded-lg p-6 mb-8 border border-amber-100">
  <h2 class="text-xl font-bold text-brand-navy mb-4">Pricing</h2>

  <div class="space-y-4 mb-6">
    {pricing.map(item => (
      <div class="flex justify-between items-center border-b border-amber-200/50 pb-3 last:border-0 last:pb-0">
        <div>
          <h3 class="font-medium text-brand-navy">{item.serviceName}</h3>
          {item.description && <p class="text-xs text-gray-600 mt-1">{item.description}</p>}
        </div>
        <div class="font-bold text-brand-navy ml-4 whitespace-nowrap">{item.price}</div>
      </div>
    ))}
  </div>

  <div class="text-xs text-gray-500 bg-white p-3 rounded border border-gray-100">
    <p>
      {disclaimer || "Prices vary by provider, region, session type, and scope of service. Parents can review provider profiles and select the option that fits their needs before booking. Final payment amount may vary depending on currency conversion, payment method, provider availability, and service scope."}
    </p>
  </div>
</div>
