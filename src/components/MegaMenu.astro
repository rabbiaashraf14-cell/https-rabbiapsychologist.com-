  {
    name: 'Home',
    href: '/'
  },
  {
    name: 'About',
    href: '/about',
    submenu: [
      { name: 'About Rabbia', href: '/about' },
      { name: 'Credentials', href: '/credentials' },
      { name: 'Research & Publications', href: '/research-hub' },
      { name: 'Webinars & Symposiums', href: '/webinars' },
      { name: 'Professional Approach', href: '/about#approach' }
    ]
  },
  {
    name: 'Find Support',
    href: '/find-support',
    submenu: [
      { name: 'Choose a Provider', href: '/choose-a-provider' },
      { name: 'Not Sure Where to Start?', href: '/not-sure-where-to-start' },
      {
        name: 'International Families',
        href: '/international-families',
        nested: [
          { name: 'Global Parent Consultation', href: '/global-consultation' },
          { name: 'USA Families', href: '/online-parent-consultation-usa' },
          { name: 'Australia Families', href: '/online-parent-consultation-australia' },
          { name: 'UK & Europe Families', href: '/online-parent-consultation-uk-europe' },
          { name: 'MENA & Gulf Families', href: '/online-parent-consultation-mena-gulf' },
          { name: 'Pakistan Families', href: '/online-parent-consultation-pakistan' },
          { name: 'International Schools', href: '/international-schools' },
          { name: 'Before You Book', href: '/before-you-book-international' },
          { name: 'Service Boundaries', href: '/service-boundaries' },
          { name: 'Privacy for International Families', href: '/privacy-for-international-families' },
        ]
      },
    ]
  },
  {
    name: 'Providers',
    href: '/providers',
    submenu: [
      { name: 'Provider Directory', href: '/providers' },
      { name: 'Rabbia Ashraf', href: '/providers/rabbia-ashraf' },
      { name: 'Australia Providers', href: '/providers/australia' },
      { name: 'USA Providers', href: '/providers/usa' },
      { name: 'MENA & Gulf Providers', href: '/providers/mena-gulf' },
      { name: 'UK & Europe Providers', href: '/providers/uk-europe' },
      { name: 'Pakistan Providers', href: '/providers/pakistan' },
      { name: 'Provider Verification', href: '/provider-verification' },
      { name: 'Join as Provider', href: '/join-as-provider' }
    ]
  },
  {
    name: 'Services',
    href: '/services',
    submenu: [
      { name: 'Global Consultation', href: '/global-consultation' },
      { name: 'Autism Support', href: '/autism-support' },
      { name: 'ADHD Support', href: '/adhd-support' },
