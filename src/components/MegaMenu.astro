    submenu: [
      { name: 'Session Pricing', href: '/pricing#sessions' },
      { name: 'Parent Packages', href: '/pricing#packages' },
      { name: 'Digital Products', href: '/pricing#products' },
      { name: 'Workshop Pricing', href: '/pricing#workshops' },
      { name: 'School/Clinic Pricing', href: '/pricing#schools' }
