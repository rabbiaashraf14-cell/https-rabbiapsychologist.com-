---
const menuItems = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Team', href: '/team' },
  { name: 'Services', href: '/services' },
  { name: 'Conditions', href: '/conditions' },
  { name: 'Assessments', href: '/assessments' },
  { name: 'International Families', href: '/international-families' },
  { name: 'Pricing', href: '/pricing' },
  { name: 'Parent Resources', href: '/resources' },
  { name: 'Training & Workshops', href: '/training' },
  { name: 'Booking', href: '/book' },
  { name: 'Contact', href: '/contact' }
];
---

<ul class="flex space-x-6 h-full items-center">
  {menuItems.map(item => (
    <li class="relative group h-full flex items-center">
      <a href={item.href} class="text-brand-navy hover:text-blue-700 font-medium py-2">
        {item.name}
      </a>
      {item.submenu && (
        <div class="absolute top-full left-0 mt-0 w-64 bg-white shadow-lg rounded-b-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 py-2 border-t border-brand-sky">
          <ul class="flex flex-col">
            {item.submenu.map(subitem => (
              <li>
                <a href={subitem.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-brand-sky hover:text-brand-navy">
                  {subitem.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </li>
  ))}
</ul>
