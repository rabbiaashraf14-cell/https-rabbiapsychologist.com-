      { name: 'School & IEP Consultation', href: '/school-iep-consultation' },
      { name: 'Behavior Support Planning', href: '/behavior-support-planning' }
    ]
  },
  {
    name: 'Resources',
    href: '/resources',
    submenu: [
      { name: 'Resource Vault', href: '/resource-vault' },
      { name: 'Free Downloads', href: '/free-downloads' },
      { name: 'Blog', href: '/blog' },
      { name: 'Parent Guides', href: '/resource-vault#guides' },
      { name: 'Worksheets & Logs', href: '/resource-vault#worksheets' },
      { name: 'FAQs', href: '/faqs' }
    ]
  },
  {
    name: 'Programs',
    href: '/programs',
    submenu: [
      { name: 'ASD Parent Guidance Program', href: '/programs#asd' },
      { name: 'ADHD Executive Function Program', href: '/programs#adhd' },
      { name: '4-Session Parent Training Package', href: '/programs#parent-training' },
