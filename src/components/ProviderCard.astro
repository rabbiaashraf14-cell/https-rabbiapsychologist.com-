---
export interface Props {
  provider: {
    name: string;
    photoUrl?: string;
    title: string;
    country: string;
    timezone: string;
    languages: string[];
    areasOfSupport: string[];
    serviceType: string;
    verifiedCredentials: string[];
    licenseNote: string;
    serviceBoundaryNote: string;
    price: string;
    bookingLink: string;
    profileSlug: string;
  };
}

const { provider } = Astro.props;
---

<div class="bg-white rounded-lg shadow-sm border border-gray-100 overflow-hidden flex flex-col h-full transition-shadow hover:shadow-md">
  <div class="p-6 flex-grow">
    <div class="flex items-start gap-4 mb-4">
      <div class="w-16 h-16 rounded-full bg-brand-sky flex items-center justify-center text-brand-navy font-bold text-xl flex-shrink-0">
        {provider.photoUrl ? (
          <img src={provider.photoUrl} alt={provider.name} class="w-full h-full object-cover rounded-full" />
        ) : (
          provider.name.charAt(0)
        )}
      </div>
      <div>
        <h3 class="text-xl font-bold text-brand-navy">{provider.name}</h3>
        <p class="text-brand-trust text-sm font-medium">{provider.title}</p>
        <p class="text-gray-500 text-xs mt-1">{provider.country} • {provider.timezone}</p>
      </div>
    </div>

    <div class="space-y-3 mb-6">
      <div>
        <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Service Type</h4>
        <p class="text-sm text-gray-700">{provider.serviceType}</p>
      </div>
      <div>
        <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Areas of Support</h4>
        <div class="flex flex-wrap gap-1">
          {provider.areasOfSupport.map(area => (
            <span class="inline-block bg-brand-cream text-gray-700 text-xs px-2 py-1 rounded-full">{area}</span>
          ))}
        </div>
      </div>
      <div>
        <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Languages</h4>
        <p class="text-sm text-gray-700">{provider.languages.join(', ')}</p>
      </div>
    </div>

    <div class="bg-gray-50 p-3 rounded-md mb-4 text-xs">
      <p class="text-gray-600 mb-2"><strong>Credentials:</strong> {provider.verifiedCredentials.join(', ')}</p>
      <p class="text-gray-600 mb-2"><strong>License Note:</strong> {provider.licenseNote}</p>
      <p class="text-gray-500 italic">{provider.serviceBoundaryNote}</p>
    </div>
  </div>

  <div class="border-t border-gray-100 p-4 bg-gray-50 flex items-center justify-between">
    <div class="text-brand-navy font-bold">{provider.price}</div>
    <div class="flex gap-2">
      <a href={`/providers/${provider.profileSlug}`} class="text-brand-trust hover:text-brand-navy font-medium text-sm py-2 px-3 transition-colors">View Profile</a>
      <a href={provider.bookingLink} target="_blank" rel="noopener noreferrer" class="bg-brand-navy text-white text-sm font-medium py-2 px-4 rounded-full hover:bg-blue-900 transition-colors">Book</a>
    </div>
  </div>
</div>
