---
import { providers } from '../../data/providers';
import ProviderCard from './ProviderCard.astro';
const displayProviders = providers.slice(0, 3);
---
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">Meet Our Providers</h2>
      <p class="text-gray-600">Verified specialists available for online consultation.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {displayProviders.map(provider => (
        <ProviderCard provider={provider} />
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/providers" class="text-brand-trust font-bold hover:underline">View All Providers &rarr;</a>
    </div>
  </div>
</section>
