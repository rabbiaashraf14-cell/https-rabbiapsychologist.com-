---
interface Props {
  provider: any;
}
const { provider } = Astro.props;
---
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
  <h3 class="text-xl font-bold text-brand-navy mb-1">{provider.name}</h3>
  <p class="text-gray-600 mb-4">{provider.title}</p>
  <div class="mb-4">
    <span class="inline-block bg-brand-cream text-brand-navy text-xs px-2 py-1 rounded mr-2">{provider.location}</span>
    <span class="inline-block bg-brand-sky text-brand-navy text-xs px-2 py-1 rounded">{provider.verificationStatus}</span>
  </div>
  <p class="text-sm text-gray-700 mb-4 line-clamp-2">{provider.scopeNote}</p>
  <div class="flex justify-between items-center mt-6">
    <span class="text-sm font-bold text-gray-900">{provider.price.split('/')[0]}</span>
    <a href={`/providers/${provider.slug}`} class="text-brand-trust font-medium hover:underline text-sm">View Profile &rarr;</a>
  </div>
</div>
