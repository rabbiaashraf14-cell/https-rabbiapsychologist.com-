---
---
<section class="py-16 md:py-24 bg-white border-t border-gray-100">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12">
      <div class="max-w-2xl mb-6 md:mb-0">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Resource Vault</h2>
        <p class="text-lg text-gray-700">Practical tools designed for parents, not academics. Download worksheets, trackers, and visual supports to use at home.</p>
      </div>
      <a href="/resources/resource-vault" class="bg-brand-navy text-white px-6 py-3 rounded-lg font-bold hover:bg-gray-800 transition-colors shadow-sm whitespace-nowrap">
        Access the Vault
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- Resource 1 -->
      <a href="/resources/resource-vault" class="group block border border-gray-200 rounded-xl overflow-hidden hover:border-brand-trust transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="h-40 bg-brand-cream flex items-center justify-center p-6 relative overflow-hidden">
          <div class="absolute inset-0 bg-brand-trust/5 group-hover:bg-brand-trust/10 transition-colors"></div>
          <svg class="w-16 h-16 text-brand-trust transform group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
        </div>
        <div class="p-6 bg-white">
          <span class="text-xs font-bold text-brand-trust uppercase tracking-wider mb-2 block">Checklist</span>
          <h3 class="text-lg font-bold text-brand-navy mb-2 group-hover:text-brand-trust transition-colors">Autism Early Signs Checklist</h3>
          <p class="text-sm text-gray-600">A clear, parent-friendly guide to recognizing developmental differences.</p>
        </div>
      </a>

      <!-- Resource 2 -->
      <a href="/resources/resource-vault" class="group block border border-gray-200 rounded-xl overflow-hidden hover:border-brand-trust transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="h-40 bg-brand-sky flex items-center justify-center p-6 relative overflow-hidden">
          <div class="absolute inset-0 bg-brand-trust/5 group-hover:bg-brand-trust/10 transition-colors"></div>
          <svg class="w-16 h-16 text-brand-trust transform group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="p-6 bg-white">
          <span class="text-xs font-bold text-brand-trust uppercase tracking-wider mb-2 block">Planner</span>
          <h3 class="text-lg font-bold text-brand-navy mb-2 group-hover:text-brand-trust transition-colors">ADHD Home Routine Planner</h3>
          <p class="text-sm text-gray-600">Structure mornings, homework, and bedtimes for executive function support.</p>
        </div>
      </a>

      <!-- Resource 3 -->
      <a href="/resources/resource-vault" class="group block border border-gray-200 rounded-xl overflow-hidden hover:border-brand-trust transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="h-40 bg-brand-lavender flex items-center justify-center p-6 relative overflow-hidden">
          <div class="absolute inset-0 bg-brand-trust/5 group-hover:bg-brand-trust/10 transition-colors"></div>
          <svg class="w-16 h-16 text-brand-trust transform group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        </div>
        <div class="p-6 bg-white">
          <span class="text-xs font-bold text-brand-trust uppercase tracking-wider mb-2 block">Log</span>
          <h3 class="text-lg font-bold text-brand-navy mb-2 group-hover:text-brand-trust transition-colors">FBA Parent Log</h3>
          <p class="text-sm text-gray-600">Track triggers and behaviors to find patterns and underlying causes.</p>
        </div>
      </a>

      <!-- Resource 4 -->
      <a href="/resources/resource-vault" class="group block border border-gray-200 rounded-xl overflow-hidden hover:border-brand-trust transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="h-40 bg-brand-cream flex items-center justify-center p-6 relative overflow-hidden">
          <div class="absolute inset-0 bg-brand-trust/5 group-hover:bg-brand-trust/10 transition-colors"></div>
          <svg class="w-16 h-16 text-brand-trust transform group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
          </svg>
        </div>
        <div class="p-6 bg-white">
          <span class="text-xs font-bold text-brand-trust uppercase tracking-wider mb-2 block">Visual Support</span>
          <h3 class="text-lg font-bold text-brand-navy mb-2 group-hover:text-brand-trust transition-colors">Visual Schedule Starter Pack</h3>
          <p class="text-sm text-gray-600">Printable icons to help with transitions and daily expectations.</p>
        </div>
      </a>

      <!-- Resource 5 -->
      <a href="/resources/resource-vault" class="group block border border-gray-200 rounded-xl overflow-hidden hover:border-brand-trust transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="h-40 bg-brand-sky flex items-center justify-center p-6 relative overflow-hidden">
          <div class="absolute inset-0 bg-brand-trust/5 group-hover:bg-brand-trust/10 transition-colors"></div>
          <svg class="w-16 h-16 text-brand-trust transform group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <div class="p-6 bg-white">
          <span class="text-xs font-bold text-brand-trust uppercase tracking-wider mb-2 block">Tracker</span>
          <h3 class="text-lg font-bold text-brand-navy mb-2 group-hover:text-brand-trust transition-colors">Tantrum & Meltdown Tracker</h3>
          <p class="text-sm text-gray-600">Understand the difference and document frequency for your provider.</p>
        </div>
      </a>

      <!-- Resource 6 -->
      <a href="/resources/resource-vault" class="group block border border-gray-200 rounded-xl overflow-hidden hover:border-brand-trust transition-all duration-300 shadow-sm hover:shadow-md">
        <div class="h-40 bg-brand-lavender flex items-center justify-center p-6 relative overflow-hidden">
          <div class="absolute inset-0 bg-brand-trust/5 group-hover:bg-brand-trust/10 transition-colors"></div>
          <svg class="w-16 h-16 text-brand-trust transform group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="p-6 bg-white">
          <span class="text-xs font-bold text-brand-trust uppercase tracking-wider mb-2 block">Templates</span>
          <h3 class="text-lg font-bold text-brand-navy mb-2 group-hover:text-brand-trust transition-colors">School Communication Pack</h3>
          <p class="text-sm text-gray-600">Ready-to-use email templates for teachers and IEP teams.</p>
        </div>
      </a>

    </div>
  </div>
</section>
