---
<section class="bg-gray-50 py-10 border-b border-gray-100">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-6">
      <p class="text-sm font-semibold text-brand-navy/60 uppercase tracking-wider">Expertise & Support Areas</p>
    </div>

    <div class="flex flex-wrap justify-center gap-4 lg:gap-6 items-stretch">

      <div class="flex items-center gap-3 bg-white px-5 py-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow min-w-[220px]">
        <div class="w-10 h-10 rounded-full bg-brand-cream flex items-center justify-center text-brand-trust shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <span class="text-sm font-bold text-brand-navy leading-tight">Child & Adolescent<br/>Psychology</span>
      </div>

      <div class="flex items-center gap-3 bg-white px-5 py-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow min-w-[220px]">
        <div class="w-10 h-10 rounded-full bg-brand-cream flex items-center justify-center text-brand-trust shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
        </div>
        <span class="text-sm font-bold text-brand-navy leading-tight">ADHD, Autism &<br/>Behaviour Support</span>
      </div>

      <div class="flex items-center gap-3 bg-white px-5 py-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow min-w-[220px]">
        <div class="w-10 h-10 rounded-full bg-brand-cream flex items-center justify-center text-brand-trust shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <span class="text-sm font-bold text-brand-navy leading-tight">Parent & School<br/>Guidance</span>
      </div>

      <div class="flex items-center gap-3 bg-white px-5 py-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow min-w-[220px]">
        <div class="w-10 h-10 rounded-full bg-brand-cream flex items-center justify-center text-brand-trust shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <span class="text-sm font-bold text-brand-navy leading-tight">Online and<br/>In-Person Support</span>
      </div>

      <div class="flex items-center gap-3 bg-white px-5 py-4 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow min-w-[220px]">
        <div class="w-10 h-10 rounded-full bg-brand-cream flex items-center justify-center text-brand-trust shrink-0">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <span class="text-sm font-bold text-brand-navy leading-tight">International Family<br/>Support</span>
      </div>

    </div>
  </div>
</section>
