---
<section class="bg-white py-12 border-b border-gray-100">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8">
      <p class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Evidence-Informed Practice & Global Reach</p>
    </div>

    <div class="flex flex-wrap justify-center gap-12 items-center opacity-70 grayscale hover:grayscale-0 transition-all duration-500">
      <!-- These are conceptual badges reflecting the platform's focus, since we can't use fake medical badges -->

      <div class="flex flex-col items-center justify-center max-w-[150px] text-center group">
        <svg class="w-12 h-12 text-gray-400 group-hover:text-brand-trust transition-colors mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        <span class="text-xs font-semibold text-gray-600 group-hover:text-brand-navy">Evidence-Informed</span>
      </div>

      <div class="flex flex-col items-center justify-center max-w-[150px] text-center group">
        <svg class="w-12 h-12 text-gray-400 group-hover:text-brand-trust transition-colors mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
        </svg>
        <span class="text-xs font-semibold text-gray-600 group-hover:text-brand-navy">Region-Aware Support</span>
      </div>

      <div class="flex flex-col items-center justify-center max-w-[150px] text-center group">
        <svg class="w-12 h-12 text-gray-400 group-hover:text-brand-trust transition-colors mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        <span class="text-xs font-semibold text-gray-600 group-hover:text-brand-navy">Parent-Centered</span>
      </div>

      <div class="flex flex-col items-center justify-center max-w-[150px] text-center group">
        <svg class="w-12 h-12 text-gray-400 group-hover:text-brand-trust transition-colors mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <span class="text-xs font-semibold text-gray-600 group-hover:text-brand-navy">Verified Providers</span>
      </div>
    </div>
  </div>
</section>
