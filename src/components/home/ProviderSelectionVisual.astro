---
---
<div class="py-12 bg-white rounded-xl shadow-sm border border-gray-100 p-8 max-w-5xl mx-auto my-12 transition-all hover:shadow-md">
  <div class="text-center mb-8">
    <h3 class="text-2xl font-bold text-brand-navy">Find the Right Fit</h3>
    <p class="text-gray-600 mt-2">Filter our multidisciplinary team to meet your unique needs.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 text-center">
    <div class="p-6 bg-gray-50 rounded-lg border border-gray-200 hover:-translate-y-1 transition-transform duration-300 group">
      <div class="w-12 h-12 mx-auto bg-brand-lavender text-brand-navy rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      </div>
      <h4 class="font-bold text-gray-800">By Region</h4>
      <p class="text-sm text-gray-500 mt-2">Local expertise and time zones</p>
    </div>

    <div class="p-6 bg-gray-50 rounded-lg border border-gray-200 hover:-translate-y-1 transition-transform duration-300 group">
      <div class="w-12 h-12 mx-auto bg-brand-sky text-brand-navy rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
      </div>
      <h4 class="font-bold text-gray-800">By Expertise</h4>
      <p class="text-sm text-gray-500 mt-2">Psychology, OT, Speech, Diet</p>
    </div>

    <div class="p-6 bg-gray-50 rounded-lg border border-gray-200 hover:-translate-y-1 transition-transform duration-300 group">
      <div class="w-12 h-12 mx-auto bg-brand-cream text-brand-navy rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
      </div>
      <h4 class="font-bold text-gray-800">By Language</h4>
      <p class="text-sm text-gray-500 mt-2">English, Urdu, Arabic, etc.</p>
    </div>

    <div class="p-6 bg-gray-50 rounded-lg border border-gray-200 hover:-translate-y-1 transition-transform duration-300 group">
      <div class="w-12 h-12 mx-auto bg-green-50 text-green-700 rounded-full flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      </div>
      <h4 class="font-bold text-gray-800">By Price</h4>
      <p class="text-sm text-gray-500 mt-2">Options fitting your budget</p>
    </div>
  </div>

  <div class="mt-8 text-center">
    <a href="/choose-a-provider" class="inline-block px-6 py-3 bg-white text-brand-navy border border-gray-300 rounded hover:bg-gray-50 font-bold transition-colors">Go to Directory</a>
  </div>
</div>
