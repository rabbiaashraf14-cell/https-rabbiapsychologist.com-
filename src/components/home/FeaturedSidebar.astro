---
import { Image } from 'astro:assets';
import { articles } from '../../data/blogArticles';
import { getArticleImage, getCategoryFallbackSvg } from '../../utils/imageMatching';
import BlogImageSlideshow from '../blog/BlogImageSlideshow.astro';

// Priority topics per user request for sidebar
const priorityTopics = [
  "Understanding the Confusion Between ADHD and Hyperactivity in Children",
  "Sensory Processing Difficulties",
  "Emotional Regulation in Children: Why They Struggle to Calm Down",
  "IEP and School Support Planning",
  "Behaviour is Communication: Finding the 'Why'"
];

const selectedArticles = priorityTopics.map(title => {
  return articles.find(a => a.title === title) || articles[0];
});

// Dynamically import all blog images for proper image priority system
const localImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/blog/*.{jpeg,jpg,png,webp,gif}', { eager: true });


---

<aside aria-label="Latest Child Development Articles" class="h-full flex flex-col gap-6">
  <div class="bg-white rounded-[24px] p-6 shadow-sm border border-brand-gold/20 flex flex-col h-full sticky top-24">
    <h2 class="text-2xl font-bold text-brand-navy mb-6 border-b border-gray-100 pb-4">
      Parent Resources
    </h2>

    <div class="flex flex-col gap-6 overflow-y-auto">
      {selectedArticles.map((article) => {
        const imageData = getArticleImage(article, localImages);
        const category = article.categories[0].toUpperCase();

        return (
          <a href={article.href} class="group/card flex flex-col sm:flex-row lg:flex-col xl:flex-row gap-4 bg-gray-50/50 rounded-xl p-3 hover:bg-white hover:shadow-md transition-all duration-300 hover:-translate-y-1 border border-transparent hover:border-gray-100 outline-none focus:ring-2 focus:ring-brand-trust">

            <div class="relative w-full sm:w-1/3 lg:w-full xl:w-1/3 aspect-video sm:aspect-square lg:aspect-video xl:aspect-square bg-gradient-to-br from-brand-cream to-gray-100 rounded-lg overflow-hidden shrink-0">

              {imageData.type === 'local' || imageData.type === 'remote' ? (
                <>
                  {imageData.type === 'local' ? (
                    <Image
                      src={imageData.src as ImageMetadata}
                      alt={article.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      width={120}
                      height={90}
                    />
                  ) : (
                    <img
                      src={imageData.src as string}
                      alt={article.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      onerror={`this.onerror=null; this.src='${getCategoryFallbackSvg(article.categories)}';`}
                    />
                  )}
                </>
              ) : (
                <BlogImageSlideshow articleTitle={article.title} fallbackSvg={imageData.src as string} />
              )}
            </div>

            <div class="flex flex-col flex-grow justify-center py-1">
               <span class="text-[10px] font-bold text-brand-trust mb-1 tracking-wider">
                 {category}
               </span>
               <h3 class="text-sm font-bold text-brand-navy leading-snug line-clamp-2 group-hover/card:text-brand-trust transition-colors mb-2">
                 {article.title}
               </h3>
               <span class="text-xs font-semibold text-gray-500 group-hover/card:text-brand-trust transition-colors flex items-center">
                 Read article
                 <svg class="w-3 h-3 ml-1 transform group-hover/card:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                 </svg>
               </span>
            </div>
          </a>
        );
      })}
    </div>

    <div class="mt-8 pt-6 border-t border-gray-100">
      <a href="/start-here" class="block bg-brand-navy rounded-xl p-5 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 border border-brand-navy group/cta relative overflow-hidden outline-none focus:ring-2 focus:ring-brand-navy focus:ring-offset-2">
        <div class="absolute top-0 right-0 p-4 opacity-10 transform translate-x-2 -translate-y-2">
           <svg class="w-16 h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
           </svg>
        </div>
        <div class="relative z-10">
          <h3 class="text-lg font-bold text-white mb-2 leading-tight">
            Book a Consultation
          </h3>
          <p class="text-brand-cream/90 text-xs mb-4">
            Take the first step towards understanding your child's needs.
          </p>
          <span class="inline-flex items-center text-xs font-bold text-brand-navy bg-white px-4 py-2 rounded-full hover:bg-gray-50 transition-colors">
            Book Now
            <svg class="w-3 h-3 ml-1 transform group-hover/cta:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </span>
        </div>
      </a>
    </div>
  </div>
</aside>
