---
---
<div class="bg-blue-50 rounded-2xl p-8 border border-blue-100 shadow-sm max-w-4xl mx-auto my-12 transition-all hover:shadow-md duration-300">
  <div class="text-center mb-8">
    <h3 class="text-2xl font-bold text-brand-navy">Behavior is Communication</h3>
    <p class="text-gray-600 mt-2">Understanding the "why" beneath the surface.</p>
  </div>

  <div class="relative flex flex-col items-center">
    <!-- Iceberg Tip -->
    <div class="bg-white px-8 py-4 rounded-t-xl border-t border-l border-r border-gray-200 z-10 text-center w-64 shadow-sm relative group">
      <span class="font-bold text-gray-800">What we see</span>
      <p class="text-sm text-gray-500 mt-1">Meltdowns, Refusal, Withdrawal</p>
      <div class="absolute inset-0 bg-brand-sky/10 opacity-0 group-hover:opacity-100 transition-opacity rounded-t-xl pointer-events-none"></div>
    </div>

    <!-- Waterline -->
    <div class="w-full h-1 bg-brand-trust/30 relative"></div>

    <!-- Iceberg Base -->
    <div class="bg-brand-navy px-8 py-8 rounded-b-xl border border-brand-navy z-10 text-center w-80 shadow-lg text-white relative overflow-hidden group">
      <div class="absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
      <span class="font-bold text-lg block mb-3">What's underneath</span>
      <div class="grid grid-cols-2 gap-2 text-sm text-brand-sky">
        <div class="bg-white/10 py-2 rounded">Sensory Overload</div>
        <div class="bg-white/10 py-2 rounded">Anxiety / Fear</div>
        <div class="bg-white/10 py-2 rounded">Communication Gap</div>
        <div class="bg-white/10 py-2 rounded">Executive Fatigue</div>
      </div>
    </div>
  </div>
</div>
