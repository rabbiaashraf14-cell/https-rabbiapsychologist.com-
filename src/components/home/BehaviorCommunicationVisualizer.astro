---
---
<section class="py-16 md:py-24 bg-white relative overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">What is the behavior communicating?</h2>
      <p class="text-lg text-gray-700 max-w-2xl mx-auto">
        Behavior is a form of communication. Understanding the 'why' helps us choose the right support strategies.
      </p>
    </div>

    <div class="max-w-4xl mx-auto space-y-6">
      <!-- Card 1 -->
      <div class="bg-brand-cream border border-gray-100 rounded-xl p-6 md:p-8 flex flex-col md:flex-row items-center gap-6 shadow-sm transition-transform hover:-translate-y-1">
        <div class="md:w-1/3 text-center md:text-left">
          <h3 class="font-bold text-xl text-gray-800">Not listening</h3>
        </div>
        <div class="hidden md:flex items-center justify-center w-12 text-brand-trust">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </div>
        <div class="md:w-1/3 text-center">
          <p class="text-gray-600 italic">Working memory or attention difficulty</p>
        </div>
        <div class="hidden md:flex items-center justify-center w-12 text-brand-trust">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </div>
        <div class="md:w-1/3 text-center md:text-right">
          <p class="font-bold text-brand-trust">One-step instructions</p>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="bg-brand-cream border border-gray-100 rounded-xl p-6 md:p-8 flex flex-col md:flex-row items-center gap-6 shadow-sm transition-transform hover:-translate-y-1">
        <div class="md:w-1/3 text-center md:text-left">
          <h3 class="font-bold text-xl text-gray-800">Tantrums</h3>
        </div>
        <div class="hidden md:flex items-center justify-center w-12 text-brand-trust">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </div>
        <div class="md:w-1/3 text-center">
          <p class="text-gray-600 italic">Overwhelm or transition difficulty</p>
        </div>
        <div class="hidden md:flex items-center justify-center w-12 text-brand-trust">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </div>
        <div class="md:w-1/3 text-center md:text-right">
          <p class="font-bold text-brand-trust">Co-regulation & visual routine</p>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="bg-brand-cream border border-gray-100 rounded-xl p-6 md:p-8 flex flex-col md:flex-row items-center gap-6 shadow-sm transition-transform hover:-translate-y-1">
        <div class="md:w-1/3 text-center md:text-left">
          <h3 class="font-bold text-xl text-gray-800">Aggression</h3>
        </div>
        <div class="hidden md:flex items-center justify-center w-12 text-brand-trust">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </div>
        <div class="md:w-1/3 text-center">
          <p class="text-gray-600 italic">Frustration or communication difficulty</p>
        </div>
        <div class="hidden md:flex items-center justify-center w-12 text-brand-trust">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </div>
        <div class="md:w-1/3 text-center md:text-right">
          <p class="font-bold text-brand-trust">Safety & replacement skill</p>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="bg-brand-cream border border-gray-100 rounded-xl p-6 md:p-8 flex flex-col md:flex-row items-center gap-6 shadow-sm transition-transform hover:-translate-y-1">
        <div class="md:w-1/3 text-center md:text-left">
          <h3 class="font-bold text-xl text-gray-800">Avoiding schoolwork</h3>
        </div>
        <div class="hidden md:flex items-center justify-center w-12 text-brand-trust">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </div>
        <div class="md:w-1/3 text-center">
          <p class="text-gray-600 italic">Task initiation difficulty</p>
        </div>
        <div class="hidden md:flex items-center justify-center w-12 text-brand-trust">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </div>
        <div class="md:w-1/3 text-center md:text-right">
          <p class="font-bold text-brand-trust">Task breakdown & reinforcement</p>
        </div>
      </div>
    </div>

  </div>
</section>
