---
<section class="py-16 bg-white">
  <div class="container mx-auto px-4 max-w-4xl">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">What happens after booking</h2>
      <p class="text-lg text-gray-700">A simple, reassuring process to get the support your family needs.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Step 1 -->
      <div class="bg-brand-cream border border-brand-border rounded-xl p-8 text-center flex flex-col items-center">
        <div class="w-16 h-16 bg-brand-navy text-white rounded-full flex items-center justify-center text-2xl font-bold mb-6">1</div>
        <h3 class="text-xl font-bold text-brand-navy mb-4">Share your child's concern</h3>
        <p class="text-gray-600">Briefly explain your child's age, concern, school issue, behaviour challenge, previous diagnosis/report, or current difficulty.</p>
      </div>

      <!-- Step 2 -->
      <div class="bg-brand-cream border border-brand-border rounded-xl p-8 text-center flex flex-col items-center">
        <div class="w-16 h-16 bg-brand-navy text-white rounded-full flex items-center justify-center text-2xl font-bold mb-6">2</div>
        <h3 class="text-xl font-bold text-brand-navy mb-4">Attend parent consultation</h3>
        <p class="text-gray-600">The session focuses on thoroughly understanding the concern and giving practical, actionable guidance for home and school.</p>
      </div>

      <!-- Step 3 -->
      <div class="bg-brand-cream border border-brand-border rounded-xl p-8 text-center flex flex-col items-center">
        <div class="w-16 h-16 bg-brand-navy text-white rounded-full flex items-center justify-center text-2xl font-bold mb-6">3</div>
        <h3 class="text-xl font-bold text-brand-navy mb-4">Leave with next steps</h3>
        <p class="text-gray-600">Receive clear direction, suggested strategies, and professional recommendations for exactly what to do next.</p>
      </div>
    </div>
  </div>
</section>
