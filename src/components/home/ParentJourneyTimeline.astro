---
---
<section class="py-16 md:py-24 bg-brand-cream border-t border-gray-100">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">The Parent Journey</h2>
      <p class="text-lg text-gray-700 max-w-2xl mx-auto">A clear path from noticing a concern to implementing effective support strategies.</p>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="relative wrap overflow-hidden p-4 md:p-10 h-full">
        <!-- Connecting Line -->
        <div class="absolute border-opacity-20 border-brand-navy border-l-2 h-full left-6 md:left-1/2 md:-ml-1 top-0 hidden sm:block"></div>

        <!-- Step 1 -->
        <div class="mb-8 flex justify-between items-center w-full sm:flex-row-reverse sm:w-1/2 sm:ml-auto right-timeline transform transition-transform hover:scale-[1.02]">
          <div class="order-1 hidden sm:block w-5/12"></div>
          <div class="z-20 flex items-center order-1 bg-brand-trust shadow-xl w-8 h-8 rounded-full">
            <h1 class="mx-auto font-semibold text-lg text-white">1</h1>
          </div>
          <div class="order-1 bg-white rounded-lg shadow-sm border border-gray-100 w-full sm:w-5/12 px-6 py-4 ml-4 sm:ml-0">
            <h3 class="mb-2 font-bold text-brand-navy text-lg">Notice the concern</h3>
            <p class="text-sm leading-snug tracking-wide text-gray-600 text-opacity-100">Observe behavior, development, or communication patterns that feel challenging.</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="mb-8 flex justify-between items-center w-full sm:flex-row sm:w-1/2 sm:mr-auto left-timeline transform transition-transform hover:scale-[1.02]">
          <div class="order-1 hidden sm:block w-5/12"></div>
          <div class="z-20 flex items-center order-1 bg-brand-trust shadow-xl w-8 h-8 rounded-full">
            <h1 class="mx-auto text-white font-semibold text-lg">2</h1>
          </div>
          <div class="order-1 bg-white rounded-lg shadow-sm border border-gray-100 w-full sm:w-5/12 px-6 py-4 ml-4 sm:ml-0">
            <h3 class="mb-2 font-bold text-brand-navy text-lg">Learn the "why"</h3>
            <p class="text-sm leading-snug tracking-wide text-gray-600 text-opacity-100">Understand what the behavior may be communicating through evidence-informed resources.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="mb-8 flex justify-between items-center w-full sm:flex-row-reverse sm:w-1/2 sm:ml-auto right-timeline transform transition-transform hover:scale-[1.02]">
          <div class="order-1 hidden sm:block w-5/12"></div>
          <div class="z-20 flex items-center order-1 bg-brand-trust shadow-xl w-8 h-8 rounded-full">
            <h1 class="mx-auto font-semibold text-lg text-white">3</h1>
          </div>
          <div class="order-1 bg-white rounded-lg shadow-sm border border-gray-100 w-full sm:w-5/12 px-6 py-4 ml-4 sm:ml-0">
            <h3 class="mb-2 font-bold text-brand-navy text-lg">Compare options</h3>
            <p class="text-sm leading-snug tracking-wide text-gray-600 text-opacity-100">Review support pathways: parent guidance, behavior planning, or school consultation.</p>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="mb-8 flex justify-between items-center w-full sm:flex-row sm:w-1/2 sm:mr-auto left-timeline transform transition-transform hover:scale-[1.02]">
          <div class="order-1 hidden sm:block w-5/12"></div>
          <div class="z-20 flex items-center order-1 bg-brand-trust shadow-xl w-8 h-8 rounded-full">
            <h1 class="mx-auto text-white font-semibold text-lg">4</h1>
          </div>
          <div class="order-1 bg-white rounded-lg shadow-sm border border-gray-100 w-full sm:w-5/12 px-6 py-4 ml-4 sm:ml-0">
            <h3 class="mb-2 font-bold text-brand-navy text-lg">Choose a provider</h3>
            <p class="text-sm leading-snug tracking-wide text-gray-600 text-opacity-100">Find a specialist who matches your region, language, and specific family needs.</p>
          </div>
        </div>

        <!-- Step 5 -->
        <div class="mb-8 flex justify-between items-center w-full sm:flex-row-reverse sm:w-1/2 sm:ml-auto right-timeline transform transition-transform hover:scale-[1.02]">
          <div class="order-1 hidden sm:block w-5/12"></div>
          <div class="z-20 flex items-center order-1 bg-brand-trust shadow-xl w-8 h-8 rounded-full">
            <h1 class="mx-auto font-semibold text-lg text-white">5</h1>
          </div>
          <div class="order-1 bg-white rounded-lg shadow-sm border border-gray-100 w-full sm:w-5/12 px-6 py-4 ml-4 sm:ml-0">
            <h3 class="mb-2 font-bold text-brand-navy text-lg">Book consultation</h3>
            <p class="text-sm leading-snug tracking-wide text-gray-600 text-opacity-100">Schedule your session directly and begin your tailored guidance process.</p>
          </div>
        </div>

        <!-- Step 6 -->
        <div class="mb-8 flex justify-between items-center w-full sm:flex-row sm:w-1/2 sm:mr-auto left-timeline transform transition-transform hover:scale-[1.02]">
          <div class="order-1 hidden sm:block w-5/12"></div>
          <div class="z-20 flex items-center order-1 bg-brand-trust shadow-xl w-8 h-8 rounded-full">
            <h1 class="mx-auto text-white font-semibold text-lg">6</h1>
          </div>
          <div class="order-1 bg-white rounded-lg shadow-sm border border-gray-100 w-full sm:w-5/12 px-6 py-4 ml-4 sm:ml-0">
            <h3 class="mb-2 font-bold text-brand-navy text-lg">Use resources</h3>
            <p class="text-sm leading-snug tracking-wide text-gray-600 text-opacity-100">Implement tools, visual schedules, and strategies at home and with educators.</p>
          </div>
        </div>

        <!-- Step 7 -->
        <div class="mb-8 flex justify-between items-center w-full sm:flex-row-reverse sm:w-1/2 sm:ml-auto right-timeline transform transition-transform hover:scale-[1.02]">
          <div class="order-1 hidden sm:block w-5/12"></div>
          <div class="z-20 flex items-center order-1 bg-brand-navy shadow-xl w-8 h-8 rounded-full">
            <h1 class="mx-auto font-semibold text-lg text-white">7</h1>
          </div>
          <div class="order-1 bg-brand-navy rounded-lg shadow-sm border border-gray-800 w-full sm:w-5/12 px-6 py-4 ml-4 sm:ml-0 text-white">
            <h3 class="mb-2 font-bold text-white text-lg">Review progress</h3>
            <p class="text-sm leading-snug tracking-wide text-gray-200 text-opacity-100">Adjust strategies as your child grows and goals evolve.</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
