---
---
<section class="bg-brand-cream py-16 md:py-24 overflow-hidden relative">
  <!-- Subtle animated background elements -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-50">
    <div class="absolute top-10 left-10 w-64 h-64 bg-brand-sky rounded-full mix-blend-multiply filter blur-3xl opacity-70 transform motion-safe:animate-pulse"></div>
    <div class="absolute bottom-10 right-10 w-80 h-80 bg-brand-lavender rounded-full mix-blend-multiply filter blur-3xl opacity-60 transform motion-safe:animate-pulse" style="animation-delay: 2s;"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Copy Side -->
      <div class="max-w-2xl transform motion-safe:translate-y-4 motion-safe:opacity-0 motion-safe:animate-[fadeUp_0.8s_ease-out_forwards]">
        <div class="inline-flex flex-wrap gap-2 mb-6">
          <span class="px-3 py-1 bg-white border border-gray-200 rounded-full text-xs font-semibold text-brand-trust shadow-sm">Parent Guidance</span>
          <span class="px-3 py-1 bg-white border border-gray-200 rounded-full text-xs font-semibold text-brand-trust shadow-sm">ASD Support</span>
          <span class="px-3 py-1 bg-white border border-gray-200 rounded-full text-xs font-semibold text-brand-trust shadow-sm">ADHD Support</span>
          <span class="px-3 py-1 bg-white border border-gray-200 rounded-full text-xs font-semibold text-brand-trust shadow-sm">School Consultation</span>
          <span class="px-3 py-1 bg-white border border-gray-200 rounded-full text-xs font-semibold text-brand-trust shadow-sm">Region-Aware</span>
          <span class="px-3 py-1 bg-white border border-gray-200 rounded-full text-xs font-semibold text-brand-trust shadow-sm">Provider Choice</span>
          <span class="px-3 py-1 bg-white border border-gray-200 rounded-full text-xs font-semibold text-brand-trust shadow-sm">Educational Resources</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-navy leading-tight mb-6">
          Find the right child development support for your family.
        </h1>

        <p class="text-lg md:text-xl text-gray-700 mb-8 max-w-xl">
          Learn from parent-friendly resources, compare available specialists, and choose consultation support for ASD, ADHD, behavior, school concerns, and child development.
        </p>

        <div class="flex flex-wrap gap-4">
          <a href="/choose-a-provider" class="bg-brand-trust text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
            Choose a Provider
          </a>
          <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" target="_blank" rel="noopener noreferrer" class="bg-brand-navy text-white px-6 py-3 rounded-lg font-bold hover:bg-gray-800 transition-colors shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
            Book with Rabbia
          </a>
          <a href="/resources/resource-vault" class="bg-white text-brand-navy border border-gray-200 px-6 py-3 rounded-lg font-bold hover:bg-gray-50 transition-colors shadow-sm hover:shadow-md transform hover:-translate-y-0.5">
            Explore Resources
          </a>
        </div>
      </div>

      <!-- Visual Side -->
      <div class="relative w-full h-[500px] hidden lg:block transform motion-safe:translate-y-4 motion-safe:opacity-0 motion-safe:animate-[fadeUp_1s_ease-out_0.2s_forwards]">

        <!-- Abstract Cards System -->
        <!-- Card 1: Parent Concern -->
        <div class="absolute top-10 right-20 w-64 h-40 bg-white rounded-xl shadow-lg p-6 border border-gray-100 transform motion-safe:animate-[float_6s_ease-in-out_infinite] z-20">
          <div class="w-10 h-10 bg-brand-sky rounded-full flex items-center justify-center mb-3">
             <svg class="w-5 h-5 text-brand-trust" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
             </svg>
          </div>
          <div class="h-2 w-24 bg-gray-200 rounded mb-2"></div>
          <div class="h-2 w-16 bg-gray-200 rounded"></div>
          <p class="text-xs text-gray-500 mt-4">Parent Concern</p>
        </div>

        <!-- Card 2: Support Plan (Center) -->
        <div class="absolute top-32 left-10 w-72 h-48 bg-gradient-to-br from-brand-trust to-brand-navy rounded-xl shadow-xl p-6 text-white transform motion-safe:animate-[float_7s_ease-in-out_1s_infinite] z-30">
          <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center mb-4">
             <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
             </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Support Plan</h3>
          <div class="h-2 w-full bg-white/30 rounded mb-2"></div>
          <div class="h-2 w-4/5 bg-white/30 rounded"></div>
        </div>

        <!-- Card 3: Provider Choice -->
        <div class="absolute bottom-10 right-10 w-60 h-40 bg-white rounded-xl shadow-lg p-6 border border-gray-100 transform motion-safe:animate-[float_5s_ease-in-out_2s_infinite] z-10">
          <div class="flex items-center mb-4">
            <div class="w-10 h-10 bg-brand-lavender rounded-full flex items-center justify-center mr-3">
               <svg class="w-5 h-5 text-brand-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
               </svg>
            </div>
            <div>
              <div class="h-3 w-20 bg-gray-200 rounded mb-1"></div>
              <div class="h-2 w-12 bg-gray-100 rounded"></div>
            </div>
          </div>
          <p class="text-xs text-gray-500 mt-2">Provider Choice</p>
        </div>

        <!-- Connecting lines (SVG) -->
        <svg class="absolute inset-0 w-full h-full pointer-events-none z-0" viewBox="0 0 400 500">
          <path d="M 180 120 C 250 150, 200 200, 280 250" fill="none" stroke="#DCEEFF" stroke-width="3" stroke-dasharray="6,6" />
          <path d="M 200 300 C 180 350, 250 380, 280 400" fill="none" stroke="#DCEEFF" stroke-width="3" stroke-dasharray="6,6" />
        </svg>

      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
</style>
