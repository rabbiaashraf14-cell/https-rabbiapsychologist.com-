---
import { Image } from 'astro:assets';

---
<div class="relative overflow-hidden bg-brand-cream py-16 lg:py-24 flex items-center min-h-[75vh]">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-cream to-blue-50 z-0 pointer-events-none"></div>
  <div class="absolute -top-40 -right-40 w-96 h-96 bg-brand-sky/30 rounded-full blur-3xl opacity-50"></div>
  <div class="absolute top-40 -left-40 w-96 h-96 bg-brand-lavender/30 rounded-full blur-3xl opacity-50"></div>

  <!-- Subtle decorative abstract shapes -->
  <svg class="absolute top-1/4 right-1/4 w-32 h-32 text-brand-gold/10 animate-spin-slow pointer-events-none hidden lg:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 4v16m8-8H4" />
  </svg>
  <svg class="absolute bottom-1/4 left-1/3 w-24 h-24 text-brand-navy/5 pointer-events-none hidden lg:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <circle cx="12" cy="12" r="10" stroke-width="1" />
  </svg>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Text Content: Mobile order-1, Desktop: order-1 -->
      <div class="order-1 text-center lg:text-left animate-fade-in-up">
        <span class="inline-block py-1 px-3 rounded-full bg-white text-brand-navy text-xs lg:text-sm font-bold tracking-wide uppercase mb-6 shadow-sm border border-brand-gold/30">
          Guiding Child Development with Care, Clarity, and Expertise
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-brand-navy mb-6 tracking-tight leading-tight">
          Child Development, ADHD & Autism Parent Guidance
        </h1>
        <p class="text-lg md:text-xl text-gray-700 max-w-2xl mx-auto lg:mx-0 mb-8 leading-relaxed">
          Support for parents who need practical next steps for ADHD, autism, behaviour concerns, school difficulties, emotional regulation, report understanding, and developmental concerns.<br/><br/>
          <strong>Parent guidance online worldwide. Local assessment in Lahore where appropriate.</strong>
        </p>
        <div class="flex flex-col sm:flex-row justify-center lg:justify-start items-center gap-4 mb-8">
          <a href="/book" class="w-full sm:w-auto px-8 py-4 bg-brand-navy text-white rounded-lg font-bold text-lg hover:bg-blue-900 transition-all shadow-lg hover:shadow-xl hover:-translate-y-1">
            Book Parent Consultation
          </a>
          <a href="/services" class="w-full sm:w-auto px-8 py-4 bg-white text-brand-navy border-2 border-brand-navy rounded-lg font-bold text-lg hover:bg-gray-50 transition-all shadow-sm hover:-translate-y-1">
            View Services
          </a>
        </div>

        <!-- Credibility Row -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-4 text-sm font-semibold text-gray-600">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-trust" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Online Worldwide
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-trust" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Parent-Friendly Guidance
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-trust" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Evidence-Informed
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-trust" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            School Support
          </span>
        </div>
      </div>

      <!-- Visual Card Block: Mobile order-2, Desktop: order-2 -->
      <div class="order-2 flex justify-center lg:justify-end animate-fade-in-up" style="animation-delay: 0.2s;">
        <div class="relative w-full max-w-[480px]">
          <!-- Background Glow -->
          <div class="absolute inset-0 bg-brand-sky/40 blur-3xl rounded-full"></div>

          <div class="relative z-10 grid grid-cols-2 gap-4">
            <!-- Parent Guidance Card -->
            <div class="bg-white rounded-2xl p-6 shadow-md hover-lift transition-all duration-300 border border-gray-100 flex flex-col items-center text-center">
              <div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center text-brand-trust mb-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
              </div>
              <h3 class="font-bold text-brand-navy">Parent Guidance</h3>
            </div>

            <!-- ADHD Support Card -->
            <div class="bg-white rounded-2xl p-6 shadow-md hover-lift transition-all duration-300 border border-gray-100 flex flex-col items-center text-center mt-6">
              <div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center text-brand-trust mb-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
              </div>
              <h3 class="font-bold text-brand-navy">ADHD Support</h3>
            </div>

            <!-- Autism Support Card -->
            <div class="bg-white rounded-2xl p-6 shadow-md hover-lift transition-all duration-300 border border-gray-100 flex flex-col items-center text-center -mt-6">
              <div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center text-brand-trust mb-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <h3 class="font-bold text-brand-navy">Autism Support</h3>
            </div>

            <!-- Assessment Guidance Card -->
            <div class="bg-white rounded-2xl p-6 shadow-md hover-lift transition-all duration-300 border border-gray-100 flex flex-col items-center text-center">
              <div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center text-brand-trust mb-4">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
              </div>
              <h3 class="font-bold text-brand-navy">Assessment Guidance</h3>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .animate-fade-in-up {
      animation: fadeInUp 0.8s ease-out forwards;
      opacity: 0;
      transform: translateY(20px);
    }
  }
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
