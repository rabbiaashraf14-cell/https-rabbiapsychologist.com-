<div class="relative overflow-hidden bg-brand-cream py-20 lg:py-32 flex items-center justify-center min-h-[70vh]">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-sky/30 to-brand-cream z-0 pointer-events-none"></div>
  <div class="absolute -top-40 -right-40 w-96 h-96 bg-brand-sky/20 rounded-full blur-3xl opacity-60"></div>
  <div class="absolute top-40 -left-40 w-96 h-96 bg-brand-lavender/30 rounded-full blur-3xl opacity-60"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center animate-fade-in-up">
    <span class="inline-block py-1 px-3 rounded-full bg-blue-50 text-blue-800 text-sm font-bold tracking-wide uppercase mb-6 shadow-sm border border-blue-100">
      Owned and clinically led by Rabbia Ashraf, Licensed Clinical Psychologist.
    </span>
    <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-brand-navy mb-6 tracking-tight leading-tight">
      Parent Support, IEP Help, and Child Development Guidance<br class="hidden md:block" />
      <span class="text-brand-trust relative">
        Beyond Therapy
        <svg class="absolute w-full h-3 -bottom-1 left-0 text-brand-sky/50" viewBox="0 0 100 10" preserveAspectRatio="none">
          <path d="M0,5 Q50,10 100,5" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
        </svg>
      </span>
    </h1>
    <p class="text-xl md:text-2xl text-gray-700 max-w-3xl mx-auto mb-10 leading-relaxed">
      Rabbia Ashraf NeuroCare helps parents understand developmental, behavioural, school, ASD, ADHD, IEP, and report-related concerns through practical guidance, home-based support plans, and between-session resources led by Rabbia Ashraf, Licensed Clinical Psychologist.
    </p>
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
      <a href="/parent-support" class="w-full sm:w-auto px-8 py-4 bg-brand-navy text-white rounded-lg font-bold text-lg hover:bg-blue-900 transition-all shadow-lg hover:shadow-xl hover:-translate-y-1">
        Start with Parent Guidance
      </a>
      <a href="/school-iep-help" class="w-full sm:w-auto px-8 py-4 bg-white text-brand-navy border-2 border-brand-navy rounded-lg font-bold text-lg hover:bg-gray-50 transition-all shadow-sm hover:-translate-y-1">
        Get IEP Help
      </a>
      <a href="/between-session-programs" class="w-full sm:w-auto px-8 py-4 bg-brand-cream text-brand-navy border border-gray-300 rounded-lg font-bold text-lg hover:bg-gray-100 transition-all shadow-sm hover:-translate-y-1">
        Explore Between-Session Support
      </a>
    </div>
  </div>
</div>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .animate-fade-in-up {
      animation: fadeInUp 0.8s ease-out forwards;
      opacity: 0;
      transform: translateY(20px);
    }
  }
  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
