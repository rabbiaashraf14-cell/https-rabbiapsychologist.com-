---
interface Props {
  title: string;
  subtitle: string;
}
const { title, subtitle } = Astro.props;
---
<section class="bg-brand-cream py-20 px-4 text-center">
  <div class="container mx-auto max-w-4xl">
    <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6 fade-up">{title}</h1>
    <p class="text-xl text-gray-700 mb-10 fade-up" style="animation-delay: 0.1s;">{subtitle}</p>
    <div class="flex flex-col sm:flex-row justify-center gap-4 fade-up" style="animation-delay: 0.2s;">
      <a href="/choose-a-provider" class="bg-brand-trust text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-700 transition">Choose a Provider</a>
      <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" class="bg-white text-brand-navy border border-gray-300 px-8 py-3 rounded-lg font-bold hover:bg-gray-50 transition">Book with Rabbia</a>
    </div>
  </div>
</section>
