---
<section class="py-16 bg-white border-t border-gray-100">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-12 max-w-5xl mx-auto">
      <div class="w-full md:w-1/2">
        <h2 class="text-2xl md:text-3xl font-bold text-brand-navy mb-4">Evidence-Informed Practice</h2>
        <p class="text-gray-700 mb-6">
          Our platform is rooted in research and clinical expertise. We prioritize strategies that have been evaluated for effectiveness in supporting child development, neurodiversity, and family systems.
        </p>
        <ul class="space-y-3">
          <li class="flex items-start">
            <svg class="w-6 h-6 text-brand-trust mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-gray-700 text-sm">Neurodiversity-affirming approaches</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-brand-trust mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-gray-700 text-sm">Evidence-based behavioral strategies</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 text-brand-trust mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-gray-700 text-sm">Family-centered care models</span>
          </li>
        </ul>
      </div>
      <div class="w-full md:w-1/2 flex justify-center">
        <!-- Abstract representation of research/data -->
        <div class="w-full max-w-sm h-64 bg-brand-cream rounded-xl border border-gray-100 p-6 flex flex-col justify-between shadow-sm relative overflow-hidden">
          <div class="absolute -right-10 -top-10 w-32 h-32 bg-brand-sky rounded-full mix-blend-multiply opacity-50"></div>
          <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-brand-lavender rounded-full mix-blend-multiply opacity-50"></div>

          <div class="flex justify-between items-end h-32 z-10 space-x-4 border-b border-gray-200 pb-2">
            <div class="w-1/4 bg-brand-sky rounded-t-sm h-12"></div>
            <div class="w-1/4 bg-brand-lavender rounded-t-sm h-20"></div>
            <div class="w-1/4 bg-brand-trust rounded-t-sm h-24"></div>
            <div class="w-1/4 bg-brand-navy rounded-t-sm h-32"></div>
          </div>
          <div class="z-10 mt-4 text-center">
            <p class="text-xs font-bold text-gray-500 uppercase tracking-widest">Data-Driven Guidance</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
