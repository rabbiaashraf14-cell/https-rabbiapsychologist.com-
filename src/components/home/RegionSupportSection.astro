---
const regions = [
  {
    name: 'USA',
    support: 'Parent guidance, ASD/ADHD strategies, and school communication preparation.',
    notReplace: 'Licensed therapy, diagnosis, or crisis support.',
    link: '/before-you-book-international',
    note: 'International consultation available.'
  },
  {
    name: 'Australia',
    support: 'Developmental guidance, parent routines, and support planning.',
    notReplace: 'NDIS assessments or local therapy.',
    link: '/before-you-book-international',
    note: 'International consultation available.'
  },
  {
    name: 'UK & Europe',
    support: 'Privacy-aware parent guidance, behavioral strategies, and school preparation.',
    notReplace: 'NHS services or clinical diagnoses.',
    link: '/before-you-book-international',
    note: 'International consultation available.'
  },
  {
    name: 'MENA & Gulf',
    support: 'Culturally sensitive parent coaching, behavioral strategies, and school communication.',
    notReplace: 'Local medical or therapeutic care.',
    link: '/before-you-book-international',
    note: 'International consultation available.'
  },
  {
    name: 'Pakistan',
    support: 'Child psychology support, parent coaching, and local assessment pathways.',
    notReplace: 'Emergency medical intervention.',
    link: '/before-you-book-international',
    note: 'Local and online services available.'
  },
  {
    name: 'International Schools',
    support: 'Collaborative consultation for parents navigating international school systems.',
    notReplace: 'School-provided services or local therapy.',
    link: '/before-you-book-international',
    note: 'Global consultation available.'
  }
];
---
<section class="py-16 md:py-24 bg-white border-t border-gray-100 relative overflow-hidden">
  <!-- Soft background shapes -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-brand-sky/20 rounded-full blur-3xl transform translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-brand-lavender/20 rounded-full blur-3xl transform -translate-x-1/2 translate-y-1/2"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Region-Aware Support</h2>
      <p class="text-lg text-gray-700">
        We understand that support looks different around the world. Choose your region to see tailored parent guidance pathways.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {regions.map(region => (
        <a href={region.link} class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md hover:border-brand-trust transition-all group block">
          <h3 class="text-xl font-bold text-brand-navy mb-2 flex items-center justify-between">
            {region.name}
            <svg class="w-5 h-5 text-gray-400 group-hover:text-brand-trust transition-colors transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </h3>
          <p class="text-xs font-semibold text-brand-trust mb-4">{region.note}</p>

          <div class="space-y-4 text-sm">
            <div>
              <p class="font-semibold text-gray-800 mb-1">Support may include:</p>
              <p class="text-gray-600 leading-relaxed">{region.support}</p>
            </div>
            <div>
              <p class="font-semibold text-gray-800 mb-1">Does not replace:</p>
              <p class="text-gray-600 leading-relaxed italic">{region.notReplace}</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/before-you-book-international" class="text-brand-navy font-bold hover:text-blue-700 inline-flex items-center">
        View Global Scope & Boundaries
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>
