---
---
<section class="py-20 bg-brand-navy relative overflow-hidden">
  <!-- Background subtle pattern -->
  <div class="absolute inset-0 opacity-10">
    <svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid-pattern" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M0 40V0H40" fill="none" stroke="currentColor" stroke-width="1"></path>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid-pattern)"></rect>
    </svg>
  </div>

  <div class="absolute top-0 right-0 w-96 h-96 bg-brand-trust rounded-full mix-blend-multiply opacity-20 filter blur-3xl transform translate-x-1/3 -translate-y-1/3"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">Ready to find support that fits?</h2>
      <p class="text-xl text-gray-300 mb-10">
        Review our verified providers, choose your region, and schedule a consultation when you're ready.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/choose-a-provider" class="bg-white text-brand-navy px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition-colors shadow-lg transform hover:-translate-y-1">
          Choose a Provider
        </a>
        <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" target="_blank" rel="noopener noreferrer" class="bg-brand-trust text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-blue-600 transition-colors shadow-lg border border-brand-trust transform hover:-translate-y-1">
          Book with Rabbia
        </a>
      </div>

      <p class="mt-8 text-sm text-gray-400">
        Not sure where to start? <a href="/contact" class="text-white underline hover:text-brand-sky">Contact us for guidance</a>.
      </p>
    </div>
  </div>
</section>
