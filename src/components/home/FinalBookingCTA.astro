---
---
<section class="py-20 bg-brand-navy relative overflow-hidden">
  <!-- Background subtle pattern -->
  <div class="absolute inset-0 opacity-10">
    <svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid-pattern" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M0 40V0H40" fill="none" stroke="currentColor" stroke-width="1"></path>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid-pattern)"></rect>
    </svg>
  </div>

  <div class="absolute top-0 right-0 w-96 h-96 bg-brand-trust rounded-full mix-blend-multiply opacity-20 filter blur-3xl transform translate-x-1/3 -translate-y-1/3"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-gold rounded-full mix-blend-multiply opacity-10 filter blur-3xl transform -translate-x-1/3 translate-y-1/3"></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">Need clarity about your child’s development or behaviour?</h2>
      <p class="text-xl text-brand-cream/90 mb-10 leading-relaxed">
        Book a parent consultation and get practical guidance for the next step.
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/book" class="bg-white text-brand-navy px-8 py-4 rounded-lg font-bold text-lg hover:bg-brand-cream transition-colors shadow-lg transform hover:-translate-y-1 w-full sm:w-auto">
          Book Consultation
        </a>
        <a href="/services" class="bg-transparent text-white border-2 border-white/30 px-8 py-4 rounded-lg font-bold text-lg hover:bg-white/10 transition-colors transform hover:-translate-y-1 w-full sm:w-auto">
          View Services
        </a>
      </div>

      <p class="mt-8 text-sm text-gray-400">
        Not sure where to start? <a href="/contact" class="text-white underline hover:text-brand-sky">Contact us for guidance</a>.
      </p>
    </div>
  </div>
</section>
