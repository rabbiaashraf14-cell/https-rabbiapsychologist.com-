---
---
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">Choose your starting point</h2>
      <p class="text-lg text-gray-700">Explore our range of child development services tailored to your family's needs.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Card 1 -->
      <a href="/services/adhd-support" class="bg-brand-cream border border-brand-gold rounded-xl p-6 shadow-sm hover:shadow-lg transition-all block group">
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-blue-800 transition-colors">1. I need ADHD support</h3>
        <p class="text-gray-600 mb-4">Executive function routines and strategies for managing attention and hyperactivity at home and school.</p>
        <span class="text-brand-trust font-bold group-hover:underline">View ADHD Support &rarr;</span>
      </a>

      <!-- Card 2 -->
      <a href="/services/asd-support" class="bg-brand-cream border border-brand-gold rounded-xl p-6 shadow-sm hover:shadow-lg transition-all block group">
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-blue-800 transition-colors">2. I need autism parent guidance</h3>
        <p class="text-gray-600 mb-4">Parent training, communication strategies, and behavioral support planning for families navigating ASD.</p>
        <span class="text-brand-trust font-bold group-hover:underline">View Autism Support &rarr;</span>
      </a>

      <!-- Card 3 -->
      <a href="/services/behaviour-planning" class="bg-brand-cream border border-brand-gold rounded-xl p-6 shadow-sm hover:shadow-lg transition-all block group">
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-blue-800 transition-colors">3. I need behaviour support</h3>
        <p class="text-gray-600 mb-4">Structured home-based guidance to help families manage challenging behaviors, meltdowns, and transitions.</p>
        <span class="text-brand-trust font-bold group-hover:underline">View Behaviour Planning &rarr;</span>
      </a>

      <!-- Card 4 -->
      <a href="/services/school-consultation" class="bg-brand-cream border border-brand-gold rounded-xl p-6 shadow-sm hover:shadow-lg transition-all block group">
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-blue-800 transition-colors">4. I need school or IEP help</h3>
        <p class="text-gray-600 mb-4">Guidance for school concerns, teacher meetings, IEP confusion, and parent-school communication plans.</p>
        <span class="text-brand-trust font-bold group-hover:underline">View School Support &rarr;</span>
      </a>

      <!-- Card 5 -->
      <a href="/report-review" class="bg-brand-cream border border-brand-gold rounded-xl p-6 shadow-sm hover:shadow-lg transition-all block group">
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-blue-800 transition-colors">5. I need help understanding a report</h3>
        <p class="text-gray-600 mb-4">Translate long clinical reports or a new diagnosis into actionable next steps for home and school.</p>
        <span class="text-brand-trust font-bold group-hover:underline">View Report Review &rarr;</span>
      </a>

      <!-- Card 6 -->
      <a href="/services/local-assessment" class="bg-brand-cream border border-brand-gold rounded-xl p-6 shadow-sm hover:shadow-lg transition-all block group">
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-blue-800 transition-colors">6. I need local assessment in Lahore</h3>
        <p class="text-gray-600 mb-4">Formal psychological testing, ADHD/ASD screening, and diagnostic reporting available locally in Pakistan.</p>
        <span class="text-brand-trust font-bold group-hover:underline">View Local Assessment &rarr;</span>
      </a>
    </div>
  </div>
</section>
