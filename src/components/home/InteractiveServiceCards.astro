---
---
<section class="py-16 md:py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Support options, not one-size-fits-all</h2>
      <p class="text-lg text-gray-700 max-w-2xl mx-auto">Explore our range of child development services tailored to your family's needs.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <a href="/global-consultation" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">Parent Guidance</h3>
        <p class="text-gray-600 relative z-10">Online sessions for parents seeking expert guidance on child behavior and development.</p>
      </a>

      <a href="/autism-support" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">ASD Support</h3>
        <p class="text-gray-600 relative z-10">Parent training and behavioral support planning for families navigating ASD.</p>
      </a>

      <a href="/adhd-support" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">ADHD Support</h3>
        <p class="text-gray-600 relative z-10">Executive function coaching and strategies for managing ADHD at home and school.</p>
      </a>

      <a href="/school-iep-consultation" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">School Consultation</h3>
        <p class="text-gray-600 relative z-10">Collaborative support for IEPs and school-based accommodations.</p>
      </a>

      <a href="/behavior-support-planning" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">Behavior Planning</h3>
        <p class="text-gray-600 relative z-10">Structured programs to equip parents with evidence-based behavioral strategies.</p>
      </a>

      <a href="/resources/resource-vault" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">Digital Tools</h3>
        <p class="text-gray-600 relative z-10">Downloadable resources, worksheets, and guides for everyday parenting.</p>
      </a>

      <a href="/webinars" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">Workshops</h3>
        <p class="text-gray-600 relative z-10">Educational webinars and specialized training sessions.</p>
      </a>

      <a href="/psychological-assessment" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">Local Assessment</h3>
        <p class="text-gray-600 relative z-10">Psychological assessment and formal diagnosis (available in select regions).</p>
      </a>
    </div>

    <div class="text-center mt-12">
      <a href="/services" class="text-brand-navy font-bold hover:text-blue-700 inline-flex items-center group">
        View all services
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>
