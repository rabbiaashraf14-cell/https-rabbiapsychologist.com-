---
<section class="py-16 md:py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Support options, not one-size-fits-all</h2>
      <p class="text-lg text-gray-700 max-w-2xl mx-auto">Explore our range of child development services tailored to your family's needs.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <a href="/services#parent-consultation" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">Parent Guidance Consultation</h3>
        <p class="text-gray-600 relative z-10">Helping parents understand concerns, clarify next steps, and prepare practical support plans.</p>
      </a>

      <a href="/services#autism-parent-guidance" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">ASD & Developmental Support</h3>
        <p class="text-gray-600 relative z-10">Parent training and behavioral support planning for families navigating ASD.</p>
      </a>

      <a href="/services#adhd-executive-function-support" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">ADHD & Behavior Support</h3>
        <p class="text-gray-600 relative z-10">Executive function coaching and strategies for managing ADHD at home and school.</p>
      </a>

      <a href="/services#referral-guidance" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">Report Review & Next-Step Planning</h3>
        <p class="text-gray-600 relative z-10">Support for parents who have received assessment reports and need help understanding what to do next.</p>
      </a>

      <a href="/services#school-iep-consultation" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">School & IEP Support</h3>
        <p class="text-gray-600 relative z-10">Guidance for school concerns, teacher meetings, IEP confusion, and parent-school communication.</p>
      </a>

      <a href="/services#behavior-support-planning" class="group bg-brand-cream border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1 block relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors relative z-10">Between-Session Support Planning</h3>
        <p class="text-gray-600 relative z-10">Structured home-based guidance that helps families continue progress between professional appointments.</p>
      </a>
    </div>

    <div class="text-center mt-12">
      <a href="/services" class="text-brand-navy font-bold hover:text-blue-700 inline-flex items-center group">
        View all services
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>
