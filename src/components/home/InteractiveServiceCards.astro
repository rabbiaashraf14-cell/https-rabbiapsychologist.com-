---
---
<section class="py-20 bg-brand-cream/30 border-t border-brand-gold/20">
  <div class="container mx-auto px-4 max-w-6xl">
    <div class="text-center mb-16">
      <span class="inline-block py-1 px-3 rounded-full bg-brand-cream text-brand-navy text-xs lg:text-sm font-bold tracking-wide uppercase mb-4 shadow-sm border border-brand-gold/30">
        Professional Support Services
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Choose your starting point</h2>
      <p class="text-lg text-gray-700 max-w-2xl mx-auto">Explore our range of child development parent guidance services tailored to your family's specific needs.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">

      <!-- Parent Consultation -->
      <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md hover-lift transition-all border border-gray-100 flex flex-col h-full group">
        <div class="w-12 h-12 bg-blue-50 text-brand-trust rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-trust group-hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-brand-navy mb-3">Parent Consultation</h3>
        <p class="text-gray-600 mb-6 flex-grow leading-relaxed">Discuss your general developmental concerns, understand if an assessment is needed, and get a clear starting point.</p>
        <a href="/parent-support" class="inline-flex items-center text-brand-trust font-bold hover:text-brand-navy transition-colors mt-auto group-hover:underline">
          Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>

      <!-- ADHD Guidance -->
      <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md hover-lift transition-all border border-gray-100 flex flex-col h-full group">
        <div class="w-12 h-12 bg-blue-50 text-brand-trust rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-trust group-hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-brand-navy mb-3">ADHD Guidance</h3>
        <p class="text-gray-600 mb-6 flex-grow leading-relaxed">Executive function routines and strategies for managing attention, impulsivity, and hyperactivity at home and school.</p>
        <a href="/services/adhd-support" class="inline-flex items-center text-brand-trust font-bold hover:text-brand-navy transition-colors mt-auto group-hover:underline">
          Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>

      <!-- Autism Parent Guidance -->
      <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md hover-lift transition-all border border-gray-100 flex flex-col h-full group">
        <div class="w-12 h-12 bg-blue-50 text-brand-trust rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-trust group-hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-brand-navy mb-3">Autism Parent Guidance</h3>
        <p class="text-gray-600 mb-6 flex-grow leading-relaxed">Parent training, communication strategies, and behavioral support planning tailored for families navigating ASD.</p>
        <a href="/services/asd-support" class="inline-flex items-center text-brand-trust font-bold hover:text-brand-navy transition-colors mt-auto group-hover:underline">
          Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>

      <!-- Behaviour Support -->
      <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md hover-lift transition-all border border-gray-100 flex flex-col h-full group">
        <div class="w-12 h-12 bg-blue-50 text-brand-trust rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-trust group-hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-brand-navy mb-3">Behaviour Support</h3>
        <p class="text-gray-600 mb-6 flex-grow leading-relaxed">Structured home-based guidance to help manage challenging behaviors, meltdowns, aggression, and transitions.</p>
        <a href="/services/behaviour-planning" class="inline-flex items-center text-brand-trust font-bold hover:text-brand-navy transition-colors mt-auto group-hover:underline">
          Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>

      <!-- School & Learning Support -->
      <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md hover-lift transition-all border border-gray-100 flex flex-col h-full group">
        <div class="w-12 h-12 bg-blue-50 text-brand-trust rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-trust group-hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14v6"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-brand-navy mb-3">School & Learning Support</h3>
        <p class="text-gray-600 mb-6 flex-grow leading-relaxed">Guidance for school concerns, teacher meetings, IEP confusion, and developing effective home-school communication.</p>
        <a href="/services/school-consultation" class="inline-flex items-center text-brand-trust font-bold hover:text-brand-navy transition-colors mt-auto group-hover:underline">
          Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>

      <!-- Assessment & Report Guidance -->
      <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md hover-lift transition-all border border-gray-100 flex flex-col h-full group">
        <div class="w-12 h-12 bg-blue-50 text-brand-trust rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-trust group-hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-brand-navy mb-3">Assessment & Report Guidance</h3>
        <p class="text-gray-600 mb-6 flex-grow leading-relaxed">Review and translate clinical reports into actionable home steps, or get guidance on finding local assessments.</p>
        <a href="/report-review" class="inline-flex items-center text-brand-trust font-bold hover:text-brand-navy transition-colors mt-auto group-hover:underline">
          Learn More <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>

    </div>
  </div>
</section>
