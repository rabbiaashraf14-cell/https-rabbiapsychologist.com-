<section class="py-20 bg-brand-cream border-t border-brand-gold/20">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="text-brand-gold font-bold tracking-wider uppercase text-sm mb-2 block">Transparent & Accessible</span>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Support That Fits Your Needs</h2>
      <p class="text-gray-700 max-w-2xl mx-auto">Clear pricing for parent guidance and child development support.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto mb-12">
      <!-- Card 1 -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 flex flex-col items-center text-center hover:shadow-md transition-shadow">
        <h3 class="text-xl font-bold text-brand-navy mb-2">Online Parent Guidance</h3>
        <p class="text-2xl font-bold text-brand-gold mb-4">USD 85 <span class="text-sm text-gray-500">/ AUD 130</span></p>
        <p class="text-sm text-gray-600 mb-6">For clarity about attention, behaviour, routines, and developmental concerns.</p>
        <a href="/pricing" class="w-full mt-auto bg-white text-brand-navy border-2 border-brand-navy px-4 py-2 rounded-lg font-bold hover:bg-gray-50 transition-colors">Details</a>
      </div>

      <!-- Card 2 -->
      <div class="bg-white rounded-xl shadow-sm border border-brand-navy p-8 flex flex-col items-center text-center relative hover:shadow-md transition-shadow">
        <div class="absolute top-0 transform -translate-y-1/2 bg-brand-navy text-white px-4 py-1 rounded-full text-xs font-bold tracking-wider uppercase">Most Popular</div>
        <h3 class="text-xl font-bold text-brand-navy mb-2">ADHD/ASD Support</h3>
        <p class="text-2xl font-bold text-brand-gold mb-4">USD 95 <span class="text-sm text-gray-500">/ AUD 145</span></p>
        <p class="text-sm text-gray-600 mb-6">Targeted home routine, sensory, and executive function support.</p>
        <a href="/book" class="w-full mt-auto bg-brand-navy text-white px-4 py-2 rounded-lg font-bold hover:bg-blue-900 transition-colors">Book Now</a>
      </div>

      <!-- Card 3 -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 flex flex-col items-center text-center hover:shadow-md transition-shadow">
        <h3 class="text-xl font-bold text-brand-navy mb-2">Report Review</h3>
        <p class="text-2xl font-bold text-brand-gold mb-4">USD 125 <span class="text-sm text-gray-500">/ AUD 190</span></p>
        <p class="text-sm text-gray-600 mb-6">Understand clinical reports and plan next steps for home and school.</p>
        <a href="/pricing" class="w-full mt-auto bg-white text-brand-navy border-2 border-brand-navy px-4 py-2 rounded-lg font-bold hover:bg-gray-50 transition-colors">Details</a>
      </div>
    </div>

    <div class="text-center">
      <a href="/pricing" class="inline-block bg-white text-brand-navy border-2 border-brand-navy px-8 py-3 rounded-lg font-bold text-lg hover:bg-gray-50 transition-colors shadow-sm">View Full Pricing</a>
    </div>
  </div>
</section>
