---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SuccessMessage from '../components/ui/SuccessMessage.astro';
---

<Layout title="Message Sent">
  <div class="min-h-[70vh] flex items-center justify-center bg-brand-cream px-4">
    <SuccessMessage
      title="Message Sent Successfully"
      message="Thank you for contacting us. We aim to respond to all inquiries within 24-48 business hours."
      nextSteps={[
        "Check your email inbox for our reply.",
        "Browse our provider directory if you are ready to book."
      ]}
    />
  </div>
</Layout>
