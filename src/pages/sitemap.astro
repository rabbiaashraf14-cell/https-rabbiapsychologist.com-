---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Sitemap | NeuroNest Child Development Centre";
const description = "Browse all public pages on NeuroNest Child Development Centre, including providers, services, international family support, resources, pricing, and contact pages.";

const mainPages = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
  { name: 'Contact', href: '/contact' }
];

const findSupport = [
  { name: 'Find Support Overview', href: '/find-support' },
  { name: 'Not sure where to start?', href: '/not-sure-where-to-start' }
];

const providers = [
  { name: 'Choose a Provider', href: '/choose-a-provider' },
  { name: 'Provider Directory', href: '/providers' },
  { name: 'Rabbia Ashraf', href: '/providers/rabbia-ashraf' },
  { name: 'Provider Scope & Boundaries', href: '/provider-scope' },
  { name: 'Join as Provider', href: '/join-as-provider' }
];

const services = [
  { name: 'All Services', href: '/services' },
  { name: 'Global Parent Consultation', href: '/services/global-parent-consultation' },
  { name: 'Autism Parent Guidance', href: '/services/autism-parent-guidance' },
  { name: 'ADHD Executive Function Support', href: '/services/adhd-executive-function-support' },
  { name: 'Behavior Support Planning', href: '/services/behavior-support-planning' },
  { name: 'Parent Training', href: '/services/parent-training' },
  { name: 'School & IEP Consultation', href: '/services/school-iep-consultation' },
  { name: 'Psychological Assessment', href: '/services/psychological-assessment-local' },
  { name: 'Referral Guidance', href: '/services/referral-guidance' }
];

const internationalFamilies = [
  { name: 'International Families Overview', href: '/international-families' },
  { name: 'USA Families', href: '/online-parent-consultation-usa' },
  { name: 'Australia Families', href: '/online-parent-consultation-australia' },
  { name: 'UK & Europe Families', href: '/online-parent-consultation-uk-europe' },
  { name: 'MENA & Gulf Families', href: '/online-parent-consultation-mena-gulf' },
  { name: 'Pakistan Families', href: '/online-parent-consultation-pakistan' },
  { name: 'International Schools', href: '/international-schools' }
];

const resources = [
  { name: 'Resources Overview', href: '/resources' },
  { name: 'Resource Vault', href: '/resources/resource-vault' },
  { name: 'Blog', href: '/blog' }
];

const pricing = [
  { name: 'Pricing', href: '/pricing' }
];

const brandAndMedia = [
  { name: 'Brand Assets', href: '/brand-assets' },
  { name: 'Media Kit', href: '/media-kit' },
  { name: 'Press Release', href: '/press/neuronest-child-development-centre-launch' },
  { name: 'Newsroom', href: '/news' },
  { name: 'Use Cases', href: '/use-cases' }
];

const legalAndSafety = [
  { name: 'Service Boundaries', href: '/service-boundaries' },
  { name: 'Privacy Policy', href: '/privacy-policy' },
  { name: 'Terms & Disclaimer', href: '/terms-and-disclaimer' }
];
---

<BaseLayout title={title} description={description}>
  <div class="bg-brand-cream py-12 md:py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Sitemap</h1>
      <p class="text-lg text-gray-700 mb-12">Browse all public pages on the NeuroNest Child Development Centre platform.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">

        <!-- Main Pages -->
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-4 border-b border-gray-200 pb-2">Main Pages</h2>
          <ul class="space-y-2">
            {mainPages.map(link => (
              <li><a href={link.href} class="text-gray-700 hover:text-brand-trust underline-offset-4 hover:underline">{link.name}</a></li>
            ))}
          </ul>
        </div>

        <!-- Find Support -->
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-4 border-b border-gray-200 pb-2">Find Support</h2>
          <ul class="space-y-2">
            {findSupport.map(link => (
              <li><a href={link.href} class="text-gray-700 hover:text-brand-trust underline-offset-4 hover:underline">{link.name}</a></li>
            ))}
          </ul>
        </div>

        <!-- Providers -->
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-4 border-b border-gray-200 pb-2">Providers</h2>
          <ul class="space-y-2">
            {providers.map(link => (
              <li><a href={link.href} class="text-gray-700 hover:text-brand-trust underline-offset-4 hover:underline">{link.name}</a></li>
            ))}
          </ul>
        </div>

        <!-- Services -->
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-4 border-b border-gray-200 pb-2">Services</h2>
          <ul class="space-y-2">
            {services.map(link => (
              <li><a href={link.href} class="text-gray-700 hover:text-brand-trust underline-offset-4 hover:underline">{link.name}</a></li>
            ))}
          </ul>
        </div>

        <!-- International Families -->
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-4 border-b border-gray-200 pb-2">International Families</h2>
          <ul class="space-y-2">
            {internationalFamilies.map(link => (
              <li><a href={link.href} class="text-gray-700 hover:text-brand-trust underline-offset-4 hover:underline">{link.name}</a></li>
            ))}
          </ul>
        </div>

        <!-- Resources -->
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-4 border-b border-gray-200 pb-2">Resources</h2>
          <ul class="space-y-2">
            {resources.map(link => (
              <li><a href={link.href} class="text-gray-700 hover:text-brand-trust underline-offset-4 hover:underline">{link.name}</a></li>
            ))}
          </ul>
        </div>

        <!-- Pricing -->
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-4 border-b border-gray-200 pb-2">Pricing</h2>
          <ul class="space-y-2">
            {pricing.map(link => (
              <li><a href={link.href} class="text-gray-700 hover:text-brand-trust underline-offset-4 hover:underline">{link.name}</a></li>
            ))}
          </ul>
        </div>

        <!-- Brand & Media -->
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-4 border-b border-gray-200 pb-2">Brand & Media</h2>
          <ul class="space-y-2">
            {brandAndMedia.map(link => (
              <li><a href={link.href} class="text-gray-700 hover:text-brand-trust underline-offset-4 hover:underline">{link.name}</a></li>
            ))}
          </ul>
        </div>

        <!-- Legal & Safety -->
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-4 border-b border-gray-200 pb-2">Legal & Safety</h2>
          <ul class="space-y-2">
            {legalAndSafety.map(link => (
              <li><a href={link.href} class="text-gray-700 hover:text-brand-trust underline-offset-4 hover:underline">{link.name}</a></li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>
