---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/global/Breadcrumbs.astro';
import ResourceCard from '../components/resources/ResourceCard.astro';
import DisclaimerBanner from '../components/global/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/global/StickyMobileBookingCTA.astro';
import { resources } from '../data/resources';

const breadcrumbs = [
  { name: 'Resources', href: '/resources' }
];

const categories = [
  {
    title: "1. ADHD",
    description: "ADHD support starts with understanding how attention, impulse control, routines, emotional regulation, working memory, and school demands interact. These resources help parents move from constant correction to practical structure.",
    faq: [
      { q: "How can I help my child focus at home?", a: "Visual schedules and breaking tasks into smaller steps are effective strategies." }
    ],
    blogs: [
      { name: "Morning Routine Problems in ADHD", href: "/blog/morning-routine-problems-in-adhd" },
      { name: "Understanding ADHD and Hyperactivity", href: "/blog/understanding-adhd-and-hyperactivity-in-children" }
    ],
    services: [{ name: "ADHD Support Consultation", href: "/services/adhd-support" }],
    cta: "Explore ADHD Support"
  },
  {
    title: "2. Autism Spectrum Disorder",
    description: "Autism support is not only about a diagnosis. Parents often need help understanding communication, play, sensory needs, routines, behaviour, and school expectations. These resources help families plan the next step.",
    faq: [
      { q: "Is speech delay always autism?", a: "No. Speech delay is common, but in autism, delays are often in social communication." }
    ],
    blogs: [
      { name: "Autism Early Signs", href: "/blog/autism-early-signs" },
      { name: "Parent Guidance After an Autism Diagnosis", href: "/blog/parent-guidance-after-an-autism-diagnosis" }
    ],
    services: [{ name: "ASD Parent Guidance Consultation", href: "/services/asd-support" }],
    cta: "Explore Autism Support"
  },
  {
    title: "3. Child Behaviour",
    description: "Behaviour is often the visible part of a deeper need. These resources help parents understand triggers, meltdowns, transitions, screen-time reactions, and replacement skills.",
    faq: [
      { q: "Why does my child behave well at school but not at home?", a: "Children use all their energy to hold it together at school, releasing exhaustion at home (restraint collapse)." }
    ],
    blogs: [
      { name: "Behaviour is Communication", href: "/blog/behaviour-is-communication" },
      { name: "Parent Guidance for Behaviour Concerns", href: "/blog/parent-guidance-for-behaviour-concerns" }
    ],
    services: [{ name: "Behaviour Support Planning", href: "/services/behaviour-planning" }],
    cta: "Explore Behaviour Support"
  },
  {
    title: "4. Emotional Regulation",
    description: "Emotional regulation requires time and adult support to develop. Learn how to help your child notice feelings, manage frustration, and recover safely.",
    faq: [
      { q: "How can I help my child calm down?", a: "The most effective way is through co-regulation. Remain calm, reduce demands, and validate the feeling." }
    ],
    blogs: [
      { name: "Emotional Regulation in Children", href: "/blog/emotional-regulation-in-children" },
      { name: "Tantrum vs Meltdown", href: "/blog/tantrum-vs-meltdown" }
    ],
    services: [{ name: "Emotional Regulation Support", href: "/services/emotional-regulation-support" }],
    cta: "Explore Emotional Regulation Support"
  },
  {
    title: "5. Executive Function",
    description: "Support for planning, working memory, task initiation, and organization. These skills are often the hidden challenge behind homework battles and morning chaos.",
    faq: [
      { q: "Can executive function improve?", a: "Yes, by adapting the environment and practicing specific skills, executive functioning can be strengthened." }
    ],
    blogs: [
      { name: "How to Support Executive Function at Home", href: "/blog/how-to-support-executive-function-at-home" }
    ],
    services: [{ name: "ADHD Support Consultation", href: "/services/adhd-support" }],
    cta: "Explore Executive Function Help"
  },
  {
    title: "6. Learning Difficulties",
    description: "Resources for when a child struggles to read, write, or calculate despite adequate instruction. Learn how to advocate for appropriate school supports.",
    faq: [
      { q: "What are early signs of learning difficulties?", a: "Difficulty with rhyming, avoiding reading aloud, or struggling to remember sequences." }
    ],
    blogs: [
      { name: "Learning Difficulties Early Signs", href: "/blog/learning-difficulties-early-signs" }
    ],
    services: [{ name: "School Consultation", href: "/services/school-consultation" }],
    cta: "Explore Learning Support"
  },
  {
    title: "7. School & Classroom Support",
    description: "Guidance for understanding IEPs, school refusal, and collaborating with teachers to create effective accommodations.",
    faq: [
      { q: "What should I ask at an IEP meeting?", a: "Ask how goals will be measured and what specific accommodations will be implemented daily." }
    ],
    blogs: [
      { name: "School Meeting Checklist", href: "/blog/school-meeting-checklist" },
      { name: "School Refusal and School Anxiety", href: "/blog/school-refusal-and-school-anxiety" }
    ],
    services: [{ name: "School Consultation", href: "/services/school-consultation" }],
    cta: "Explore School Support"
  },
  {
    title: "8. Parent Guidance",
    description: "The core of our approach. Empowering parents with knowledge, strategies, and confidence to be the best support for their child's development.",
    faq: [
      { q: "Does parent guidance really work?", a: "Yes, parents are the primary environment for the child. Changing parent responses often changes child behaviour." }
    ],
    blogs: [
      { name: "Parent Burnout in Child Development", href: "/blog/parent-burnout-child-development-support" }
    ],
    services: [{ name: "Behaviour Planning", href: "/services/behaviour-planning" }],
    cta: "Explore Parent Guidance"
  },
  {
    title: "9. Daily Routines",
    description: "Mastering mornings, bedtimes, and transitions. Predictability reduces anxiety and behavioural challenges.",
    faq: [
      { q: "How do I make mornings less stressful?", a: "Use visual schedules, prepare the night before, and build in extra time for transitions." }
    ],
    blogs: [
      { name: "Sleep Routine and Child Behaviour", href: "/blog/sleep-routine-and-child-behaviour" }
    ],
    services: [{ name: "ADHD Support Consultation", href: "/services/adhd-support" }],
    cta: "Explore Routine Support"
  },
  {
    title: "10. Sensory Processing",
    description: "Understanding how your child perceives and responds to sensory input (sound, touch, movement) and how to create a sensory-friendly home.",
    faq: [
      { q: "What is sensory overload?", a: "When the brain receives more sensory input than it can process, often leading to a meltdown or shutdown." }
    ],
    blogs: [
      { name: "Sensory Processing Difficulties", href: "/blog/sensory-processing-difficulties" }
    ],
    services: [{ name: "ASD Parent Guidance Consultation", href: "/services/asd-support" }],
    cta: "Explore Sensory Support"
  },
  {
    title: "11. Speech & Communication",
    description: "Resources on language development, speech delays, and alternative forms of communication for neurodivergent children.",
    faq: [
      { q: "When should I worry about speech delay?", a: "If your child is not using gestures by 12 months or single words by 16 months, seek guidance." }
    ],
    blogs: [
      { name: "Speech Delay vs Autism", href: "/blog/speech-delay-vs-autism" },
      { name: "Social Communication Concerns", href: "/blog/social-communication-concerns" }
    ],
    services: [{ name: "ASD Parent Guidance Consultation", href: "/services/asd-support" }],
    cta: "Explore Communication Support"
  },
  {
    title: "12. Assessment & Reports",
    description: "Demystifying psychological assessments, understanding clinical jargon, and turning reports into actionable steps.",
    faq: [
      { q: "How do I explain an assessment report to the school?", a: "Focus on the key findings and the specific accommodations recommended by the evaluator." }
    ],
    blogs: [
      { name: "Understanding Psychological Reports", href: "/blog/understanding-psychological-reports" },
      { name: "How to Prepare for Child Assessment", href: "/blog/how-to-prepare-for-child-assessment" }
    ],
    services: [{ name: "Report Review", href: "/report-review" }],
    cta: "Explore Report Review"
  },
  {
    title: "13. International Parent Guidance",
    description: "Tailored support for families living abroad, navigating different educational systems and cultural expectations.",
    faq: [
      { q: "Do you offer consultations for families outside Pakistan?", a: "Yes, we provide online developmental and parent guidance to families worldwide." }
    ],
    blogs: [
      { name: "Parent Guidance After an Autism Diagnosis", href: "/blog/parent-guidance-after-an-autism-diagnosis" }
    ],
    services: [{ name: "Behaviour Planning", href: "/services/behaviour-planning" }],
    cta: "Explore International Support"
  },
  {
    title: "14. Free Downloads",
    description: "Accessible tools, checklists, and visual schedules you can download and use at home today.",
    faq: [
      { q: "Are the downloads free?", a: "Yes, these are provided as a starting point to support your child's development." }
    ],
    blogs: [],
    services: [],
    cta: "View Free Downloads",
    ctaLink: "/free-downloads"
  },
  {
    title: "15. Resource Vault",
    description: "A comprehensive collection of our premium resources, templates, and guided videos for members and clients.",
    faq: [
      { q: "How do I access the Resource Vault?", a: "Access is often provided as part of our consultation packages or available for separate purchase." }
    ],
    blogs: [],
    services: [],
    cta: "Access Resource Vault",
    ctaLink: "/resource-vault"
  }
];

// Combine all actual resources to display at the top
const featuredResources = resources || [];

---

<BaseLayout
  title="Parent Support Resource Center | Rabbia Psychologist"
  description="Explore resources for ADHD, autism, child behavior, emotional regulation, and school support. Practical guidance for parents."
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-5xl">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="text-center mt-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-4">Parent Support Resource Center</h1>
      <p class="text-xl text-gray-700 max-w-3xl mx-auto">
        Practical, parent-friendly resources on child development, ADHD, autism, behaviour, emotional regulation, and learning difficulties.
      </p>
    </div>

    {featuredResources.length > 0 && (
      <div class="mb-16">
        <h2 class="text-3xl font-bold text-brand-navy mb-6 text-center border-b pb-4">Featured Resources</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredResources.map(resource => (
            <ResourceCard resource={resource} />
          ))}
        </div>
      </div>
    )}

    <div class="space-y-16">
      {categories.map((category) => (
        <section class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 hover-lift">
          <h2 class="text-3xl font-bold text-brand-navy mb-4">{category.title}</h2>
          <p class="text-lg text-gray-700 mb-6">{category.description}</p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-6">
            <div>
              <h3 class="text-xl font-bold text-brand-navy mb-3">Common Questions</h3>
              {category.faq.map((f) => (
                <div class="mb-4">
                  <h4 class="font-bold text-gray-800">{f.q}</h4>
                  <p class="text-gray-600 text-sm">{f.a}</p>
                </div>
              ))}

              <h3 class="text-xl font-bold text-brand-navy mb-3 mt-6">Parents Also Ask</h3>
               <div class="space-y-2">
                 <p class="text-sm font-bold text-gray-800">Is this normal behaviour or something more?</p>
                 <p class="text-sm text-gray-600">If it significantly impacts daily life, it may need support. Read our <a href="/blog/when-to-seek-developmental-assessment" class="text-brand-trust hover:underline">guide on assessments</a>.</p>
               </div>
            </div>

            <div>
              {category.blogs.length > 0 && (
                <div class="mb-6">
                  <h3 class="text-xl font-bold text-brand-navy mb-3">Featured Articles</h3>
                  <ul class="list-disc pl-5 space-y-2">
                    {category.blogs.map((blog) => (
                      <li><a href={blog.href} class="text-brand-trust hover:underline font-medium">{blog.name}</a></li>
                    ))}
                  </ul>
                </div>
              )}

              {category.services.length > 0 && (
                <div>
                  <h3 class="text-xl font-bold text-brand-navy mb-3">Related Services</h3>
                  <ul class="list-disc pl-5 space-y-2">
                    {category.services.map((service) => (
                      <li><a href={service.href} class="text-brand-trust hover:underline font-medium">{service.name}</a></li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </div>

          <div class="mt-6 text-center md:text-left">
            {category.ctaLink ? (
              <a href={category.ctaLink} class="inline-block bg-brand-trust text-white px-6 py-3 rounded-lg font-bold hover:bg-teal-800 transition-colors">
                {category.cta}
              </a>
            ) : (
              <a href="/book" class="inline-block bg-brand-navy text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">
                Book a Parent Consultation
              </a>
            )}
          </div>
        </section>
      ))}
    </div>

  </div>

</BaseLayout>
