---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/seo/SEO.astro';
import Breadcrumbs from '../components/global/Breadcrumbs.astro';
import ServiceCard from '../components/services/ServiceCard.astro';
import DisclaimerBanner from '../components/global/DisclaimerBanner.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' }
];

const pricingData = [
  { title: 'Initial Parent Consultation with Rabbia', price: 'PKR 7,000' },
  { title: 'International Parent Guidance with Rabbia', price: 'USD 50 / AUD 75' },
  { title: 'Follow-up Parent Guidance', price: 'USD 45 / AUD 70' },
  { title: 'ADHD Executive Function Consultation', price: 'USD 55 / AUD 85' },
  { title: 'ASD Parent Guidance Consultation', price: 'USD 55 / AUD 85' },
  { title: '4-Session Parent Guidance Package', price: 'USD 180 / AUD 280' },
  { title: 'School/IEP Consultation', price: 'From USD 100 / AUD 155' },
  { title: 'Local Psychological Assessment with Report', price: 'PKR 25,000+' },
  { title: 'ADHD Screening / Structured Screening', price: 'PKR 15,000+' },
  { title: 'Provider Consultation', price: 'Provider-specific' },
  { title: 'Digital Resources', price: 'Free to USD 29' },
];

const coreServices = [
  {
    title: 'Global Parent Consultation',
    description: 'Parent education, developmental guidance, ASD/ADHD support planning, and referral direction for families worldwide.',
    href: '/services/global-parent-consultation',
    slug: 'global-parent-consultation'
  },
  {
    title: 'Autism Parent Guidance',
    description: 'Support for parents concerned about autism signs, routines, sensory needs, or daily functioning.',
    href: '/services/autism-parent-guidance',
    slug: 'autism-parent-guidance'
  },
  {
    title: 'ADHD Executive Function Support',
    description: 'Guidance for attention, working memory, task initiation, planning, and emotional regulation.',
    href: '/services/adhd-executive-function-support',
    slug: 'adhd-executive-function-support'
  },
  {
    title: 'Behavior Support Planning',
    description: 'Understanding what behavior communicates and creating practical support plans for home and school.',
    href: '/services/behavior-support-planning',
    slug: 'behavior-support-planning'
  },
  {
    title: 'Parent Training',
    description: 'Structured parent sessions to help caregivers use practical strategies at home.',
    href: '/services/parent-training',
    slug: 'parent-training'
  },
  {
    title: 'School & IEP Consultation',
    description: 'Support for parents preparing for school meetings, learning supports, and individualized planning.',
    href: '/services/school-iep-consultation',
    slug: 'school-iep-consultation'
  },
  {
    title: 'Psychological Assessment, Local Only',
    description: 'Local assessment pathways for families in Lahore/Pakistan where available.',
    href: '/services/psychological-assessment-local',
    slug: 'psychological-assessment-local'
  },
  {
    title: 'Referral Guidance',
    description: 'Guidance on when to seek a pediatrician, psychologist, occupational therapist, or emergency support.',
    href: '/services/referral-guidance',
    slug: 'referral-guidance'
  }
];
---

<Layout title="Services - Child Development & Parent Guidance">
  <SEO
    title="Child Development & Parent Guidance Services | Rabbia Ashraf"
    description="Explore child development services including parent consultation, autism guidance, ADHD support, behavior planning, school consultation, local assessment pathways, and provider choice."
  />

  <DisclaimerBanner />

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    {/* Hero section */}
    <div class="max-w-4xl mx-auto mt-8 mb-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Child Development, Parent Guidance, and Specialist Consultation Services</h1>
      <p class="text-xl text-gray-700 mb-8">
        Explore parent consultation, ASD/ADHD guidance, behavior support planning, school consultation, local assessment pathways, and international support options. Parents can learn, compare services, choose a provider, and book the support route that fits their family.
      </p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="/providers" class="bg-brand-trust text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700 transition-colors">Choose a Provider</a>
        <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" class="bg-brand-navy text-white px-6 py-3 rounded-md font-medium hover:bg-gray-800 transition-colors">Book with Rabbia</a>
        <a href="/resources" class="text-brand-trust font-medium hover:underline px-6 py-3">Explore Parent Resources</a>
      </div>
    </div>

    {/* Trust strip */}
    <div class="flex flex-wrap justify-center gap-3 mb-16">
      {['Parent Guidance', 'ASD Support', 'ADHD Support', 'Behavior Support', 'School Consultation', 'Region-Aware', 'Local Assessment Pathways', 'Provider Choice'].map(badge => (
        <span class="bg-gray-100 text-gray-700 text-sm font-medium px-4 py-2 rounded-full">{badge}</span>
      ))}
    </div>

    {/* "How to choose the right service" section */}
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-8 text-center">How to choose the right service</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/services/behavior-support-planning" class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center">
          <h3 class="font-bold text-brand-navy mb-2">I need help understanding my child's behavior</h3>
        </a>
        <a href="/services/autism-parent-guidance" class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center">
          <h3 class="font-bold text-brand-navy mb-2">I am concerned about autism or developmental signs</h3>
        </a>
        <a href="/services/adhd-executive-function-support" class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center">
          <h3 class="font-bold text-brand-navy mb-2">I am concerned about ADHD, focus, or routines</h3>
        </a>
        <a href="/services/school-iep-consultation" class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center">
          <h3 class="font-bold text-brand-navy mb-2">I need school support or assessment guidance</h3>
        </a>
      </div>
    </div>

    {/* Core services grid */}
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-8 text-center">Core Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {coreServices.map(service => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>

    {/* Parent journey section */}
    <div class="mb-16 bg-brand-cream rounded-xl p-8 border border-gray-100">
      <h2 class="text-3xl font-bold text-brand-navy mb-8 text-center">From concern to a clear support plan</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-2xl font-bold text-brand-trust mb-2">1. Notice the concern</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-trust mb-2">2. Learn what it may mean</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-trust mb-2">3. Choose the right support route</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-trust mb-2">4. Select a provider</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-trust mb-2">5. Book consultation</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-trust mb-2">6. Use strategies at home and school</div>
        </div>
        <div>
          <div class="text-2xl font-bold text-brand-trust mb-2">7. Review progress and next steps</div>
        </div>
      </div>
    </div>

    {/* Service boundary section */}
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-6 text-center">Understanding Service Boundaries</h2>
      <div class="bg-white p-6 rounded-xl border border-gray-100 shadow-sm text-gray-700">
        <p class="mb-4"><strong>Our services include:</strong> Parent education, parent consultation, developmental guidance, behavior support planning, and school consultation.</p>
        <p class="mb-4"><strong>Additional local services:</strong> Psychological assessment and diagnosis are available only locally where legally and ethically permitted.</p>
        <p class="mb-4 text-brand-navy font-medium"><strong>Important Note:</strong> Education and consultation are not the same as regulated therapy, assessment, or diagnosis. We do not provide emergency care.</p>
      </div>
    </div>

    {/* Pricing preview */}
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-6 text-center">Pricing Overview</h2>
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-left">
          <tbody class="divide-y divide-gray-100">
            {pricingData.map((item) => (
              <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 font-medium text-brand-navy">{item.title}</td>
                <td class="px-6 py-4 text-gray-600">{item.price}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-sm text-gray-500 mt-4 text-center">Prices vary by provider, region, session type, currency conversion, payment method, and scope of service. Parents can review provider profiles and select the option that fits their needs before booking.</p>
    </div>

    {/* Provider choice section */}
    <div class="mb-16 text-center bg-brand-cream border border-gray-100 rounded-xl p-8">
      <h2 class="text-3xl font-bold text-brand-navy mb-4">Choose support in a way that fits your family</h2>
      <p class="text-gray-700 mb-6 max-w-2xl mx-auto">Parents can compare provider profiles, region, language, service scope, and pricing before booking. The platform provides information and booking pathways, but parents choose the provider they wish to book.</p>
      <a href="/providers" class="inline-block bg-brand-trust text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700 transition-colors">View Provider Directory</a>
    </div>

    {/* FAQ section */}
    <div class="mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-8 text-center">Frequently Asked Questions</h2>
      <div class="space-y-4 max-w-3xl mx-auto">
        {/* Placeholder for FAQ Accordions. Real implementation would use a reusable FAQAccordion component if available, but simple HTML is fine here. */}
        <details class="bg-white border border-gray-100 rounded-lg p-4">
          <summary class="font-bold text-brand-navy cursor-pointer">Which service should I choose first?</summary>
          <p class="text-gray-700 mt-2">If you're unsure, starting with a Global Parent Consultation is often the best step to discuss your concerns broadly and map out a support plan.</p>
        </details>
        <details class="bg-white border border-gray-100 rounded-lg p-4">
          <summary class="font-bold text-brand-navy cursor-pointer">Is this therapy?</summary>
          <p class="text-gray-700 mt-2">No. Our online services are parent education, consultation, and developmental guidance, not regulated psychotherapy or medical treatment.</p>
        </details>
        <details class="bg-white border border-gray-100 rounded-lg p-4">
          <summary class="font-bold text-brand-navy cursor-pointer">Can my child be diagnosed online?</summary>
          <p class="text-gray-700 mt-2">No. We do not provide formal medical or psychological diagnosis online.</p>
        </details>
        <details class="bg-white border border-gray-100 rounded-lg p-4">
          <summary class="font-bold text-brand-navy cursor-pointer">Can international families book?</summary>
          <p class="text-gray-700 mt-2">Yes, our global parent consultation and guidance services are designed for families worldwide.</p>
        </details>
        <details class="bg-white border border-gray-100 rounded-lg p-4">
          <summary class="font-bold text-brand-navy cursor-pointer">Is assessment available?</summary>
          <p class="text-gray-700 mt-2">Formal psychological assessments are only available locally in Lahore, Pakistan, subject to professional availability and appropriateness.</p>
        </details>
        <details class="bg-white border border-gray-100 rounded-lg p-4">
          <summary class="font-bold text-brand-navy cursor-pointer">Can you help with school concerns?</summary>
          <p class="text-gray-700 mt-2">Yes, our School & IEP Consultation helps parents prepare for school meetings and discuss learning supports.</p>
        </details>
        <details class="bg-white border border-gray-100 rounded-lg p-4">
          <summary class="font-bold text-brand-navy cursor-pointer">What if my child needs urgent help?</summary>
          <p class="text-gray-700 mt-2">We do not provide emergency services. If your child is in immediate danger or experiencing a medical emergency, please contact your local emergency services immediately.</p>
        </details>
        <details class="bg-white border border-gray-100 rounded-lg p-4">
          <summary class="font-bold text-brand-navy cursor-pointer">How do I prepare before booking?</summary>
          <p class="text-gray-700 mt-2">Review our service descriptions, understand our service boundaries, compare our providers, and gather any relevant notes about your child's behavior or history to discuss during your consultation.</p>
        </details>
      </div>
    </div>

    {/* Final CTA */}
    <div class="text-center">
      <h2 class="text-3xl font-bold text-brand-navy mb-6">Not sure which service fits your child?</h2>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="/providers" class="bg-brand-trust text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700 transition-colors">Choose a Provider</a>
        <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" class="bg-brand-navy text-white px-6 py-3 rounded-md font-medium hover:bg-gray-800 transition-colors">Book with Rabbia</a>
        <a href="/resources" class="text-brand-trust font-medium hover:underline px-6 py-3">Explore Resources</a>
      </div>
    </div>

  </div>

</Layout>
