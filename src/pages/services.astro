---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services } from '../data/services';

const title = "Services | Rabbia Psychologist Child Development Services";
const description = "Explore our child development services including parent guidance, ASD support, ADHD strategies, school IEP help, and behavior support planning.";
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-16 max-w-5xl">
    <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6 text-center">Our Services</h1>
    <p class="text-xl text-gray-700 mb-12 text-center max-w-3xl mx-auto">
      Support options, not one-size-fits-all. We offer tailored guidance for your family's unique needs.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map(service => (
        <div id={service.slug} class="bg-white border border-gray-200 rounded-xl p-8 shadow-sm hover:shadow-md transition-all scroll-mt-24">
          <h2 class="text-2xl font-bold text-brand-navy mb-4">{service.title}</h2>
          <p class="text-gray-700 mb-6">{service.description}</p>

          <div class="mb-6">
            <h3 class="font-semibold text-gray-800 mb-2">Who it helps:</h3>
            <p class="text-gray-600">{service.whoItHelps}</p>
          </div>

          <div class="mb-6">
             <h3 class="font-semibold text-gray-800 mb-2">What it includes:</h3>
             <ul class="list-disc pl-5 text-gray-600 space-y-1">
               {service.whatItIncludes.map(item => (
                 <li>{item}</li>
               ))}
             </ul>
          </div>

           <div class="mb-8">
             <h3 class="font-semibold text-gray-800 mb-2">What it does NOT include:</h3>
             <ul class="list-disc pl-5 text-gray-600 space-y-1 italic">
               {service.whatItDoesNotInclude.map(item => (
                 <li>{item}</li>
               ))}
             </ul>
          </div>

          <p class="text-xs text-gray-500 italic mb-6">{service.disclaimer}</p>

          <a href="/book" class="inline-block w-full text-center bg-brand-trust text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors">
            {service.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
