---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services } from '../data/services';

const title = "Services | Rabbia Psychologist Child Development Services";
const description = "Explore our child development services including parent guidance, ASD support, ADHD strategies, school IEP help, and behavior support planning.";
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-16 max-w-5xl">
    <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6 text-center">Our Services</h1>
    <p class="text-xl text-gray-700 mb-12 text-center max-w-3xl mx-auto">
      Support options, not one-size-fits-all. We offer tailored guidance for your family's unique needs.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map(service => (
        <div id={service.slug} class="group bg-white border border-gray-200 rounded-xl p-8 shadow-sm hover:shadow-md transition-all scroll-mt-24 flex flex-col relative h-full">
          <a href={service.ctaUrl} class="group-hover:text-brand-trust transition-colors">
            <h2 class="text-2xl font-bold text-brand-navy mb-4 group-hover:text-brand-trust">{service.title}</h2>
          </a>
          <p class="text-gray-700 mb-6 font-medium">{service.description}</p>

          <div class="mb-4">
            <h3 class="font-bold text-brand-navy mb-1 text-sm uppercase tracking-wider">This is right for you if:</h3>
            <p class="text-gray-600 text-sm">{service.whoItIsFor}</p>
          </div>

          <div class="mb-6">
            <h3 class="font-bold text-brand-navy mb-1 text-sm uppercase tracking-wider">Common Concerns:</h3>
            <p class="text-gray-600 text-sm italic">"{service.commonConcerns}"</p>
          </div>

          <div class="mb-6">
             <h3 class="font-semibold text-gray-800 mb-2">What it includes:</h3>
             <ul class="list-disc pl-5 text-gray-600 space-y-1 text-sm">
               {service.whatItIncludes.map(item => (
                 <li>{item}</li>
               ))}
             </ul>
          </div>

           <div class="mb-8 flex-grow">
             <h3 class="font-semibold text-gray-800 mb-2">What it does NOT include:</h3>
             <ul class="list-disc pl-5 text-gray-600 space-y-1 text-sm">
               {service.whatItDoesNotInclude.map(item => (
                 <li>{item}</li>
               ))}
             </ul>
          </div>

          <a href={service.ctaUrl} class="block text-center text-brand-trust font-bold mb-4 hover:underline">View Service Details &rarr;</a>
          <a href="/book" class="inline-block w-full text-center bg-brand-navy text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors mt-auto">
            Book Consultation
          </a>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
