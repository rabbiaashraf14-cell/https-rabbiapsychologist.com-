---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'International Families', href: '/international-families' },
  { name: 'Pakistan', href: '/international-families/pakistan' }
];
---

<BaseLayout title="Child Psychology Services in Pakistan | Rabbia Psychologist" description="Local in-person psychological assessment and discounted consultation pricing for residents of Pakistan.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="mt-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Support for Families in Pakistan</h1>
      <p class="text-xl text-gray-700">Local in-person assessment in Lahore and discounted online consultation pricing for residents of Pakistan.</p>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700">
      <h2 class="text-2xl font-bold text-brand-navy">Local Services in Lahore</h2>
      <p>For families residing in Pakistan, we offer in-person clinical services, including:</p>
      <ul>
        <li><a href="/services/local-assessment" class="text-brand-trust font-bold">Local Psychological Assessment</a> (Starting from PKR 25,000+)</li>
        <li><strong>ADHD / Structured Screening</strong> (Starting from PKR 15,000+)</li>
      </ul>
      <p class="text-sm italic">Screening is not the same as a medical diagnosis. If medical evaluation or medication is needed, referral to a developmental pediatrician, psychiatrist, neurologist, or relevant physician may be recommended.</p>

      <h2 class="text-2xl font-bold text-brand-navy">Discounted Local Pricing</h2>
      <p>We understand the economic realities in Pakistan. Residents of Pakistan may be eligible for discounted pricing for online parent guidance, ADHD/ASD support, and report review sessions.</p>

      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Contact Us for Local Booking</h3>
        <p class="mb-4">Please contact us to discuss your child's needs and inquire about local assessment or discounted consultation pricing.</p>
        <a href="/book" class="inline-block bg-brand-navy text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">Ask About Local Pricing</a>
      </div>
    </div>
  </div>
</BaseLayout>
