---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'International Families', href: '/international-families' }
];
---

<BaseLayout title="International Family Support Hub | Rabbia Psychologist" description="Online parent guidance, child development consultation, and school support for families worldwide.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-5xl">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="mt-8 mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Global Families Hub</h1>
      <p class="text-xl text-gray-700 max-w-3xl mx-auto">Professional online parent guidance, child development consultation, and school support for families worldwide.</p>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700 mb-12">
      <p>Rabbia Psychologist Child Development Services supports families across the globe who are seeking clarity, strategies, and evidence-informed guidance for their child's development, behaviour, and education.</p>

      <h2 class="text-2xl font-bold text-brand-navy">Select Your Region for Specific Information</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8 not-prose">
        <a href="/international-families/usa" class="block p-6 bg-white rounded-xl shadow-sm border border-gray-200 hover:border-brand-navy hover:shadow-md transition-all text-center">
          <h3 class="text-xl font-bold text-brand-navy mb-2">USA</h3>
          <p class="text-sm text-gray-600">Guidance and pricing information for families based in the United States.</p>
        </a>
        <a href="/international-families/australia" class="block p-6 bg-white rounded-xl shadow-sm border border-gray-200 hover:border-brand-navy hover:shadow-md transition-all text-center">
          <h3 class="text-xl font-bold text-brand-navy mb-2">Australia</h3>
          <p class="text-sm text-gray-600">Guidance and pricing information for families based in Australia.</p>
        </a>
        <a href="/international-families/uk-europe" class="block p-6 bg-white rounded-xl shadow-sm border border-gray-200 hover:border-brand-navy hover:shadow-md transition-all text-center">
          <h3 class="text-xl font-bold text-brand-navy mb-2">UK & Europe</h3>
          <p class="text-sm text-gray-600">Support for families residing in the United Kingdom and Europe.</p>
        </a>
        <a href="/international-families/middle-east-gulf" class="block p-6 bg-white rounded-xl shadow-sm border border-gray-200 hover:border-brand-navy hover:shadow-md transition-all text-center">
          <h3 class="text-xl font-bold text-brand-navy mb-2">Middle East & Gulf</h3>
          <p class="text-sm text-gray-600">Culturally sensitive support for families in the UAE, Saudi Arabia, and the Gulf region.</p>
        </a>
        <a href="/international-families/overseas-pakistani-families" class="block p-6 bg-white rounded-xl shadow-sm border border-gray-200 hover:border-brand-navy hover:shadow-md transition-all text-center">
          <h3 class="text-xl font-bold text-brand-navy mb-2">Overseas Pakistani Families</h3>
          <p class="text-sm text-gray-600">Culturally attuned parent guidance for the Pakistani diaspora worldwide.</p>
        </a>
        <a href="/international-families/pakistan" class="block p-6 bg-brand-cream rounded-xl shadow-sm border border-brand-gold hover:shadow-md transition-all text-center">
          <h3 class="text-xl font-bold text-brand-navy mb-2">Pakistan</h3>
          <p class="text-sm text-gray-600">Local in-person assessment and discounted consultation pricing for residents.</p>
        </a>
      </div>

      <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 mt-12">
        <h3 class="font-bold text-brand-navy text-lg mb-2 mt-0">Important Service Boundaries for International Families</h3>
        <p class="text-sm">International services provided by Rabbia Psychologist are strictly limited to <strong>parent education, developmental guidance, and school consultation</strong>. These online sessions do not constitute emergency care, psychiatric crisis intervention, or a formal cross-border medical/psychological diagnosis. If your child requires a formal diagnosis for insurance, school funding, or medication, you must consult a regulated professional in your local jurisdiction. We provide report review and home strategy implementation support. For institutional support, we also offer <a href="/school-partnerships" class="text-brand-trust hover:underline font-medium">International School Partnerships</a>.</p>
      </div>
    </div>
  </div>
</BaseLayout>
