---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'International Families', href: '/international-families' },
  { name: 'UK & Europe', href: '/international-families/uk-europe' }
];
---

<BaseLayout title="Parent Guidance & Child Psychology Support for UK & Europe | Rabbia Psychologist" description="Online parent guidance, ADHD support, and school consultation for families in the UK and Europe.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="mt-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Support for Families in the UK & Europe</h1>
      <p class="text-xl text-gray-700">Expert online parent guidance for families navigating long public system waitlists or seeking supplemental support.</p>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700">
      <h2 class="text-2xl font-bold text-brand-navy">Bridging the Gap</h2>
      <p>Whether you are on a long waitlist for the NHS (UK) or navigating private systems in Europe, we provide immediate, actionable parent guidance online.</p>

      <ul>
        <li><strong>Home Routine Support:</strong> Implement effective strategies for ADHD or Autism while awaiting formal assessment.</li>
        <li><strong>Report Translation:</strong> Review existing clinical reports and create a home action plan.</li>
        <li><strong>School Preparation:</strong> Plan how to communicate effectively with SENCOs (Special Educational Needs Coordinators) or equivalent school staff.</li>
      </ul>

      <h2 class="text-2xl font-bold text-brand-navy">Service Boundaries</h2>
      <p>Our services are strictly parent education and consultation. We do not provide formal diagnosis, EHCP assessments, or medical treatment across borders.</p>

      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Book a Consultation</h3>
        <p class="mb-4">Services are billed in USD or AUD.</p>
        <a href="/pricing" class="inline-block bg-brand-navy text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">View Pricing</a>
      </div>
    </div>
  </div>
</BaseLayout>
