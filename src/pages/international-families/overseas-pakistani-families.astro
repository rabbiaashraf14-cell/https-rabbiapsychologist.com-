---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'International Families', href: '/international-families' },
  { name: 'Overseas Pakistani Families', href: '/international-families/overseas-pakistani-families' }
];
---

<BaseLayout title="Support for Overseas Pakistani Families | Rabbia Psychologist" description="Culturally attuned parent guidance and child development support for the Pakistani diaspora worldwide.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="mt-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Support for Overseas Pakistani Families</h1>
      <p class="text-xl text-gray-700">Culturally attuned parent guidance for the Pakistani diaspora.</p>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700">
      <h2 class="text-2xl font-bold text-brand-navy">Culturally Relevant Support</h2>
      <p>Navigating a child's developmental, behavioral, or learning differences in a foreign country can be isolating. We provide parent guidance that understands both Western clinical models and Pakistani cultural contexts, family dynamics, and expectations.</p>

      <ul>
        <li><strong>Language:</strong> Consultations are available in English and Urdu.</li>
        <li><strong>Stigma & Family Dynamics:</strong> Guidance on how to talk to extended family members about a child's diagnosis (like Autism or ADHD).</li>
        <li><strong>System Navigation:</strong> Helping you bridge the cultural gap when advocating for your child in your host country's school system.</li>
      </ul>

      <h2 class="text-2xl font-bold text-brand-navy">Service Boundaries</h2>
      <p>Our online services are strictly parent consultation and psychoeducation. We do not provide cross-border medical diagnosis. You must utilize local professionals for formal diagnosis and emergency care.</p>

      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Book a Consultation</h3>
        <p class="mb-4">Standard international pricing applies (billed in USD/AUD).</p>
        <a href="/pricing" class="inline-block bg-brand-navy text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">View Pricing & Book</a>
      </div>
    </div>
  </div>
</BaseLayout>
