---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found - 404" description="Page not found on Rabbia Psychologist — NeuroCare Child Development Services." noindex={true}>
  <div class="min-h-[70vh] flex items-center justify-center bg-brand-cream px-4">
    <div class="text-center max-w-lg">
      <div class="text-brand-sky font-bold text-6xl mb-4">404</div>
      <h1 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Page Not Found</h1>
      <p class="text-gray-600 mb-8">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable. If you are looking for support, please use the links below.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/" class="px-6 py-3 bg-brand-navy text-white rounded font-bold hover:bg-blue-900 transition-colors">
          Return Home
        </a>
        <a href="/start-here" class="px-6 py-3 bg-white text-brand-navy border border-gray-300 rounded font-bold hover:bg-gray-50 transition-colors">
          Start Here
        </a>
        <a href="/parent-support" class="px-6 py-3 bg-white text-brand-navy border border-gray-300 rounded font-bold hover:bg-gray-50 transition-colors">
          Parent Support
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
