---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'School & IEP Consultation', href: '/school-iep-consultation' }
];
---

<Layout title="School & IEP Consultation">
  <SEO
    title="School Collaboration & IEP Consultation for Parents"
    description="Expert guidance for developing effective Individualized Education Programs (IEPs) and advocating for school accommodations."
  />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">School & IEP Consultation</h1>
      <p class="text-xl text-brand-trust font-medium mb-2">From IEP confusion to a clear support plan.</p>
      <p class="text-xl text-gray-700 mb-12 border-l-4 border-brand-sky pl-4">
        Understand the meeting, prepare the right questions, and turn school concerns into practical next steps for your child.
      </p>
      <div class="prose prose-lg text-gray-700 max-w-none">
        <p>Navigating the school system and advocating for accommodations can be overwhelming. We provide consultation to parents and educators to translate clinical profiles into practical, effective classroom strategies.</p>
        <div class="bg-gray-50 p-6 rounded-xl my-8 border border-gray-200">
          <h3 class="text-xl font-bold text-brand-navy mb-4">How We Can Help:</h3>
          <ul class="list-disc pl-6 space-y-2">
            <li><strong>IEP Review:</strong> Analyzing current goals and accommodations to ensure they are measurable, appropriate, and effective.</li>
            <li><strong>Teacher Collaboration:</strong> Providing psychoeducation to educators regarding a child's specific diagnosis (e.g., how ADHD presents in the classroom).</li>
            <li><strong>Behavior Support Alignment:</strong> Ensuring that strategies used at home are consistent with those used at school.</li>
            <li><strong>Accommodation Recommendations:</strong> Suggesting specific, realistic environmental and instructional modifications.</li>
          </ul>
        </div>
      </div>
    </div>
    <BookingCTA />
  </div>
  <StickyMobileBookingCTA />
</Layout>
