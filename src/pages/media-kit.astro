---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = "Media Kit | Rabbia Psychologist — NeuroCare Child Development Services";
const description = "Access Rabbia Psychologist — NeuroCare Child Development Services media information, brand summary, clinical director profile, approved descriptions, and contact details for press and collaboration inquiries.";
---
<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-4xl font-bold text-brand-navy mb-8">Media Kit</h1>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">1. About Rabbia Psychologist — NeuroCare Child Development Services</h2>
        <p class="text-gray-700">Rabbia Psychologist — NeuroCare Child Development Services provides parent guidance, developmental consultation support, school guidance, and multidisciplinary child development pathways for families in Pakistan and abroad.</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">2. Clinical Director Profile</h2>
        <p class="text-gray-700">Led by Rabbia Ashraf, Clinical Psychologist licensed in Pakistan.</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">3. Approved Bio</h2>
        <p class="text-gray-700">Rabbia Ashraf is a Clinical Psychologist licensed in Pakistan and Clinical Director of Rabbia Psychologist — NeuroCare Child Development Services. Her work focuses on child development, parent guidance, ASD and ADHD support, school consultation, behaviour planning, and helping families understand developmental and psychological concerns through practical, evidence-informed guidance.</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">4. Areas of Focus</h2>
        <ul class="list-disc pl-5 text-gray-700">
          <li>Parent Guidance</li>
          <li>ASD and ADHD Support</li>
          <li>School Consultation</li>
          <li>Behaviour Planning</li>
          <li>Developmental Concerns</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">5. Approved Quotes</h2>
        <blockquote class="border-l-4 border-brand-trust pl-4 italic text-gray-700 my-4">
          “Families often need clarity before they need complexity. Rabbia Psychologist — NeuroCare Child Development Services was created to help parents understand what their child may need, which professional pathway may fit, and how to move from confusion to a practical support plan.”
        </blockquote>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">6. Brand Assets</h2>
        <p class="text-gray-700"><a href="/brand-assets" class="text-blue-600 underline hover:text-blue-800">View and download brand assets</a></p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">7. Press Release</h2>
        <p class="text-gray-700"><a href="/press/neuronest-child-development-centre-launch" class="text-blue-600 underline hover:text-blue-800">Rabbia Psychologist — NeuroCare Child Development Services Launch Press Release</a></p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">8. Contact / Collaboration Inquiry</h2>
        <p class="text-gray-700">Please direct media inquiries to: [Contact Placeholder]</p>
      </section>
    </div>
  </div>
</BaseLayout>
