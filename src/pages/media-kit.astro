---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = "Media Kit | Rabbia Psychologist Child Development Services";
const description = "Access Rabbia Psychologist Child Development Services media information, brand summary, clinical psychologist profile, approved descriptions, and contact details for press and collaboration inquiries.";
---
<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-4xl font-bold text-brand-navy mb-8">Media Kit</h1>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">1. Brand Description</h2>
        <p class="text-gray-700">Rabbia Psychologist Child Development Services provides parent guidance and child development support for families worldwide, focused on ADHD, autism, behaviour, emotional regulation, learning concerns, school support, report review, and practical developmental next steps.</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">2. Clinical Psychologist Profile & Bios</h2>
        <h3 class="font-bold mt-4 text-brand-navy">Approved Short Bio</h3>
        <p class="text-gray-700 mt-2">Led by Rabbia Ashraf, Clinical Psychologist | Child & Adolescent Development Support.</p>
        <h3 class="font-bold mt-4 text-brand-navy">Approved Long Bio</h3>
        <p class="text-gray-700 mt-2">Rabbia Ashraf is a Clinical Psychologist | Child & Adolescent Development Support and Clinical Psychologist of Rabbia Psychologist Child Development Services. Her work focuses on child development, parent guidance, ASD and ADHD support, school consultation, behaviour planning, and helping families understand developmental and psychological concerns through practical, evidence-informed guidance.</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">3. Areas of Expertise & Speaking Topics</h2>
        <ul class="list-disc pl-5 text-gray-700">
          <li>Child Development & Parenting Strategies</li>
          <li>ASD and ADHD Support at Home</li>
          <li>School Consultation and IEP Support</li>
          <li>Behaviour Planning & Emotional Regulation</li>
          <li>Understanding Psychological Reports</li>
          <li>Parent Burnout & Self-Care</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">4. Approved Quotes</h2>
        <blockquote class="border-l-4 border-brand-trust pl-4 italic text-gray-700 my-4">
          “Families often need clarity before they need complexity. Rabbia Psychologist Child Development Services was created to help parents understand what their child may need, which professional pathway may fit, and how to move from confusion to a practical support plan.”
        </blockquote>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">5. Service Boundary Note</h2>
        <p class="text-gray-700 text-sm p-4 bg-gray-50 border border-gray-200 rounded">
          The website provides educational information and parent-guidance support. It does not provide emergency care. International sessions do not replace local regulated medical, psychological, educational, legal, or crisis services. Formal diagnosis and regulated assessment services depend on location, scope, and legal requirements.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">6. Media Resources</h2>
        <ul class="list-disc pl-5 text-gray-700 space-y-2">
          <li><a href="/brand-assets" class="text-blue-600 underline hover:text-blue-800">Brand Assets & Logos</a></li>
          <li><a href="/press/rabbia-psychologist-child-development-services-launch" class="text-blue-600 underline hover:text-blue-800">Launch Press Release</a></li>
          <li><a href="/about" class="text-blue-600 underline hover:text-blue-800">About Page</a></li>
          <li><a href="/services" class="text-blue-600 underline hover:text-blue-800">Services Overview</a></li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">7. Contact / Collaboration Inquiry</h2>
        <p class="text-gray-700">Media inquiries and collaborations: please use the <a href="/contact" class="text-blue-600 underline hover:text-blue-800">website contact form</a> or email psychologistrabbia@gmail.com</p>
      </section>
    </div>
  </div>
</BaseLayout>
