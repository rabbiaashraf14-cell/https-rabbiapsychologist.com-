---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';

const breadcrumbs = [
  { name: 'Privacy for International Families', href: '/privacy-for-international-families' }
];
---
<Layout title="Privacy and Legal Notice for International Families">
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-4xl font-bold text-brand-navy mb-6">Privacy & Guidance Scope for International Families</h1>
    <div class="bg-blue-50 border border-blue-100 p-6 rounded-lg mb-8">
      <strong>Important Context:</strong> As an international multidisciplinary platform, we serve families across various jurisdictions. This page outlines how our services apply globally.
    </div>
    <div class="prose prose-lg text-gray-700">
      <h2 class="text-2xl font-bold text-brand-navy mt-8">Scope of Service</h2>
      <p>Our international support is strictly focused on <strong>parent education, developmental guidance, ASD/ADHD support planning, behavior strategy discussion, executive-function routines, and school communication preparation.</strong></p>

      <h2 class="text-2xl font-bold text-brand-navy mt-8">Regulatory Limitations</h2>
      <p>We do not provide "worldwide therapy" or "global diagnosis". Clinical therapy, formal medical diagnosis, comprehensive assessment, and regulated psychological services are provided <strong>only</strong> where legally and ethically permitted by the professional's credentials and the client's physical location.</p>

      <h2 class="text-2xl font-bold text-brand-navy mt-8">Data & Privacy Compliance</h2>
      <p>We prioritize your data security and advise against sending sensitive medical documentation or diagnostic reports via unencrypted channels, including our live chat interface.</p>
    </div>
  </div>
</Layout>
