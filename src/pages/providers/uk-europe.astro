---
import Layout from '../../layouts/Layout.astro';
import SEO from '../../components/SEO.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DisclaimerBanner from '../../components/DisclaimerBanner.astro';
import ProviderDirectory from '../../components/ProviderDirectory.astro';
import RegionFilterTabs from '../../components/RegionFilterTabs.astro';
import ServiceBoundaryBanner from '../../components/ServiceBoundaryBanner.astro';

const providers = [];
---

<Layout title="UK & Europe Providers | Rabbia Ashraf & Associates">
  <SEO
    title="Child Psychology Providers for UK & Europe Families"
    description="Find child development specialists, parent consultants, and behavioral support professionals serving families in the UK and Europe."
  />

  <DisclaimerBanner />
  <Header />

  <main class="py-8 md:py-12 bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Providers for UK & Europe Families</h1>
        <p class="text-gray-700 max-w-3xl">
          Browse professionals offering parent guidance and child development consultation for families located in the United Kingdom and Europe.
        </p>
      </div>

      <RegionFilterTabs activeRegion="uk-europe" />
      <ServiceBoundaryBanner region="UK & Europe" isInternational={true} />

      <ProviderDirectory providers={providers} />
    </div>
  </main>

  <Footer />
</Layout>
