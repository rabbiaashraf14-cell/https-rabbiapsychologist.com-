---
import Layout from '../../layouts/Layout.astro';
import SEO from '../../components/SEO.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DisclaimerBanner from '../../components/DisclaimerBanner.astro';
import ProviderDirectory from '../../components/ProviderDirectory.astro';
import RegionFilterTabs from '../../components/RegionFilterTabs.astro';
import ServiceBoundaryBanner from '../../components/ServiceBoundaryBanner.astro';

// In a real app, you would filter your provider database by region
const providers = [
  // Example provider list
];
---

<Layout title="Australia Providers | Rabbia Ashraf & Associates">
  <SEO
    title="Child Psychology Providers for Australia Families"
    description="Find child development specialists, parent consultants, and behavioral support professionals serving families in Australia."
  />


  <main class="py-8 md:py-12 bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Providers for Australia Families</h1>
        <p class="text-gray-700 max-w-3xl">
          Browse professionals offering parent guidance and child development consultation for families located in Australia.
        </p>
      </div>

      <RegionFilterTabs activeRegion="australia" />
      <ServiceBoundaryBanner region="Australia" isInternational={true} />

      <ProviderDirectory providers={providers} />
    </div>
  </main>

</Layout>
