---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import ProviderMatchingForm from '../components/ProviderMatchingForm.astro';
---

<Layout title="Provider Matching Request | NeuroNest Child Development Centre">
  <SEO
    title="Provider Matching Request | Find the Right Support"
    description="Submit a request to get informational suggestions on child development providers who may fit your family's needs."
  />


  <main class="py-12 md:py-20 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h1 class="text-3xl md:text-5xl font-bold text-brand-navy mb-6 text-center">Find the Right Support</h1>
      <p class="text-xl text-gray-700 mb-12 text-center">
        Tell us what you're looking for, and we'll suggest providers who may be a good fit for your child's needs, your budget, and your region.
      </p>

      <ProviderMatchingForm />
    </div>
  </main>

</Layout>
