---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RegionHero from '../components/RegionHero.astro';
import RegionSupportCard from '../components/RegionSupportCard.astro';
import InternationalDisclaimerBanner from '../components/InternationalDisclaimerBanner.astro';
import RegionFAQAccordion from '../components/RegionFAQAccordion.astro';
import BeforeYouBookChecklist from '../components/BeforeYouBookChecklist.astro';
import RegionPricingCards from '../components/RegionPricingCards.astro';
import ChooseProviderCTA from '../components/ChooseProviderCTA.astro';
import Schema from '../components/Schema.astro';

const faqs = [
  {
    question: "Can families anywhere in the world book a consultation?",
    answer: "Yes, our parent consultation and educational guidance services are available internationally. However, please note that this is not regulated therapy or diagnostic assessment unless specifically stated based on your location and the provider's credentials."
  },
  {
    question: "Is this service considered therapy?",
    answer: "For most international clients, our services are considered parent consultation, psychoeducation, and developmental guidance. We provide actionable strategies to support your child, but we do not provide clinical therapy or psychiatric treatment outside of licensed jurisdictions."
  },
  {
    question: "Can my child receive an online diagnosis?",
    answer: "No. Formal diagnosis (e.g., for Autism or ADHD) requires assessment by a qualified professional licensed in your local jurisdiction. We can provide educational guidance, support while you wait for an assessment, and help understanding reports."
  },
  {
    question: "How do I choose the right provider?",
    answer: "Review our provider profiles to find someone with expertise in your specific concerns (e.g., behavior, ASD, school support). Consider language preferences and whether they have experience with families in your region."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": typeof faqs !== 'undefined' ? faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  })) : []
};
---

<Layout title="International Parent Consultation | Child Development Support">
  <SEO
    title="International Parent Consultation | Child Development Support"
    description="Explore region-aware parent guidance for families in Pakistan, USA, Australia, UK/Europe, MENA/Gulf, and international school communities."
    schema={schema}
  />


  <RegionHero
    regionName="International Families"
    heroTitle="International Parent Guidance and Child Development Support"
    heroSubtitle="Learn from evidence-informed resources, compare available specialists, and choose support that fits your child, family, region, language, and goals."
  />

  <main class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">

      <InternationalDisclaimerBanner />

      <section class="my-16 grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold text-brand-navy mb-6">Who this is for</h2>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start">
              <svg class="h-5 w-5 text-brand-growth mr-3 mt-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Parents seeking strategies for behavior, ASD, or ADHD.
            </li>
            <li class="flex items-start">
              <svg class="h-5 w-5 text-brand-growth mr-3 mt-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Families on waitlists for local assessments.
            </li>
            <li class="flex items-start">
              <svg class="h-5 w-5 text-brand-growth mr-3 mt-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Expatriate families needing culturally sensitive support.
            </li>
            <li class="flex items-start">
              <svg class="h-5 w-5 text-brand-growth mr-3 mt-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Parents needing help preparing for school meetings.
            </li>
          </ul>
        </div>
        <div>
          <h2 class="text-3xl font-bold text-brand-navy mb-6">What international support does NOT replace</h2>
          <div class="bg-red-50 p-6 rounded-lg border border-red-100">
             <ul class="space-y-3 text-gray-800">
              <li class="flex items-start">
                <svg class="h-5 w-5 text-red-500 mr-3 mt-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                Local psychiatric care or medication management.
              </li>
              <li class="flex items-start">
                <svg class="h-5 w-5 text-red-500 mr-3 mt-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                Formal diagnosis of learning or developmental conditions.
              </li>
              <li class="flex items-start">
                <svg class="h-5 w-5 text-red-500 mr-3 mt-1 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                Crisis intervention for self-harm, severe regression, or abuse.
              </li>
            </ul>
            <p class="mt-4 text-sm font-medium">Please seek local emergency services or registered professionals for these needs.</p>
          </div>
        </div>
      </section>

      <section class="my-16">
        <h2 class="text-3xl font-bold text-brand-navy mb-8 text-center">Choose by Region</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <RegionSupportCard
            title="USA Families"
            description="Educational guidance, ASD/ADHD parent strategies, behavior support planning, and IEP preparation."
            href="/online-parent-consultation-usa"
            disclaimer="Educational consultation only. No diagnostic or HIPAA-compliant therapy services provided unless verified."
          />
          <RegionSupportCard
            title="Australia Families"
            description="Parent education, ASD/ADHD routines, school communication preparation, and developmental guidance."
            href="/online-parent-consultation-australia"
            disclaimer="Consultation only. Not a registered psychological service or NDIS provider."
          />
          <RegionSupportCard
            title="UK & Europe Families"
            description="Parent psychoeducation, executive-function routines, and school support preparation."
            href="/online-parent-consultation-uk-europe"
            disclaimer="Educational guidance adhering to strict data privacy standards. Not local regulated care."
          />
          <RegionSupportCard
            title="MENA & Gulf Families"
            description="Culturally sensitive parent guidance, behavior strategies, home routines, and school support."
            href="/online-parent-consultation-mena-gulf"
            disclaimer="Parent consultation services. Does not replace local medical diagnosis."
          />
          <RegionSupportCard
            title="Pakistan Families"
            description="Child psychology consultation, parent guidance, ASD/ADHD support, and local assessment pathways."
            href="/online-parent-consultation-pakistan"
            disclaimer="Includes local assessment options where providers are based and registered."
          />
          <RegionSupportCard
            title="International Schools"
            description="Support for parents, SENCOs, and teachers seeking guidance around classroom routines and referral planning."
            href="/international-schools"
            disclaimer="Consultative support for educational teams. Does not replace school psychologists."
          />
        </div>
      </section>

      <RegionPricingCards />

      <BeforeYouBookChecklist />

      <section class="my-16">
        <h2 class="text-3xl font-bold text-brand-navy mb-8 text-center">Frequently Asked Questions</h2>
        <RegionFAQAccordion faqs={faqs} />
      </section>

      <ChooseProviderCTA />

    </div>
  </main>

</Layout>
