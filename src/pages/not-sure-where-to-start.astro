---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import ProviderMatchingForm from '../components/ProviderMatchingForm.astro';
---

<Layout title="Not Sure Where to Start? | Rabbia Ashraf & Associates">
  <SEO
    title="Not Sure Where to Start? | Find Child Development Support"
    description="Get guidance on choosing the right online parent consultation or child development specialist for your family's needs."
  />


  <main class="py-12 md:py-20 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-5xl font-bold text-brand-navy mb-4">Not Sure Who to Choose?</h1>
        <p class="text-xl text-gray-700 max-w-2xl mx-auto">
          It can be overwhelming to find the right support. Here are a few ways to get started finding the right provider for your family.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
          <h2 class="text-2xl font-bold text-brand-navy mb-4">Option 1: Start with Rabbia</h2>
          <p class="text-gray-600 mb-6">Book an initial consultation with Rabbia Ashraf for general parent guidance and help navigating your child's needs.</p>
          <a href="/providers/rabbia-ashraf" class="text-brand-trust font-medium hover:underline">View Rabbia's Profile &rarr;</a>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
          <h2 class="text-2xl font-bold text-brand-navy mb-4">Option 2: Browse the Directory</h2>
          <p class="text-gray-600 mb-6">Explore our provider directory. You can filter by region, concern, budget, language, and service type.</p>
          <a href="/providers" class="text-brand-trust font-medium hover:underline">Browse Directory &rarr;</a>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="bg-brand-navy p-8 text-white text-center">
          <h2 class="text-2xl font-bold mb-2">Option 3: Use Provider Matching</h2>
          <p class="text-brand-sky">Tell us what you're looking for, and we'll suggest providers who may be a good fit.</p>
        </div>
        <div class="p-4">
          <ProviderMatchingForm />
        </div>
      </div>

      <div class="mt-12 text-center text-sm text-gray-500 max-w-3xl mx-auto">
        <p>
          This platform helps parents access education, parent guidance, consultation options, and provider information. Parents are responsible for choosing the provider they wish to book. Provider suggestions are informational and do not guarantee clinical suitability, diagnosis, treatment outcome, or provider availability.
        </p>
      </div>
    </div>
  </main>

</Layout>
