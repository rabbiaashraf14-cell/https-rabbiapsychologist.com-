---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
---

<Layout title="Join as a Provider | Rabbia Ashraf & Associates">
  <SEO
    title="Join the Provider Directory | Child Psychology Professionals"
    description="Information for child psychologists, educational consultants, and therapists interested in joining our global provider directory."
  />

  <DisclaimerBanner />
  <Header />

  <main class="py-12 md:py-20 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-brand-navy mb-6">Join Our Directory</h1>
      <p class="text-xl text-gray-700 mb-12">
        We are building a trusted network of child development professionals to support families worldwide.
      </p>

      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 md:p-12">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">Provider Onboarding is Currently Invite-Only</h2>
        <p class="text-gray-700 mb-6">
          We are currently in a closed beta phase for our provider directory, working with a select group of trusted professionals to refine the parent-choice platform.
        </p>
        <p class="text-gray-700 mb-8">
          If you are a licensed or registered professional specializing in Autism, ADHD, behavioral support, or parent coaching, you can join our waitlist.
        </p>

        <form class="max-w-md mx-auto space-y-4 text-left">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
            <input type="text" class="w-full border-gray-300 rounded-md shadow-sm p-2 border" disabled placeholder="Waitlist currently closed" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" class="w-full border-gray-300 rounded-md shadow-sm p-2 border" disabled placeholder="Waitlist currently closed" />
          </div>
          <button type="button" disabled class="w-full bg-gray-300 text-gray-500 font-bold py-2 px-4 rounded-md cursor-not-allowed">
            Join Waitlist
          </button>
        </form>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
