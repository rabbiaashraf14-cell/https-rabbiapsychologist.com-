        title={title}
        category="Autism & Communication"
        readTime="6 min"
        datePublished="Mar 15, 2024"
        dateModified="Mar 15, 2024"
        authorName="Rabbia Ashraf"
        imageSrc="/images/blog/speech-delay-autism-hero.jpg"
        imageAlt="Parent interacting with a toddler, observing communication styles and gestures"
      />

