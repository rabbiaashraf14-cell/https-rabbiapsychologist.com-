---
import BlogLayout from '../../layouts/BlogLayout.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'placeholder-post' } }
  ];
}
---
<BlogLayout title="Placeholder Post">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-brand-navy mb-6">Blog: {Astro.params.slug}</h1>
    <p>Placeholder content.</p>
  </div>
</BlogLayout>
