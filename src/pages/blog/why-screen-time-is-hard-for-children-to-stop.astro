const title = "Why Is It Hard for Children to Stop Screen Time? | Child Psychology Guide";
const description = "Many children struggle to stop screen time because screens activate reward pathways, emotional desire, and behaviour patterns. Learn why transitions are hard and how parents can respond consistently.";
const keywords = "screen time children, why children cannot stop screens, screen time tantrums, child psychology screen time, dopamine and screen time, parenting screen rules, behaviour planning, child psychologist";

const currentUrl = "/blog/why-screen-time-is-hard-for-children-to-stop";
const canonicalURL = `https://www.rabbiapsychologist.com${currentUrl}`;

const headings = [
  { text: "The Brain Likes Fast Rewards", slug: "fast-rewards", level: 2 },
  { text: "Screens Can Become a Coping Tool", slug: "coping-tool", level: 2 },
  { text: "The Power of Desire", slug: "power-of-desire", level: 2 },
  { text: "Why Tantrums May Get Worse Before They Improve", slug: "extinction-burst", level: 2 },
  { text: "Why Giving In Makes the Cycle Stronger", slug: "giving-in", level: 2 },
  { text: "How Parents Can Make Screen Transitions Easier", slug: "easier-transitions", level: 2 },
  { text: "Replace the Reward, Do Not Only Remove It", slug: "replace-reward", level: 2 },
  { text: "When to Seek Professional Help", slug: "professional-help", level: 2 }
];

