import Breadcrumbs from '../../components/global/Breadcrumbs.astro';
import ProgressBar from '../../components/blog/ProgressBar.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import CalloutBox from '../../components/blog/CalloutBox.astro';
import ArticleAuthor from '../../components/blog/ArticleAuthor.astro';
import ArticleHero from '../../components/blog/ArticleHero.astro';
import ArticleIntro from '../../components/blog/ArticleIntro.astro';
import QuickFacts from '../../components/blog/QuickFacts.astro';
import WhatYouWillLearn from '../../components/blog/WhatYouWillLearn.astro';
import ExpertTip from '../../components/blog/ExpertTip.astro';
import MythVsFact from '../../components/blog/MythVsFact.astro';
import WarningBox from '../../components/blog/WarningBox.astro';
import ActionChecklist from '../../components/blog/ActionChecklist.astro';
import KeyTakeaways from '../../components/blog/KeyTakeaways.astro';
import RelatedArticles from '../../components/blog/RelatedArticles.astro';
import BlogCTA from '../../components/blog/BlogCTA.astro';
import PrevNextNav from '../../components/blog/PrevNextNav.astro';
import FAQAccordion from '../../components/blog/FAQAccordion.astro';
import heroImage from '../../assets/blog/sensory-processing-difficulties.webp';

const title = "Sensory Processing Difficulties: When the World is Too Loud";
const description = "Understand sensory processing differences in children, the difference between sensory seeking and avoiding, and how to create a sensory-friendly home.";
const currentUrl = "/blog/sensory-processing-difficulties";
const canonicalURL = `https://www.rabbiapsychologist.com${currentUrl}`;

const keywords = ["sensory processing difficulties", "sensory overload children", "autism sensory issues", "sensory seeking vs avoiding", "child development sensory"];

const headings = [
  { text: "Introduction", slug: "introduction", level: 2 },
  { text: "What is Sensory Processing?", slug: "what-is-sensory-processing", level: 2 },
  { text: "Sensory Seeking vs. Sensory Avoiding", slug: "seeking-vs-avoiding", level: 2 },
  { text: "The Link with Autism and ADHD", slug: "autism-adhd-link", level: 2 },
  { text: "Practical Home Strategies", slug: "practical-home-strategies", level: 2 },
  { text: "When to Seek Professional Support", slug: "when-to-seek-support", level: 2 }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "image": "https://www.rabbiapsychologist.com/images/blog/sensory-processing-hero.jpg",
    "author": {
      "@type": "Person",
      "name": "Rabbia Ashraf",
      "jobTitle": "Clinical Psychologist",
      "url": "https://www.rabbiapsychologist.com/about"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Rabbia Psychologist Child Development Services",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.rabbiapsychologist.com/favicon.png"
      }
    },
    "datePublished": "2024-04-05T08:00:00+00:00",
    "dateModified": "2024-04-05T08:00:00+00:00",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalURL
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.rabbiapsychologist.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.rabbiapsychologist.com/blog" },
      { "@type": "ListItem", "position": 3, "name": "Sensory Processing Difficulties", "item": canonicalURL }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Why does my child cover their ears for normal sounds?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For a child with sensory processing differences, a vacuum cleaner or a hand dryer doesn't just sound 'loud'—it can sound physically painful. Their brain does not filter out background noise the way a neurotypical brain does."
        }
      },
      {
        "@type": "Question",
        "name": "Is being a 'picky eater' always a sensory issue?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Often, yes. Many children restrict their diet not because of the taste, but because of the texture. For example, a blueberry is unpredictable (some are mushy, some are tart), whereas a cracker is the exact same texture every time."
        }
      },
      {
        "@type": "Question",
        "name": "Can sensory overload cause meltdowns?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. When a child takes in more sensory information than their nervous system can process, their brain triggers a 'fight or flight' response, resulting in a meltdown."
        }
      }
    ]
  }
];
---

<Layout title={`${title} | Rabbia Psychologist`} description={description}>
  <SEO
    title={title}
    description={description}
    keywords={keywords}
    schema={schema}
    canonical={canonicalURL}
    ogTitle={title}
    ogDescription={description}
    ogImage="/images/blog/sensory-processing-hero.jpg"
    type="article"
  />

  <ProgressBar />

  <article class="bg-[#FAF8F3] min-h-screen pb-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="max-w-4xl mx-auto pt-6 mb-4">
        <Breadcrumbs paths={[
          { name: 'Resources', href: '/resources' },
          { name: 'Blog', href: '/blog' },
          { name: 'Sensory Processing', href: currentUrl }
        ]} />
      </div>

      <ArticleHero
        title={title}
        category="Autism & Sensory Support"
        readTime="6 min"
        datePublished="Apr 5, 2024"
        dateModified="Apr 5, 2024"
        authorName="Rabbia Ashraf"
        imageSrc={heroImage}
        imageAlt="Child wearing noise-canceling headphones to manage sensory input in a busy environment"
      />

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start relative mt-12">

        {/* Main Content Area */}
        <div class="lg:col-span-8 prose prose-lg md:prose-xl max-w-[820px] mx-auto text-gray-800 prose-headings:text-brand-navy prose-headings:font-bold prose-a:text-brand-trust hover:prose-a:text-blue-700 prose-p:leading-relaxed prose-p:mb-6">

          <ArticleIntro>
            Imagine walking into a room where the lights are blindingly bright, the radio is playing three different stations at maximum volume, and your sweater feels made of sandpaper.
            For a child with sensory processing difficulties, this is not imagination—it is their daily reality.
          </ArticleIntro>

          <QuickFacts
            time="6 min"
            age="Toddler to Teen"
          />

          <WhatYouWillLearn
            items={[
              "How the brain processes sensory information",
              "The difference between sensory avoiding and sensory seeking",
              "Why sensory differences are so common in autism and ADHD",
              "How sensory overload leads to meltdowns",
              "Practical ways to create a sensory-friendly home"
            ]}
          />

          <h2 id="what-is-sensory-processing">What is Sensory Processing?</h2>
          <p>Sensory processing is how our brain takes in information from our senses, organizes it, and responds to it. While we usually think of the five main senses (sight, sound, smell, taste, touch), occupational therapists also look at two critical hidden senses:</p>
          <ul>
            <li><strong>Proprioception:</strong> Body awareness. Knowing where your body is in space without looking.</li>
            <li><strong>Vestibular:</strong> Balance and movement. The sense of motion and gravity.</li>
          </ul>
          <p>When a child's brain struggles to filter or organize this information, they experience a "traffic jam" of sensory input.</p>

          <h2 id="seeking-vs-avoiding">Sensory Seeking vs. Sensory Avoiding</h2>
          <p>Sensory difficulties usually present in one of two ways, and many children show a mix of both.</p>

          <h3>The Sensory Avoider (Over-Responsive)</h3>
          <p>This child's nervous system feels sensory input too intensely. A light touch feels like a hit. A normal classroom feels like a rock concert.</p>
          <ul>
            <li>Covers ears for everyday noises (blenders, hand dryers).</li>
            <li>Refuses to wear certain clothes, hates tags, or only wears soft pants.</li>
            <li>Avoids messy play, getting their hands dirty, or certain food textures.</li>
          </ul>

          <h3>The Sensory Seeker (Under-Responsive)</h3>
          <p>This child's nervous system does not register sensory input easily. They need <em>more</em> input just to feel normal and regulated.</p>
          <ul>
            <li>Constantly jumping, crashing into couches, or spinning.</li>
            <li>Chewing on shirt collars, pencils, or toys.</li>
            <li>Playing very roughly, not realizing their own strength.</li>
          </ul>

          <MythVsFact
            myth="They just need to get used to the noise; they are being dramatic."
            fact="You cannot 'discipline' a sensory difference away. Forcing a sensory avoider into a loud, overwhelming environment will only trigger a 'fight or flight' meltdown."
          />

          <h2 id="autism-adhd-link">The Link with Autism and ADHD</h2>
          <p>While any child can have sensory processing difficulties, they are extremely common in neurodivergent children.</p>
          <p>In autism, sensory differences are actually part of the core diagnostic criteria. Autistic children may find certain sensory inputs painful, while using repetitive movements (like hand-flapping) to actively regulate their nervous system.</p>
          <p>In ADHD, children are often sensory seekers, moving their bodies constantly to generate the stimulation their brain craves to focus.</p>

          <h2 id="practical-home-strategies">Practical Home Strategies</h2>
          <p>The goal is to create a "sensory diet"—a plan that provides the right sensory input to keep the child regulated throughout the day.</p>

          <ActionChecklist
            items={[
              "For Avoiders: Provide noise-canceling headphones for loud environments. Remove tags from clothing and buy seamless socks.",
              "For Seekers: Build 'heavy work' into the routine. Have them push a laundry basket, carry groceries, or jump on a safe mini-trampoline.",
              "For Oral Seekers: Provide safe, dedicated chew-jewelry rather than constantly telling them to 'stop chewing your shirt.'",
              "Create a safe retreat: Have a dim, quiet 'calm corner' (like a pop-up tent) where they can retreat when overwhelmed."
            ]}
          />

          <h2 id="when-to-seek-support">When to Seek Professional Support</h2>
          <p>If sensory differences are severely restricting a child's diet, preventing them from attending school, or causing daily, explosive meltdowns, it is time to seek support.</p>
          <p>A developmental assessment and parent consultation can help you design a home and school environment that respects their sensory needs, often in collaboration with an Occupational Therapist.</p>

          <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 mt-8 mb-8 text-sm text-gray-600">
            <p class="m-0"><strong>Disclaimer:</strong> This article is for educational guidance only and does not replace a professional developmental, psychological, or medical assessment. If you are concerned about your child’s development, behaviour, attention, learning, or communication, it is helpful to consult a qualified professional.</p>
          </div>

          <KeyTakeaways
            items={[
              "Sensory processing differences cause a 'traffic jam' in the nervous system.",
              "Sensory avoiders find everyday input painful or overwhelming.",
              "Sensory seekers need intense movement or pressure to feel regulated.",
              "Sensory overload is a leading cause of involuntary meltdowns.",
              "Accommodate, don't force. Use tools like headphones and safe chewables."
            ]}
          />

            datePublished="April 5, 2024"
            dateModified="April 5, 2024"
            readTime="6 min"
          />

          <FAQAccordion faqs={[
            {
              question: "Why does my child cover their ears for normal sounds?",
              answer: "For a child with sensory processing differences, a vacuum cleaner or a hand dryer doesn't just sound 'loud'—it can sound physically painful. Their brain does not filter out background noise the way a neurotypical brain does."
            },
            {
              question: "Is being a 'picky eater' always a sensory issue?",
              answer: "Often, yes. Many children restrict their diet not because of the taste, but because of the texture. For example, a blueberry is unpredictable (some are mushy, some are tart), whereas a cracker is the exact same texture every time."
            },
            {
              question: "Can sensory overload cause meltdowns?",
              answer: "Absolutely. When a child takes in more sensory information than their nervous system can process, their brain triggers a 'fight or flight' response, resulting in a meltdown."
            }
          ]} />

          <PrevNextNav
            prev={{ title: "School Refusal and Anxiety", href: "/blog/school-refusal-and-school-anxiety" }}
            next={{ title: "How to Prepare for a Child Assessment", href: "/blog/how-to-prepare-for-child-assessment" }}
          />

        <ArticleAuthor
          author="Rabbia Ashraf"
          title="Clinical Psychologist | Child & Adolescent Development Support"
          bio="Rabbia supports families with ADHD, autism, behaviour concerns, emotional regulation, learning difficulties, school support, parent counseling, and psychological report review."
        />

          <BlogCTA />

          <RelatedArticles currentUrl={currentUrl} />
        </div>

        {/* Sidebar / Table of Contents */}
        <div class="lg:col-span-4 order-first lg:order-last">
          <TableOfContents headings={headings} />
        </div>

      </div>
    </div>
  </article>
</Layout>
