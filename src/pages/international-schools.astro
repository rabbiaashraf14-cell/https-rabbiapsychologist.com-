---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RegionHero from '../components/RegionHero.astro';
import InternationalDisclaimerBanner from '../components/InternationalDisclaimerBanner.astro';
import RegionFAQAccordion from '../components/RegionFAQAccordion.astro';
import ChooseProviderCTA from '../components/ChooseProviderCTA.astro';
import Schema from '../components/Schema.astro';

const faqs = [
  { question: "Can the platform work with schools?", answer: "Yes, we collaborate with international schools and local schools to support neurodivergent students." },
  { question: "Can providers attend school meetings?", answer: "Providers can attend IEP or support meetings virtually to act as an educational advocate and provide input on behavior support plans." },
  { question: "Is this an IEP service?", answer: "We provide consultation to help parents and teachers develop effective IEPs, but we do not enforce legal mandates." },
  { question: "Can you create behavior support templates?", answer: "Yes, we provide structured templates for behavior tracking and intervention." },
  { question: "Can teachers fill observation forms?", answer: "Yes, we encourage teachers to use our observation forms to gather data before consultation." },
  { question: "Can this replace school psychologist services?", answer: "No, this is a consultative service and does not replace formal assessments or therapy provided by a school psychologist." },
  { question: "What documents should parents prepare?", answer: "Recent school reports, IEPs, and any previous psychological assessments (for context only)." }
];
---
<Layout title="School Consultation | Rabbia Ashraf">
  <SEO
    title="School Consultation for International Schools and Families"
    description="Support for parents, SENCOs, and international school communities seeking guidance around ASD, ADHD, behavior, and classroom routines."
    canonicalUrl="https://rabbiaashraf.com/international-schools"
    ogTitle="School Consultation for International Schools and Families"
  />

  <Schema
    type="FAQPage"
    data={{
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    }}
  />


  <RegionHero
    regionName="International Schools"
    heroTitle="School Consultation for International Schools and Families"
    heroSubtitle="From IEP confusion to a clear support plan. Understand the meeting, prepare the right questions, and turn school concerns into practical next steps for your child."
  />

  <main class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">

      <InternationalDisclaimerBanner text="School consultation is an educational and advisory service designed to support parents and educational teams. It does not replace the formal role of a registered school psychologist, nor does it provide legal IEP advocacy or formal diagnosis." />

      <section class="my-12">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Who this is for</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Parents needing support translating clinical recommendations into practical classroom accommodations.</li>
          <li>International school teachers and SENCOs seeking behavioral strategies for neurodivergent students.</li>
          <li>Families moving between countries who need help establishing continuity of support.</li>
        </ul>
      </section>

      <div class="grid md:grid-cols-2 gap-8 my-12">
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
          <h2 class="text-xl font-bold text-brand-navy mb-4">Parent-School Communication</h2>
          <p class="text-gray-700">We help parents formulate clear, concise requests and prepare for meetings with school staff to ensure collaborative support for the child.</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
          <h2 class="text-xl font-bold text-brand-navy mb-4">Behavior Support Planning</h2>
          <p class="text-gray-700">Developing actionable strategies to manage classroom meltdowns, school refusal, and peer interactions.</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
          <h2 class="text-xl font-bold text-brand-navy mb-4">Home-School Progress Tracking</h2>
          <p class="text-gray-700">Establishing systems and logs to ensure consistent communication and tracking of behavioral goals between home and school.</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
          <h2 class="text-xl font-bold text-brand-navy mb-4">IEP/Learning-Plan Preparation</h2>
          <p class="text-gray-700">Reviewing reports to help parents suggest appropriate accommodations for executive functioning, sensory needs, and learning differences.</p>
        </div>
      </div>

      <section class="my-12 bg-brand-lavender bg-opacity-20 p-8 rounded-xl border border-brand-lavender">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">Teacher Observation Forms</h2>
        <p class="text-gray-700 mb-6">We provide structured observation forms that teachers can complete to help us understand the child's triggers and strengths in the classroom environment.</p>
        <a href="/resource-vault" class="inline-block bg-brand-trust text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700 transition-colors">
          Access Forms in Resource Vault
        </a>
      </section>

      <section class="my-12">
        <h2 class="text-2xl font-bold text-brand-navy mb-6 text-center">Consultation Options & Pricing</h2>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 text-center max-w-2xl mx-auto">
          <h3 class="text-xl font-semibold mb-2">School/Clinic Training & Consultation</h3>
          <p class="text-gray-600 mb-4">Virtual attendance at school meetings or collaborative strategy sessions with teachers.</p>
          <div class="text-3xl font-bold text-brand-trust mb-6">From USD 75 <span class="text-sm text-gray-500 font-normal">/ session</span></div>
          <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" target="_blank" rel="noopener noreferrer" class="bg-brand-navy text-white px-8 py-3 rounded-lg font-medium hover:bg-blue-800 transition-colors inline-block">
            Book School Consultation
          </a>
        </div>
      </section>

      <section class="my-16">
        <h2 class="text-3xl font-bold text-brand-navy mb-8 text-center">School FAQs</h2>
        <RegionFAQAccordion faqs={faqs} />
      </section>

      <ChooseProviderCTA />

    </div>
  </main>

</Layout>
