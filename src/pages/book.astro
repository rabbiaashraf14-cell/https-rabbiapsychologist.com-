---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';
import { promotion } from '../config/promotion';
import { isPromotionActive } from '../utils/pricing';

const breadcrumbs = [
  { name: 'Book', href: '/book' }
];
---

<Layout title="Book a Consultation">
  <SEO
    title="Book a Consultation | Child Psychology & Parent Support"
    description="Schedule your online parent consultation, autism support session, or ADHD coaching. Global availability."
  />

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="max-w-4xl mx-auto mt-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Book a Consultation</h1>
      <p class="text-xl text-gray-700 mb-12">
        Take the first step towards clarity and a customized support plan for your child.
      </p>

      <!-- How to book and pay section -->
      <div class="bg-brand-cream border border-brand-gold/30 rounded-2xl p-8 mb-12 text-left">
        <h2 class="text-2xl font-bold text-brand-navy mb-6 text-center">How to book and pay</h2>
        <div class="space-y-6 max-w-2xl mx-auto">
          <div class="flex items-start">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-navy text-white flex items-center justify-center font-bold mr-4 mt-1">1</div>
            <div>
              <h3 class="font-bold text-lg text-brand-navy">Choose the consultation type</h3>
              <p class="text-gray-700">Select the service that best fits your needs (e.g., Parent Guidance, ADHD Support, Report Review).</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-navy text-white flex items-center justify-center font-bold mr-4 mt-1">2</div>
            <div>
              <h3 class="font-bold text-lg text-brand-navy">Book or request a slot</h3>
              <p class="text-gray-700">Use our calendar link to find a time that works for you in your local time zone.</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-navy text-white flex items-center justify-center font-bold mr-4 mt-1">3</div>
            <div>
              <h3 class="font-bold text-lg text-brand-navy">Share your child's concern</h3>
              <p class="text-gray-700">Briefly provide details such as your child's age, main concern, and any previous reports to help us prepare.</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-navy text-white flex items-center justify-center font-bold mr-4 mt-1">4</div>
            <div>
              <h3 class="font-bold text-lg text-brand-navy">Receive payment instructions</h3>
              <p class="text-gray-700">Payment details are shared at the time of booking once your slot is confirmed.</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-navy text-white flex items-center justify-center font-bold mr-4 mt-1">5</div>
            <div>
              <h3 class="font-bold text-lg text-brand-navy">Attend the session</h3>
              <p class="text-gray-700">Join the secure online link (or attend locally if appropriate) to begin planning your next steps.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white p-8 md:p-12 rounded-2xl shadow-sm border border-brand-sky mb-16">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">Schedule via Google Calendar</h2>
        <p class="text-gray-600 mb-8">Choose a time that works best for you. All times will automatically be displayed in your local time zone.</p>

        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 mb-8 text-left text-sm max-w-xl mx-auto">
          <p class="font-bold text-brand-navy mb-2">When booking, please be ready to provide:</p>
          <ul class="list-disc pl-5 text-gray-700 space-y-1">
            <li>Parent name</li>
            <li>Child age</li>
            <li>Country/city</li>
            <li>Main concern</li>
            <li>School/class (optional)</li>
            <li>Previous diagnosis/report if any (optional)</li>
            <li>Preferred service</li>
            <li>Preferred consultation mode</li>
            <li>Brief message</li>
          </ul>
        </div>

        <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" target="_blank" rel="noopener noreferrer" class="inline-block bg-brand-navy text-white px-10 py-4 rounded-full font-bold text-lg hover:bg-blue-900 transition-colors shadow-md hover:shadow-lg track-booking-btn">
          {isPromotionActive() ? 'Claim July Discount' : 'Open Booking Calendar'}
        </a>
      </div>

      {isPromotionActive() && (
        <div class="bg-brand-cream border-2 border-brand-navy rounded-2xl p-8 mb-16 shadow-md text-left max-w-xl mx-auto" id="checkout-pricing-summary">
          <h2 class="text-2xl font-bold text-brand-navy mb-4 text-center">🎉 July Promotion Applied</h2>
          <p class="text-gray-700 mb-6 text-center">Your 35% discount will be applied to your final invoice.</p>

          <div class="space-y-3">
            <div class="flex justify-between items-center text-gray-500">
              <span>Original Price (e.g., Parent Support)</span>
              <span class="line-through">USD 85.00</span>
            </div>
            <div class="flex justify-between items-center text-brand-gold font-bold">
              <span>Discount ({promotion.discount}%)</span>
              <span>- USD 29.75</span>
            </div>
            <div class="border-t border-gray-200 pt-3 flex justify-between items-center font-bold text-xl text-brand-navy">
              <span>Today's Price</span>
              <span>USD 55.25</span>
            </div>
            <div class="flex justify-between items-center text-sm font-bold text-green-600 mt-2">
              <span>You Saved</span>
              <span>USD 29.75</span>
            </div>
          </div>
          <p class="text-xs text-gray-500 mt-6 text-center italic">* Discount automatically applied to all consultation types during July.</p>
        </div>
      )}

      <div id="before-you-book" class="text-left bg-gray-50 p-8 rounded-xl border border-gray-200">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Before You Book</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-lg font-bold text-brand-navy mb-2">What to expect in the initial session</h3>
            <p class="text-gray-700">The first session is typically for parents only. We will discuss your primary concerns, your child's developmental history, and establish clear goals for our work together. You'll leave with immediate, practical strategies to begin implementing.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-brand-navy mb-2">International Consultation Note</h3>
            <p class="text-gray-700">Please note that consultations are provided as educational, parent-guidance, and support-planning services. Clinical therapy, diagnosis, and regulated psychological services are provided only where legally and ethically permitted. <a href="/terms-and-disclaimer" class="text-brand-navy underline hover:text-blue-700">Read full disclaimer</a>.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-brand-navy mb-2">Rescheduling & Cancellation</h3>
            <p class="text-gray-700">We request at least 24 hours notice for cancellations or rescheduling to allow us to offer the time slot to another family.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <StickyMobileBookingCTA />
</Layout>
