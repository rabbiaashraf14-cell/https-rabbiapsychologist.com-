---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Book', href: '/book' }
];
---

<Layout title="Book a Consultation">
  <SEO
    title="Book a Consultation | Child Psychology & Parent Support"
    description="Schedule your online parent consultation, autism support session, or ADHD coaching. Global availability."
  />


  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="max-w-4xl mx-auto mt-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Book a Consultation</h1>
      <p class="text-xl text-gray-700 mb-12">
        Take the first step towards clarity and a customized support plan for your child.
      </p>

      <div class="bg-white p-8 md:p-12 rounded-2xl shadow-sm border border-brand-sky mb-16">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">Schedule via Google Calendar</h2>
        <p class="text-gray-600 mb-8">Choose a time that works best for you. All times will automatically be displayed in your local time zone.</p>
        <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" target="_blank" rel="noopener noreferrer" class="inline-block bg-brand-navy text-white px-10 py-4 rounded-full font-bold text-lg hover:bg-blue-900 transition-colors shadow-md hover:shadow-lg">
          Open Booking Calendar
        </a>
      </div>

      <div id="before-you-book" class="text-left bg-gray-50 p-8 rounded-xl border border-gray-200">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Before You Book</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-lg font-bold text-brand-navy mb-2">What to expect in the initial session</h3>
            <p class="text-gray-700">The first session is typically for parents only. We will discuss your primary concerns, your child's developmental history, and establish clear goals for our work together. You'll leave with immediate, practical strategies to begin implementing.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-brand-navy mb-2">International Consultation Note</h3>
            <p class="text-gray-700">Please note that international consultations are provided as educational, parent-guidance, and support-planning services. Clinical therapy, diagnosis, and regulated psychological services are provided only where legally and ethically permitted. <a href="/terms-and-disclaimer" class="text-brand-navy underline hover:text-blue-700">Read full disclaimer</a>.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-brand-navy mb-2">Rescheduling & Cancellation</h3>
            <p class="text-gray-700">We request at least 24 hours notice for cancellations or rescheduling to allow us to offer the time slot to another family.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <StickyMobileBookingCTA />
</Layout>
