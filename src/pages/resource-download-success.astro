---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SuccessMessage from '../components/ui/SuccessMessage.astro';
---

<Layout title="Resource Downloaded">
  <div class="min-h-[70vh] flex items-center justify-center bg-brand-cream px-4">
    <SuccessMessage
      title="Download Preparing"
      message="Your requested resource is ready."
      nextSteps={[
        "If the download doesn't start automatically, check your email.",
        "Explore more articles and guides in the Resource Vault."
      ]}
    />
  </div>
</Layout>
