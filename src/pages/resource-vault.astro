---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Resources', href: '/resources' },
  { name: 'Resource Vault', href: '/resource-vault' }
];
---

<Layout title="Resource Vault">
  <SEO
    title="Digital Products & Resource Vault for Parents"
    description="Premium digital workbooks, planners, and behavior logs for parents managing ASD and ADHD."
  />
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Resource Vault</h1>
      <p class="text-xl text-gray-700 mb-12">
        Comprehensive digital tools designed to help you implement clinical strategies at home.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="worksheets">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 flex flex-col h-full">
          <div class="flex-grow">
            <div class="flex justify-between items-start mb-2">
              <div class="text-sm font-bold text-purple-600 uppercase">Workbook</div>
              <img src="/brand/logo-stacked.svg" alt="" class="h-8 w-auto opacity-50 grayscale" aria-hidden="true" />
            </div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">ADHD Executive Function Workbook</h3>
            <p class="text-gray-600 mb-4">Practical exercises for developing routines and improving working memory.</p>
          </div>
          <button class="bg-brand-navy text-white px-4 py-2 rounded font-medium hover:bg-blue-900 w-full mt-auto">Coming Soon</button>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 flex flex-col h-full" id="guides">
          <div class="flex-grow">
            <div class="flex justify-between items-start mb-2">
              <div class="text-sm font-bold text-purple-600 uppercase">Toolkit</div>
              <img src="/brand/logo-stacked.svg" alt="" class="h-8 w-auto opacity-50 grayscale" aria-hidden="true" />
            </div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">Functional Behavior Analysis Log</h3>
            <p class="text-gray-600 mb-4">Templates for tracking ABCs (Antecedent, Behavior, Consequence) to understand patterns.</p>
          </div>
          <button class="bg-brand-navy text-white px-4 py-2 rounded font-medium hover:bg-blue-900 w-full mt-auto">Coming Soon</button>
        </div>
      </div>
    </div>
  </div>
  <Footer />
  <StickyMobileBookingCTA />
</Layout>
