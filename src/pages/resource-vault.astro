---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Resources', href: '/resources' },
  { name: 'Resource Vault', href: '/resource-vault' }
];
---

<Layout title="Resource Vault">
  <SEO
    title="Digital Products & Resource Vault for Parents"
    description="Premium digital workbooks, planners, and behavior logs for parents managing ASD and ADHD."
  />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Resource Vault</h1>
      <p class="text-xl text-gray-700 mb-12">
        Comprehensive digital tools designed to help you implement parent support strategies, routines, and guidance at home.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="worksheets">
        {[
          { type: 'Worksheet', title: 'ADHD Executive Function Workbook', desc: 'Practical exercises for developing routines and improving working memory.' },
          { type: 'Toolkit', title: 'Functional Behavior Analysis Log', desc: 'Templates for tracking ABCs (Antecedent, Behavior, Consequence) to understand patterns.' },
          { type: 'Mini Course', title: 'School Meeting Prep Course', desc: 'A short guide to preparing for IEPs and parent-teacher meetings.' },
          { type: 'Template', title: 'Home Program Template', desc: 'Structure your child’s after-school routine effectively.' },
          { type: 'Checklist', title: 'Developmental Milestones Tracker', desc: 'Keep track of your child’s progress week over week.' },
          { type: 'Guide', title: 'Report Review Translation Guide', desc: 'Helpful tips for decoding common terms found in educational and psychological reports.' }
        ].map(item => (
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 flex flex-col h-full">
            <div class="flex-grow">
              <div class="flex justify-between items-start mb-2">
                <div class="text-sm font-bold text-purple-600 uppercase">{item.type}</div>
                <img src="/brand/logo-stacked.svg" alt="" class="h-8 w-auto opacity-50 grayscale" aria-hidden="true" />
              </div>
              <h3 class="text-xl font-bold text-brand-navy mb-3">{item.title}</h3>
              <p class="text-gray-600 mb-4">{item.desc}</p>
            </div>
            <button class="bg-brand-navy text-white px-4 py-2 rounded font-medium hover:bg-blue-900 w-full mt-auto">Coming Soon</button>
          </div>
        ))}
      </div>
    </div>
  </div>
  <StickyMobileBookingCTA />
</Layout>
