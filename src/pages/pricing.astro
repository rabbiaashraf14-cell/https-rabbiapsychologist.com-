---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';
import { pricingNote, pricingServiceScope, pricing } from '../data/pricing';

const breadcrumbs = [
  { name: 'Pricing', href: '/pricing' }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "Pricing for Services and Resources",
  "description": "View pricing for parent guidance consultation, between-session programs, report review, school support, and digital child development resources."
};
---

<Layout title="Pricing | Rabbia Psychologist Child Development Services">
  <SEO
    title="Pricing | Rabbia Psychologist Child Development Services"
    description="View pricing for parent guidance, IEP and school support, report review, between-session support planning, structured parent programs, resources, workshops, and webinars."
    schema={schema}
  />


  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="max-w-4xl mx-auto mt-8 mb-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Pricing</h1>
      <p class="text-xl text-gray-700">
        Transparent, accessible pricing for global consultations and comprehensive support packages.
      </p>

      <div class="bg-blue-50 border border-blue-100 rounded-lg p-6 mt-8 text-sm text-gray-700 text-left">
        <strong>Important:</strong> {pricingNote}
      </div>
      <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 mt-4 text-sm text-gray-600 text-left">
        {pricingServiceScope}
      </div>
    </div>

    <div class="max-w-4xl mx-auto bg-white rounded-xl shadow-sm border border-gray-200 p-8 mb-16 mt-12">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {pricing.map((item: { name: string, price: string }) => (
          <div class="flex justify-between items-center py-3 border-b border-gray-100 last:border-0">
            <span class="text-gray-700">{item.name}</span>
            <span class="font-bold text-brand-navy">{item.price}</span>
          </div>
        ))}
      </div>
    </div>


  </div>

  <StickyMobileBookingCTA />
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "Rabbia Psychologist Child Development Services Services Pricing",
  "itemListElement": [
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Online Parent Guidance Consultation"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "50",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Between-Session Support Planning"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "50",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Report Review and Next-Step Planning"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "minPrice": "60",
        "maxPrice": "80",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "School & IEP Support Session"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "minPrice": "60",
        "maxPrice": "80",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Workshops / Webinars"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "minPrice": "200",
        "maxPrice": "300",
        "priceCurrency": "USD"
      }
    }
  ]
}
</script>
</Layout>
