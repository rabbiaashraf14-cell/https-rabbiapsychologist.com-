---
import BaseLayout from '../layouts/BaseLayout.astro';
import StickyMobileBookingCTA from '../components/global/StickyMobileBookingCTA.astro';
import PriceDisplay from '../components/global/PriceDisplay.astro';
import CountdownSection from '../components/global/CountdownSection.astro';
import { isPromotionActive } from '../utils/pricing';

const title = "Pricing & Fees | Rabbia Psychologist";
const description = "Transparent pricing for online parent consultation, ADHD/ASD support, behavior planning, and report reviews.";
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-16 max-w-5xl">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Pricing</h1>
      <p class="text-xl text-gray-700 max-w-3xl mx-auto">
        Clear and transparent fees for parent guidance and child development support.
      </p>
    </div>

    <CountdownSection />

    <!-- Core Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">

      <!-- Card A -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Online Parent Guidance Consultation</h3>
        <PriceDisplay price="USD 85 / AUD 130" />
        <p class="text-sm text-gray-500 mb-4">Duration: 50–60 minutes</p>
        <p class="text-sm text-gray-700 mb-4 h-20 overflow-hidden"><strong>Best for:</strong> general developmental concerns, parenting stress, and initial guidance without a formal diagnosis.</p>
        <ul class="list-disc pl-5 text-gray-600 text-sm mb-8 space-y-1 flex-grow">
          <li>developmental review</li>
          <li>initial strategies</li>
        </ul>
        <a href="/book" class="w-full text-center bg-brand-navy text-white px-4 py-2 rounded-lg font-bold hover:bg-blue-900 transition-colors mt-auto">{isPromotionActive() ? 'Book Now – Save 35%' : 'Book Consultation'}</a>
      </div>

      <!-- Card B -->
      <div class="bg-white rounded-xl shadow-sm border border-brand-navy p-8 flex flex-col h-full hover:shadow-md transition-shadow relative">
        <div class="absolute top-0 right-1/2 transform translate-x-1/2 -translate-y-1/2 bg-brand-navy text-white px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase whitespace-nowrap">Most Popular</div>
        <h3 class="text-2xl font-bold text-brand-navy mb-2">ADHD Support Consultation</h3>
        <PriceDisplay price="USD 95 / AUD 145" />
        <p class="text-sm text-gray-500 mb-4">Duration: 50–60 minutes</p>
        <p class="text-sm text-gray-700 mb-4 h-20 overflow-hidden"><strong>Best for:</strong> home routines, executive function, and managing attention/hyperactivity.</p>
        <ul class="list-disc pl-5 text-gray-600 text-sm mb-8 space-y-1 flex-grow">
          <li>routine planning</li>
          <li>executive function support</li>
        </ul>
        <a href="/book" class="w-full text-center bg-brand-navy text-white px-4 py-2 rounded-lg font-bold hover:bg-blue-900 transition-colors mt-auto">{isPromotionActive() ? 'Book Now – Save 35%' : 'Book Consultation'}</a>
      </div>

      <!-- Card C -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">ASD Parent Guidance Consultation</h3>
        <PriceDisplay price="USD 95 / AUD 145" />
        <p class="text-sm text-gray-500 mb-4">Duration: 50–60 minutes</p>
        <p class="text-sm text-gray-700 mb-4 h-20 overflow-hidden"><strong>Best for:</strong> communication strategies, sensory needs, and autism parent training.</p>
        <ul class="list-disc pl-5 text-gray-600 text-sm mb-8 space-y-1 flex-grow">
          <li>sensory accommodation</li>
          <li>behavior support</li>
        </ul>
        <a href="/book" class="w-full text-center bg-brand-navy text-white px-4 py-2 rounded-lg font-bold hover:bg-blue-900 transition-colors mt-auto">{isPromotionActive() ? 'Book Now – Save 35%' : 'Book Consultation'}</a>
      </div>

      <!-- Card D -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Behaviour Planning Session</h3>
        <PriceDisplay price="USD 95 / AUD 145" />
        <p class="text-sm text-gray-500 mb-4">Duration: 50–60 minutes</p>
        <p class="text-sm text-gray-700 mb-4 h-20 overflow-hidden"><strong>Best for:</strong> meltdowns, tantrums, aggression, and difficult transitions.</p>
        <ul class="list-disc pl-5 text-gray-600 text-sm mb-8 space-y-1 flex-grow">
          <li>de-escalation strategies</li>
          <li>proactive routine building</li>
        </ul>
        <a href="/book" class="w-full text-center bg-brand-navy text-white px-4 py-2 rounded-lg font-bold hover:bg-blue-900 transition-colors mt-auto">{isPromotionActive() ? 'Book Now – Save 35%' : 'Book Consultation'}</a>
      </div>

      <!-- Card E -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Report Review & Parent Explanation</h3>
        <PriceDisplay price="USD 125 / AUD 190" />
        <p class="text-sm text-gray-500 mb-4">Duration: 60–75 minutes</p>
        <p class="text-sm text-gray-700 mb-4 h-20 overflow-hidden"><strong>Best for:</strong> parents who have a clinical/psychological report and need help translating it into action.</p>
        <ul class="list-disc pl-5 text-gray-600 text-sm mb-8 space-y-1 flex-grow">
          <li>plain English explanation</li>
          <li>next steps mapped out</li>
        </ul>
        <a href="/book" class="w-full text-center bg-brand-navy text-white px-4 py-2 rounded-lg font-bold hover:bg-blue-900 transition-colors mt-auto">{isPromotionActive() ? 'Book Now – Save 35%' : 'Book Consultation'}</a>
      </div>

      <!-- Card F -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">School / IEP Consultation</h3>
        <PriceDisplay price="From USD 140 / AUD 215" />
        <p class="text-sm text-gray-500 mb-4">Duration: 60–75 minutes</p>
        <p class="text-sm text-gray-700 mb-4 h-20 overflow-hidden"><strong>Best for:</strong> parent-teacher meetings, accommodation planning, and school communication.</p>
        <ul class="list-disc pl-5 text-gray-600 text-sm mb-8 space-y-1 flex-grow">
          <li>meeting preparation</li>
          <li>suggested accommodations</li>
        </ul>
        <a href="/book" class="w-full text-center bg-brand-navy text-white px-4 py-2 rounded-lg font-bold hover:bg-blue-900 transition-colors mt-auto">{isPromotionActive() ? 'Book Now – Save 35%' : 'Book Consultation'}</a>
      </div>

      <!-- Card G -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Four-Session Parent Guidance Package</h3>
        <p class="text-xl font-bold text-brand-gold mb-1">USD 320 / AUD 490</p>
        <p class="text-sm text-gray-500 mb-4">Includes: four 50–60 minute online sessions</p>
        <p class="text-sm text-gray-700 mb-4 h-20 overflow-hidden"><strong>Best for:</strong> families who need ongoing support for ADHD, ASD, or behaviour planning.</p>
        <ul class="list-disc pl-5 text-gray-600 text-sm mb-8 space-y-1 flex-grow">
          <li>structured progress review</li>
          <li>practical home plan adjustments</li>
        </ul>
        <a href="/book" class="w-full text-center bg-brand-navy text-white px-4 py-2 rounded-lg font-bold hover:bg-blue-900 transition-colors mt-auto">{isPromotionActive() ? 'Book Now – Save 35%' : 'Book Consultation'}</a>
      </div>

      <!-- Card H -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Workshop / Parent Training</h3>
        <PriceDisplay price="USD 150–200 / AUD 230–305" />
        <p class="text-sm text-gray-500 mb-4">Format: group or custom workshop</p>
        <p class="text-sm text-gray-700 mb-4 h-20 overflow-hidden"><strong>Best for:</strong> schools, parent groups, or organizations.</p>
        <ul class="list-disc pl-5 text-gray-600 text-sm mb-8 space-y-1 flex-grow">
          <li>custom topics</li>
          <li>practical strategies</li>
        </ul>
        <a href="/book" class="w-full text-center bg-brand-navy text-white px-4 py-2 rounded-lg font-bold hover:bg-blue-900 transition-colors mt-auto">{isPromotionActive() ? 'Book Now – Save 35%' : 'Book Consultation'}</a>
      </div>

      <!-- Card I -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 flex flex-col h-full hover:shadow-md transition-shadow">
        <h3 class="text-2xl font-bold text-brand-navy mb-2">Digital Resources</h3>
        <PriceDisplay price="Free to USD 29 / AUD 45" />
        <p class="text-sm text-gray-500 mb-4">Downloadable PDF tools</p>
        <p class="text-sm text-gray-700 mb-4 h-20 overflow-hidden"><strong>Includes:</strong> checklists, workbooks, school meeting templates, behaviour logs.</p>
        <ul class="list-disc pl-5 text-gray-600 text-sm mb-8 space-y-1 flex-grow">
          <li>Easy to use</li>
        </ul>
        <a href="/resource-vault" class="w-full text-center bg-white text-brand-navy border-2 border-brand-navy px-4 py-2 rounded-lg font-bold hover:bg-gray-50 transition-colors mt-auto">View Resource Vault</a>
      </div>
    </div>

    <div class="text-center mb-16">
      <p class="text-lg text-gray-600 italic">Assessment, screening, and payment details are confirmed at the time of booking.</p>
    </div>

    <!-- Which option should I choose? -->
    <div class="max-w-4xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-6 text-center">Which option should I choose?</h2>
      <div class="space-y-4">
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <h4 class="font-bold text-lg text-brand-navy mb-2">I am worried about my child's behaviour or development, but I don't have a diagnosis.</h4>
          <p class="text-gray-700">The <strong>Online Parent Guidance Consultation</strong> is the best starting point. We will discuss your concerns, map out a plan, and figure out if further assessment is needed.</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <h4 class="font-bold text-lg text-brand-navy mb-2">My child was recently diagnosed with ADHD or Autism and I feel overwhelmed.</h4>
          <p class="text-gray-700">Choose the <strong>ADHD Support Consultation</strong> or <strong>ASD Parent Guidance Consultation</strong> for focused, practical strategies to support your child at home.</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-lg p-6">
          <h4 class="font-bold text-lg text-brand-navy mb-2">I have a 10-page report from a specialist and I don't know what it means for school.</h4>
          <p class="text-gray-700">Book the <strong>Report Review and Parent Explanation Session</strong>. We will translate the clinical jargon into actionable home and school steps.</p>
        </div>
      </div>
    </div>

    <!-- What pricing does not include -->
    <div class="max-w-4xl mx-auto mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-6 text-center">What pricing does not include</h2>
      <div class="bg-brand-cream border border-brand-gold/30 rounded-lg p-8 text-center">
        <p class="text-gray-700 text-lg">Fees do not include emergency care, medication prescription or management, guarantee of school placement, or formal cross-border clinical diagnosis.</p>
      </div>
    </div>

  </div>

  <StickyMobileBookingCTA />
</BaseLayout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "Rabbia Psychologist Child Development Services Pricing",
  "itemListElement": [
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Online Parent Guidance Consultation"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "85",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "ADHD Support Consultation"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "95",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "ASD Parent Guidance Consultation"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "95",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Behaviour Planning Session"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "95",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Report Review and Parent Explanation Session"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "125",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "School / IEP Consultation"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "minPrice": "140",
        "priceCurrency": "USD"
      }
    }
  ]
}
</script>

<script>
  import { getDiscountedPrice, isPromotionActive } from '../utils/pricing';

  if (isPromotionActive()) {
    try {
      const schemaScript = document.querySelector('script[type="application/ld+json"]');

      // Inject new SEO script for Limited Time Offer
      const promoScript = document.createElement('script');
      promoScript.type = 'application/ld+json';
      promoScript.textContent = JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebPage",
        "name": "July Promotion - Limited Time Offer",
        "description": "Parent Consultation Discount - 35% OFF mid-July promotion."
      });
      document.head.appendChild(promoScript);

      if (schemaScript && schemaScript.textContent) {
        const schema = JSON.parse(schemaScript.textContent);
        if (schema.itemListElement) {
          schema.itemListElement.forEach((item: any) => {
            if (item.priceSpecification) {
              if (item.priceSpecification.price) {
                item.priceSpecification.price = getDiscountedPrice(Number(item.priceSpecification.price)).toString();
              } else if (item.priceSpecification.minPrice) {
                item.priceSpecification.minPrice = getDiscountedPrice(Number(item.priceSpecification.minPrice)).toString();
              }
            }
          });
          schemaScript.textContent = JSON.stringify(schema);
        }
      }
    } catch (e) {
      console.error('Error updating pricing schema dynamically', e);
    }
  }
</script>
