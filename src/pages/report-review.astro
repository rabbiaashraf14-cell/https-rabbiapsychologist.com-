---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Report Review', href: '/report-review' }
];
---

<BaseLayout title="Report Review & Parent Explanation | Rabbia Psychologist" description="Online parent explanation sessions for psychological, educational, and developmental reports.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="mt-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Report Review & Parent Explanation Session</h1>
      <p class="text-xl text-gray-700">Translating complex clinical jargon into practical next steps for home and school.</p>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700">
      <h2 class="text-2xl font-bold text-brand-navy">Who Needs This Service?</h2>
      <p>Parents who have recently received a lengthy diagnostic or developmental report for their child and feel overwhelmed by the terminology, confused about the recommendations, or unsure of what to do next.</p>

      <h2 class="text-2xl font-bold text-brand-navy">Reports We Can Review</h2>
      <p>We provide explanation and implementation guidance for:</p>
      <ul>
        <li>Psychoeducational Assessments</li>
        <li>Autism or ADHD Diagnostic Reports</li>
        <li>Speech and Language Therapy Reports</li>
        <li>Occupational Therapy Reports</li>
        <li>School IEPs or Learning Support Plans</li>
      </ul>

      <h2 class="text-2xl font-bold text-brand-navy">What Parents Receive in the Session</h2>
      <ul>
        <li><strong>Plain-English Translation:</strong> We break down the clinical jargon and explain what the scores and percentiles actually mean for your child's daily life.</li>
        <li><strong>Strengths & Needs Summary:</strong> Refocusing on what your child is good at, and exactly where they need scaffolding.</li>
        <li><strong>Actionable Next Steps:</strong> Turning a generic list of "recommendations" into a realistic 30-day home action plan.</li>
        <li><strong>Advocacy Preparation:</strong> Identifying the specific questions you need to ask the school or the diagnosing clinician in your follow-up meeting.</li>
      </ul>

      <h2 class="text-2xl font-bold text-brand-navy">Important Disclaimer</h2>
      <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 mt-4">
        <p class="mb-0 text-sm">A report review is a <strong>parent psychoeducation and consultation service</strong>. It does not replace the original formal assessment, nor does it serve as a second medical opinion, new diagnosis, or legal mandate for school services. It is designed purely to help parents understand existing documents and plan home support.</p>
      </div>

      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Make sense of the paperwork.</h3>
        <p class="mb-6">Book a Report Review Session (USD 125 / AUD 190).</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/book" class="bg-brand-navy text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">Book Report Review</a>
          <a href="/pricing" class="bg-white text-brand-navy border-2 border-brand-navy px-6 py-3 rounded-lg font-bold hover:bg-gray-50 transition-colors">View All Pricing</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
