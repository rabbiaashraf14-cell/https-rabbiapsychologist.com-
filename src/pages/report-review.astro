---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Report Review & Parent Explanation', href: '/report-review' }
];
---

<BaseLayout title="Report Review & Parent Explanation | Rabbia Psychologist" description="Translate long clinical reports or a new diagnosis into actionable next steps for home and school.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <!-- 1. Hero section -->
    <div class="mt-8 mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-4">Report Review & Parent Explanation</h1>
      <p class="text-xl text-gray-700 mb-4">Translate long clinical reports or a new diagnosis into actionable next steps for home and school.</p>
      <p class="text-lg font-bold text-brand-gold mb-6">USD 125 / AUD 190</p>
      <a href="/book" class="inline-block bg-brand-navy text-white px-8 py-4 rounded-lg font-bold hover:bg-blue-900 transition-colors shadow-md">Book Consultation</a>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700 space-y-12">

      <!-- 2. This is right for you if -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">This is right for you if</h2>
        <ul>
          <li>You just received a diagnostic report and don't know what it means.</li>
          <li>The report is full of clinical jargon you don't understand.</li>
          <li>You need to explain the report's recommendations to your child's school.</li>
          <li>You have the diagnosis, but no practical plan for what to do at home.</li>
        </ul>
      </section>

      <!-- 3. Common concerns parents bring -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">Common concerns parents bring</h2>
        <ul>
          <li>"The doctor gave us this 10-page report and told us to 'get support', but what kind?"</li>
          <li>"I don't understand what 'executive dysfunction' or 'working memory deficit' actually means for my child."</li>
          <li>"How do I tell the school about this without them labeling my child negatively?"</li>
        </ul>
      </section>

      <!-- 4. What we do in the session -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What we do in the session</h2>
        <p>You provide the report before the session so I can review it thoroughly. During the session, we will go through the key findings, translate the clinical terms into plain English, and discuss what these findings actually look like in your child's day-to-day life.</p>
      </section>

      <!-- 5. What you leave with -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What you leave with</h2>
        <p>A clear understanding of your child's profile and a prioritized list of next steps. You'll know exactly which accommodations to ask the school for and which strategies to start using at home immediately.</p>
      </section>

      <!-- 6. What this service does not include -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What this service does not include</h2>
        <ul>
          <li>Second opinions or changes to the diagnosis.</li>
          <li>Rewriting the original medical or psychological report.</li>
          <li>Legal review for special education disputes.</li>
        </ul>
      </section>

      <!-- 7. Related services -->
      <section class="bg-gray-50 p-6 rounded-xl border border-gray-200">
        <h3 class="text-xl font-bold text-brand-navy mb-4">Related Services</h3>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/services/school-consultation" class="text-brand-trust font-bold hover:underline">School Consultation &rarr;</a>
          <a href="/services/adhd-support" class="text-brand-trust font-bold hover:underline">ADHD Support &rarr;</a>
          <a href="/services/asd-support" class="text-brand-trust font-bold hover:underline">ASD Support &rarr;</a>
        </div>
      </section>

      <!-- 8. FAQ section -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-4 mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Do I need to send the report before the session?</h4>
            <p class="text-sm">Yes, please send the report at least 48 hours in advance so I can review it and prepare for our discussion.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Can you disagree with the diagnosis?</h4>
            <p class="text-sm">My role is not to provide a second diagnostic opinion online, but rather to help you understand the information presented in the report and how to use it constructively.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Is this session just for reports from psychologists?</h4>
            <p class="text-sm">I can review psychoeducational reports, autism assessments, ADHD evaluations, and allied health (OT/Speech) reports to help synthesize a support plan.</p>
          </div>
        </div>
      </section>

      <!-- 9. CTA block -->
      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Ready to understand your child's report?</h3>
        <p class="mb-6">Book your Report Review and get clarity on the next steps.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/book" class="bg-brand-navy text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">Book Report Review</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
