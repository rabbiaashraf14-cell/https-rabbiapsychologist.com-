---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RegionHero from '../components/RegionHero.astro';
import RegionProviderList from '../components/RegionProviderList.astro';
import InternationalDisclaimerBanner from '../components/InternationalDisclaimerBanner.astro';
import RegionFAQAccordion from '../components/RegionFAQAccordion.astro';
import RegionPricingCards from '../components/RegionPricingCards.astro';
import Schema from '../components/Schema.astro';
import PrivacyNoticeBlock from '../components/PrivacyNoticeBlock.astro';

const faqs = [
  { question: "Can UK/Europe families book?", answer: "Yes, families in the UK and Europe can access our online educational consultation services." },
  { question: "Is this regulated therapy?", answer: "No. These are educational parent consultation and guidance sessions, not regulated psychological therapy within the UK/EU." },
  { question: "How is child information handled?", answer: "We take privacy seriously. We only collect necessary information for consultation and comply with requests for data deletion in line with EU/UK standards." },
  { question: "Can I choose a UK/Europe provider if available?", answer: "Yes, you can browse our directory to select a provider whose experience aligns with your region." },
  { question: "Can this support school communication?", answer: "Yes, we can help you understand reports to better communicate with your child's SENCO or school team." },
  { question: "What if my child needs local assessment?", answer: "You must seek a local pediatrician, psychiatrist, or educational psychologist for formal assessment." },
  { question: "What happens after booking?", answer: "You will receive a confirmation email with a secure video link for your session and any intake forms needed." },
  { question: "Can I request deletion of submitted information?", answer: "Yes. Parents in the EU/UK may request deletion of their data at any time by contacting our support team." }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": typeof faqs !== 'undefined' ? faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  })) : []
};
---
<Layout title="Online Parent Consultation for UK & Europe Families">
  <SEO
    title="Online Parent Consultation for UK & Europe Families"
    description="Privacy-aware parent guidance for UK and European families seeking ASD/ADHD support, child development guidance, and school communication preparation."
    schema={schema}
  />


  <RegionHero
    regionName="UK & Europe Families"
    heroTitle="Online Parent Consultation for UK & Europe Families"
    heroSubtitle="For UK and European families seeking parent psychoeducation, ASD/ADHD guidance, executive-function routines, school support preparation, and developmental consultation."
  />

  <main class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">

      <InternationalDisclaimerBanner text="International support for UK & Europe families may include parent education, developmental guidance, ASD/ADHD support planning, behavior strategy discussion, executive-function routines, school communication preparation, resource guidance, and referral direction. Clinical therapy, diagnosis, assessment, and regulated psychological services are provided only where legally and ethically permitted by the provider's credentials and the client's location." />

      <section class="my-12">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Common concerns UK/Europe parents bring</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Seeking interim guidance while waiting for NHS or private developmental assessments.</li>
          <li>Needing practical support for neurodivergent children at home.</li>
          <li>Looking for help preparing to communicate with school SENCOs.</li>
          <li>Desiring flexible, online psychoeducation from experienced professionals.</li>
        </ul>
      </section>

      <div class="grid md:grid-cols-2 gap-8 my-12">
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
          <h2 class="text-xl font-bold text-brand-navy mb-4">What consultation may include</h2>
          <ul class="space-y-2 text-gray-700">
            <li>✔ Psychoeducation on child development and behavior.</li>
            <li>✔ Strategic planning for home routines (sleep, transitions).</li>
            <li>✔ Guidance on creating sensory-friendly environments.</li>
            <li>✔ Support in interpreting educational psychology reports.</li>
          </ul>
        </div>
        <div class="bg-red-50 p-6 rounded-lg border border-red-100">
           <h2 class="text-xl font-bold text-red-800 mb-4">When to seek local regulated care</h2>
           <ul class="space-y-2 text-gray-800">
            <li>✘ When a formal diagnosis (e.g., Autism, ADHD) is required.</li>
            <li>✘ If you need medication prescribed or managed.</li>
            <li>✘ If your child needs direct, regulated psychological therapy.</li>
            <li>✘ For crisis intervention or severe mental health concerns.</li>
          </ul>
        </div>
      </div>

      <PrivacyNoticeBlock />

      <section class="my-12">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">School Communication Support</h2>
        <p class="text-gray-700">We can help you synthesize your child's needs into clear communication points to share with their school, helping you advocate effectively during meetings with educational teams.</p>
      </section>

      <RegionProviderList region="UK & Europe Families" providers={[]} />

      <RegionPricingCards />

      <section class="my-16">
        <h2 class="text-3xl font-bold text-brand-navy mb-8 text-center">UK/Europe FAQs</h2>
        <RegionFAQAccordion faqs={faqs} />
      </section>

    </div>
  </main>

</Layout>
