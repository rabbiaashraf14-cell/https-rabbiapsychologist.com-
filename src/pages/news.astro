---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = "Newsroom | Rabbia Ashraf NeuroCare Child Development Services";
const description = "Read Rabbia Ashraf NeuroCare Child Development Services updates, press releases, parent resources, child development news, school support updates, and wellness guidance for families.";
---
<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-4xl font-bold text-brand-navy mb-8">Newsroom</h1>
    <p class="text-lg text-gray-700 mb-12">Read Rabbia Ashraf NeuroCare Child Development Services updates, press releases, parent resources, child development news, school support updates, and wellness guidance for families.</p>

    <div class="space-y-8">
      <article class="bg-white p-6 shadow rounded border border-gray-100 hover:shadow-md transition-shadow">
        <span class="inline-block px-3 py-1 bg-brand-cream text-brand-navy text-xs font-semibold rounded-full mb-3 uppercase tracking-wider">Press Release</span>
        <h2 class="text-2xl font-bold text-brand-navy mb-3">
          <a href="/press/neuronest-child-development-centre-launch" class="hover:text-brand-trust transition-colors">Rabbia Ashraf NeuroCare Child Development Services Launches Parent Guidance Platform</a>
        </h2>
        <p class="text-gray-700 mb-4">Rabbia Ashraf NeuroCare announces a parent guidance and child development support platform for families seeking clearer support pathways for ASD, ADHD, school, behaviour, report-review, and developmental concerns.</p>
        <a href="/press/neuronest-child-development-centre-launch" class="text-brand-trust font-medium hover:underline inline-flex items-center">
          Read full release <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      </article>
    </div>
  </div>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Newsroom",
  "publisher": {
    "@type": "Organization",
    "name": "Rabbia Ashraf NeuroCare Child Development Services"
  }
}
</script>
</BaseLayout>
