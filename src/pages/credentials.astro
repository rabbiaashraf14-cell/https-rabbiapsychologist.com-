---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'About', href: '/about' },
  { name: 'Credentials', href: '/credentials' }
];
---

<Layout title="Credentials & Qualifications">
  <SEO
    title="Credentials | Rabbia Ashraf Clinical Child Psychologist"
    description="Review the professional credentials, degrees, and specialized training of Rabbia Ashraf."
  />
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Credentials & Qualifications</h1>
      <div class="prose prose-lg text-gray-700 max-w-none">
        <p>A commitment to evidence-based practice is foundational to my work. My qualifications reflect dedicated training in clinical child psychology and specialized interventions.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-10">Education</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li><strong>MS Clinical Psychology</strong></li>
          <li><strong>BS (Hons) Applied Psychology</strong></li>
        </ul>

        <h2 class="text-2xl font-bold text-brand-navy mt-10">Specialized Training & Expertise</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>ASD & ADHD Intervention Specialist</li>
          <li>Applied Behavior Analysis (ABA) Informed Practice</li>
          <li>Early Childhood Development (ECD)</li>
          <li>Psychological Assessment & Diagnostics</li>
        </ul>

        <div class="mt-12 bg-brand-sky p-8 rounded-xl">
          <p class="font-medium text-brand-navy">For a complete list of certifications, clinical experience, and professional history, please view my <a href="https://www.linkedin.com/in/rabbiapsychologist" target="_blank" rel="noopener noreferrer" class="underline hover:text-blue-700">LinkedIn Profile</a>.</p>
        </div>
      </div>
    </div>
  </div>
  <Footer />
  <StickyMobileBookingCTA />
</Layout>
