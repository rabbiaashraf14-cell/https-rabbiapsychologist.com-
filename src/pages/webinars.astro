---
import { Image } from 'astro:assets';


import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'About', href: '/about' },
  { name: 'Webinars & Symposiums', href: '/webinars' }
];
---

<Layout title="Webinars & Symposiums">
  <SEO
    title="Parenting Webinars & Workshops"
    description="Register for upcoming webinars and workshops on child development, neurodiversity, and parenting strategies."
  />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Webinars & Symposiums</h1>
      <p class="text-xl text-gray-700 mb-12">
        Join our live online events designed to provide accessible, expert education for parents and professionals globally.
      </p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
        <div class="order-1 lg:order-2 fade-in">
          <div class="relative">
            <div class="absolute inset-0 bg-brand-sky/30 blur-3xl rounded-full"></div>
            <div class="relative z-10 w-full rounded-[24px] shadow-md border border-gray-100 hover-lift transition-all duration-300 aspect-video bg-brand-cream flex items-center justify-center p-8 text-center text-brand-gold">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
              </svg>
            </div>
          </div>
        </div>

        <div class="order-2 lg:order-1 fade-in">
          <h2 class="text-3xl font-bold text-brand-navy mb-4">Workshops • Parent Education • Professional Training</h2>
          <p class="text-lg text-gray-700 mb-6">
            Rabbia provides engaging, practical, and evidence-informed educational sessions tailored for various audiences.
          </p>
          <ul class="space-y-3 text-gray-700 mb-8">
            <li class="flex items-start">
              <svg class="w-6 h-6 text-brand-trust mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <strong>Parent workshops</strong> & community education
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-brand-trust mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <strong>Teacher training</strong> & school awareness sessions
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-brand-trust mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <strong>Professional seminars</strong> & child development talks
            </li>
            <li class="flex items-start">
              <svg class="w-6 h-6 text-brand-trust mr-2 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <strong>ADHD awareness</strong> & Autism awareness
            </li>
          </ul>
          <a href="/contact" class="inline-block px-8 py-4 bg-brand-navy text-white rounded-lg font-bold text-lg hover:bg-blue-900 transition-all shadow-md hover:-translate-y-1">
            Book a Workshop
          </a>
        </div>
      </div>

      <div class="bg-gray-50 p-8 rounded-xl text-center border border-gray-200 mt-12">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">No upcoming public events currently scheduled</h2>
        <p class="text-gray-600 mb-6">Check back soon for our schedule of upcoming public webinars and workshops on topics including executive function, emotional regulation, and behavior support.</p>
        <a href="/contact" class="inline-block bg-white text-brand-navy border border-gray-300 px-8 py-3 rounded-full font-bold hover:bg-gray-100 transition-colors">
          Join Mailing List to be Notified
        </a>
      </div>
    </div>
  </div>
  <StickyMobileBookingCTA />
</Layout>
