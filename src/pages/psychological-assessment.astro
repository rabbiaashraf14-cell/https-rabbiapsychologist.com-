---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Psychological Assessment', href: '/psychological-assessment' }
];
---

<Layout title="Psychological Assessment">
  <SEO
    title="Child Psychological & Developmental Assessments | Lahore"
    description="Comprehensive cognitive, developmental, and ADHD/ASD assessments available locally in Lahore, Pakistan."
  />
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Psychological Assessment</h1>
      <div class="bg-brand-lavender text-brand-navy py-2 px-4 rounded font-medium inline-block mb-8">
        Available locally in Lahore, Pakistan only
      </div>
      <p class="text-xl text-gray-700 mb-12 border-l-4 border-brand-sky pl-4">
        Comprehensive evaluations to provide clarity on your child's cognitive profile, developmental trajectory, and diagnostic needs.
      </p>
      <div class="prose prose-lg text-gray-700 max-w-none">
        <p>A thorough psychological assessment is often the crucial first step in securing the right support for your child, both at home and in school. We use standardized, evidence-based tools to provide a clear, actionable profile of your child's strengths and challenges.</p>
        <div class="bg-gray-50 p-6 rounded-xl my-8 border border-gray-200">
          <h3 class="text-xl font-bold text-brand-navy mb-4">Available Assessments:</h3>
          <ul class="list-disc pl-6 space-y-2">
            <li><strong>Developmental Assessments:</strong> Evaluating milestones in early childhood.</li>
            <li><strong>Cognitive Assessments (IQ):</strong> Understanding learning profiles and intellectual functioning.</li>
            <li><strong>ADHD Screening:</strong> Structured clinical interviews and standardized rating scales.</li>
            <li><strong>Autism Diagnostics:</strong> Utilizing gold-standard tools to assess for ASD.</li>
          </ul>
        </div>
      </div>
    </div>
    <BookingCTA />
  </div>
  <Footer />
  <StickyMobileBookingCTA />
</Layout>
