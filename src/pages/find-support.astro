---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://rabbiapsychologist.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Find Support",
      "item": "https://rabbiapsychologist.com/find-support"
    }
  ]
};
---

<Layout title="Find Support | NeuroNest Child Development Centre">
  <SEO
    title="Find Support | Global Parent Guidance & Child Development"
    description="Explore parent guidance, developmental support, and specialist consultation options that fit your family's unique needs, region, and goals."
  />
  <Schema schema={breadcrumbSchema} />


  <main>
    <section class="bg-brand-sky py-16 md:py-24">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Find the Support That Fits Your Family</h1>
        <p class="text-xl text-gray-700 mb-8">
          Learn from evidence-informed resources. Compare available specialists. Choose the support that fits your child, family, region, and goals.
        </p>
      </div>
    </section>

    <section class="py-16">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

          <a href="/choose-a-provider" class="block group">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 h-full transition-all group-hover:shadow-md group-hover:border-brand-trust">
              <div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center mb-6 text-brand-trust">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
              <h2 class="text-2xl font-bold text-brand-navy mb-3">Choose a Provider</h2>
              <p class="text-gray-600 mb-4">Browse our directory of verified professionals, compare options, and choose the specialist that fits your needs.</p>
              <span class="text-brand-trust font-medium group-hover:underline">Browse Directory &rarr;</span>
            </div>
          </a>

          <a href="/not-sure-where-to-start" class="block group">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 h-full transition-all group-hover:shadow-md group-hover:border-brand-trust">
              <div class="w-12 h-12 bg-brand-cream rounded-full flex items-center justify-center mb-6 text-brand-trust">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h2 class="text-2xl font-bold text-brand-navy mb-3">Not Sure Where to Start?</h2>
              <p class="text-gray-600 mb-4">Feeling overwhelmed? Let us help you navigate the options based on your concerns, budget, and region.</p>
              <span class="text-brand-trust font-medium group-hover:underline">Get Guidance &rarr;</span>
            </div>
          </a>

        </div>

        <div class="mt-16 text-center">
          <h2 class="text-2xl font-bold text-brand-navy mb-8">Support by Region</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a href="/providers/usa" class="bg-white border border-gray-200 rounded-lg py-4 px-6 hover:bg-brand-sky hover:border-brand-sky transition-colors text-brand-navy font-medium">USA Families</a>
            <a href="/providers/australia" class="bg-white border border-gray-200 rounded-lg py-4 px-6 hover:bg-brand-sky hover:border-brand-sky transition-colors text-brand-navy font-medium">Australia Families</a>
            <a href="/providers/uk-europe" class="bg-white border border-gray-200 rounded-lg py-4 px-6 hover:bg-brand-sky hover:border-brand-sky transition-colors text-brand-navy font-medium">UK & Europe Families</a>
            <a href="/providers/mena-gulf" class="bg-white border border-gray-200 rounded-lg py-4 px-6 hover:bg-brand-sky hover:border-brand-sky transition-colors text-brand-navy font-medium">MENA & Gulf Families</a>
          </div>
        </div>

        <div id="international-schools" class="mt-16 bg-brand-navy text-white rounded-xl p-8 md:p-12 text-center">
          <h2 class="text-2xl font-bold mb-4">Support for International Schools</h2>
          <p class="mb-6 max-w-2xl mx-auto text-brand-sky">We offer specialized consultation and training for international schools seeking to better support students with neurodevelopmental differences.</p>
          <a href="/contact" class="inline-block bg-white text-brand-navy font-bold py-3 px-8 rounded-full hover:bg-gray-100 transition-colors">Request School Consultation</a>
        </div>

      </div>
    </section>
  </main>

</Layout>
