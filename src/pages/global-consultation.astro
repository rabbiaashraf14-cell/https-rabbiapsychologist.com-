---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Global Consultation', href: '/global-consultation' }
];
---

<Layout title="Global Consultation">
  <SEO
    title="Online Parent Consultation | Global Child Psychology Support"
    description="Expert online developmental guidance, psychoeducation, and parent strategy sessions for international families."
  />

  <DisclaimerBanner />
  <Header />

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Global Online Consultation</h1>
      <p class="text-xl text-gray-700 mb-12 border-l-4 border-brand-sky pl-4">
        Accessible, expert guidance for parents navigating developmental, behavioral, or emotional challenges, no matter where you are in the world.
      </p>

      <div class="prose prose-lg text-gray-700 max-w-none">
        <h2 class="text-2xl font-bold text-brand-navy">What is Global Parent Consultation?</h2>
        <p>
          Global parent consultation is an educational and guidance-focused service designed to empower parents across borders. It provides expert support, behavior strategies, and developmental insights tailored to your family's unique situation.
        </p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">What it can include:</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>Parent education on ASD, ADHD, and general child development.</li>
          <li>Developmental guidance and milestone tracking.</li>
          <li>Behavior support planning and strategy discussion.</li>
          <li>Executive-function routines and home organization.</li>
          <li>School communication preparation and IEP review.</li>
          <li>Resource guidance and referral direction.</li>
        </ul>

        <h2 class="text-2xl font-bold text-red-800 mt-8">What it cannot include:</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>Formal psychological diagnosis (unless locally regulated).</li>
          <li>Regulated psychological therapy across international borders.</li>
          <li>Medication prescribing or management.</li>
          <li>Emergency care or crisis intervention.</li>
        </ul>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Who may benefit:</h2>
        <ul class="list-disc pl-6 space-y-2">
          <li>Parents navigating behavioral challenges like meltdowns or school refusal.</li>
          <li>Families on waitlists for local developmental assessments.</li>
          <li>Expatriate families seeking English-speaking, culturally competent support.</li>
          <li>Parents needing practical routines for neurodivergent children.</li>
        </ul>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Choose your provider:</h2>
        <p>Our platform allows you to review provider profiles, compare their expertise and regional experience, and select the professional who best aligns with your family's needs and language preferences.</p>
        <p><a href="/choose-a-provider" class="text-brand-trust hover:underline font-bold">Browse Provider Directory &rarr;</a></p>

        <div class="bg-blue-50 p-6 rounded-xl my-8 border border-blue-100">
          <h3 class="text-xl font-bold text-brand-navy mb-4">What happens during a session?</h3>
          <p>Sessions are conducted via secure video link. Your provider will listen to your concerns, review any context you've provided, and collaborate with you to brainstorm actionable strategies. The focus is entirely on equipping you, the parent, with tools.</p>

          <h3 class="text-xl font-bold text-brand-navy mt-6 mb-4">What parents receive after the session:</h3>
          <ul class="list-disc pl-6 space-y-2">
            <li>A summary of the strategies discussed.</li>
            <li>Relevant templates, logs, and reading materials from our resource vault.</li>
            <li>Recommendations for local referral pathways if formal assessment is needed.</li>
          </ul>
        </div>

        <h2 class="text-2xl font-bold text-brand-navy mt-10">Pricing</h2>
        <p>Pricing varies by provider, region, session type, and scope of service. Parent Guidance Sessions begin at USD 35. You can review specific rates on each provider's profile before booking.</p>
      </div>
    </div>

    <div class="mt-12 text-center">
      <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" target="_blank" rel="noopener noreferrer" class="inline-block bg-brand-navy text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-blue-800 transition-colors shadow-lg">
        Book Consultation
      </a>
    </div>
  </div>

  <Footer />
  <StickyMobileBookingCTA />
</Layout>
