---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Global Consultation', href: '/global-consultation' }
];
---

<Layout title="Global Consultation">
  <SEO
    title="Online Parent Consultation | Global Child Psychology Support"
    description="Expert online developmental guidance, psychoeducation, and parent strategy sessions for international families."
  />

  <DisclaimerBanner />
  <Header />

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Global Online Consultation</h1>
      <p class="text-xl text-gray-700 mb-12 border-l-4 border-brand-sky pl-4">
        Accessible, expert guidance for parents navigating developmental, behavioral, or emotional challenges, no matter where you are in the world.
      </p>

      <div class="prose prose-lg text-gray-700 max-w-none">
        <h2 class="text-2xl font-bold text-brand-navy">What is Online Parent Consultation?</h2>
        <p>
          Online parent consultation is an educational and guidance-focused service designed to empower parents. It is not traditional 1-on-1 child therapy, but rather a collaborative process where we work together to understand your child's needs and develop effective, personalized strategies you can implement at home.
        </p>

        <div class="bg-gray-50 p-6 rounded-xl my-8 border border-gray-200">
          <h3 class="text-xl font-bold text-brand-navy mb-4">Who this is for:</h3>
          <ul class="list-disc pl-6 space-y-2">
            <li>Parents seeking strategies for challenging behaviors (tantrums, non-compliance, aggression).</li>
            <li>Families navigating a new diagnosis or waiting for an assessment.</li>
            <li>Parents needing support with daily routines, transitions, or sleep issues.</li>
            <li>Expatriate families looking for culturally sensitive, English-speaking expert guidance.</li>
          </ul>
        </div>

        <h2 class="text-2xl font-bold text-brand-navy mt-10">What You Receive</h2>
        <ul class="list-disc pl-6 space-y-2 mb-8">
          <li><strong>Clarity:</strong> A better understanding of the "why" behind the behavior.</li>
          <li><strong>Actionable Strategies:</strong> Practical, immediate steps tailored to your family's dynamic.</li>
          <li><strong>Resource Support:</strong> Relevant templates, logs, and reading materials from our resource vault.</li>
          <li><strong>Ongoing Partnership:</strong> The option for follow-up sessions to adjust strategies as your child grows and changes.</li>
        </ul>

        <h2 class="text-2xl font-bold text-brand-navy mt-10">Important Notice for International Families</h2>
        <p class="text-sm bg-brand-lavender p-4 rounded-lg">
          Please note that international consultations are provided as educational, parent-guidance, and support-planning services. Clinical therapy, diagnosis, and regulated psychological services are provided only where legally and ethically permitted according to your local jurisdiction.
        </p>
      </div>
    </div>

    <BookingCTA />
  </div>

  <Footer />
  <StickyMobileBookingCTA />
</Layout>
