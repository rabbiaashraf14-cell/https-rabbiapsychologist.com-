---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Contact', href: '/contact' }
];
---

<Layout title="Contact">
  <SEO
    title="Contact Rabbia Ashraf | Child Psychology Consultation"
    description="Get in touch for inquiries about online parent consultation, autism support, ADHD guidance, or local psychological assessments."
  />


  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="max-w-4xl mx-auto mt-8 mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6 text-center">Contact</h1>
      <p class="text-xl text-gray-700 text-center mb-12">
        Have questions before booking? We're here to help.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-brand-navy mb-6">Get in Touch</h2>

          <div class="space-y-6">
            <div class="flex items-start">
              <svg class="w-6 h-6 text-brand-navy mt-1 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <h3 class="font-bold text-brand-navy">Email</h3>
                <p class="text-gray-600">contact@rabbiapsychologist.com</p>
              </div>
            </div>
            <div class="flex items-start">
              <svg class="w-6 h-6 text-brand-navy mt-1 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <h3 class="font-bold text-brand-navy">Professional Network</h3>
                <a href="https://www.linkedin.com/in/rabbiapsychologist" target="_blank" rel="noopener noreferrer" class="text-brand-navy hover:text-blue-700 underline">Connect on LinkedIn</a>
              </div>
            </div>
            <div class="flex items-start">
              <svg class="w-6 h-6 text-brand-navy mt-1 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <h3 class="font-bold text-brand-navy">Location</h3>
                <p class="text-gray-600">Lahore, Pakistan<br/><span class="text-sm">(Global consultations available online)</span></p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
          <h2 class="text-2xl font-bold text-brand-navy mb-6">Ready to start?</h2>
          <p class="text-gray-600 mb-8">The most efficient way to begin is by booking an initial consultation where we can discuss your specific needs in detail.</p>
          <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-brand-navy text-white py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">
            Book Consultation
          </a>
        </div>
      </div>

      <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 my-12">
        <h3 class="text-xl font-bold text-brand-navy mb-4">Live Chat Privacy & Safety Notice</h3>
        <p class="text-gray-700 mb-4">
          Live chat is for general questions, booking guidance, and support navigation only. Please do not share emergency concerns, full medical records, diagnosis documents, or sensitive child information through live chat. For urgent concerns, contact local emergency services or the nearest hospital.
        </p>
        <p class="text-gray-700 text-sm">
          Note: Tawk.to live chat is not suitable for exchanging regulated health information.
        </p>
      </div>
    </div>
  </div>

  <StickyMobileBookingCTA />
</Layout>
