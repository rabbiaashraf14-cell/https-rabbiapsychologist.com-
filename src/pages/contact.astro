---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Contact', href: '/contact' }
];
---

<Layout title="Contact">
  <SEO
    title="Contact Rabbia Ashraf | Child Psychology Consultation"
    description="Get in touch for inquiries about online parent consultation, autism support, ADHD guidance, or local psychological assessments."
  />


  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="max-w-4xl mx-auto mt-8 mb-16">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6 text-center">Contact Rabbia Psychologist</h1>
      <p class="text-xl text-gray-700 text-center mb-12">
        Get in touch to ask about psychological assessments, child development services, parent counselling, behavioural support, online consultations, or appointment availability.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
        <!-- Office Location Card -->
        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover-lift text-center flex flex-col h-full md:col-span-2">
          <div class="w-12 h-12 bg-blue-50 text-brand-navy rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-navy mb-2">Rabbia Ashraf</h3>
          <p class="text-brand-navy font-semibold mb-2">Clinical Psychologist</p>
          <p class="text-gray-600 mb-2 font-medium">Office Address:</p>
          <p class="text-gray-800 mb-4">519 F2, Johar Town, Lahore, Punjab, Pakistan</p>

          <div class="flex flex-col md:flex-row gap-4 justify-center items-center mt-auto pt-4 border-t border-gray-100">
             <div class="text-center md:text-right">
               <p class="text-sm text-gray-500 mb-1">Phone/WhatsApp</p>
               <a href="https://wa.me/923364114002" target="_blank" rel="noopener noreferrer" class="font-bold text-green-600 hover:text-green-700">+92 336 4114002</a>
             </div>
             <div class="hidden md:block w-px h-10 bg-gray-200"></div>
             <div class="text-center md:text-left">
               <p class="text-sm text-gray-500 mb-1">Email</p>
               <a href="mailto:psychologistrabbia@gmail.com" class="font-bold text-brand-navy hover:text-blue-700">psychologistrabbia@gmail.com</a>
             </div>
          </div>
        </div>

        <!-- Contact Options -->
        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover-lift text-center flex flex-col h-full">
          <div class="w-12 h-12 bg-green-50 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-navy mb-2">WhatsApp Chat</h3>
          <p class="text-gray-600 mb-4 flex-grow">Message us for quick queries and support.</p>
          <a href="https://wa.me/923364114002?text=Assalamualaikum%2C%20I%20visited%20your%20website%20and%20would%20like%20to%20ask%20about%20consultation%20or%20appointment%20availability." target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-green-600 text-white py-3 rounded-lg font-bold hover:bg-green-700 transition-colors mt-auto">
            Contact via WhatsApp
          </a>
        </div>

        <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100 hover-lift text-center flex flex-col h-full">
          <div class="w-12 h-12 bg-blue-50 text-brand-navy rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-brand-navy mb-2">Book an Appointment</h3>
          <p class="text-gray-600 mb-2">Online consultation available worldwide.</p>
          <p class="text-gray-600 mb-4 flex-grow text-sm">In-person consultation availability in Lahore.</p>
          <a href="/book" class="block w-full text-center bg-brand-navy text-white py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors mt-auto">
            Book Consultation
          </a>
        </div>
      </div>

      <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
        <h2 class="text-2xl font-bold text-brand-navy mb-6 text-center">Send an Enquiry</h2>
        <form id="contact-form" class="space-y-6">
          <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-brand-navy focus:border-brand-navy outline-none transition-shadow" placeholder="Your Full Name" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-brand-navy focus:border-brand-navy outline-none transition-shadow" placeholder="your.email@example.com" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="whatsapp" class="block text-sm font-medium text-gray-700 mb-1">WhatsApp Number *</label>
              <input type="tel" id="whatsapp" name="whatsapp" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-brand-navy focus:border-brand-navy outline-none transition-shadow" placeholder="+92 300 1234567" />
            </div>
            <div>
              <label for="country" class="block text-sm font-medium text-gray-700 mb-1">Country *</label>
              <input type="text" id="country" name="country" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-brand-navy focus:border-brand-navy outline-none transition-shadow" placeholder="e.g. United Kingdom" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="service" class="block text-sm font-medium text-gray-700 mb-1">Service Required *</label>
              <select id="service" name="service" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-brand-navy focus:border-brand-navy outline-none transition-shadow bg-white">
                <option value="">Please select a service...</option>
                <option value="Autism Assessment and Support">Autism Assessment and Support</option>
                <option value="ADHD Assessment and Behaviour Management">ADHD Assessment and Behaviour Management</option>
                <option value="Learning Difficulties">Learning Difficulties</option>
                <option value="Child Behaviour Consultation">Child Behaviour Consultation</option>
                <option value="Parent Counselling">Parent Counselling</option>
                <option value="Adult Counselling">Adult Counselling</option>
                <option value="Psychological Assessment">Psychological Assessment</option>
                <option value="Report Review or Second Opinion">Report Review or Second Opinion</option>
                <option value="School Guidance">School Guidance</option>
                <option value="School Partnership Services">School Partnership Services</option>
                <option value="Online Consultation">Online Consultation</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div>
              <label for="age" class="block text-sm font-medium text-gray-700 mb-1">Patient or Client Age *</label>
              <input type="text" id="age" name="age" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-brand-navy focus:border-brand-navy outline-none transition-shadow" placeholder="Age in years/months" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Preferred Consultation Type *</label>
            <div class="space-y-2">
              <div class="flex items-center">
                <input type="radio" id="consultation_online" name="consultation_type" value="Online consultation" required class="w-4 h-4 text-brand-navy border-gray-300 focus:ring-brand-navy" />
                <label for="consultation_online" class="ml-2 text-gray-700">Online consultation</label>
              </div>
              <div class="flex items-center">
                <input type="radio" id="consultation_inperson" name="consultation_type" value="In-person consultation" class="w-4 h-4 text-brand-navy border-gray-300 focus:ring-brand-navy" />
                <label for="consultation_inperson" class="ml-2 text-gray-700">In-person consultation</label>
              </div>
              <div class="flex items-center">
                <input type="radio" id="consultation_notsure" name="consultation_type" value="Not sure yet" class="w-4 h-4 text-brand-navy border-gray-300 focus:ring-brand-navy" />
                <label for="consultation_notsure" class="ml-2 text-gray-700">Not sure yet</label>
              </div>
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
            <textarea id="message" name="message" rows="4" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-brand-navy focus:border-brand-navy outline-none transition-shadow" placeholder="How can we help you?"></textarea>
          </div>

          <div class="flex items-start bg-gray-50 p-4 rounded-lg border border-gray-200">
            <div class="flex items-center h-5">
              <input id="consent" name="consent" type="checkbox" required class="w-4 h-4 text-brand-navy border-gray-300 rounded focus:ring-brand-navy" />
            </div>
            <div class="ml-3 text-sm">
              <label for="consent" class="font-medium text-gray-700">I understand that this contact form is for appointment and service enquiries and should not be used for emergencies.</label>
            </div>
          </div>

          <p class="text-sm text-gray-500 italic mt-2">
            Please avoid submitting highly sensitive medical or personal information through this form. Detailed concerns can be discussed privately during your consultation.
          </p>

          <button type="submit" id="submit-btn" class="w-full bg-brand-navy text-white py-4 px-6 rounded-lg font-bold text-lg hover:bg-blue-900 transition-colors shadow-md flex items-center justify-center gap-2">
            <span>Send Enquiry</span>
            <svg id="submit-spinner" class="animate-spin -ml-1 mr-3 h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>

          <div id="form-result" class="hidden rounded-lg p-4 mt-4 text-center"></div>
        </form>
      </div>

      <div class="bg-blue-50 border-l-4 border-blue-500 rounded-r-lg p-6 my-8">
        <h3 class="text-lg font-bold text-brand-navy mb-2 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Disclaimer
        </h3>
        <p class="text-gray-700">
          This website does not provide emergency or crisis services. If you or someone else is in immediate danger, please contact your local emergency service or visit the nearest hospital.
        </p>
      </div>
    </div>
  </div>

  <StickyMobileBookingCTA />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('contact-form') as HTMLFormElement;
      const resultDiv = document.getElementById('form-result') as HTMLDivElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const spinner = document.getElementById('submit-spinner') as HTMLElement;

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          // Basic validation is handled by HTML5 required attributes,
          // but we can add more specific client side validation here if needed.

          const formData = new FormData(form);
          const object = Object.fromEntries(formData);
          const json = JSON.stringify(object);

          // Honeypot check
          if (object.botcheck) {
             return; // Silent fail for bots
          }

          resultDiv.classList.add('hidden');
          submitBtn.disabled = true;
          submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
          spinner.classList.remove('hidden');

          try {
            const response = await fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: json
            });
            const result = await response.json();

            resultDiv.classList.remove('hidden', 'bg-red-50', 'text-red-700', 'border-red-200');

            if (response.status === 200) {
              resultDiv.classList.add('bg-green-50', 'text-green-700', 'border', 'border-green-200');
              resultDiv.innerHTML = "Thank you for contacting Rabbia Psychologist. Your enquiry has been received. You will usually receive a response within one business day.";
              form.reset();
            } else {
              resultDiv.classList.add('bg-red-50', 'text-red-700', 'border', 'border-red-200');
              resultDiv.innerHTML = "We could not send your message at this time. Please email <a href='mailto:psychologistrabbia@gmail.com' class='underline'>psychologistrabbia@gmail.com</a> or contact us through WhatsApp at <a href='https://wa.me/923364114002' class='underline'>+92 336 4114002</a>.";
            }
          } catch (error) {
            resultDiv.classList.remove('hidden', 'bg-green-50', 'text-green-700', 'border-green-200');
            resultDiv.classList.add('bg-red-50', 'text-red-700', 'border', 'border-red-200');
            resultDiv.innerHTML = "We could not send your message at this time. Please email <a href='mailto:psychologistrabbia@gmail.com' class='underline'>psychologistrabbia@gmail.com</a> or contact us through WhatsApp at <a href='https://wa.me/923364114002' class='underline'>+92 336 4114002</a>.";
          } finally {
            submitBtn.disabled = false;
            submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
            spinner.classList.add('hidden');
          }
        });
      }
    });
  </script>
</Layout>
