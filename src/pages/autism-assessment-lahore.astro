---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';
---

<Layout title="Autism Assessment Lahore">
  <SEO
    title="Autism Assessment & Diagnosis in Lahore | ASD Support"
    description="Comprehensive, standardized autism assessments and diagnostic services in Lahore, Pakistan."
  />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Autism Assessment in Lahore</h1>
      <p class="text-xl text-gray-700 mb-8 border-l-4 border-brand-sky pl-4">
        Thorough diagnostic evaluations for Autism Spectrum Disorder using standardized, gold-standard assessment tools.
      </p>
      <BookingCTA />
    </div>
  </div>
  <StickyMobileBookingCTA />
</Layout>
