---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'School Partnership Services', href: '/services/school-partnership' }
];

const title = "School Partnership & Student Support Services | Rabbia Psychologist";
const description = "Support every child with greater confidence. Practical guidance for schools, teachers, and support teams to manage developmental, behavioural, and learning needs.";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "School Partnership Services",
  "description": description,
  "provider": {
    "@type": "Organization",
    "name": "Rabbia Psychologist Child Development Services"
  },
  "areaServed": "International"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can you work with individual students referred by our school?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The appropriate service will depend on the student’s concern, location, available records, parental consent, and whether consultation, observation, screening, assessment, or referral is required."
      }
    },
    {
      "@type": "Question",
      "name": "Can you train our entire teaching team?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Workshops can be customized for teachers, coordinators, counsellors, learning-support staff, school leadership, or parents."
      }
    },
    {
      "@type": "Question",
      "name": "Do you provide online school consultation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Online consultation, staff training, report discussion, support planning, and case conferences can be arranged for schools in different cities and countries."
      }
    },
    {
      "@type": "Question",
      "name": "Can you help us develop Individualized Education Plans?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Guidance can be provided for developing practical goals, accommodations, support strategies, and progress-monitoring procedures."
      }
    }
  ]
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <!-- Hero section -->
    <div class="mt-8 mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-4">School Partnership & Student Support Services</h1>
      <p class="text-xl text-gray-700 mb-4">Support Every Child with Greater Confidence</p>
      <p class="text-lg text-gray-600 mb-6 max-w-2xl mx-auto">Schools do not always need another general recommendation. They need practical guidance that teachers can apply in the classroom, parents can continue at home, and support teams can monitor over time.</p>
      <a href="/contact" class="inline-block bg-brand-navy text-white px-8 py-4 rounded-lg font-bold hover:bg-blue-900 transition-colors shadow-md">Request a School Partnership Consultation</a>
    </div>

    <div class="space-y-16">

      <!-- Section 1: School Partnership Services -->
      <section>
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-brand-navy mb-4">School Partnership Services</h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">Supporting schools, teachers, families, and student-support teams through practical psychological, developmental, behavioural, and learning guidance.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- Card 1 -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col hover:-translate-y-1 transition-transform duration-300">
            <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4 text-brand-navy">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">Student Consultation</h3>
            <p class="text-gray-600 text-sm mb-4">Professional consultation to understand a student’s developmental, behavioural, emotional, learning, or classroom needs.</p>
            <ul class="text-sm text-gray-600 space-y-2 mb-4 flex-grow list-disc list-inside">
              <li>Attention and concentration</li>
              <li>ADHD and impulsivity</li>
              <li>Autism and social communication</li>
              <li>Emotional regulation</li>
              <li>Learning and developmental concerns</li>
              <li>School adjustment or refusal</li>
            </ul>
            <div class="bg-gray-50 p-3 rounded-lg text-sm text-brand-navy font-medium mb-4">
              <strong>Outcome:</strong> Identify suitable next steps for the school and family.
            </div>
            <details class="group bg-white rounded-lg border border-gray-200 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-1.5 p-3 text-sm font-medium text-gray-700">
                View full service details
                <span class="shrink-0 transition duration-300 group-open:-rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </span>
              </summary>
              <div class="p-3 pt-0 text-sm text-gray-600 border-t border-gray-100 mt-2">
                Detailed professional consultation for students experiencing complex concerns. The aim is to thoroughly understand the student’s needs through a review of history, behaviour, and learning patterns to identify appropriate next steps for the school and family.
              </div>
            </details>
          </div>

          <!-- Card 2 -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col hover:-translate-y-1 transition-transform duration-300">
            <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4 text-brand-navy">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">Classroom Observation</h3>
            <p class="text-gray-600 text-sm mb-4">Where appropriate and professionally permitted, classroom observation helps identify factors affecting student behaviour and participation.</p>
            <ul class="text-sm text-gray-600 space-y-2 mb-4 flex-grow list-disc list-inside">
              <li>Behaviour triggers</li>
              <li>Sensory or environmental challenges</li>
              <li>Communication difficulties</li>
              <li>Attention and participation needs</li>
              <li>Helpful strategies already being used</li>
            </ul>
            <div class="bg-gray-50 p-3 rounded-lg text-sm text-brand-navy font-medium mb-4">
              <strong>Outcome:</strong> Receive practical recommendations for routines, transitions, communication, and behaviour support.
            </div>
            <details class="group bg-white rounded-lg border border-gray-200 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-1.5 p-3 text-sm font-medium text-gray-700">
                View full service details
                <span class="shrink-0 transition duration-300 group-open:-rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </span>
              </summary>
              <div class="p-3 pt-0 text-sm text-gray-600 border-t border-gray-100 mt-2">
                Observation can identify situations that trigger difficult behaviour, environmental challenges, academic demands affecting behaviour, patterns of avoidance, and strategies already working for the student. Following consultation, the school receives practical recommendations.
              </div>
            </details>
          </div>

          <!-- Card 3 -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col hover:-translate-y-1 transition-transform duration-300">
            <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4 text-brand-navy">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">IEP and Support Planning</h3>
            <p class="text-gray-600 text-sm mb-4">Guidance for developing practical and measurable student-support plans.</p>
            <ul class="text-sm text-gray-600 space-y-2 mb-4 flex-grow list-disc list-inside">
              <li>Individualized Education Plans</li>
              <li>Behaviour Support Plans</li>
              <li>Classroom accommodations</li>
              <li>Learning and participation goals</li>
              <li>Home-school progress plans</li>
              <li>Monitoring and review systems</li>
            </ul>
            <div class="bg-gray-50 p-3 rounded-lg text-sm text-brand-navy font-medium mb-4">
              <strong>Outcome:</strong> Create realistic support plans that teachers and families can manage.
            </div>
            <details class="group bg-white rounded-lg border border-gray-200 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-1.5 p-3 text-sm font-medium text-gray-700">
                View full service details
                <span class="shrink-0 transition duration-300 group-open:-rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </span>
              </summary>
              <div class="p-3 pt-0 text-sm text-gray-600 border-t border-gray-100 mt-2">
                Schools receive guidance in developing or reviewing Individual Support Plans, emotional-regulation strategies, and communication goals. Recommendations are designed to be clear, measurable, realistic, and manageable for teachers and families.
              </div>
            </details>
          </div>

          <!-- Card 4 -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col hover:-translate-y-1 transition-transform duration-300">
            <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4 text-brand-navy">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            </div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">Teacher Consultation</h3>
            <p class="text-gray-600 text-sm mb-4">Practical guidance that helps teachers respond more confidently to student needs.</p>
            <ul class="text-sm text-gray-600 space-y-2 mb-4 flex-grow list-disc list-inside">
              <li>Attention and impulsivity</li>
              <li>Autism support</li>
              <li>Emotional outbursts</li>
              <li>Classroom participation</li>
              <li>Transitions and routines</li>
              <li>Parent communication</li>
            </ul>
            <div class="bg-gray-50 p-3 rounded-lg text-sm text-brand-navy font-medium mb-4">
              <strong>Outcome:</strong> Provide strategies that can be used within the real classroom environment.
            </div>
            <details class="group bg-white rounded-lg border border-gray-200 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-1.5 p-3 text-sm font-medium text-gray-700">
                View full service details
                <span class="shrink-0 transition duration-300 group-open:-rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </span>
              </summary>
              <div class="p-3 pt-0 text-sm text-gray-600 border-t border-gray-100 mt-2">
                Teachers are often the first people to notice that a student is struggling. Consultation helps teachers understand what may be happening beneath the behaviour and how to respond more effectively to emotional distress and learning challenges.
              </div>
            </details>
          </div>

          <!-- Card 5 -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col hover:-translate-y-1 transition-transform duration-300">
            <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4 text-brand-navy">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H15" /></svg>
            </div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">Staff Training and Workshops</h3>
            <p class="text-gray-600 text-sm mb-4">Customized training for teachers, coordinators, counsellors, learning-support staff, and school leadership.</p>
            <div class="flex flex-wrap gap-2 mb-4 flex-grow">
              <span class="px-2 py-1 bg-brand-sky text-brand-navy text-xs rounded-full">ADHD in the classroom</span>
              <span class="px-2 py-1 bg-brand-sky text-brand-navy text-xs rounded-full">Autism & neurodiversity</span>
              <span class="px-2 py-1 bg-brand-sky text-brand-navy text-xs rounded-full">Positive behaviour support</span>
              <span class="px-2 py-1 bg-brand-sky text-brand-navy text-xs rounded-full">Emotional regulation</span>
              <span class="px-2 py-1 bg-brand-sky text-brand-navy text-xs rounded-full">Learning disabilities</span>
              <span class="px-2 py-1 bg-brand-sky text-brand-navy text-xs rounded-full">IEP planning</span>
              <span class="px-2 py-1 bg-brand-sky text-brand-navy text-xs rounded-full">Parent communication</span>
              <span class="px-2 py-1 bg-brand-sky text-brand-navy text-xs rounded-full">Inclusive education</span>
            </div>
            <a href="#enquiry-form" class="inline-block text-center w-full bg-white text-brand-navy border border-brand-navy px-4 py-2 rounded-lg text-sm font-bold hover:bg-gray-50 transition-colors mt-auto">Discuss a Staff Workshop</a>
          </div>

          <!-- Card 6 -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col hover:-translate-y-1 transition-transform duration-300">
            <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4 text-brand-navy">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">Parent Education</h3>
            <p class="text-gray-600 text-sm mb-4">Sessions that help parents understand school concerns and maintain consistent strategies at home.</p>
            <ul class="text-sm text-gray-600 space-y-2 mb-4 flex-grow list-disc list-inside">
              <li>Understanding school feedback</li>
              <li>Behaviour management at home</li>
              <li>Homework and attention support</li>
              <li>Consistent home-school routines</li>
              <li>Understanding assessment reports</li>
              <li>Parent-school communication</li>
            </ul>
            <div class="bg-gray-50 p-3 rounded-lg text-sm text-brand-navy font-medium mb-4">
              <strong>Outcome:</strong> Strengthen consistency between home and school.
            </div>
            <details class="group bg-white rounded-lg border border-gray-200 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-1.5 p-3 text-sm font-medium text-gray-700">
                View full service details
                <span class="shrink-0 transition duration-300 group-open:-rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </span>
              </summary>
              <div class="p-3 pt-0 text-sm text-gray-600 border-t border-gray-100 mt-2">
                Schools can arrange parent seminars, individual parent meetings, or small-group guidance sessions to support children with ADHD, autism, learning, or developmental needs and prepare for further professional assessment.
              </div>
            </details>
          </div>

          <!-- Card 7 -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col hover:-translate-y-1 transition-transform duration-300">
            <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4 text-brand-navy">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" /></svg>
            </div>
            <h3 class="text-xl font-bold text-brand-navy mb-3">Case Conferences</h3>
            <p class="text-gray-600 text-sm mb-4">Structured collaboration for students receiving support from several professionals.</p>

            <div class="flex items-center justify-between text-xs text-gray-500 mb-4 px-2 py-3 bg-gray-50 rounded-lg border border-gray-100 flex-grow">
              <div class="flex flex-col items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                <span>Family</span>
              </div>
              <div class="w-full border-t-2 border-dashed border-gray-300 mx-2"></div>
              <div class="flex flex-col items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                <span>School</span>
              </div>
              <div class="w-full border-t-2 border-dashed border-gray-300 mx-2"></div>
              <div class="flex flex-col items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                <span>Support</span>
              </div>
            </div>

            <div class="bg-gray-50 p-3 rounded-lg text-sm text-brand-navy font-medium mb-4 mt-auto">
              <strong>Outcome:</strong> Develop one coordinated plan and reduce conflicting recommendations.
            </div>
            <details class="group bg-white rounded-lg border border-gray-200 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-1.5 p-3 text-sm font-medium text-gray-700">
                View full service details
                <span class="shrink-0 transition duration-300 group-open:-rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </span>
              </summary>
              <div class="p-3 pt-0 text-sm text-gray-600 border-t border-gray-100 mt-2">
                School partnership support may include structured meetings with parents, teachers, school coordinators, clinical psychologists, special educators, and therapists (speech, occupational, behaviour) to coordinate care.
              </div>
            </details>
          </div>

          <!-- Card 8 -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col hover:-translate-y-1 transition-transform duration-300">
            <div class="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center mb-4 text-brand-navy">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
