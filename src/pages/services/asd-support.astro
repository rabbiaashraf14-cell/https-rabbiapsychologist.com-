---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "ASD Support | Autism Parent Guidance | Rabbia Psychologist";
const description = "Parent guidance for autism-related concerns, developmental needs, communication challenges, behavior concerns, routines, report review, and next-step planning with Rabbia Ashraf, Clinical Psychologist.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "ASD Support",
  "provider": {
    "@type": "Organization",
    "name": "Rabbia Psychologist Child Development Services",
    "employee": {
      "@type": "Person",
      "name": "Rabbia Ashraf",
      "jobTitle": "Clinical Psychologist"
    }
  },
  "areaServed": "Worldwide",
  "serviceType": "Parent Guidance and Developmental Consultation",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "url": "https://rabbiapsychologist.com/pricing"
  }
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="bg-brand-cream py-16 lg:py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">ASD Support for Parents and Families</h1>
      <p class="text-xl text-gray-700 leading-relaxed">
        Autism-related concerns can feel confusing for parents, especially when they are trying to understand their child’s communication, behavior, social interaction, daily routines, sensory needs, or assessment report. ASD support at Rabbia Psychologist Child Development Services focuses on helping parents understand their child’s needs and plan practical next steps for home and school.
      </p>
      <div class="mt-8 flex justify-center space-x-4">
        <a href="/book" class="inline-block px-8 py-4 bg-brand-navy text-white rounded-lg font-bold text-lg hover:bg-blue-900 transition-all shadow-lg">Book ASD Parent Guidance Consultation &rarr;</a>
        <a href="/pricing" class="inline-block px-8 py-4 bg-white text-brand-navy border border-gray-300 rounded-lg font-bold text-lg hover:bg-gray-50 transition-all shadow-sm">View Pricing</a>
      </div>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <section class="mb-12">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">This support may help if your child</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Has autism-related concerns or a recent ASD diagnosis</li>
          <li>Shows difficulty with communication or social interaction</li>
          <li>Struggles with transitions, routines, or emotional regulation</li>
          <li>Has repetitive behaviors or sensory sensitivities</li>
          <li>Has behavior challenges at home or school</li>
          <li>Has received an assessment report and parents need help understanding it</li>
          <li>Needs practical home-based guidance after diagnosis or referral</li>
        </ul>
      </section>

      <section class="mb-12">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">What we focus on</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Parent guidance and psychoeducation</li>
          <li>Understanding developmental and behavioral patterns</li>
          <li>Review of available reports and recommendations</li>
          <li>Home routine planning</li>
          <li>Communication and behavior support guidance</li>
          <li>School and IEP-related planning</li>
          <li>Referral guidance when speech therapy, occupational therapy, developmental pediatrics, or other support is needed</li>
        </ul>
      </section>

      <section class="mb-12 bg-brand-cream border border-brand-sky rounded-xl p-8">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">What happens in a consultation</h2>
        <ol class="list-decimal pl-6 space-y-2 text-gray-700 font-medium">
          <li>Parent shares the main concerns</li>
          <li>Existing reports or school notes are reviewed if available</li>
          <li>Rabbia explains the concern in simple language</li>
          <li>Practical home and school next steps are discussed</li>
          <li>Follow-up support can be planned if needed</li>
        </ol>
      </section>

      <div class="bg-gray-50 border-l-4 border-brand-trust p-6 mb-12 rounded-r-lg">
        <p class="text-sm text-gray-600 italic">
          <strong>Important note:</strong> Online ASD support is parent guidance and developmental consultation. It does not replace emergency care, medical treatment, or in-person diagnostic assessment when required.
        </p>
      </div>

      <div class="text-center">
        <a href="/book" class="inline-block px-8 py-4 bg-brand-trust text-white rounded-lg font-bold text-lg hover:bg-blue-700 transition-all shadow-lg">Book ASD Parent Guidance Consultation &rarr;</a>
      </div>
    </div>
  </div>
</BaseLayout>
