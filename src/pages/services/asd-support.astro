---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'ASD Support', href: '/services/asd-support' }
];
---

<BaseLayout title="Autism Parent Guidance & Support | Rabbia Psychologist" description="Online parent guidance for autism-related concerns, social communication, sensory needs, and routines.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="mt-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Autism Parent Guidance</h1>
      <p class="text-xl text-gray-700">Practical guidance for navigating social communication, sensory needs, rigid routines, and behaviour support at home.</p>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700">
      <h2 class="text-2xl font-bold text-brand-navy">Common Parent Concerns</h2>
      <ul>
        <li>Difficulty understanding why a child is having frequent meltdowns.</li>
        <li>Struggles with sensory sensitivities (clothing, food textures, noise).</li>
        <li>Challenges with communication—understanding what the child is trying to express through behaviour.</li>
        <li>Extreme distress during transitions or changes in routine.</li>
        <li>Confusion about what to do immediately following an autism diagnosis.</li>
      </ul>

      <h2 class="text-2xl font-bold text-brand-navy">How We Support Families</h2>

      <h3>1. Parent Guidance After Diagnosis</h3>
      <p>Receiving an autism diagnosis can be overwhelming. We help parents process the information, understand their child's unique profile, and figure out the immediate next steps for home support.</p>

      <h3>2. Communication & Sensory Support</h3>
      <p>Guidance on creating an environment that respects a child's sensory needs while encouraging functional communication and reducing frustration.</p>

      <h3>3. Routine & Behaviour Planning</h3>
      <p>Developing visual supports, predictable structures, and proactive strategies to manage anxiety and prevent meltdowns.</p>

      <h3>4. Report Understanding & School Support</h3>
      <p>We review your diagnostic reports with you, translating clinical terms into plain English, and mapping out what accommodations to request at school.</p>

      <h2 class="text-2xl font-bold text-brand-navy">Frequently Asked Questions</h2>
      <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 mt-4">
        <h4 class="font-bold text-brand-navy">Do you provide ABA therapy?</h4>
        <p class="mb-4">No. We provide parent coaching and psychoeducation based on neurodiversity-affirming, developmental, and behaviour-support principles. We focus on helping parents support their child's regulatory and communication needs.</p>

        <h4 class="font-bold text-brand-navy">My child doesn't have a diagnosis yet, but I suspect autism. Can we still book?</h4>
        <p>Yes. Parent guidance is highly effective while you are on a waitlist for formal assessment. We can start working on home routines and communication strategies immediately.</p>
      </div>

      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Start supporting your child today.</h3>
        <p class="mb-6">Book an ASD Parent Guidance Consultation (USD 95 / AUD 145).</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/book" class="bg-brand-navy text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">Book ASD Support</a>
          <a href="/pricing" class="bg-white text-brand-navy border-2 border-brand-navy px-6 py-3 rounded-lg font-bold hover:bg-gray-50 transition-colors">View All Pricing</a>
        </div>
      </div>

      <div class="mt-8 text-sm flex gap-4 justify-center">
        <a href="/report-review" class="text-brand-trust hover:underline">Report Review</a> |
        <a href="/services/school-consultation" class="text-brand-trust hover:underline">School Consultation</a> |
        <a href="/resource-vault" class="text-brand-trust hover:underline">Resource Vault</a>
      </div>
    </div>
  </div>
</BaseLayout>
