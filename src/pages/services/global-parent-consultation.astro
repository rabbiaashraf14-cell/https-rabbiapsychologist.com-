---
import Layout from '../../layouts/Layout.astro';
import SEO from '../../components/seo/SEO.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';
import Schema from '../../components/seo/Schema.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Global Parent Consultation', href: '/services/global-parent-consultation' }
];

const faqs = [
  { question: "Is this therapy?", answer: "No, this is parent education and developmental guidance, not regulated therapy." },
  { question: "Can international families book?", answer: "Yes, our global parent consultation and guidance services are designed for families worldwide." },
  { question: "Do you provide diagnosis?", answer: "No, we do not provide diagnosis online. We can offer referral direction for formal diagnosis where needed." }
];
---

<Layout title="Global Parent Consultation">
  <SEO
    title="Global Parent Consultation | Developmental Guidance"
    description="Parent education and developmental guidance for families worldwide, including ASD/ADHD support planning, behavior strategies, school communication, and referral direction."
    canonicalURL="https://rabbiapsychologist.com/services/global-parent-consultation"
    type="WebPage"
  />
  <Schema
    type="Service"
    data={{
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Global Parent Consultation",
      "provider": {
        "@type": "Organization",
        "name": "NeuroNest Child Development Centre"
      },
      "description": "Parent education and developmental guidance for families worldwide, including ASD/ADHD support planning, behavior strategies, school communication, and referral direction."
    }}
  />
  <Schema
    type="FAQPage"
    data={{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }}
  />

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="max-w-4xl mx-auto mt-8 mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Global Parent Consultation</h1>
      <p class="text-xl text-gray-700">
        Parent education, developmental guidance, ASD/ADHD support planning, behavior strategy discussion, executive-function routines, school communication preparation, and referral direction for families worldwide.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-16 max-w-5xl mx-auto">
      <div>
        <h2 class="text-2xl font-bold text-brand-navy mb-4">Who this service is for</h2>
        <p class="text-gray-700 mb-6">Families worldwide seeking expert guidance on their child's development, behavior, and learning needs from a multidisciplinary perspective.</p>

        <h2 class="text-2xl font-bold text-brand-navy mb-4">Common parent concerns</h2>
        <ul class="list-disc pl-5 text-gray-700 space-y-2 mb-6">
          <li>Understanding early developmental signs</li>
          <li>Managing challenging behaviors at home</li>
          <li>Building effective daily routines</li>
          <li>Navigating school communication and support</li>
          <li>Knowing when and how to seek formal assessment</li>
        </ul>
      </div>

      <div class="bg-brand-cream p-6 rounded-xl border border-gray-100">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">What this service may include</h2>
        <ul class="list-disc pl-5 text-gray-700 space-y-2 mb-6">
          <li>ASD/ADHD support planning</li>
          <li>Behavior strategy discussion</li>
          <li>Executive-function routines</li>
          <li>School communication preparation</li>
          <li>Referral direction</li>
        </ul>

        <h2 class="text-2xl font-bold text-red-800 mb-4">What this service does not include</h2>
        <p class="text-gray-700 font-medium bg-red-50 p-4 rounded-md border border-red-100">
          Important boundary: This is not a promise of regulated therapy, diagnosis, or assessment in every country.
        </p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mb-16">
      <h2 class="text-2xl font-bold text-brand-navy mb-4">What parents may receive</h2>
      <p class="text-gray-700 mb-6">Actionable strategies, a clearer understanding of your child's profile, visual supports (where applicable), and a tailored support plan for home and school.</p>

      <h2 class="text-2xl font-bold text-brand-navy mb-4">How to prepare</h2>
      <p class="text-gray-700 mb-6">Gather any previous reports, note down specific behavioral examples, and outline your top concerns and goals for the consultation.</p>

      <div class="flex gap-4 flex-wrap">
        <a href="/providers" class="text-brand-trust font-medium hover:underline">View Related Providers &rarr;</a>
        <a href="/resources" class="text-brand-trust font-medium hover:underline">Explore Related Resources &rarr;</a>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mb-16">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Pricing</h2>
      <ul class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-4 text-gray-700">
        <li class="flex justify-between border-b border-gray-50 pb-2"><span>Initial Parent Consultation with Rabbia</span> <span>Pakistan-based families may receive local pricing or booking-stage discounts. Final pricing is confirmed during booking or consultation coordination.</span></li>
        <li class="flex justify-between border-b border-gray-50 pb-2"><span>International Parent Guidance with Rabbia</span> <span>USD 50 / AUD 75</span></li>
        <li class="flex justify-between"><span>Provider Consultation</span> <span>Provider-specific</span></li>
      </ul>
    </div>

    <div class="max-w-4xl mx-auto mb-16">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="bg-white border border-gray-100 rounded-lg p-4">
            <summary class="font-bold text-brand-navy cursor-pointer">{faq.question}</summary>
            <p class="text-gray-700 mt-2">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <div class="max-w-4xl mx-auto mb-16 bg-gray-50 p-6 rounded-xl text-sm text-gray-600 text-center border border-gray-200">
      <strong>Safety & Legal Disclaimer:</strong> International support may include parent education, developmental guidance, ASD/ADHD support planning, behavior strategy discussion, executive-function routines, school communication preparation, resource guidance, and referral direction. Clinical therapy, diagnosis, assessment, and regulated psychological services are provided only where legally and ethically permitted by the provider’s credentials and the client’s location.
    </div>

    <div class="max-w-4xl mx-auto text-center bg-brand-cream border border-brand-trust/20 rounded-xl p-8">
      <h2 class="text-2xl font-bold text-brand-navy mb-4">Ready to start?</h2>
      <p class="text-gray-700 mb-6">Book a consultation today to discuss your child's needs and develop a tailored support plan.</p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" class="bg-brand-trust text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700 transition-colors">Book Consultation</a>
      </div>
    </div>
  </div>
</Layout>
