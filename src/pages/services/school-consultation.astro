---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "School Consultation and IEP Support | Rabbia Psychologist";
const description = "School consultation and IEP support for children with developmental, behavioral, learning, attention, autism-related, or emotional concerns.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "School Consultation and IEP Support",
  "provider": {
    "@type": "Organization",
    "name": "Rabbia Psychologist Child Development Services",
    "employee": {
      "@type": "Person",
      "name": "Rabbia Ashraf",
      "jobTitle": "Clinical Psychologist"
    }
  },
  "areaServed": "Worldwide",
  "serviceType": "Educational Planning Support",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "url": "https://rabbiapsychologist.com/pricing"
  }
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="bg-brand-cream py-16 lg:py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">School Consultation and IEP Support</h1>
      <p class="text-xl text-gray-700 leading-relaxed">
        Many children struggle at school because of attention difficulties, learning needs, developmental concerns, behavior challenges, emotional concerns, speech and language delays, or autism-related needs. School consultation helps parents understand what kind of support the child may need and how to communicate those needs clearly with the school.
      </p>
      <div class="mt-8 flex justify-center space-x-4">
        <a href="/book" class="inline-block px-8 py-4 bg-brand-navy text-white rounded-lg font-bold text-lg hover:bg-blue-900 transition-all shadow-lg">Book School Consultation &rarr;</a>
        <a href="/pricing" class="inline-block px-8 py-4 bg-white text-brand-navy border border-gray-300 rounded-lg font-bold text-lg hover:bg-gray-50 transition-all shadow-sm">View Pricing</a>
      </div>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <section class="mb-12">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">This support may help if</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Your child is receiving repeated school complaints</li>
          <li>The school has suggested assessment or support</li>
          <li>Your child has difficulty with attention, behavior, learning, or social adjustment</li>
          <li>Your child has an ASD, ADHD, learning, or developmental concern</li>
          <li>You need help understanding school recommendations</li>
          <li>You need support preparing for a school meeting</li>
          <li>Your child may need IEP-related planning or classroom accommodations</li>
        </ul>
      </section>

      <section class="mb-12">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">What we focus on</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Understanding school concerns</li>
          <li>Reviewing school notes, reports, or teacher feedback</li>
          <li>Explaining the child’s needs in parent-friendly language</li>
          <li>Planning practical school support</li>
          <li>Helping parents prepare for school meetings</li>
          <li>Suggesting classroom accommodations where appropriate</li>
          <li>Supporting IEP-related planning and developmental goals</li>
        </ul>
      </section>

      <section class="mb-12 bg-brand-cream border border-brand-sky rounded-xl p-8">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Examples of school support areas</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Attention and classroom participation</li>
          <li>Behavior and emotional regulation</li>
          <li>Communication and social interaction</li>
          <li>Learning difficulties</li>
          <li>Homework routines</li>
          <li>School refusal or adjustment issues</li>
          <li>Developmental and behavioral support planning</li>
        </ul>
      </section>

      <div class="bg-gray-50 border-l-4 border-brand-trust p-6 mb-12 rounded-r-lg">
        <p class="text-sm text-gray-600 italic">
          <strong>Important note:</strong> School consultation is guidance for parents and educational planning support. It does not replace formal school evaluation, legal advocacy, or in-person assessment where required.
        </p>
      </div>

      <div class="text-center">
        <a href="/book" class="inline-block px-8 py-4 bg-brand-trust text-white rounded-lg font-bold text-lg hover:bg-blue-700 transition-all shadow-lg">Book School Consultation &rarr;</a>
      </div>
    </div>
  </div>
</BaseLayout>
