---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'School & IEP Consultation', href: '/services/school-consultation' }
];
---

<BaseLayout title="School & IEP Consultation | Rabbia Psychologist" description="Guidance for school concerns, teacher meetings, IEP confusion, and parent-school communication plans.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <!-- 1. Hero section -->
    <div class="mt-8 mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-4">School & IEP Consultation</h1>
      <p class="text-xl text-gray-700 mb-4">From IEP confusion to a clear support plan. Understand the meeting, prepare the right questions, and turn school concerns into practical next steps for your child.</p>
      <p class="text-lg font-bold text-brand-gold mb-6">From USD 140 / AUD 215</p>
      <a href="/book" class="inline-block bg-brand-navy text-white px-8 py-4 rounded-lg font-bold hover:bg-blue-900 transition-colors shadow-md">Book Consultation</a>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700 space-y-12">

      <!-- 2. This is right for you if -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">This is right for you if</h2>
        <ul>
          <li>You are preparing for an important school meeting (like an IEP or support plan review).</li>
          <li>Your child is struggling academically or socially but the school isn't sure how to help.</li>
          <li>You feel intimidated or overwhelmed communicating with teachers and school admin.</li>
          <li>You want to know what realistic accommodations you can ask for.</li>
        </ul>
      </section>

      <!-- 3. Common concerns parents bring -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">Common concerns parents bring</h2>
        <ul>
          <li>The school is suggesting an assessment and you don't know why.</li>
          <li>Your child's current IEP or learning plan isn't working.</li>
          <li>Teacher complaints about behavior or attention.</li>
          <li>Your child is refusing to go to school (school can't).</li>
          <li>You don't understand the jargon being used by the school SENCO/support team.</li>
        </ul>
      </section>

      <!-- 4. What we do in the session -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What we do in the session</h2>
        <p>We review your child's current challenges, read over any existing school documents or plans you have, and help you understand your child's needs in the school context. We practice how to advocate effectively without being adversarial.</p>
      </section>

      <!-- 5. What you leave with -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What you leave with</h2>
        <p>A clear meeting preparation plan. You'll leave with specific questions to ask, a list of reasonable accommodations to request, and a strategy for maintaining positive communication with the school.</p>
      </section>

      <!-- 6. What this service does not include -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What this service does not include</h2>
        <ul>
          <li>Legal advocacy or representation at school meetings.</li>
          <li>Guaranteeing school placement or compliance.</li>
          <li>Direct communication with the school on your behalf (we coach you).</li>
          <li>Formal diagnostic assessments.</li>
        </ul>
      </section>

      <!-- 7. Related services -->
      <section class="bg-gray-50 p-6 rounded-xl border border-gray-200">
        <h3 class="text-xl font-bold text-brand-navy mb-4">Related Services</h3>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/report-review" class="text-brand-trust font-bold hover:underline">Report Review &rarr;</a>
          <a href="/services/adhd-support" class="text-brand-trust font-bold hover:underline">ADHD Support &rarr;</a>
          <a href="/services/asd-support" class="text-brand-trust font-bold hover:underline">ASD Support &rarr;</a>
        </div>
      </section>

      <!-- 8. FAQ section -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-4 mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Can you attend the school meeting with me?</h4>
            <p class="text-sm">No, this is a consultation service to prepare and coach you prior to the meeting. We do not act as your legal advocate or attend the meetings.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Do you review IEP documents before the session?</h4>
            <p class="text-sm">Yes, you can share relevant documents prior to the session for review, so our time is spent efficiently discussing strategy.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Are you familiar with international school systems?</h4>
            <p class="text-sm">We provide general, evidence-based recommendations for support. However, we do not provide legal advice regarding specific education laws (like IDEA in the US) in your country.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">What if the school refuses accommodations?</h4>
            <p class="text-sm">We can brainstorm alternative approaches and help you plan your next steps for communication and collaboration.</p>
          </div>
        </div>
      </section>

      <!-- 9. CTA block -->
      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Ready to advocate clearly for your child?</h3>
        <p class="mb-6">Book your School Consultation to prepare for your next meeting.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/book" class="bg-brand-navy text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">Book School Consultation</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
