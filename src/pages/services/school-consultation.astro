---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'School Consultation', href: '/services/school-consultation' }
];
---

<BaseLayout title="School & IEP Consultation for Parents | Rabbia Psychologist" description="From IEP confusion to a clear support plan. Prepare for parent-teacher meetings and advocate for your child.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="mt-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">School / IEP Consultation</h1>
      <p class="text-xl text-gray-700">From IEP confusion to a clear support plan.</p>
      <p class="text-lg text-gray-600 mt-2">Understand the meeting, prepare the right questions, and turn school concerns into practical next steps for your child.</p>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700">
      <h2 class="text-2xl font-bold text-brand-navy">Why Parents Book This Service</h2>
      <ul>
        <li>You have an upcoming IEP (Individualized Education Program) or accommodation meeting and don't know what to ask for.</li>
        <li>The school is reporting frequent behavioral issues, but you aren't sure how to bridge the gap between home and school.</li>
        <li>You feel the teacher doesn't fully understand your child's ADHD, Autism, or learning profile.</li>
        <li>You have a clinical report but need help translating its recommendations into realistic classroom strategies.</li>
      </ul>

      <h2 class="text-2xl font-bold text-brand-navy">What the Session Covers</h2>

      <h3>1. Parent-Teacher Meeting Preparation</h3>
      <p>We review your main concerns and build a prioritized agenda so you go into the meeting feeling confident and focused, not defensive.</p>

      <h3>2. IEP-Style Accommodation Planning</h3>
      <p>We discuss reasonable, practical accommodations based on your child's profile—such as preferred seating, movement breaks, visual schedules, or adjusted homework expectations.</p>

      <h3>3. Teacher Communication Strategy</h3>
      <p>Guidance on how to maintain a positive, collaborative relationship with the school, including templates for weekly check-ins or behavior logs.</p>

      <h2 class="text-2xl font-bold text-brand-navy">What to Bring to Your Session</h2>
      <p>To get the most out of our time, please have available:</p>
      <ul>
        <li>Recent school reports or teacher emails highlighting the concern.</li>
        <li>Any existing IEP, 504 plan, or learning support plan.</li>
        <li>Recent psychological, speech, or occupational therapy reports (if applicable).</li>
      </ul>

      <h2 class="text-2xl font-bold text-brand-navy">Frequently Asked Questions</h2>
      <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 mt-4">
        <h4 class="font-bold text-brand-navy">Will you attend the school meeting with me?</h4>
        <p class="mb-4">This service is designed as <strong>parent preparation and coaching</strong>. Direct advocacy (attending meetings with the school) is generally outside the scope of international online consultation due to scheduling and jurisdiction, but we equip you to be the best advocate for your child.</p>
      </div>

      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Feel confident at your next school meeting.</h3>
        <p class="mb-6">Book a School Consultation (From USD 140 / AUD 215).</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/book" class="bg-brand-navy text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">Book School Consultation</a>
          <a href="/pricing" class="bg-white text-brand-navy border-2 border-brand-navy px-6 py-3 rounded-lg font-bold hover:bg-gray-50 transition-colors">View All Pricing</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
