---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Local Child Assessment Guidance | Rabbia Psychologist";
const description = "Local child assessment support for developmental, behavioral, learning, ADHD, autism-related, school, and emotional concerns. Available for families who can attend in person where appropriate.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Local Child Assessment Support",
  "provider": {
    "@type": "Organization",
    "name": "Rabbia Psychologist Child Development Services",
    "employee": {
      "@type": "Person",
      "name": "Rabbia Ashraf",
      "jobTitle": "Clinical Psychologist"
    }
  },
  "areaServed": "Lahore",
  "serviceType": "Assessment Guidance",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "url": "https://rabbiapsychologist.com/pricing"
  }
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="bg-brand-cream py-16 lg:py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Local Child Assessment Support</h1>
      <p class="text-xl text-gray-700 leading-relaxed">
        Some child development concerns require careful in-person assessment, observation, parent interview, school information, and review of previous reports. Local assessment support is for families who need help understanding developmental, behavioral, learning, emotional, ADHD-related, autism-related, or school-related concerns.
      </p>
      <div class="mt-8 flex justify-center space-x-4">
        <a href="/book" class="inline-block px-8 py-4 bg-brand-navy text-white rounded-lg font-bold text-lg hover:bg-blue-900 transition-all shadow-lg">Book Assessment Guidance Consultation &rarr;</a>
        <a href="/pricing" class="inline-block px-8 py-4 bg-white text-brand-navy border border-gray-300 rounded-lg font-bold text-lg hover:bg-gray-50 transition-all shadow-sm">View Pricing</a>
      </div>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <section class="mb-12">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">Assessment support may be helpful for</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Developmental delay concerns</li>
          <li>ADHD-related concerns</li>
          <li>Autism-related concerns</li>
          <li>Learning or academic difficulties</li>
          <li>Behavior concerns</li>
          <li>Emotional and adjustment concerns</li>
          <li>School readiness or school support planning</li>
          <li>Report review and next-step planning</li>
        </ul>
      </section>

      <section class="mb-12 bg-brand-cream border border-brand-sky rounded-xl p-8">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">What may be included</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Parent interview</li>
          <li>Review of developmental history</li>
          <li>Review of school concerns or teacher feedback</li>
          <li>Observation where appropriate</li>
          <li>Screening or assessment guidance depending on the concern</li>
          <li>Written recommendations where applicable</li>
          <li>Referral guidance if another specialist is needed</li>
        </ul>
      </section>

      <section class="mb-12">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">Important clarification</h2>
        <p class="text-gray-700 mb-4">
          Local assessment availability depends on the child’s age, concern, location, and whether in-person assessment is appropriate. Some concerns may require referral to a developmental pediatrician, speech therapist, occupational therapist, psychiatrist, neurologist, or other relevant professional.
        </p>
        <p class="text-gray-700 italic">
          Residents of Pakistan may be eligible for discounted in-person pricing rates. Please contact us for details.
        </p>
      </section>

      <div class="bg-gray-50 border-l-4 border-brand-trust p-6 mb-12 rounded-r-lg">
        <p class="text-sm text-gray-600 italic">
          <strong>Important note:</strong> Online consultation cannot replace in-person diagnostic assessment where direct observation, testing, or multidisciplinary evaluation is required.
        </p>
      </div>

      <div class="text-center">
        <a href="/book" class="inline-block px-8 py-4 bg-brand-trust text-white rounded-lg font-bold text-lg hover:bg-blue-700 transition-all shadow-lg">Book Assessment Guidance Consultation &rarr;</a>
      </div>
    </div>
  </div>
</BaseLayout>
