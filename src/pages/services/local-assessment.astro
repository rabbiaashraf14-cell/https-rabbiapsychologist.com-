---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Local Assessment', href: '/services/local-assessment' }
];
---

<BaseLayout title="Local Psychological Assessment in Lahore | Rabbia Psychologist" description="In-person psychological assessment and ADHD screening for families based in Lahore, Pakistan.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="mt-8 mb-12">
      <div class="inline-block bg-brand-navy text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">Pakistan / Lahore Only</div>
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Local Psychological Assessment</h1>
      <p class="text-xl text-gray-700">In-person psychological evaluation, developmental observation, and ADHD screening for local families.</p>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700">
      <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-8">
        <p class="text-sm m-0"><strong>Important Notice:</strong> Formal psychological testing and assessment are provided strictly <strong>in-person in Lahore, Pakistan</strong>. We do not provide formal cross-border medical or psychological diagnosis via online consultation.</p>
      </div>

      <h2 class="text-2xl font-bold text-brand-navy">Assessment Services Provided</h2>

      <h3>Comprehensive Psychological Assessment</h3>
      <p>A detailed evaluation to understand a child's cognitive, developmental, and psychological profile.</p>
      <ul>
        <li>Parent interview to gather developmental history.</li>
        <li>Child observation and standardized testing (where professionally appropriate).</li>
        <li>Scoring and clinical interpretation.</li>
        <li>A comprehensive written report (timeline varies based on complexity).</li>
        <li>A feedback session to explain the results and recommend next steps.</li>
      </ul>

      <h3>Structured ADHD Screening</h3>
      <p>A focused screening process to identify symptoms of ADHD and related executive function challenges.</p>
      <ul>
        <li>Clinical interview and standardized rating scales.</li>
        <li>Observation where applicable.</li>
        <li>Summary of findings and recommendations for school and home.</li>
      </ul>

      <h2 class="text-2xl font-bold text-brand-navy">Important Boundaries and Referrals</h2>
      <p>A psychological assessment or screening is an important piece of the puzzle, but it is <strong>not the same as a medical diagnosis</strong>. If medical evaluation, ruling out physical conditions, or medication management is needed, we will provide a referral direction to a developmental pediatrician, psychiatrist, neurologist, or relevant physician.</p>

      <h2 class="text-2xl font-bold text-brand-navy">Local Pricing Structure</h2>
      <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 mt-4">
        <ul class="list-none pl-0 space-y-4">
          <li class="flex justify-between border-b border-gray-200 pb-2">
            <span class="font-bold">Comprehensive Assessment with Report</span>
            <span class="text-brand-gold font-bold">Starting from PKR 25,000+</span>
          </li>
          <li class="flex justify-between">
            <span class="font-bold">ADHD Screening</span>
            <span class="text-brand-gold font-bold">Starting from PKR 15,000+</span>
          </li>
        </ul>
        <p class="text-sm mt-4 italic text-gray-500">Note: Final fees depend on the specific testing required and the complexity of the report.</p>
      </div>

      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Request a Local Assessment</h3>
        <p class="mb-6">Please contact us to discuss your child's needs and schedule an in-person evaluation in Lahore.</p>
        <a href="/book" class="inline-block bg-brand-navy text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">Ask About Local Assessment</a>
      </div>
    </div>
  </div>
</BaseLayout>
