---
import Layout from '../../layouts/Layout.astro';
import SEO from '../../components/seo/SEO.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';
import Schema from '../../components/seo/Schema.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Psychological Assessment', href: '/services/psychological-assessment-local' }
];

const faqs = [
  { question: "Can I get an assessment online?", answer: "No, formal psychological assessments require in-person observation and testing." },
  { question: "Where is this service available?", answer: "This service is currently only available locally in Lahore, Pakistan." }
];
---

<Layout title="Psychological Assessment (Local)">
  <SEO
    title="Psychological Assessment | Lahore | Pakistan"
    description="Local psychological assessment pathways in Lahore/Pakistan for developmental, behavioral, emotional, academic, ASD, and ADHD concerns where available."
    canonicalURL="https://rabbiapsychologist.com/services/psychological-assessment-local"
    type="WebPage"
  />
  <Schema
    type="Service"
    data={{
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Psychological Assessment",
      "provider": {
        "@type": "Organization",
        "name": "NeuroNest Child Development Centre"
      },
      "areaServed": "Lahore, Pakistan",
      "description": "Local psychological assessment pathways in Lahore/Pakistan for developmental, behavioral, emotional, academic, ASD, and ADHD concerns where available."
    }}
  />
  <Schema
    type="FAQPage"
    data={{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }}
  />

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="max-w-4xl mx-auto mt-8 mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Psychological Assessment, Local Only</h1>
      <p class="text-xl text-gray-700">
        Local assessment pathways for families in Lahore/Pakistan where legally and ethically available.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-16 max-w-5xl mx-auto">
      <div>
        <h2 class="text-2xl font-bold text-brand-navy mb-4">Who this service is for</h2>
        <p class="text-gray-700 mb-6">Families residing in or traveling to Lahore, Pakistan, who require formal diagnostic clarification for their child's developmental, behavioral, or academic challenges.</p>

        <h2 class="text-2xl font-bold text-brand-navy mb-4">Common parent concerns</h2>
        <ul class="list-disc pl-5 text-gray-700 space-y-2 mb-6">
          <li>Uncertainty about a specific diagnosis (e.g., Autism, ADHD)</li>
          <li>School requesting a formal evaluation for accommodations</li>
          <li>Unexplained academic struggles or learning delays</li>
          <li>Complex behavioral or emotional presentations</li>
        </ul>
      </div>

      <div class="bg-brand-cream p-6 rounded-xl border border-gray-100">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">What this service may include</h2>
        <ul class="list-disc pl-5 text-gray-700 space-y-2 mb-6">
          <li>Developmental concerns evaluation</li>
          <li>ASD/ADHD screening pathways</li>
          <li>Behavior and emotional concerns assessment</li>
          <li>Academic/learning concerns assessment</li>
          <li>Report and feedback where applicable</li>
        </ul>

        <h2 class="text-2xl font-bold text-red-800 mb-4">What this service does not include</h2>
        <p class="text-gray-700 font-medium bg-red-50 p-4 rounded-md border border-red-100">
          Important boundary: Formal assessment availability depends on local setting, child needs, professional scope, tools available, and ethical/legal requirements. Not available online or internationally.
        </p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mb-16">
      <h2 class="text-2xl font-bold text-brand-navy mb-4">What parents may receive</h2>
      <p class="text-gray-700 mb-6">A comprehensive clinical interview, direct testing/observation with the child, collateral information gathering (e.g., from school), a feedback session, and a formal written report.</p>

      <h2 class="text-2xl font-bold text-brand-navy mb-4">How to prepare</h2>
      <p class="text-gray-700 mb-6">Gather all previous medical, developmental, and school records. Ensure your child is well-rested before the testing appointment.</p>

      <div class="flex gap-4 flex-wrap">
        <a href="/services/school-iep-consultation" class="text-brand-trust font-medium hover:underline">Explore School Consultation &rarr;</a>
        <a href="/providers" class="text-brand-trust font-medium hover:underline">View Related Providers &rarr;</a>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mb-16">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Pricing</h2>
      <ul class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-4 text-gray-700">
        <li class="flex justify-between border-b border-gray-50 pb-2"><span>ADHD Screening / Structured Screening</span> <span>PKR 15,000+</span></li>
        <li class="flex justify-between border-b border-gray-50 pb-2"><span>Local Psychological Assessment with Report</span> <span>PKR 25,000+</span></li>
      </ul>
    </div>

    <div class="max-w-4xl mx-auto mb-16">
      <h2 class="text-2xl font-bold text-brand-navy mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="bg-white border border-gray-100 rounded-lg p-4">
            <summary class="font-bold text-brand-navy cursor-pointer">{faq.question}</summary>
            <p class="text-gray-700 mt-2">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>

    <div class="max-w-4xl mx-auto mb-16 bg-gray-50 p-6 rounded-xl text-sm text-gray-600 text-center border border-gray-200">
      <strong>Safety & Legal Disclaimer:</strong> International support may include parent education, developmental guidance, ASD/ADHD support planning, behavior strategy discussion, executive-function routines, school communication preparation, resource guidance, and referral direction. Clinical therapy, diagnosis, assessment, and regulated psychological services are provided only where legally and ethically permitted by the provider’s credentials and the client’s location.
    </div>

    <div class="max-w-4xl mx-auto text-center bg-brand-cream border border-brand-trust/20 rounded-xl p-8">
      <h2 class="text-2xl font-bold text-brand-navy mb-4">Ready to start?</h2>
      <p class="text-gray-700 mb-6">Book a consultation today to discuss your child's needs and develop a tailored support plan.</p>
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="https://calendar.app.google/zMKejpnpCjh91WRG7" class="bg-brand-trust text-white px-6 py-3 rounded-md font-medium hover:bg-blue-700 transition-colors">Book Consultation</a>
      </div>
    </div>
  </div>
</Layout>
