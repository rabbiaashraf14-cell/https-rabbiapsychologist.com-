---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'ADHD Support', href: '/services/adhd-support' }
];
---

<BaseLayout title="ADHD Support & Parent Guidance | Rabbia Psychologist" description="Online parent guidance for ADHD routines, executive function, school support, and emotional regulation.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <!-- 1. Hero section -->
    <div class="mt-8 mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-4">ADHD Support & Parent Guidance</h1>
      <p class="text-xl text-gray-700 mb-4">Practical strategies for attention, hyperactivity, impulsivity, and executive function struggles at home and school.</p>
      <p class="text-lg font-bold text-brand-gold mb-6">USD 95 / AUD 145</p>
      <a href="/book" class="inline-block bg-brand-navy text-white px-8 py-4 rounded-lg font-bold hover:bg-blue-900 transition-colors shadow-md">Book Consultation</a>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700 space-y-12">

      <!-- 2. This is right for you if -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">This is right for you if</h2>
        <ul>
          <li>Your child has a recent ADHD diagnosis and you need a home plan.</li>
          <li>You are waiting for an assessment but need strategies right now.</li>
          <li>You feel exhausted managing your child's daily routines.</li>
          <li>You need help communicating your child's needs to their school.</li>
        </ul>
      </section>

      <!-- 3. Common concerns parents bring -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">Common concerns parents bring</h2>
        <ul>
          <li>Morning routine battles and refusing to get dressed.</li>
          <li>Homework refusal or taking hours to do simple tasks.</li>
          <li>Screen transitions resulting in meltdowns.</li>
          <li>Child not following instructions or seeming to ignore you.</li>
          <li>Emotional outbursts that escalate quickly.</li>
          <li>Teacher complaints about fidgeting or distraction.</li>
        </ul>
      </section>

      <!-- 4. What we do in the session -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What we do in the session</h2>
        <p>We review your specific challenges, analyze what is triggering the behavior or resistance, and map out a practical intervention. We focus heavily on executive functioning—how to adapt the environment so your child can succeed.</p>
      </section>

      <!-- 5. What you leave with -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What you leave with</h2>
        <p>You will leave with a clear, step-by-step action plan. This might include a custom morning routine structure, a script for how to respond during an outburst, or a list of specific accommodations to ask the school for.</p>
      </section>

      <!-- 6. What this service does not include -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What this service does not include</h2>
        <ul>
          <li>Medical diagnosis of ADHD.</li>
          <li>Medication prescription or management.</li>
          <li>Direct therapy with the child (this is parent guidance).</li>
          <li>Emergency crisis intervention.</li>
        </ul>
      </section>

      <!-- 7. Related services -->
      <section class="bg-gray-50 p-6 rounded-xl border border-gray-200">
        <h3 class="text-xl font-bold text-brand-navy mb-4">Related Services</h3>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/services/behaviour-planning" class="text-brand-trust font-bold hover:underline">Behaviour Planning &rarr;</a>
          <a href="/services/school-consultation" class="text-brand-trust font-bold hover:underline">School Consultation &rarr;</a>
          <a href="/report-review" class="text-brand-trust font-bold hover:underline">Report Review &rarr;</a>
        </div>
      </section>

      <!-- 8. FAQ section -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-4 mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Do you diagnose ADHD online?</h4>
            <p class="text-sm">No. Online consultation is for parent guidance, not formal medical diagnosis. We help you manage the symptoms at home.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">What if we already have a diagnosis?</h4>
            <p class="text-sm">Perfect. Our guidance sessions focus purely on action—routines, behavior responses, and school planning based on your existing report.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Can you help with school IEPs?</h4>
            <p class="text-sm">Yes, we can help you prepare for the meeting and suggest reasonable accommodations to request.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Is my child involved in the session?</h4>
            <p class="text-sm">No, this is a parent-focused session to equip you with strategies to use at home.</p>
          </div>
        </div>
      </section>

      <!-- 9. CTA block -->
      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Ready for clarity and a clear plan?</h3>
        <p class="mb-6">Book your consultation today and take the first step towards a calmer home.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/book" class="bg-brand-navy text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">Book ADHD Support</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
