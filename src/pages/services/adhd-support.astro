---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'ADHD Support', href: '/services/adhd-support' }
];
---

<BaseLayout title="ADHD Support & Parent Guidance | Rabbia Psychologist" description="Online parent guidance for ADHD routines, executive function, school support, and emotional regulation.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <div class="mt-8 mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">ADHD Support & Parent Guidance</h1>
      <p class="text-xl text-gray-700">Practical strategies for attention, hyperactivity, impulsivity, and executive function struggles at home and school.</p>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700">
      <h2 class="text-2xl font-bold text-brand-navy">Signs Parents May Notice</h2>
      <ul>
        <li>Difficulty getting ready for school without constant reminders.</li>
        <li>Homework battles, procrastination, or rushing through assignments.</li>
        <li>Extreme reactions when told "no" or when transitioning off screens.</li>
        <li>Forgetting instructions immediately after hearing them.</li>
        <li>Constant fidgeting or inability to stay seated during meals.</li>
      </ul>

      <h2 class="text-2xl font-bold text-brand-navy">How We Support Families</h2>

      <h3>1. Home Routine Support</h3>
      <p>We work together to design visual schedules and structured transitions that reduce friction during the morning rush and bedtime.</p>

      <h3>2. Executive Function Support</h3>
      <p>Strategies to help your child start tasks, organize their belongings, and improve their working memory using practical environmental tweaks.</p>

      <h3>3. Emotional Regulation</h3>
      <p>Understanding the link between ADHD and intense emotions. We'll map out a plan for how you should respond during a meltdown vs. a tantrum.</p>

      <h3>4. School Support</h3>
      <p>Translating home strategies into classroom accommodations. We help you prepare for teacher meetings so you know exactly what supports to ask for.</p>

      <h2 class="text-2xl font-bold text-brand-navy">Frequently Asked Questions</h2>
      <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 mt-4">
        <h4 class="font-bold text-brand-navy">Do you diagnose ADHD online?</h4>
        <p class="mb-4">No. Online consultation is for parent guidance, not formal medical diagnosis. If you need a diagnosis for medication or legal school accommodations, we will guide you on who to see locally.</p>

        <h4 class="font-bold text-brand-navy">What if we already have a diagnosis?</h4>
        <p>Perfect. If you already have a report but don't know what to do next, our guidance sessions focus purely on action—routines, behavior responses, and school planning.</p>
      </div>

      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Ready for clarity and a clear plan?</h3>
        <p class="mb-6">Book an ADHD Support Consultation (USD 95 / AUD 145).</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/book" class="bg-brand-navy text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">Book ADHD Support</a>
          <a href="/pricing" class="bg-white text-brand-navy border-2 border-brand-navy px-6 py-3 rounded-lg font-bold hover:bg-gray-50 transition-colors">View All Pricing</a>
        </div>
      </div>

      <div class="mt-8 text-sm flex gap-4 justify-center">
        <a href="/services/behaviour-planning" class="text-brand-trust hover:underline">Behaviour Planning</a> |
        <a href="/services/school-consultation" class="text-brand-trust hover:underline">School Consultation</a> |
        <a href="/report-review" class="text-brand-trust hover:underline">Report Review</a>
      </div>
    </div>
  </div>
</BaseLayout>
