---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Behaviour Planning', href: '/services/behaviour-planning' }
];
---

<BaseLayout title="Behaviour Support Planning | Rabbia Psychologist" description="Structured home-based guidance to help families manage challenging behaviors, meltdowns, and transitions.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-4xl">
    <Breadcrumbs paths={breadcrumbs} />

    <!-- 1. Hero section -->
    <div class="mt-8 mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-4">Behaviour Support Planning</h1>
      <p class="text-xl text-gray-700 mb-4">Structured home-based guidance to help families manage challenging behaviors, meltdowns, and transitions.</p>
      <p class="text-lg font-bold text-brand-gold mb-6">USD 95 / AUD 145</p>
      <a href="/book" class="inline-block bg-brand-navy text-white px-8 py-4 rounded-lg font-bold hover:bg-blue-900 transition-colors shadow-md">Book Consultation</a>
    </div>

    <div class="prose prose-lg max-w-none text-gray-700 space-y-12">

      <!-- 2. This is right for you if -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">This is right for you if</h2>
        <ul>
          <li>You feel like you are walking on eggshells around your child.</li>
          <li>Traditional discipline methods are not working.</li>
          <li>Your child's behavior is impacting family life or school.</li>
          <li>You want to respond calmly but don't know how in the moment.</li>
        </ul>
      </section>

      <!-- 3. Common concerns parents bring -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">Common concerns parents bring</h2>
        <ul>
          <li>Aggression towards siblings or parents.</li>
          <li>Severe tantrums or meltdowns.</li>
          <li>Refusal to follow basic instructions.</li>
          <li>School complaints about disruptive behavior.</li>
          <li>Difficulties with screen time limits.</li>
          <li>Running away or unsafe behaviors.</li>
        </ul>
      </section>

      <!-- 4. What we do in the session -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What we do in the session</h2>
        <p>We work to understand the function of the behavior—what is your child trying to communicate? We look at triggers, how the environment might be contributing, and how current responses might be unintentionally maintaining the behavior.</p>
      </section>

      <!-- 5. What you leave with -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What you leave with</h2>
        <p>A structured behavior support plan. This includes preventative strategies, how to respond during the behavior (de-escalation), and how to teach a replacement skill.</p>
      </section>

      <!-- 6. What this service does not include -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-2">What this service does not include</h2>
        <ul>
          <li>Therapy for severe psychiatric conditions.</li>
          <li>Emergency or crisis intervention.</li>
          <li>Quick fixes or guarantees of immediate behavior change.</li>
          <li>Medical diagnosis.</li>
        </ul>
      </section>

      <!-- 7. Related services -->
      <section class="bg-gray-50 p-6 rounded-xl border border-gray-200">
        <h3 class="text-xl font-bold text-brand-navy mb-4">Related Services</h3>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/services/adhd-support" class="text-brand-trust font-bold hover:underline">ADHD Support &rarr;</a>
          <a href="/services/school-consultation" class="text-brand-trust font-bold hover:underline">School Consultation &rarr;</a>
          <a href="/parent-support" class="text-brand-trust font-bold hover:underline">Parent Consultation &rarr;</a>
        </div>
      </section>

      <!-- 8. FAQ section -->
      <section>
        <h2 class="text-2xl font-bold text-brand-navy border-b pb-4 mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">How long does it take to see changes?</h4>
            <p class="text-sm">Behavior change takes time and consistency. Depending on the complexity, you may see shifts in a few weeks, but lasting change requires ongoing commitment to the plan.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Will you talk to my child?</h4>
            <p class="text-sm">No. We work directly with parents to empower you to support your child in their everyday environment.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">What if my child's behavior is dangerous?</h4>
            <p class="text-sm">If your child is a danger to themselves or others, you must seek immediate local crisis or emergency medical support. Online consultation is not suitable for emergency care.</p>
          </div>
          <div class="border border-gray-200 rounded-lg p-4">
            <h4 class="font-bold text-brand-navy mb-2">Do you use punishment strategies?</h4>
            <p class="text-sm">We focus on proactive, positive behavior support—understanding the 'why' and teaching skills, rather than punitive measures.</p>
          </div>
        </div>
      </section>

      <!-- 9. CTA block -->
      <div class="bg-brand-cream p-8 rounded-xl border border-brand-gold mt-12 text-center">
        <h3 class="text-2xl font-bold text-brand-navy mb-4">Ready to create a calmer home environment?</h3>
        <p class="mb-6">Book your Behaviour Planning Session and get a clear path forward.</p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/book" class="bg-brand-navy text-white px-8 py-3 rounded-lg font-bold hover:bg-blue-900 transition-colors">Book Behaviour Support</a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
