---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Behaviour Planning for Children | Parent Guidance | Rabbia Psychologist";
const description = "Parent guidance for child behavior concerns, emotional outbursts, routines, transitions, school behavior, attention difficulties, and home-based behavior planning.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Behaviour Planning",
  "provider": {
    "@type": "Organization",
    "name": "Rabbia Psychologist Child Development Services",
    "employee": {
      "@type": "Person",
      "name": "Rabbia Ashraf",
      "jobTitle": "Clinical Psychologist"
    }
  },
  "areaServed": "Worldwide",
  "serviceType": "Parent Guidance and Developmental Support",
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "url": "https://www.rabbiapsychologist.com/pricing"
  }
};
---

<BaseLayout title={title} description={description} schema={schema}>
  <div class="bg-brand-cream py-16 lg:py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Behaviour Planning for Children</h1>
      <p class="text-xl text-gray-700 leading-relaxed">
        Child behavior is often a form of communication. When a child is having frequent outbursts, refusing routines, struggling with transitions, showing aggression, avoiding schoolwork, or becoming emotionally overwhelmed, parents need practical guidance rather than blame. Behaviour planning helps families understand what may be behind the behavior and how to respond consistently at home and school.
      </p>
      <div class="mt-8 flex justify-center space-x-4">
        <a href="/book" class="inline-block px-8 py-4 bg-brand-navy text-white rounded-lg font-bold text-lg hover:bg-blue-900 transition-all shadow-lg">Book Behaviour Planning Consultation &rarr;</a>
        <a href="/resources" class="inline-block px-8 py-4 bg-white text-brand-navy border border-gray-300 rounded-lg font-bold text-lg hover:bg-gray-50 transition-all shadow-sm">View Parent Resources</a>
      </div>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <section class="mb-12">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">This support may help if your child</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Has frequent tantrums or emotional outbursts</li>
          <li>Refuses routines, homework, or instructions</li>
          <li>Becomes aggressive, impulsive, or easily frustrated</li>
          <li>Struggles with transitions or changes in routine</li>
          <li>Has behavior concerns at school</li>
          <li>Has ASD, ADHD, developmental delay, or learning-related concerns</li>
          <li>Needs a practical home behavior plan</li>
        </ul>
      </section>

      <section class="mb-12">
        <h2 class="text-3xl font-bold text-brand-navy mb-6">What we focus on</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Understanding triggers behind behavior</li>
          <li>Parent response planning</li>
          <li>Home routine structure</li>
          <li>Positive behavior support</li>
          <li>Emotional regulation strategies</li>
          <li>School behavior support discussion</li>
          <li>Reducing confusion and inconsistency in daily handling</li>
        </ul>
      </section>

      <section class="mb-12 bg-brand-cream border border-brand-sky rounded-xl p-8">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Behaviour planning may include</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Identifying common triggers</li>
          <li>Planning routines and visual supports</li>
          <li>Setting realistic expectations</li>
          <li>Creating simple parent response strategies</li>
          <li>Supporting emotional regulation</li>
          <li>Planning follow-up steps if behavior is severe or complex</li>
        </ul>
      </section>

      <div class="bg-gray-50 border-l-4 border-brand-trust p-6 mb-12 rounded-r-lg">
        <p class="text-sm text-gray-600 italic">
          <strong>Important note:</strong> Behaviour planning is parent guidance and developmental support. It does not replace emergency care, crisis intervention, medical treatment, or specialized in-person intervention when required.
        </p>
      </div>

      <div class="text-center">
        <a href="/book" class="inline-block px-8 py-4 bg-brand-trust text-white rounded-lg font-bold text-lg hover:bg-blue-700 transition-all shadow-lg">Book Behaviour Planning Consultation &rarr;</a>
      </div>
    </div>
  </div>
</BaseLayout>
