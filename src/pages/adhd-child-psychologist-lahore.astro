---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';
---

<Layout title="ADHD Child Psychologist Lahore">
  <SEO
    title="ADHD Child Psychologist Lahore | Assessment & Coaching"
    description="Specialized ADHD assessments, executive function coaching, and behavior support in Lahore, Pakistan."
  />
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">ADHD Support & Assessment in Lahore</h1>
      <p class="text-xl text-gray-700 mb-8 border-l-4 border-brand-sky pl-4">
        Expert evaluation and management strategies for Attention-Deficit/Hyperactivity Disorder.
      </p>
      <BookingCTA />
    </div>
  </div>
  <Footer />
  <StickyMobileBookingCTA />
</Layout>
