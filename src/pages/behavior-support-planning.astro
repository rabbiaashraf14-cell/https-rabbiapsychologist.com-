---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Behavior Support Planning', href: '/behavior-support-planning' }
];
---

<Layout title="Behavior Support Planning">
  <SEO
    title="Custom Behavior Support Planning for Children"
    description="Developing comprehensive, proactive behavior support plans based on functional behavior analysis and positive reinforcement."
  />
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Behavior Support Planning</h1>
      <p class="text-xl text-gray-700 mb-12 border-l-4 border-brand-sky pl-4">
        Moving beyond punishment and rewards to develop comprehensive plans that address the root cause of challenging behaviors.
      </p>
      <div class="prose prose-lg text-gray-700 max-w-none">
        <p>Every behavior is a form of communication. When we understand what a child is trying to achieve (or avoid) through a specific behavior, we can teach them more adaptive ways to meet that need.</p>
        <div class="bg-gray-50 p-6 rounded-xl my-8 border border-gray-200">
          <h3 class="text-xl font-bold text-brand-navy mb-4">The Planning Process:</h3>
          <ol class="list-decimal pl-6 space-y-4">
            <li><strong>Functional Analysis:</strong> We work together to track and analyze the antecedents (what happens before) and consequences (what happens after) of the target behavior.</li>
            <li><strong>Hypothesis Development:</strong> We determine the function of the behavior (e.g., escape, attention, sensory access).</li>
            <li><strong>Proactive Strategies:</strong> Modifying the environment or routine to prevent the behavior from occurring.</li>
            <li><strong>Skill Teaching:</strong> Identifying and teaching replacement behaviors that serve the same function.</li>
            <li><strong>Reactive Strategies:</strong> Establishing a safe, consistent plan for how to respond when the challenging behavior does occur.</li>
          </ol>
        </div>
      </div>
    </div>
    <BookingCTA />
  </div>
  <Footer />
  <StickyMobileBookingCTA />
</Layout>
