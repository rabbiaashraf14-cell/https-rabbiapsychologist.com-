---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ResearchCard from '../components/ResearchCard.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'About', href: '/about' },
  { name: 'Research Hub', href: '/research-hub' }
];
---

<Layout title="Research Hub">
  <SEO
    title="Research & Publications | Child Psychology"
    description="Explore peer-reviewed research and publications by Rabbia Ashraf in the field of child psychology and development."
  />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Publications & Research</h1>
      <p class="text-xl text-gray-700 mb-12">
        My clinical practice is deeply informed by active participation in scientific research. Below is a selection of peer-reviewed publications.
      </p>

      <div class="space-y-6">
        <ResearchCard
          title="Understanding Early Interventions in Autism"
          journal="Journal of Child Psychology"
          year="2023"
        />
        <ResearchCard
          title="Efficacy of Behavioral Strategies for ADHD"
          journal="Journal of Child Psychology"
          year="2022"
        />
        <!-- Note: Real publication links to PLOS ONE, Cureus, etc., will be added here once verified -->
      </div>
    </div>
  </div>
  <StickyMobileBookingCTA />
</Layout>
