---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Resources', href: '/resources' },
  { name: 'Free Downloads', href: '/free-downloads' }
];
---

<Layout title="Free Downloads">
  <SEO
    title="Free Resources & Checklists for Parents"
    description="Download free visual schedules, early signs checklists, and behavior tracking sheets."
  />
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Free Downloads</h1>
      <p class="text-xl text-gray-700 mb-12">
        Start implementing foundational strategies today with our free, accessible tools.
      </p>

      <div class="bg-gray-50 p-8 rounded-xl text-center border border-gray-200">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">Downloads currently being updated</h2>
        <p class="text-gray-600 mb-6">We are organizing our free resource library. Check back soon for checklists and templates.</p>
      </div>
    </div>
  </div>
  <Footer />
  <StickyMobileBookingCTA />
</Layout>
