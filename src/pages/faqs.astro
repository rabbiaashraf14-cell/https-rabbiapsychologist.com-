---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Resources', href: '/resources' },
  { name: 'FAQs', href: '/faqs' }
];

const faqs = [
  {
    question: "Do you provide online consultations globally?",
    answer: "Yes, I provide online parent consultation and educational support for families worldwide, including the US, UK, Australia, Canada, and the Gulf countries. Please note that international sessions are strictly educational parent-guidance and support-planning, not regulated clinical therapy or diagnosis."
  },
  {
    question: "What is the difference between parent training and child therapy?",
    answer: "In parent training, the focus is on equipping you with the tools to manage behaviors and support your child's development at home. Research shows that for many behavioral challenges, training parents is highly effective because you spend the most time with your child and can implement strategies consistently."
  },
  {
    question: "Do you assess for Autism or ADHD online?",
    answer: "No. Formal psychological assessments, diagnosis, and psychological testing require structured, standardized, often in-person evaluations. I provide formal assessments locally in Lahore. For international clients, I provide screening discussions and guidance on what to look for, but not formal diagnoses."
  },
  {
    question: "How many sessions will we need?",
    answer: "This varies entirely based on your goals. Some parents only need 1-2 sessions to troubleshoot a specific routine issue. Others opt for a structured 4-6 session package for comprehensive behavior planning."
  }
];
---

<Layout title="Frequently Asked Questions">
  <SEO
    title="FAQs | Consultation & Services Info"
    description="Answers to common questions about our global online consultations, parent training, and local assessment services."
  />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6 text-center">Frequently Asked Questions</h1>
      <p class="text-xl text-gray-700 mb-12 text-center">
        Find quick answers regarding our services, approach, and booking process.
      </p>

      <FAQAccordion faqs={faqs} />

      <div class="mt-16 text-center">
        <p class="text-lg text-gray-700 mb-6">Still have questions?</p>
        <a href="/contact" class="inline-block bg-brand-sky text-brand-navy px-8 py-3 rounded-full font-bold hover:bg-blue-100 transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </div>
  <StickyMobileBookingCTA />
</Layout>
