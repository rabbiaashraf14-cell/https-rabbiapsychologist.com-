---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Privacy Policy', href: '/privacy-policy' }
];
---

<Layout title="Privacy Policy">
  <SEO
    title="Privacy Policy | Rabbia Ashraf"
    description="Privacy policy and data protection information for website users and clients."
  />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Privacy Policy</h1>
      <div class="prose prose-lg text-gray-700 max-w-none">
        <p>Your privacy is important to us. This policy outlines how we collect, use, and protect your information.</p>
        <h2 class="text-2xl font-bold text-brand-navy mt-8">Information Collection</h2>
        <p>We collect information you provide directly to us when booking consultations or filling out contact forms.</p>
        <h2 class="text-2xl font-bold text-brand-navy mt-8">Data Usage</h2>
        <p>Information is used solely for the purpose of providing educational and consultation services.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Live Chat Policy</h2>
        <ul>
          <li>The website uses Tawk.to live chat.</li>
          <li>Chat may collect user-entered information and technical metadata.</li>
          <li>Parents should avoid submitting sensitive child information through chat.</li>
          <li>Emergency concerns should go to local emergency services, nearest hospital, or local licensed professional.</li>
        </ul>

        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 my-12">
          <h3 class="text-xl font-bold text-brand-navy mb-4">Live Chat Privacy & Safety Notice</h3>
          <p class="text-gray-700 mb-4">
            Live chat is for general questions, booking guidance, and support navigation only. Please do not share emergency concerns, full medical records, diagnosis documents, or sensitive child information through live chat. For urgent concerns, contact local emergency services or the nearest hospital.
          </p>
          <p class="text-gray-700 text-sm">
            Note: Tawk.to live chat is not suitable for exchanging regulated health information.
          </p>
        </div>

        <p class="text-sm mt-12 text-gray-500">Last updated: [Date]</p>
      </div>
    </div>
  </div>
  <StickyMobileBookingCTA />
</Layout>
