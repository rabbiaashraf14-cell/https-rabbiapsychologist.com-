---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Privacy Policy', href: '/privacy-policy' }
];
---

<Layout title="Privacy Policy">
  <SEO
    title="Privacy Policy | Rabbia Ashraf"
    description="Privacy policy and data protection information for website users and clients."
  />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Privacy Policy</h1>
      <div class="prose prose-lg text-gray-700 max-w-none">
        <p>Your privacy is important to us. This policy outlines how we collect, use, and protect your information.</p>

        <div class="bg-gray-100 p-6 rounded-lg mb-8 border border-gray-300">
          <h2 class="text-xl font-bold text-brand-navy mt-0">Important Clinical Services Notice</h2>
          <p class="font-medium text-brand-navy">
            Rabbia Psychologist Child Development Services provides parent guidance, educational resources, developmental support planning, report review support, school guidance, and between-session parent support programs.
          </p>
          <p class="font-medium text-brand-navy mt-4">
            These services are not emergency services.
          </p>
          <p class="font-medium text-brand-navy mt-4">
            Online support does not replace local medical, psychological, educational, legal, crisis, or school-based services.
          </p>
          <p class="font-medium text-brand-navy mt-4">
            Between-session support programs are designed to support parent understanding, home carryover, routines, and practical implementation. They do not guarantee outcomes and do not replace direct therapy, diagnosis, emergency care, or local regulated services where required.
          </p>
          <p class="font-medium text-brand-navy mt-4">
            Regulated services are provided only within the professional scope, credentials, and legal requirements of the professional and client location.
          </p>
          <p class="text-sm text-gray-600 mt-4 italic">
          </p>
        </div>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Information Collection</h2>
        <p>We may collect the following information you provide directly to us:</p>
        <ul>
          <li>Client name</li>
          <li>Email address</li>
          <li>Phone and WhatsApp number</li>
          <li>Booking details</li>
          <li>Payment-related information</li>
          <li>Assessment and consultation information</li>
          <li>Contact form submissions</li>
        </ul>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Website Analytics and Cookies</h2>
        <p>We collect standard website analytics and use cookies to improve user experience and monitor site performance.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">How Personal Information is Used</h2>
        <p>Information is used solely for the purpose of communicating with you, managing bookings, and providing educational and consultation services.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">How Information is Protected</h2>
        <p>We take appropriate security measures to protect your personal information against unauthorized access or disclosure.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Third-Party Service Providers and Payment Gateway Processing</h2>
        <p>We use trusted third-party service providers to facilitate our services. This includes payment gateway processing. <strong>Please note that this website does not directly store full debit or credit card information.</strong> All payments are processed securely through authorized third-party payment gateways.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Data Retention</h2>
        <p>We retain your personal information only as long as necessary to fulfill the purposes for which it was collected and to comply with legal requirements.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Client Rights</h2>
        <p>You have the right to request access to, correction of, or deletion of your personal data. Please reach out via our contact details for any such requests.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Contact Details</h2>
        <p>If you have any questions or concerns about this privacy policy, please visit our <a href="/contact" class="text-brand-navy underline">Contact page</a>.</p>

        <h2 class="text-2xl font-bold text-brand-navy mt-8">Live Chat or WhatsApp Communication</h2>
        <ul>
          <li>The website uses live chat and WhatsApp for communication.</li>
          <li>Chat may collect user-entered information and technical metadata.</li>
          <li>Parents should avoid submitting sensitive child information through chat.</li>
          <li>Emergency concerns should go to local emergency services, nearest hospital, or local licensed professional.</li>
        </ul>

        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 my-12">
          <h3 class="text-xl font-bold text-brand-navy mb-4">Live Chat Privacy & Safety Notice</h3>
          <p class="text-gray-700 mb-4">
            Live chat is for general questions, booking guidance, and support navigation only. Please do not share emergency concerns, full medical records, diagnosis documents, or sensitive child information through live chat. For urgent concerns, contact local emergency services or the nearest hospital.
          </p>
          <p class="text-gray-700 text-sm">
            Note: Tawk.to live chat is not suitable for exchanging regulated health information.
          </p>
        </div>

        <p class="text-sm mt-12 text-gray-500">Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
      </div>
    </div>
  </div>
  <StickyMobileBookingCTA />
</Layout>
