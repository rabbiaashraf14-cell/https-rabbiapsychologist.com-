---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';
---

<Layout title="Child Psychologist Lahore">
  <SEO
    title="Clinical Child Psychologist in Lahore | Rabbia Ashraf"
    description="Expert clinical child psychologist in Lahore providing local assessments, autism support, ADHD guidance, and behavioral therapy."
  />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Clinical Child Psychologist in Lahore</h1>
      <p class="text-xl text-gray-700 mb-8 border-l-4 border-brand-sky pl-4">
        Local, in-person psychological assessments, parent training, and evidence-based interventions for children in Lahore, Pakistan.
      </p>
      <BookingCTA />
    </div>
  </div>
  <StickyMobileBookingCTA />
</Layout>
