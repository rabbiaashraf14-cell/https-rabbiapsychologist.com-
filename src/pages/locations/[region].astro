---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import BookingCTA from '../../components/BookingCTA.astro';
import SEO from '../../components/seo/SEO.astro';
import Schema from '../../components/seo/Schema.astro';

import { countries } from '../../data/locations/countries';
import { getFeaturedLocationsByGroup, getRegionSlug, type PublicCityProjection } from '../../data/locations/locationHelpers';

export function getStaticPaths() {
  const allRegions = [
    { name: "North America", slug: "north-america", group: "us-cities" },
    { name: "Latin America and the Caribbean", slug: "latin-america-caribbean", group: "globalCities" },
    { name: "United Kingdom & Ireland", slug: "uk-ireland", group: "uk-cities" },
    { name: "Western Europe", slug: "western-europe", group: "globalCities" },
    { name: "Northern Europe", slug: "northern-europe", group: "globalCities" },
    { name: "Southern Europe", slug: "southern-europe", group: "globalCities" },
    { name: "Central & Eastern Europe", slug: "central-eastern-europe", group: "globalCities" },
    { name: "Middle East and Gulf", slug: "middle-east-gulf", group: "gulf-cities" },
    { name: "South Asia", slug: "south-asia", group: "pakistani-cities" },
    { name: "Southeast Asia", slug: "southeast-asia", group: "southeast-asian-cities" },
    { name: "East Asia", slug: "east-asia", group: "globalCities" },
    { name: "Central Asia", slug: "central-asia", group: "globalCities" },
    { name: "Africa", slug: "africa", group: "globalCities" },
    { name: "Australia and New Zealand", slug: "australia-new-zealand", group: "australian-cities" },
    { name: "Pacific and Island Regions", slug: "pacific-islands", group: "globalCities" }
  ];

  return allRegions.map(region => ({
    params: { region: region.slug },
    props: { region }
  }));
}

const { region } = Astro.props;
const regionCountries = countries.filter(c => getRegionSlug(c.countrySlug, c.publicationRegion) === region.slug && c.status === 'planned');
const featuredCities = getFeaturedLocationsByGroup(region.group, 8).filter(city => city.regionSlug === region.slug);

// SEO & Schema
const title = `Online Parent Guidance in ${region.name} | Rabbia Psychologist`;
const description = `Parent guidance and child development support for families in ${region.name}. Get practical help for ADHD, autism, behaviour, and emotional regulation.`;
const canonicalUrl = `https://www.rabbiapsychologist.com/locations/${region.slug}`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://www.rabbiapsychologist.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Locations",
      "item": "https://www.rabbiapsychologist.com/locations"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": region.name,
      "item": canonicalUrl
    }
  ]
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${region.name} Locations Directory`,
  "description": description
};
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <SEO slot="head" title={title} description={description} canonicalUrl={canonicalUrl} />
  <Schema slot="head" schema={breadcrumbSchema} />
  <Schema slot="head" schema={collectionSchema} />

  {/* REGION HERO */}
  <section class="bg-brand-navy text-white pt-32 pb-20 rounded-b-[40px] relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/noise.png')] opacity-5 mix-blend-overlay"></div>
    <div class="container mx-auto px-4 relative z-10 text-center max-w-4xl">
      <nav class="mb-6 flex justify-center text-sm font-medium text-brand-mist/80" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li class="inline-flex items-center">
            <a href="/" class="hover:text-brand-gold transition-colors">Home</a>
          </li>
          <li>
            <div class="flex items-center">
              <svg class="w-3 h-3 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/></svg>
              <a href="/locations" class="hover:text-brand-gold transition-colors">Locations</a>
            </div>
          </li>
          <li aria-current="page">
            <div class="flex items-center">
              <svg class="w-3 h-3 mx-1" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 6 10"><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 9 4-4-4-4"/></svg>
              <span class="ml-1 text-white">{region.name}</span>
            </div>
          </li>
        </ol>
      </nav>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-white leading-tight">
        Parent Support in {region.name}
      </h1>
      <p class="text-lg md:text-xl text-brand-mist mb-10 max-w-3xl mx-auto leading-relaxed">
        We provide online consultation and practical developmental guidance for families navigating parenting challenges, behaviour concerns, and school support in {region.name}.
      </p>
      <div class="flex justify-center">
        <a href="/book" class="bg-brand-gold text-brand-navy font-bold py-4 px-8 rounded-full hover:bg-white hover-lift transition-all shadow-lg text-center text-lg">
          Book Consultation
        </a>
      </div>
    </div>
  </section>

  {/* REGIONAL CONTEXT */}
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
       <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
         <div>
           <h2 class="text-3xl font-bold text-brand-navy mb-6">Expert Guidance for Families in {region.name}</h2>
           <p class="text-gray-700 leading-relaxed mb-6">
             Finding the right support for your child's development can be overwhelming. Our online parent consultations offer a practical space to discuss your concerns, review existing reports, and develop actionable strategies tailored to your family's routine.
           </p>
           <p class="text-gray-700 leading-relaxed mb-6">
             Whether you are waiting for a local assessment or need help managing daily challenging behaviours, we bridge the gap with professional, evidence-based guidance.
           </p>

           <div class="bg-brand-warm-white p-6 rounded-[20px] border border-brand-mist/50">
             <h3 class="font-bold text-brand-navy mb-3">Available Online Services:</h3>
             <ul class="space-y-2 text-sm text-gray-700">
               <li class="flex items-center gap-2">
                 <svg class="w-4 h-4 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                 Parent Behaviour Guidance
               </li>
               <li class="flex items-center gap-2">
                 <svg class="w-4 h-4 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                 Psychological Report Review
               </li>
               <li class="flex items-center gap-2">
                 <svg class="w-4 h-4 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                 School Strategy Preparation
               </li>
             </ul>
           </div>
         </div>

         {/* INTERNATIONAL DISCLAIMER - REQUIRED */}
         <div class="bg-gray-50 border border-gray-200 rounded-[32px] p-8 shadow-sm">
           <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-brand-navy mb-4 shadow-sm">
             <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
           </div>
           <h3 class="text-xl font-bold text-brand-navy mb-3">Important Service Information</h3>
           <p class="text-gray-700 text-sm leading-relaxed mb-4">
             Rabbia Psychologist provides educational parent consultation and developmental guidance.
             Website content is for educational purposes only and does not replace emergency care, medical diagnosis, or direct clinical assessment.
           </p>
           <p class="text-gray-700 text-sm leading-relaxed">
             Regulated services are provided only within the professional scope, credentials, and legal requirements of the professional and client location. Families are encouraged to seek local, regulated healthcare providers for formal diagnosis and treatment.
           </p>
         </div>
       </div>
    </div>
  </section>

  {/* FEATURED CITIES IN REGION */}
  {featuredCities.length > 0 && (
    <section class="py-24 bg-brand-warm-white">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Supporting Parents in {region.name}</h2>
          <p class="text-lg text-gray-700 max-w-2xl mx-auto">Online guidance is available for families across the region.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {featuredCities.map(city => (
            <a href={city.destinationUrl} class="bg-white p-6 rounded-[20px] shadow-sm hover-lift border border-gray-100 group">
              <h3 class="text-lg font-bold text-brand-navy mb-1 group-hover:text-brand-gold transition-colors">{city.cityName}</h3>
              <p class="text-xs text-gray-500">{city.countryName}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* COUNTRIES DIRECTORY */}
  {regionCountries.length > 0 && (
    <section class="py-24 bg-white border-t border-gray-100">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Explore Support by Country</h2>
          <p class="text-lg text-gray-700 max-w-2xl mx-auto">Find specific parent guidance information for countries in {region.name}.</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {regionCountries.map(country => (
            <a href={`/locations/${country.countrySlug}`} class="bg-brand-warm-white p-4 rounded-[16px] shadow-sm hover-lift text-center border border-brand-mist/50 group">
              <span class="font-bold text-brand-navy group-hover:text-brand-gold transition-colors">{country.countryName}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <BookingCTA
    title="Ready to Find Practical Solutions?"
    subtitle="Book an online consultation to discuss your child's needs and create a tailored plan for home support."
  />
</Layout>
