---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';

const breadcrumbs = [
  { name: 'Service Boundaries', href: '/service-boundaries' }
];
---
<Layout title="Service Boundaries & Emergency Care Policy">
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-4xl font-bold text-brand-navy mb-6">Service Boundaries</h1>

    <div class="bg-red-50 border border-red-200 p-6 rounded-lg mb-8 text-red-800">
      <h2 class="text-xl font-bold mb-2">Not for Emergencies</h2>
      <p>
        This platform is not suitable for emergencies, self-harm risk, abuse crisis, medical emergencies, or immediate safety concerns. In urgent situations, contact local emergency services, the nearest hospital, or a local licensed mental health professional immediately.
      </p>
    </div>

    <div class="prose prose-lg text-gray-700">
      <h2 class="text-2xl font-bold text-brand-navy mt-8">What We Provide</h2>
      <ul>
        <li>Parent guidance and education</li>
        <li>Consultation for behavior, ADHD, and ASD strategies</li>
        <li>Referral pathway guidance</li>
        <li>Access to digital learning resources</li>
        <li>Local psychological assessments (only in specific legal jurisdictions such as Lahore, Pakistan)</li>
      </ul>

      <h2 class="text-2xl font-bold text-brand-navy mt-8">What We Do Not Provide</h2>
      <ul>
        <li>Crisis intervention or emergency care</li>
        <li>Prescription of medication or medical management</li>
        <li>Custody evaluations or forensic testimony</li>
        <li>Regulated global clinical therapy outside the provider's licensed jurisdiction</li>
      </ul>
    </div>
  </div>
</Layout>
