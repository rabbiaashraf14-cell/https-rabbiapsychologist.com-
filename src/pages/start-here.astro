---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Start Here | Rabbia Psychologist — NeuroCare Child Development Services"
  description="Not sure where to begin? Start here to understand which Rabbia Psychologist — NeuroCare Child Development Services support pathway may fit your family’s developmental, behavioural, school, ASD, ADHD, or report-review concerns."
>
  <div class="bg-brand-cream py-16 lg:py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Not Sure Where to Begin?</h1>
      <p class="text-xl text-gray-700 leading-relaxed">
        If your child’s behaviour, school feedback, developmental progress, ASD/ADHD concerns, or report results feel confusing, this page helps you choose the right starting point.
      </p>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-3xl font-bold text-brand-navy mb-8 text-center">Find Your Support Pathway</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-6 bg-brand-cream border border-brand-sky rounded-lg hover:shadow-md transition">
          <h3 class="text-xl font-bold text-brand-navy mb-3">Parent Support & Guidance</h3>
          <p class="text-gray-700 mb-4">Navigating daily routines, behavioral challenges, or understanding developmental milestones? Start here to explore how we guide parents step-by-step.</p>
          <a href="/parent-support" class="text-brand-trust font-bold hover:underline">Explore Parent Support &rarr;</a>
        </div>

        <div class="p-6 bg-brand-cream border border-brand-sky rounded-lg hover:shadow-md transition">
          <h3 class="text-xl font-bold text-brand-navy mb-3">Between-Session Programs</h3>
          <p class="text-gray-700 mb-4">Need structured activities and support to maintain momentum while waiting for therapy or between formal sessions? We provide targeted guidance.</p>
          <a href="/between-session-programs" class="text-brand-trust font-bold hover:underline">Explore Programs &rarr;</a>
        </div>

        <div class="p-6 bg-brand-cream border border-brand-sky rounded-lg hover:shadow-md transition">
          <h3 class="text-xl font-bold text-brand-navy mb-3">School & IEP Help</h3>
          <p class="text-gray-700 mb-4">Confused by school feedback or IEP meetings? Let's turn academic concerns into a practical support plan you can take to the classroom.</p>
          <a href="/school-iep-help" class="text-brand-trust font-bold hover:underline">Get School Help &rarr;</a>
        </div>

        <div class="p-6 bg-brand-cream border border-brand-sky rounded-lg hover:shadow-md transition">
          <h3 class="text-xl font-bold text-brand-navy mb-3">Report Review</h3>
          <p class="text-gray-700 mb-4">Received an assessment report but unsure what it means for daily life? We help you translate clinical language into actionable strategies.</p>
          <a href="/report-review" class="text-brand-trust font-bold hover:underline">Review a Report &rarr;</a>
        </div>

        <div class="p-6 bg-brand-cream border border-brand-sky rounded-lg hover:shadow-md transition">
          <h3 class="text-xl font-bold text-brand-navy mb-3">International Families</h3>
          <p class="text-gray-700 mb-4">Living abroad and struggling to find culturally responsive guidance? We support overseas Pakistani families globally.</p>
          <a href="/international-families" class="text-brand-trust font-bold hover:underline">International Support &rarr;</a>
        </div>

        <div class="p-6 bg-brand-cream border border-brand-sky rounded-lg hover:shadow-md transition">
          <h3 class="text-xl font-bold text-brand-navy mb-3">Resource Hub</h3>
          <p class="text-gray-700 mb-4">Looking for worksheets, visual schedules, or tracking tools to use right now? Browse our library of free and premium resources.</p>
          <a href="/resources" class="text-brand-trust font-bold hover:underline">Access Resources &rarr;</a>
        </div>
      </div>

      <div class="mt-16 text-center">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Ready to take the next step?</h2>
        <a href="/book" class="inline-block px-8 py-4 bg-brand-navy text-white rounded-lg font-bold text-lg hover:bg-blue-900 transition-all shadow-lg">
          Book a Consultation
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
