---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedHero from '../components/home/AnimatedHero.astro';
import TrustBadgeStrip from '../components/home/TrustBadgeStrip.astro';
import WhatNeuroCare Child Development ServicesProvides from '../components/home/WhatNeuroCare Child Development ServicesProvides.astro';
import BehaviorCommunicationVisualizer from '../components/home/BehaviorCommunicationVisualizer.astro';
import InteractiveServiceCards from '../components/home/InteractiveServiceCards.astro';
import RegionSupportSection from '../components/home/RegionSupportSection.astro';
import ParentJourneyTimeline from '../components/home/ParentJourneyTimeline.astro';
import ResourceVaultPreview from '../components/home/ResourceVaultPreview.astro';
import PricingPreview from '../components/home/PricingPreview.astro';
import ResearchCredibilitySection from '../components/home/ResearchCredibilitySection.astro';
import FAQPreview from '../components/home/FAQPreview.astro';
import FinalBookingCTA from '../components/home/FinalBookingCTA.astro';
import HomepageSchema from '../components/home/HomepageSchema.astro';

const title = "Rabbia Psychologist | NeuroCare Child Development Services";
const description = "Rabbia Psychologist — NeuroCare Child Development Services provides parent guidance, IEP help, report review, between-session support, and child development resources for families in Pakistan and abroad.";
---

<BaseLayout title={title} description={description}>
  <AnimatedHero />
  <TrustBadgeStrip />
  <WhatNeuroCare Child Development ServicesProvides />
  <BehaviorCommunicationVisualizer />
  <InteractiveServiceCards />
  <RegionSupportSection />
  <ParentJourneyTimeline />
  <ResourceVaultPreview />
  <ResearchCredibilitySection />
  <PricingPreview />
  <FAQPreview />
  <FinalBookingCTA />

  <HomepageSchema slot="head" />


<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Rabbia Psychologist — NeuroCare Child Development Services",
  "alternateName": "Rabbia Psychologist — NeuroCare Child Development Services",
  "url": "https://www.rabbiapsychologist.com",
  "logo": "https://www.rabbiapsychologist.com/brand/logo-primary.svg",
  "founder": {
    "@type": "Person",
    "name": "Rabbia Ashraf",
    "jobTitle": "clinical lead",
    "description": "Clinical Psychologist licensed in Pakistan"
  },
  "description": "Owner-led parent guidance, child development resources, school support, report review support, and between-session support programs for families in Pakistan and abroad."
}
</script>
</BaseLayout>
