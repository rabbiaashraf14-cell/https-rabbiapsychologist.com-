---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedHero from '../components/home/AnimatedHero.astro';
import TrustBadgeStrip from '../components/home/TrustBadgeStrip.astro';
import ParentChoiceSection from '../components/home/ParentChoiceSection.astro';
import BehaviorCommunicationVisualizer from '../components/home/BehaviorCommunicationVisualizer.astro';
import InteractiveServiceCards from '../components/home/InteractiveServiceCards.astro';
import ProviderPreviewSection from '../components/home/ProviderPreviewSection.astro';
import RegionSupportSection from '../components/home/RegionSupportSection.astro';
import ParentJourneyTimeline from '../components/home/ParentJourneyTimeline.astro';
import ResourceVaultPreview from '../components/home/ResourceVaultPreview.astro';
import PricingPreview from '../components/home/PricingPreview.astro';
import ResearchCredibilitySection from '../components/home/ResearchCredibilitySection.astro';
import FAQPreview from '../components/home/FAQPreview.astro';
import FinalBookingCTA from '../components/home/FinalBookingCTA.astro';
import HomepageSchema from '../components/home/HomepageSchema.astro';

const title = "NeuroNest Child Development Centre | Child Development & Parent Guidance";
const description = "Learn from parent-friendly resources, compare child development specialists, and book parent consultation for ASD, ADHD, behavior, school concerns, and developmental support.";
---

<BaseLayout title={title} description={description}>
  <section class="bg-brand-sky py-20 text-center">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl md:text-6xl font-bold text-brand-navy mb-6">Multidisciplinary Child Development Support for Growing Minds</h1>
      <p class="text-xl text-gray-700 max-w-3xl mx-auto mb-8">NeuroNest Child Development Centre helps families understand developmental, behavioural, emotional, learning, speech, sensory, and school-related concerns through parent guidance, specialist consultation pathways, and evidence-informed resources.</p>
      <div class="flex flex-wrap justify-center gap-3 mt-8">
        <span class="px-4 py-2 bg-white rounded-full text-sm font-medium text-brand-navy shadow-sm">Multidisciplinary Care</span>
        <span class="px-4 py-2 bg-white rounded-full text-sm font-medium text-brand-navy shadow-sm">Parent Guidance</span>
        <span class="px-4 py-2 bg-white rounded-full text-sm font-medium text-brand-navy shadow-sm">ASD & ADHD Support</span>
        <span class="px-4 py-2 bg-white rounded-full text-sm font-medium text-brand-navy shadow-sm">School Support</span>
        <span class="px-4 py-2 bg-white rounded-full text-sm font-medium text-brand-navy shadow-sm">Developmental Pathways</span>
        <span class="px-4 py-2 bg-white rounded-full text-sm font-medium text-brand-navy shadow-sm">Provider Choice</span>
        <span class="px-4 py-2 bg-white rounded-full text-sm font-medium text-brand-navy shadow-sm">Evidence-Informed Resources</span>
      </div>
    </div>
  </section>
  <TrustBadgeStrip />
  <ParentChoiceSection />
  <BehaviorCommunicationVisualizer />
  <InteractiveServiceCards />
  <ProviderPreviewSection />
  <RegionSupportSection />
  <ParentJourneyTimeline />
  <ResourceVaultPreview />
  <ResearchCredibilitySection />
  <PricingPreview />
  <FAQPreview />
  <FinalBookingCTA />

  <HomepageSchema slot="head" />


</BaseLayout>
