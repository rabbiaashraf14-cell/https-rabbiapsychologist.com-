---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import ServiceCard from '../components/ServiceCard.astro';
import BookingCTA from '../components/BookingCTA.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Rabbia Ashraf",
  "jobTitle": "Clinical Child Psychologist",
  "url": "https://rabbiapsychologist.com",
  "sameAs": [
    "https://www.linkedin.com/in/rabbiapsychologist"
  ]
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Rabbia Ashraf Multidisciplinary Child Development Centre",
  "url": "https://rabbiapsychologist.com",
  "description": "A multidisciplinary child development and neurodiversity centre providing evidence-informed parent consultation, developmental guidance, and support for international families."
};
---

<Layout title="Home">
  <SEO
    title="Multidisciplinary Child Development Centre | Autism & ADHD Support"
    description="Rabbia Ashraf offers evidence-informed parent consultation, developmental guidance, and assessment support for children, adolescents, and international families."
  />
  <Schema schema={personSchema} />
  <Schema schema={organizationSchema} />

  <DisclaimerBanner />
  <Header />

  <Hero
    title="Specialist developmental and psychological support for children, adolescents, and families."
    subtitle="Evidence-informed parent consultation, developmental guidance, assessment support, behaviour planning, school support, and multidisciplinary care for autism, ADHD, learning, speech, sensory, and emotional concerns."
    ctaText="Book a Consultation"
    secondaryCtaText="Not Sure Where to Start?"
  />

  <TrustStrip />

  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">Why Families Choose Our Centre</h2>
      <p class="text-xl text-gray-700 mb-8 max-w-3xl mx-auto">
        A multidisciplinary child development and neurodiversity centre dedicated to providing evidence-informed support.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
        <div class="text-left">
          <h3 class="text-xl font-bold text-brand-navy mb-3">Founder-led Clinical Service</h3>
          <p class="text-gray-600">Expert guidance led by Rabbia Ashraf, Clinical Psychologist, ensuring high standards of care.</p>
        </div>
        <div class="text-left">
          <h3 class="text-xl font-bold text-brand-navy mb-3">Multidisciplinary Care Model</h3>
          <p class="text-gray-600">Collaborative support from specialists tailored to your child's unique developmental needs.</p>
        </div>
        <div class="text-left">
          <h3 class="text-xl font-bold text-brand-navy mb-3">Child & Adolescent Focus</h3>
          <p class="text-gray-600">Dedicated solely to the developmental, behavioral, and emotional well-being of young minds.</p>
        </div>
        <div class="text-left">
          <h3 class="text-xl font-bold text-brand-navy mb-3">Parent-friendly Guidance</h3>
          <p class="text-gray-600">Empowering families with evidence-informed resources, practical strategies, and compassionate support.</p>
        </div>
        <div class="text-left">
          <h3 class="text-xl font-bold text-brand-navy mb-3">Online Support for International Families</h3>
          <p class="text-gray-600">Accessible developmental guidance and parent consultation from anywhere in the world, where appropriate.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">Conditions & Concerns We Support</h2>
      <p class="text-xl text-gray-700 mb-8 max-w-3xl mx-auto">
        We provide specialized guidance and intervention for a wide range of developmental and behavioral challenges.
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-8">
        <span class="bg-brand-sky text-brand-navy px-6 py-3 rounded-full font-medium shadow-sm">Autism</span>
        <span class="bg-brand-sky text-brand-navy px-6 py-3 rounded-full font-medium shadow-sm">ADHD</span>
        <span class="bg-brand-sky text-brand-navy px-6 py-3 rounded-full font-medium shadow-sm">Speech and language delay</span>
        <span class="bg-brand-sky text-brand-navy px-6 py-3 rounded-full font-medium shadow-sm">Learning difficulties</span>
        <span class="bg-brand-sky text-brand-navy px-6 py-3 rounded-full font-medium shadow-sm">Sensory concerns</span>
        <span class="bg-brand-sky text-brand-navy px-6 py-3 rounded-full font-medium shadow-sm">Behaviour challenges</span>
        <span class="bg-brand-sky text-brand-navy px-6 py-3 rounded-full font-medium shadow-sm">Emotional regulation</span>
        <span class="bg-brand-sky text-brand-navy px-6 py-3 rounded-full font-medium shadow-sm">School refusal</span>
        <span class="bg-brand-sky text-brand-navy px-6 py-3 rounded-full font-medium shadow-sm">Parenting challenges</span>
      </div>
    </div>
  </section>

  <section class="bg-brand-sky py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Core Services</h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto">Comprehensive support for your child's unique developmental journey.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <ServiceCard
          title="Parent Consultation"
          description="Initial guidance sessions to explore developmental and behavioral concerns safely."
          href="/services"
        />
        <ServiceCard
          title="Developmental Guidance"
          description="Targeted support for managing developmental milestones and behavioral goals."
          href="/services"
        />
        <ServiceCard
          title="Behaviour & Parenting Support"
          description="Evidence-informed strategies to manage challenges at home and in the community."
          href="/services"
        />
        <ServiceCard
          title="Report Review"
          description="Review of external assessments and clinical reports to plan supportive next steps."
          href="/services"
        />
        <ServiceCard
          title="School Support Planning"
          description="Collaborative strategies for IEP development and classroom accommodations."
          href="/services"
        />
        <ServiceCard
          title="Multidisciplinary Case Review"
          description="Comprehensive review of your child's needs by our specialized clinical team."
          href="/services"
        />
        <ServiceCard
          title="Training & Workshops"
          description="Educational sessions for parents, caregivers, and educators on neurodiversity."
          href="/training"
        />
      </div>
      <div class="text-center mt-12">
        <a href="/services" class="text-brand-navy font-bold hover:text-blue-700 inline-flex items-center">
          View all services
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">Our Multidisciplinary Team</h2>
      <p class="text-xl text-gray-700 mb-8 max-w-3xl mx-auto">
        A collaborative group of specialists ensuring comprehensive care from multiple clinical perspectives.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 mt-8">
        <div class="p-6 border border-brand-sky rounded-xl bg-gray-50 font-semibold text-brand-navy">Developmental Pediatricians</div>
        <div class="p-6 border border-brand-sky rounded-xl bg-gray-50 font-semibold text-brand-navy">Clinical Psychologists</div>
        <div class="p-6 border border-brand-sky rounded-xl bg-gray-50 font-semibold text-brand-navy">Counselling Psychologists</div>
        <div class="p-6 border border-brand-sky rounded-xl bg-gray-50 font-semibold text-brand-navy">Psychiatrists</div>
        <div class="p-6 border border-brand-sky rounded-xl bg-gray-50 font-semibold text-brand-navy">SNE / Special Needs Educators</div>
        <div class="p-6 border border-brand-sky rounded-xl bg-gray-50 font-semibold text-brand-navy">Occupational Therapists</div>
        <div class="p-6 border border-brand-sky rounded-xl bg-gray-50 font-semibold text-brand-navy">SLP / Speech & Language Pathologists</div>
        <div class="p-6 border border-brand-sky rounded-xl bg-gray-50 font-semibold text-brand-navy">Dietitians</div>
      </div>
    </div>
  </section>

  <section class="bg-brand-sky py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-6">Support for International Families</h2>
      <p class="text-lg text-gray-700 mb-6">
        We offer secure online developmental guidance and parent consultation for overseas Pakistani families and international parents.
      </p>
      <p class="text-md text-gray-600 italic">
        Please note: We do not provide licensed therapy, emergency support, or official legal diagnosis for international clients. Our global services focus on expert coaching, developmental guidance, and psychoeducation.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-brand-navy mb-4">Your Booking Journey</h2>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto">A seamless process to get the right support for your family.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="flex flex-col items-center text-center p-6">
          <div class="bg-brand-navy text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-xl mb-4">1</div>
          <h3 class="font-bold text-brand-navy mb-2">Share Concerns & Choose Service</h3>
        </div>
        <div class="flex flex-col items-center text-center p-6">
          <div class="bg-brand-navy text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-xl mb-4">2</div>
          <h3 class="font-bold text-brand-navy mb-2">Select Time Zone & Complete Intake</h3>
        </div>
        <div class="flex flex-col items-center text-center p-6">
          <div class="bg-brand-navy text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-xl mb-4">3</div>
          <h3 class="font-bold text-brand-navy mb-2">Confirm Payment & Attend Consultation</h3>
        </div>
        <div class="flex flex-col items-center text-center p-6">
          <div class="bg-brand-navy text-white rounded-full w-12 h-12 flex items-center justify-center font-bold text-xl mb-4">4</div>
          <h3 class="font-bold text-brand-navy mb-2">Receive Recommendations</h3>
        </div>
      </div>
    </div>
  </section>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <BookingCTA />
  </div>

  <Footer />
  <StickyMobileBookingCTA />
</Layout>
