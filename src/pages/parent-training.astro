---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'Parent Training', href: '/parent-training' }
];
---

<Layout title="Parent Training">
  <SEO
    title="Evidence-Based Parent Training & Strategy Sessions"
    description="Structured parent training programs designed to equip you with effective behavioral tools and connection strategies."
  />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Parent Training & Strategy Sessions</h1>
      <p class="text-xl text-gray-700 mb-12 border-l-4 border-brand-sky pl-4">
        Empowering you with the knowledge and tools to become the most effective advocate and guide for your child.
      </p>
      <div class="prose prose-lg text-gray-700 max-w-none">
        <p>Research consistently shows that training parents is often more effective than individual therapy for the child, especially for behavioral challenges and developmental delays. Our training is practical, structured, and focused on your specific goals.</p>
        <div class="bg-gray-50 p-6 rounded-xl my-8 border border-gray-200">
          <h3 class="text-xl font-bold text-brand-navy mb-4">Training Focus Areas:</h3>
          <ul class="list-disc pl-6 space-y-2">
            <li><strong>Positive Behavior Support:</strong> Techniques to encourage desired behaviors while maintaining a strong parent-child connection.</li>
            <li><strong>De-escalation:</strong> How to respond effectively during moments of high stress or emotional dysregulation.</li>
            <li><strong>Consistency & Boundaries:</strong> Establishing clear, predictable expectations that help children feel secure.</li>
            <li><strong>Data Tracking:</strong> Learning to use simple logs to understand behavioral patterns and measure progress.</li>
          </ul>
        </div>
      </div>
    </div>
    <BookingCTA />
  </div>
  <StickyMobileBookingCTA />
</Layout>
