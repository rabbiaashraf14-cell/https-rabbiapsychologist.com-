---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';

const breadcrumbs = [
  { name: 'Parent Choice Disclaimer', href: '/parent-choice-disclaimer' }
];
---
<Layout title="Parent Choice and Provider Directory Disclaimer">
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-4xl font-bold text-brand-navy mb-6">Parent Choice & Provider Directory Disclaimer</h1>
    <div class="prose prose-lg text-gray-700">
      <p>NeuroNest Child Development Centre operates as a platform for parent education and specialist discovery. We believe in empowering parents to make informed choices for their children.</p>

      <div class="bg-gray-50 border border-gray-200 p-6 rounded-lg my-8">
        <h2 class="text-xl font-bold text-brand-navy mb-4">Core Disclaimer</h2>
        <p class="text-gray-700">
          Parents choose the provider they wish to book. Each provider is responsible for working within their own qualifications, scope, license, registration, and regional requirements. This platform does not provide emergency care and does not replace local medical, psychological, educational, legal, or emergency services.
        </p>
      </div>

      <h2 class="text-2xl font-bold text-brand-navy mt-8">No Guarantees</h2>
      <p>We do not guarantee specific outcomes, such as guaranteed child behavioral improvement, guaranteed diagnosis, guaranteed school placement, or guaranteed provider suitability. Child development is complex and heavily dependent on multifaceted environmental, biological, and systemic factors.</p>
    </div>
  </div>
</Layout>
