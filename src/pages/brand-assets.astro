---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = "Brand Assets | Rabbia Psychologist Child Development Services";
const description = "Download and reference approved Rabbia Psychologist Child Development Services brand assets, including logo usage, tagline, colors, and media description.";
---
<BaseLayout title={title} description={description}>
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-4xl font-bold text-brand-navy mb-8">Brand Assets</h1>

    <div class="space-y-8">
      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">1. Brand Name</h2>
        <p class="text-gray-700">Rabbia Psychologist Child Development Services</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">2. Tagline</h2>
        <p class="text-gray-700">ADHD & Child Development Support at Home — Care Beyond the Session</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">3. Approved Short Description</h2>
        <p class="text-gray-700">Rabbia Psychologist Child Development Services provides parent guidance, developmental consultation support, school guidance, and multidisciplinary child development pathways for families in Pakistan and abroad.</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">4. Approved Long Description</h2>
        <p class="text-gray-700">Rabbia Psychologist Child Development Services is a child development and parent guidance platform led by Rabbia Ashraf, Clinical Psychologist | Child & Adolescent Development Support. The centre supports families navigating developmental, behavioural, emotional, learning, school, ASD, ADHD, and report-review concerns through evidence-informed guidance, referral direction, and multidisciplinary consultation pathways.</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">5. Logo Usage</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="p-4 bg-gray-50 border border-gray-200 rounded">
            <img src="/brand/logo-primary.svg" alt="Rabbia Psychologist Child Development Services logo" class="mb-2 max-w-full h-auto" />
            <p class="text-sm text-gray-500">Primary Logo</p>
          </div>
          <div class="p-4 bg-gray-50 border border-gray-200 rounded">
            <img src="/brand/logo-stacked.svg" alt="Rabbia Psychologist Child Development Services logo" class="mb-2 max-w-full h-auto" />
            <p class="text-sm text-gray-500">Stacked Logo</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">6. Color Palette</h2>
        <ul class="list-disc pl-5 text-gray-700">
          <li>Deep Navy (#0F2742)</li>
          <li>Soft Sky Blue (#DCEEFF)</li>
          <li>Trust Blue (#4B8BBE)</li>
          <li>Warm Cream (#FFF8EF)</li>
          <li>Soft Lavender (#EEE9FF)</li>
          <li>Growth Green (#8BBF9F)</li>
          <li>Charcoal Text (#1F2933)</li>
          <li>White (#FFFFFF)</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">7. Clinical Psychologist Wording</h2>
        <p class="text-gray-700">Rabbia Ashraf is a Clinical Psychologist | Child & Adolescent Development Support and serves as Clinical Psychologist of Rabbia Psychologist Child Development Services, providing evidence-informed parent guidance and developmental consultation support for families in Pakistan and abroad.</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">8. Media Contact</h2>
        <p class="text-gray-700">Please direct media inquiries to: rabbia@rabbiapsychologist.com</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-brand-trust mb-4">9. Usage Note</h2>
        <p class="text-gray-700 p-4 bg-yellow-50 border-l-4 border-yellow-400">Please do not modify the Rabbia Psychologist Child Development Services logo, colors, or clinical description without written approval. The brand should not be used to imply emergency care, guaranteed outcomes, medical diagnosis, or internationally licensed clinical services.</p>
      </section>
    </div>
  </div>
</BaseLayout>
