---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/global/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Resources', href: '/resources' },
  { name: 'Blog', href: '/blog' }
];

const articles = [
  {
    title: "Understanding the Confusion Between ADHD and Hyperactivity in Children",
    excerpt: "Not every child with ADHD is visibly hyperactive. Some children struggle more with attention, organization, forgetfulness, or impulsivity.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Jan 10, 2024",
    categories: ["ADHD", "Parenting"],
    href: "/blog/understanding-adhd-and-hyperactivity-in-children"
  },
  {
    title: "The Science of Screen Time: Why It Is So Hard for Children to Unplug",
    excerpt: "Stopping screen time is not always simple for children. Screens can strongly activate reward, desire, and emotional regulation systems.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Jan 12, 2024",
    categories: ["Behaviour", "Screen Time"],
    href: "/blog/why-screen-time-is-hard-for-children-to-stop"
  },
  {
    title: "How to Support Executive Function at Home",
    excerpt: "Practical tips to help your child start tasks, organize belongings, and remember instructions.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Jan 15, 2024",
    categories: ["ADHD", "Learning"],
    href: "/blog/how-to-support-executive-function-at-home"
  },
  {
    title: "Tantrum vs Meltdown: What is the Difference?",
    excerpt: "Why the traditional advice to 'ignore it' doesn't work for sensory meltdowns and what to do instead.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Feb 2, 2024",
    categories: ["Behaviour", "Emotional Regulation"],
    href: "/blog/tantrum-vs-meltdown"
  },
  {
    title: "Autism Early Signs Parents Should Notice",
    excerpt: "A guide for parents on what to look for regarding communication, social interaction, and sensory processing differences.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Feb 5, 2024",
    categories: ["Autism", "Development"],
    href: "/blog/autism-early-signs"
  },
  {
    title: "School Meeting Checklist for Parents",
    excerpt: "How to prepare for an IEP or teacher meeting so you feel confident advocating for your child's needs.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Feb 10, 2024",
    categories: ["School Support", "Advocacy"],
    href: "/blog/school-meeting-checklist"
  },
  {
    title: "Understanding Psychological Reports",
    excerpt: "Translate clinical jargon into practical next steps for your child.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Feb 15, 2024",
    categories: ["Assessments", "School Support"],
    href: "/blog/understanding-psychological-reports"
  },
  {
    title: "Screen Time and Emotional Regulation",
    excerpt: "Strategies to manage transitions and reduce screen-related meltdowns.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Feb 18, 2024",
    categories: ["Behaviour", "Screen Time"],
    href: "/blog/screen-time-and-emotional-regulation"
  },
  {
    title: "Behaviour Is Communication",
    excerpt: "Decoding what your child is trying to say through their challenging behaviours.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Feb 22, 2024",
    categories: ["Behaviour", "Parenting"],
    href: "/blog/behaviour-is-communication"
  },
  {
    title: "Parent Guidance After an Autism Diagnosis",
    excerpt: "Immediate home strategies to support your newly diagnosed child.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Mar 1, 2024",
    categories: ["Autism", "Development"],
    href: "/blog/parent-guidance-after-an-autism-diagnosis"
  },
  {
    title: "When to Seek Developmental Assessment",
    excerpt: "Signs that it might be time to move from wait-and-see to formal evaluation.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Mar 5, 2024",
    categories: ["Assessments", "Development"],
    href: "/blog/when-to-seek-developmental-assessment"
  },
  {
    title: "Speech Delay vs. Autism: How to Tell the Difference",
    excerpt: "Does late talking mean autism? Learn the critical differences between a speech delay and autism spectrum disorder, and what non-verbal signs parents should look for.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Mar 15, 2024",
    categories: ["Autism", "Communication"],
    href: "/blog/speech-delay-vs-autism"
  },
  {
    title: "Emotional Regulation in Children: Teaching Kids to Handle Big Feelings",
    excerpt: "Learn what emotional regulation is, why children with ADHD and autism struggle with it, and practical home strategies to build this vital life skill.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Mar 20, 2024",
    categories: ["Behaviour", "Parenting"],
    href: "/blog/emotional-regulation-in-children"
  },
  {
    title: "Learning Difficulties: Early Signs Parents Need to Notice",
    excerpt: "Is your child lazy, or is it a learning difficulty? Learn the early signs of reading, writing, and math struggles, and how a formal assessment can help.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Mar 25, 2024",
    categories: ["Learning Difficulties", "School Support"],
    href: "/blog/learning-difficulties-early-signs"
  },
  {
    title: "School Refusal and School Anxiety: When Mornings Become a Battle",
    excerpt: "Understand the root causes of school refusal and anxiety in children, and learn practical steps parents can take to support their child and collaborate with the school.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Apr 1, 2024",
    categories: ["School Support", "Emotional Regulation"],
    href: "/blog/school-refusal-and-school-anxiety"
  },
  {
    title: "Sensory Processing Difficulties: When the World is Too Loud",
    excerpt: "Understand sensory processing differences in children, the difference between sensory seeking and avoiding, and how to create a sensory-friendly home.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Apr 5, 2024",
    categories: ["Autism", "Sensory Support"],
    href: "/blog/sensory-processing-difficulties"
  },
  {
    title: "How to Prepare for a Child Developmental Assessment",
    excerpt: "Learn what documents to bring, what to expect during the evaluation, and exactly what to tell your child before a psychological or developmental assessment.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Apr 10, 2024",
    categories: ["Assessments", "Development"],
    href: "/blog/how-to-prepare-for-child-assessment"
  },
  {
    title: "Parent Guidance for Behaviour Concerns: A Clinical Approach",
    excerpt: "When time-outs and sticker charts stop working, what is next? Discover clinical parent guidance strategies for managing challenging child behaviour effectively.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Apr 15, 2024",
    categories: ["Behaviour", "Parenting"],
    href: "/blog/parent-guidance-for-behaviour-concerns"
  },
  {
    title: "Morning Routine Problems in ADHD: Why Mornings Are So Hard",
    excerpt: "Are mornings a daily battle? Discover why children with ADHD struggle with morning routines and learn practical, visual strategies to get out the door on time.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Apr 20, 2024",
    categories: ["ADHD", "Executive Function"],
    href: "/blog/morning-routine-problems-in-adhd"
  },
  {
    title: "Homework Battles and Attention Difficulties: How to Help Your Child Focus",
    excerpt: "End the nightly homework struggle. Learn why attention fatigue happens, how to structure homework for ADHD brains, and when a formal assessment is needed.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Apr 25, 2024",
    categories: ["Learning", "ADHD"],
    href: "/blog/homework-battles-and-attention-difficulties"
  },
  {
    title: "Social Communication Concerns: Beyond Just Talking",
    excerpt: "Social communication is more than speech. Learn the hidden signs of social communication difficulties in children, the connection to autism, and how to support your child.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "Apr 30, 2024",
    categories: ["Autism", "Communication"],
    href: "/blog/social-communication-concerns"
  },
  {
    title: "Sleep, Routine, and Child Behaviour: The Hidden Connection",
    excerpt: "Is your child's challenging behaviour actually a sign of chronic sleep deprivation? Discover how sleep impacts emotional regulation and how to build a peaceful bedtime routine.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "May 5, 2024",
    categories: ["Routines", "Behaviour"],
    href: "/blog/sleep-routine-and-child-behaviour"
  },
  {
    title: "IEP and School Support Planning: A Parent's Guide",
    excerpt: "From IEP confusion to a clear support plan. Learn how to prepare for school meetings, request effective accommodations, and turn school concerns into practical next steps.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "May 10, 2024",
    categories: ["School Support", "Assessments"],
    href: "/blog/iep-and-school-support-planning"
  },
  {
    title: "Parent Burnout When Supporting a Child with Developmental Needs",
    excerpt: "Raising a child with ADHD, autism, or learning difficulties carries a heavy emotional load. Learn the signs of parent burnout and why seeking your own support is critical.",
    author: "Rabbia Ashraf, Clinical Psychologist",
    date: "May 15, 2024",
    categories: ["Parent Support", "Parenting"],
    href: "/blog/parent-burnout-child-development-support"
  }
];

// Sort articles by date descending
articles.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const categories = ["ADHD", "Autism", "Behaviour", "Emotional Regulation", "Learning Difficulties", "School Support", "Assessments", "Parent Guidance"];

const startHereSlugs = [
  "/blog/understanding-adhd-and-hyperactivity-in-children",
  "/blog/autism-early-signs",
  "/blog/when-to-seek-developmental-assessment",
  "/blog/why-screen-time-is-hard-for-children-to-stop"
];
const startHereArticles = articles.filter(a => startHereSlugs.includes(a.href));
const otherArticles = articles.filter(a => !startHereSlugs.includes(a.href));
---

<BaseLayout title="Child Psychology & Parenting Blog | Rabbia Psychologist" description="Insights, articles, and practical advice on child development, managing ADHD/ASD, and behavior support.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />

    <section class="bg-gradient-to-b from-brand-cream to-white py-16 px-6 mt-8 mb-12 text-center rounded-2xl shadow-sm border border-brand-border/50">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Insights & Articles</h1>
        <p class="text-xl md:text-2xl text-gray-700 leading-relaxed max-w-3xl mx-auto mb-8 font-light">
          Practical child development guidance for parents who want to understand behaviour, learning, attention, emotions, and developmental concerns with more clarity.
        </p>

        <div class="flex overflow-x-auto gap-3 pb-4 justify-center flex-wrap sm:flex-nowrap sm:justify-start md:justify-center px-4 -mx-4 sm:mx-0 no-scrollbar">
          {categories.map(cat => (
            <span class="inline-block bg-white text-brand-navy border border-brand-border text-sm font-bold px-4 py-2 rounded-full whitespace-nowrap shadow-sm hover:border-brand-gold hover:text-brand-gold transition-colors cursor-pointer">{cat}</span>
          ))}
        </div>
      </div>
    </section>

    <div class="mb-16">
      <h2 class="text-3xl font-bold text-brand-navy mb-8 border-b border-brand-border pb-4">Start Here for Parents</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {startHereArticles.map(article => (
          <a href={article.href} class="hover-lift bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col group h-full">
            <div class="p-5 flex flex-col flex-grow">
              <div class="flex gap-2 mb-3 flex-wrap">
                {article.categories.map(cat => (
                  <span class="inline-block bg-brand-cream text-brand-navy text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider">{cat}</span>
                ))}
              </div>
              <h3 class="text-lg font-bold text-brand-navy mb-2 group-hover:text-brand-trust transition-colors leading-tight">{article.title}</h3>
              <p class="text-gray-600 mb-4 flex-grow text-sm line-clamp-3">{article.excerpt}</p>
              <div class="mt-auto border-t border-gray-100 pt-3">
                <p class="text-[11px] font-bold text-brand-navy">{article.author}</p>
                <div class="flex justify-between items-center mt-1">
                  <p class="text-[11px] text-gray-500">{article.date}</p>
                  <span class="text-brand-gold font-bold text-xs group-hover:translate-x-1 transition-transform">Read &rarr;</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="bg-brand-navy text-white rounded-xl p-8 md:p-10 mb-16 text-center shadow-lg mx-auto max-w-5xl flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-left md:w-2/3">
        <h3 class="text-2xl font-bold mb-2">Not sure what your child needs?</h3>
        <p class="text-lg text-gray-200 font-light">Book a parent consultation and get clear next steps from a clinical psychologist.</p>
      </div>
      <div>
        <a href="/book" class="inline-block bg-brand-gold text-brand-navy font-bold px-8 py-3 rounded-lg hover:bg-yellow-500 transition-colors shadow-sm text-lg whitespace-nowrap">Book Consultation</a>
      </div>
    </div>

    <div>
      <h2 class="text-3xl font-bold text-brand-navy mb-8 border-b border-brand-border pb-4">Latest Articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        {otherArticles.map(article => (
          <a href={article.href} class="hover-lift bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col group h-full">
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex gap-2 mb-3 flex-wrap">
                {article.categories.map(cat => (
                  <span class="inline-block bg-brand-cream text-brand-navy text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider">{cat}</span>
                ))}
              </div>
              <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-trust transition-colors leading-tight">{article.title}</h3>
              <p class="text-gray-600 mb-6 flex-grow text-sm line-clamp-3">{article.excerpt}</p>
              <div class="mt-auto border-t border-gray-100 pt-4">
                <p class="text-xs font-bold text-brand-navy">{article.author}</p>
                <div class="flex justify-between items-center mt-1">
                  <p class="text-xs text-gray-500">{article.date}</p>
                  <span class="text-brand-gold font-bold text-sm group-hover:translate-x-1 transition-transform">Read article &rarr;</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
