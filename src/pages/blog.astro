---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/global/Breadcrumbs.astro';
import { articles } from '../data/blogArticles';

// Dynamically import all blog images for proper image priority system
const localImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/blog/*.{jpeg,jpg,png,webp,gif}', { eager: true });

const title = "Child Psychology, ADHD, Autism & Parent Guidance Blog | Rabbia Psychologist";
const description = "Practical, parent-friendly articles on child development, ADHD, autism, behaviour, emotional regulation, learning difficulties, school support, assessments, and home routines.";
const canonicalURL = "https://www.rabbiapsychologist.com/blog";

const breadcrumbs = [
  { name: 'Blog', href: '/blog' }
];

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Child Psychology and Parent Guidance Blog",
  "description": "Articles on child development, ADHD, autism, behaviour, emotional regulation, learning difficulties, school support, assessments, and home routines.",
  "url": canonicalURL
};

// Reverting deletions to ensure no blogs are lost while adding improvements
const categories = [
  "ADHD",
  "Autism",
  "Behaviour",
  "Emotional Regulation",
  "Learning Difficulties",
  "School Support",
  "Reports & Assessments",
  "Parent Guidance",
  "Sensory Processing",
  "Speech & Communication"
];

const startingArticles = [
  { title: "Autism Early Signs", href: "/blog/autism-early-signs" },
  { title: "Speech Delay vs Autism", href: "/blog/speech-delay-vs-autism" },
  { title: "Tantrum vs Meltdown", href: "/blog/tantrum-vs-meltdown" },
  { title: "Behaviour Is Communication", href: "/blog/behaviour-is-communication" },
  { title: "School Meeting Checklist", href: "/blog/school-meeting-checklist" },
  { title: "Understanding Psychological Reports", href: "/blog/understanding-psychological-reports" },
  { title: "Morning Routine Problems in ADHD", href: "/blog/morning-routine-problems-in-adhd" }
];


// Sort articles by date descending
const sortedArticles = [...articles].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function getCategoryFallbackSvg(categories: string[]) {
  const cats = categories.map(c => c.toLowerCase());

  // Default base SVG with a soft background glow
  let svgContent = `<rect width="100%" height="100%" fill="#F3F0E8" />`;
  let icon = `<circle cx="50%" cy="50%" r="20" fill="#062B4F" opacity="0.1" />`;

  if (cats.includes('adhd') || cats.includes('attention')) {
    icon = `<circle cx="30%" cy="50%" r="15" fill="#062B4F" opacity="0.1" /><circle cx="50%" cy="40%" r="20" fill="#7C9988" opacity="0.15" /><circle cx="70%" cy="60%" r="10" fill="#C8A15A" opacity="0.2" />`;
  } else if (cats.includes('autism') || cats.includes('asd')) {
    icon = `<path d="M 30 50 Q 50 20 70 50 T 110 50" stroke="#7C9988" stroke-width="4" fill="none" opacity="0.3" transform="scale(3) translate(0, -10)" />`;
  } else if (cats.includes('behaviour') || cats.includes('behavior')) {
    icon = `<rect x="35%" y="40%" width="30%" height="20%" rx="10" fill="#062B4F" opacity="0.1" /><rect x="45%" y="30%" width="10%" height="40%" rx="5" fill="#C8A15A" opacity="0.2" />`;
  } else if (cats.includes('emotional regulation') || cats.includes('anxiety')) {
    icon = `<path d="M 20 50 C 40 10, 60 90, 80 50 S 120 10, 140 50" stroke="#C8A15A" stroke-width="5" fill="none" opacity="0.2" transform="scale(2) translate(10, 0)" />`;
  } else if (cats.includes('school support') || cats.includes('learning')) {
    icon = `<polygon points="50,20 80,40 80,80 20,80 20,40" fill="#7C9988" opacity="0.15" transform="scale(1.5) translate(20, -5)" />`;
  } else if (cats.includes('sensory') || cats.includes('sensory processing')) {
    icon = `<circle cx="50%" cy="50%" r="30" fill="none" stroke="#062B4F" stroke-width="2" stroke-dasharray="5,5" opacity="0.2" /><circle cx="50%" cy="50%" r="15" fill="#7C9988" opacity="0.15" />`;
  } else if (cats.includes('parenting') || cats.includes('parent guidance')) {
    icon = `<circle cx="45%" cy="50%" r="25" fill="#062B4F" opacity="0.1" /><circle cx="55%" cy="55%" r="15" fill="#C8A15A" opacity="0.2" />`;
  }

  const svgString = `<svg xmlns="http://www.w3.org/2000/svg" width="400" height="225" viewBox="0 0 400 225">${svgContent}${icon}</svg>`;
  // Base64 encode the SVG to ensure it works correctly as a data URI across all browsers without hex color parsing issues.
  const encodedSvg = Buffer.from(svgString).toString('base64');
  return `data:image/svg+xml;base64,${encodedSvg}`;
}

function getArticleImage(article: any) {
  if (article.sanityImage) {
    return { type: 'remote', src: article.sanityImage };
  }

  const slug = article.href.replace('/blog/', '').replace(/\/$/, '');
  const imagePath = Object.keys(localImages).find(path => path.includes(`/${slug}.`));

  if (imagePath && localImages[imagePath]) {
    return { type: 'local', src: localImages[imagePath].default };
  }

  if (article.imageUrl) {
    return { type: 'remote', src: article.imageUrl };
  }

  return { type: 'fallback', src: getCategoryFallbackSvg(article.categories) };
}

---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalURL} />
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  </Fragment>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 max-w-5xl">
    <Breadcrumbs paths={breadcrumbs} />

    <!-- 1. Blog hero -->
    <div class="mt-8 mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Child Psychology, ADHD, Autism & Parent Guidance Blog</h1>

      <!-- 2. Intro -->
      <p class="text-xl text-gray-700 max-w-3xl mx-auto mb-8">
        Practical, parent-friendly articles on child development, ADHD, autism, behaviour, emotional regulation, learning difficulties, school support, assessments, and home routines.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

      <!-- Sidebar / Filters -->
      <div class="lg:col-span-1 space-y-8">
        <!-- 3. Featured categories -->
        <div class="bg-gray-50 p-6 rounded-xl border border-gray-100">
          <h2 class="text-xl font-bold text-brand-navy mb-4 border-b pb-2">Browse by Concern</h2>
          <ul class="space-y-2">
            {categories.map((category) => (
              <li><a href="/resources" class="text-brand-trust hover:underline font-medium">{category}</a></li>
            ))}
          </ul>
        </div>

        <!-- 5. Most helpful for parents starting today -->
        <div class="bg-brand-cream p-6 rounded-xl border border-brand-sky">
          <h2 class="text-xl font-bold text-brand-navy mb-4 border-b pb-2 border-brand-navy/20">Most Helpful for Parents Starting Today</h2>
          <ul class="space-y-3">
            {startingArticles.map((article) => (
              <li><a href={article.href} class="text-brand-trust hover:underline font-medium block">{article.title}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Main Blog List -->
      <div class="lg:col-span-3">
        <!-- 4. Featured articles section -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sortedArticles.map((article) => {
            const imageData = getArticleImage(article);
            return (
            <article class="bg-white rounded-2xl shadow-sm border border-gray-100 hover-lift flex flex-col group h-full overflow-hidden">
              <a href={article.href} class="block relative aspect-video w-full bg-brand-cream border-b border-gray-100 overflow-hidden shrink-0">
                {imageData.type === 'local' ? (
                  <Image
                    src={imageData.src}
                    alt={article.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    width={600}
                    height={338}
                    loading="lazy"
                  />
                ) : (
                  <img
                    src={imageData.src}
                    alt={article.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                    onerror={`this.onerror=null; this.src='${getCategoryFallbackSvg(article.categories)}';`}
                  />
                )}
              </a>
              <div class="p-6 flex flex-col flex-grow">
                <div class="flex gap-2 mb-3 flex-wrap">
                  {article.categories.map((cat) => (
                    <span class="text-xs font-bold uppercase tracking-wider text-brand-trust bg-brand-cream px-2 py-1 rounded">{cat}</span>
                  ))}
                </div>
                <h3 class="text-xl font-bold text-brand-navy mb-2 leading-tight">
                  <a href={article.href} class="hover:text-brand-trust transition-colors">{article.title}</a>
                </h3>
                <p class="text-gray-600 mb-4 flex-grow">{article.excerpt}</p>
                <div class="text-sm text-gray-500 mt-auto border-t pt-4 flex justify-between items-center">
                  <span>{article.author}</span>
                  <span class="text-brand-gold font-bold text-sm group-hover:translate-x-1 transition-transform">Read article &rarr;</span>
                </div>
              </div>
            </article>
            );
          })}
        </div>

        <!-- 7. Blog CTA -->
        <div class="mt-12 bg-brand-navy text-white p-8 rounded-xl text-center shadow-md flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="text-left md:w-2/3">
            <h2 class="text-2xl font-bold mb-4">Need help applying this to your child?</h2>
            <p class="text-brand-cream">Turn reading into action. Get a personalized plan for your family's unique situation.</p>
          </div>
          <div>
            <a href="/start-here" class="inline-block bg-white text-brand-navy px-8 py-3 rounded-lg font-bold hover:bg-gray-100 transition-colors whitespace-nowrap">Find Your Support Pathway</a>
          </div>
        </div>

        <!-- Internal Links for discovery -->
        <div class="mt-8 flex flex-wrap justify-center gap-4 text-sm font-medium">
           <a href="/services" class="text-brand-trust hover:underline">Services</a>
           <span class="text-gray-300">|</span>
           <a href="/pricing" class="text-brand-trust hover:underline">Pricing</a>
           <span class="text-gray-300">|</span>
           <a href="/faqs" class="text-brand-trust hover:underline">FAQs</a>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
