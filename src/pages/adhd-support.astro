---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';

const breadcrumbs = [
  { name: 'Services', href: '/services' },
  { name: 'ADHD Support', href: '/adhd-support' }
];
---

<Layout title="ADHD Support">
  <SEO
    title="ADHD Executive Function Coaching & Parent Guidance"
    description="Specialized support for ADHD, focusing on executive function coaching, working memory, and emotional regulation strategies for parents."
  />
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs paths={breadcrumbs} />
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">ADHD Support & Executive Function Coaching</h1>
      <p class="text-xl text-gray-700 mb-12 border-l-4 border-brand-sky pl-4">
        "When a child is not listening, the issue may not be unwillingness. It may be difficulty with attention, working memory, task initiation, emotional regulation, or processing."
      </p>
      <div class="prose prose-lg text-gray-700 max-w-none">
        <p>ADHD is fundamentally a challenge of executive functioning. Our support focuses on bridging the gap between what a child knows and what they can consistently do by providing environmental scaffolding and skill-building strategies.</p>
        <div class="bg-gray-50 p-6 rounded-xl my-8 border border-gray-200">
          <h3 class="text-xl font-bold text-brand-navy mb-4">What We Address:</h3>
          <ul class="list-disc pl-6 space-y-2">
            <li><strong>Task Initiation:</strong> Strategies for starting homework and chores without conflict.</li>
            <li><strong>Working Memory:</strong> Tools to help children remember multi-step instructions.</li>
            <li><strong>Emotional Regulation:</strong> Managing the intense emotions and impulsivity often associated with ADHD.</li>
            <li><strong>Organization & Planning:</strong> Creating external systems to support internal executive function deficits.</li>
          </ul>
        </div>
      </div>
    </div>
    <BookingCTA />
  </div>
  <Footer />
  <StickyMobileBookingCTA />
</Layout>
