---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import ParentJourneyTimeline from '../components/home/ParentJourneyTimeline.astro';
---

<Layout title="Booking Guidance | How to Prepare for Your Session">
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 py-12">
    <div class="max-w-4xl mx-auto text-center mb-12">
      <h1 class="text-4xl font-bold text-brand-navy mb-4">Booking Guidance</h1>
      <p class="text-xl text-gray-700">What to expect before, during, and after your consultation.</p>
    </div>

    <div class="bg-blue-50 border border-blue-100 p-6 rounded-lg max-w-4xl mx-auto mb-12">
      <h2 class="font-bold text-xl text-brand-navy mb-2">Important Before You Book</h2>
      <p class="text-gray-700 mb-2">Please ensure you select the correct region and provider type. Remember that international support focuses on guidance and parent education.</p>
      <a href="/choose-a-provider" class="text-brand-trust font-bold hover:underline">View Directory</a>
    </div>

    <ParentJourneyTimeline />
  </div>
  <Footer />
</Layout>
