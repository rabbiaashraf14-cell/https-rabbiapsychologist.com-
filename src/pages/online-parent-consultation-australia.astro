---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';
---

<Layout title="Online Parent Consultation Australia">
  <SEO
    title="Online Parent Consultation & Guidance for Australian Families"
    description="Expert educational parent consultation, behavior support planning, and developmental guidance for families across Australia."
  />
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Online Parent Consultation for Australian Families</h1>
      <p class="text-xl text-gray-700 mb-8 border-l-4 border-brand-sky pl-4">
        Providing specialized educational guidance and behavioral strategy sessions for parents in Australia navigating ADHD, ASD, and behavioral challenges.
      </p>
      <BookingCTA />
    </div>
  </div>
  <Footer />
  <StickyMobileBookingCTA />
</Layout>
