---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RegionHero from '../components/RegionHero.astro';
import RegionProviderList from '../components/RegionProviderList.astro';
import InternationalDisclaimerBanner from '../components/InternationalDisclaimerBanner.astro';
import RegionFAQAccordion from '../components/RegionFAQAccordion.astro';
import RegionPricingCards from '../components/RegionPricingCards.astro';

const faqs = [
  { question: "Can Australian families book?", answer: "Yes, parents in Australia can access our online parent education and developmental guidance." },
  { question: "Is this therapy or parent guidance?", answer: "Our international services are strictly parent guidance and education. We do not provide regulated psychological therapy for clients in Australia." },
  { question: "Can I choose an Australian provider if one is available?", answer: "Yes, you can check our provider directory for professionals who may hold specific Australian registrations or experience." },
  { question: "Can this replace a local psychologist?", answer: "No. If your child requires clinical treatment, formal assessment, or crisis support, you should consult a local registered psychologist." },
  { question: "Can this help with school communication?", answer: "Yes, we can help you prepare to discuss your child's needs with their teachers or school support team." },
  { question: "Can you support ASD/ADHD home routines?", answer: "Absolutely. We specialize in providing practical, actionable strategies for building routines at home." },
  { question: "What if my child needs formal assessment?", answer: "You will need to see a pediatrician or registered psychologist in Australia for formal diagnostic assessments." },
  { question: "What should I prepare?", answer: "Identify the main behaviors or routines you want to improve, and gather any existing reports for context." }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---
<Layout title="Online Parent Consultation for Australian Families">
  <SEO
    title="Online Parent Consultation for Australian Families"
    description="Parent education and child development guidance for Australian families seeking ASD/ADHD routines, behavior support planning, and school preparation."
    schema={schema}
  />

  <Header />

  <RegionHero
    regionName="Australia Families"
    heroTitle="Online Parent Consultation for Australian Families"
    heroSubtitle="For parents in Australia seeking parent education, ASD/ADHD routines, school communication preparation, behavior support planning, and developmental guidance."
  />

  <main class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">

      <InternationalDisclaimerBanner text="International support for Australian families may include parent education, developmental guidance, ASD/ADHD support planning, behavior strategy discussion, executive-function routines, school communication preparation, resource guidance, and referral direction. Clinical therapy, diagnosis, assessment, and regulated psychological services are provided only where legally and ethically permitted by the provider's credentials and the client's location." />

      <section class="my-12">
        <h2 class="text-2xl font-bold text-brand-navy mb-6">Common concerns Australian parents bring</h2>
        <ul class="list-disc pl-6 space-y-2 text-gray-700">
          <li>Seeking proactive strategies while navigating long public waitlists or waiting for NDIS funding approval.</li>
          <li>Needing practical guidance on creating neurodiversity-affirming home routines.</li>
          <li>Wanting support in understanding assessments to better advocate at school.</li>
          <li>Managing behaviors of concern, anxiety, or emotional dysregulation at home.</li>
        </ul>
      </section>

      <div class="grid md:grid-cols-2 gap-8 my-12">
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100">
          <h2 class="text-xl font-bold text-brand-navy mb-4">What parent consultation may include</h2>
          <ul class="space-y-2 text-gray-700">
            <li>✔ Parent education on developmental stages and neurodivergence.</li>
            <li>✔ Brainstorming environmental adjustments for home.</li>
            <li>✔ Discussing behavior support strategies based on current best practices.</li>
            <li>✔ Helping you organize questions for your local GP, pediatrician, or school team.</li>
          </ul>
        </div>
        <div class="bg-red-50 p-6 rounded-lg border border-red-100">
           <h2 class="text-xl font-bold text-red-800 mb-4">What this service does NOT replace</h2>
           <ul class="space-y-2 text-gray-800">
            <li>✘ Registered psychological therapy under Medicare.</li>
            <li>✘ Formal NDIS assessments or diagnostic reports.</li>
            <li>✘ Crisis intervention or acute mental health care.</li>
          </ul>
        </div>
      </div>

      <section class="my-12">
        <h2 class="text-2xl font-bold text-brand-navy mb-4">When to Seek Local Registered Care</h2>
        <p class="text-gray-700">If your child requires an official diagnosis, clinical treatment for severe mental health concerns, or documentation for NDIS applications, you must seek an evaluation from a provider registered with AHPRA (e.g., a Clinical Psychologist) or a local Pediatrician in Australia.</p>
      </section>

      <RegionProviderList region="Australia Families" providers={[]} />

      <RegionPricingCards />

      <section class="my-16">
        <h2 class="text-3xl font-bold text-brand-navy mb-8 text-center">Australia FAQs</h2>
        <RegionFAQAccordion faqs={faqs} />
      </section>

    </div>
  </main>

  <Footer />
</Layout>
