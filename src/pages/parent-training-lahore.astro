---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';
---

<Layout title="Parent Training Lahore">
  <SEO
    title="Parent Training & Behavior Therapy in Lahore"
    description="Evidence-based parent training programs and behavioral therapy services in Lahore, Pakistan."
  />
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Parent Training in Lahore</h1>
      <p class="text-xl text-gray-700 mb-8 border-l-4 border-brand-sky pl-4">
        Structured programs to equip local parents with effective strategies for managing challenging behaviors and supporting development.
      </p>
      <BookingCTA />
    </div>
  </div>
  <Footer />
  <StickyMobileBookingCTA />
</Layout>
