---
import Layout from '../layouts/Layout.astro';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BookingCTA from '../components/BookingCTA.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import StickyMobileBookingCTA from '../components/StickyMobileBookingCTA.astro';
---

<Layout title="Online Parent Consultation USA">
  <SEO
    title="Online Parent Consultation & Guidance for USA Families"
    description="Expert educational parent consultation, behavior support planning, and developmental guidance for families across the United States."
  />
  <DisclaimerBanner />
  <Header />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="max-w-4xl mx-auto mt-8">
      <h1 class="text-4xl md:text-5xl font-bold text-brand-navy mb-6">Online Parent Consultation for USA Families</h1>
      <p class="text-xl text-gray-700 mb-8 border-l-4 border-brand-sky pl-4">
        Providing specialized educational guidance and behavioral strategy sessions for parents in the United States navigating ADHD, ASD, and behavioral challenges.
      </p>
      <div class="bg-brand-lavender p-4 rounded-lg mb-8 text-sm">
        <strong>Important Note for US Residents:</strong> Services provided internationally to the USA are strictly educational parent-coaching and strategy-planning. They do not constitute licensed medical or psychological treatment, diagnosis, or therapy under state licensing board regulations.
      </div>
      <BookingCTA />
    </div>
  </div>
  <Footer />
  <StickyMobileBookingCTA />
</Layout>
