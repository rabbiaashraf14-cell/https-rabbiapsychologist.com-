---
import '../styles/global.css';
import SEO from '../components/seo/SEO.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import StickyMobileBookingCTA from '../components/global/StickyMobileBookingCTA.astro';
import CountdownBanner from '../components/global/CountdownBanner.astro';
import FloatingWhatsApp from '../components/global/FloatingWhatsApp.astro';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  type?: string;
  image?: string;
  noindex?: boolean;
}

const { title, description, canonicalURL, type, image, noindex } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={title}
      description={description || "Rabbia Psychologist Child Development Services offers global parent guidance, child development support, and specialist consultation."}
      canonical={canonicalURL}
      type={type}
      image={image}
      noindex={noindex}
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0F2742" />
    <meta name="generator" content={Astro.generator} />
    <slot name="head" />
  </head>
  <body class="bg-brand-cream text-brand-navy font-sans antialiased flex flex-col min-h-screen">
    <Header />
    <main class="flex-grow pb-24 md:pb-0">
      <slot />
    </main>
    <Footer />
    <CountdownBanner />
    <StickyMobileBookingCTA />
    <FloatingWhatsApp />

    <!--Start of Tawk.to Script-->
    <script type="text/javascript">
    var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
    (function(){
    var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
    s1.async=true;
    s1.src='https://embed.tawk.to/6a3e8d8f84036f1d4819a7c2/default';
    s1.charset='UTF-8';
    s1.setAttribute('crossorigin','*');
    s0.parentNode.insertBefore(s1,s0);
    })();
    </script>
    <!--End of Tawk.to Script-->

    <!-- Analytics Tracking Script -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // Privacy-safe analytics logging
        const trackEvent = (eventName, params = {}) => {
           // Ensure we only log allowed events
           const allowedEvents = ['city_page_view', 'city_primary_cta_click', 'city_secondary_cta_click', 'city_service_link_click', 'city_booking_start', 'city_country_link_click', 'city_region_link_click', 'city_faq_open', 'city_source_link_click', 'city_related_resource_click', 'city_error_encountered'];
           const allowedParams = ['city_id', 'city_slug', 'country_code', 'content_version', 'destination_type', 'faq_id', 'source_type', 'device_category'];

           if (!allowedEvents.includes(eventName)) return;

           const safeParams = {};
           for (const [key, value] of Object.entries(params)) {
             if (allowedParams.includes(key)) safeParams[key] = value;
           }

           console.log(`[Analytics] ${eventName}`, safeParams);
        };

        // If on a city page, log view
        if (window.location.pathname.includes('/locations/')) {
           trackEvent('city_page_view', { device_category: window.innerWidth < 768 ? 'mobile' : 'desktop' });
        }

        // Track Sale Banner Clicks
        const promoBanner = document.getElementById('promo-banner');
        if (promoBanner) {
          // Log impression
          console.log('[Analytics] countdown impressions');

          promoBanner.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            // Ignore close button clicks for the banner click metric
            if (!target.closest('#close-promo')) {
               console.log('[Analytics] sale banner clicks');
            }
          });
        }

        // Track Booking Button Clicks
        const bookingButtons = document.querySelectorAll('a[href="/book"], a[href^="https://calendar.app.google"]');
        bookingButtons.forEach(btn => {
          btn.addEventListener('click', () => {
             console.log('[Analytics] booking button clicks');
             trackEvent('city_booking_start', {});

             // Pseudo conversion logic for this specific button that leads to booking
             if (btn.classList.contains('track-booking-btn') || btn.getAttribute('href')?.startsWith('https://calendar.app.google')) {
               console.log('[Analytics] conversion rate');
             }
          });
        });
      });
    </script>
  </body>
</html>
